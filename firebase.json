{
  "hosting": {
    "site": "treetopgrowthstrategy",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      { "source": "/insights/what-is-a-fractional-cmo", "destination": "/resources/what-is-a-fractional-cmo", "type": 301 },
      { "source": "/insights/:slug*", "destination": "/resources/:slug*", "type": 301 },
      { "source": "/fractional-cmo-austin-tx", "destination": "/fractional-cmo-austin", "type": 301 }
    ],
    "rewrites": [
      { "source": "/api/lead-capture",            "function": "leadCapture" },
      { "source": "/api/training-inquiry",        "function": "trainingInquiry" },
      { "source": "/api/quiz-submit",             "function": "quizSubmit" },
      { "source": "/api/ecofit-assessment-submit","function": "ecofitAssessmentSubmit" },
      { "source": "/api/ecofit-demo-request",     "function": "ecofitDemoRequest" },
      { "source": "/api/stack-checkout",          "function": "stackCheckout" },
      { "source": "/api/product-checkout",        "function": "productCheckout" },
      { "source": "/api/verify-purchase",         "function": "verifyPurchase" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}
