{
  "name": "treetop-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for Treetop Growth Strategy",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-functions": "^6.4.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "private": true
}
