<script is:inline>
function fmt(n){return '$' + Math.round(n).toLocaleString();}

function recalc(){
  const stage = parseFloat(document.getElementById('stage').value); // revenue in $M
  const need = document.getElementById('need').value;
  const hours = parseFloat(document.getElementById('hours').value);

  // Stage multiplier (early stage = lower rates; later = senior-only)
  const stageMul = stage < 5 ? 0.85 : stage < 15 ? 1.0 : stage < 40 ? 1.15 : 1.3;

  // Need multiplier (light scope = lower cost; full rebuild = higher)
  const needMul = { campaign: 0.85, pipeline: 1.0, leadership: 1.15, full: 1.3 }[need];

  // Fractional CMO: hourly rate × hours × 52 weeks
  const fracHourly = 275 * stageMul;
  const fracAnnual = fracHourly * hours * 52 * (needMul * 0.95); // small needMul effect (scope adjusted)

  // Agency: hourly rate × hours × 52 weeks (more hours required for same outcomes)
  const agencyHourly = 225 * stageMul;
  const agencyHours = hours * 1.4; // agency needs ~40% more hours due to coordination overhead
  const agencyAnnual = agencyHourly * agencyHours * 52 * needMul;

  // Full-time hire: base + benefits + recruiting amortized + ramp loss
  let ftBase = stage < 5 ? 220000 : stage < 15 ? 280000 : stage < 40 ? 340000 : 400000;
  const benefits = ftBase * 0.25;
  const recruiting = ftBase * 0.25 / 3; // amortize 25% over 3 years
  const equityCost = stage < 15 ? ftBase * 0.10 : ftBase * 0.20; // proxy for equity dilution
  const ftAnnual = ftBase + benefits + recruiting + equityCost;
  const ftActiveHours = hours; // can do up to 40

  // Only show full-time as viable if hours >= 24
  const ftViable = hours >= 24;
  // Only show agency as viable for campaign/pipeline (not full leadership)
  const agencyViable = need === 'campaign' || need === 'pipeline';

  // Winner = lowest annual cost AMONG viable options
  const candidates = [
    { name: 'Fractional CMO', desc: 'Senior operator, defined hours, retainer model.', annual: fracAnnual, viable: true,
      breakdown: [
        ['Effective hourly', fmt(fracHourly) + '/hr'],
        ['Hours per week', hours + ' hrs'],
        ['Annual investment', fmt(fracAnnual)],
        ['Setup / onboarding', fmt(fracHourly * 12)],
      ]},
    { name: 'Marketing Agency', desc: 'Team of specialists, more hands but more coordination.', annual: agencyAnnual, viable: agencyViable,
      breakdown: [
        ['Blended hourly', fmt(agencyHourly) + '/hr'],
        ['Hours per week', Math.round(agencyHours) + ' hrs'],
        ['Annual fees', fmt(agencyAnnual)],
        ['Coordination overhead', '+40%'],
      ]},
    { name: 'Full-Time CMO', desc: 'Owns the role permanently. Long ramp, high commitment.', annual: ftAnnual, viable: ftViable,
      breakdown: [
        ['Base salary', fmt(ftBase)],
        ['Benefits + payroll burden', fmt(benefits)],
        ['Recruiting (amortized)', fmt(recruiting)],
        ['Equity dilution proxy', fmt(equityCost)],
      ]},
  ];

  const viableCandidates = candidates.filter(c => c.viable);
  const winner = viableCandidates.reduce((a, b) => a.annual < b.annual ? a : b);

  // Render compare grid
  const grid = document.getElementById('compare-grid');
  grid.innerHTML = candidates.map(c => `
    <div class="option-card ${c === winner ? 'winner' : ''}" ${!c.viable ? 'style="opacity:0.45"' : ''}>
      ${c === winner ? '<span class="option-winner-tag">Best fit</span>' : ''}
      <div class="option-name">${c.name}</div>
      <div class="option-desc">${c.desc}${!c.viable ? ' Not viable for selected scope.' : ''}</div>
      <div class="option-price">${fmt(c.annual)}</div>
      <div class="option-price-sub">12-month all-in</div>
      <div class="option-breakdown">
        ${c.breakdown.map(([k, v]) => `<div><span>${k}</span><span>${v}</span></div>`).join('')}
      </div>
    </div>
  `).join('');

  // Recommendation
  const others = viableCandidates.filter(c => c !== winner);
  const savings = others.length > 0 ? Math.max(...others.map(o => o.annual - winner.annual)) : 0;

  let headline, body;
  if (winner.name === 'Fractional CMO') {
    headline = `Fractional CMO is your best fit — saves up to ${fmt(savings)}/year vs the next option.`;
    body = `At your stage and scope, a fractional CMO gives you senior leadership without the full-time burden. You get strategic ownership, hands-on execution, and 2–4 week ramp — at roughly ${Math.round((winner.annual / (others[0]?.annual || winner.annual)) * 100)}% the cost of ${others[0]?.name || 'the alternative'}.`;
  } else if (winner.name === 'Marketing Agency') {
    headline = `Agency is the cheapest viable option here — but you give up strategy ownership.`;
    body = `For pure campaign execution at lower hours, agencies are cost-effective. But you'll need someone internal to own strategy and outcomes. Many companies start here and graduate to fractional CMO once they need a strategy owner.`;
  } else {
    headline = `Full-time CMO makes sense given your scale and hour needs.`;
    body = `At 24+ hours/week of senior time, the math starts favoring a full-time hire over fractional. The trade-off: 3–6 month ramp, ~30% higher all-in cost, and significantly less flexibility. Worth it if you're at $30M+ ARR and need permanent institutional knowledge.`;
  }

  document.getElementById('rec-headline').textContent = headline;
  document.getElementById('rec-body').textContent = body;
}

// Initial render
recalc();
</script>

</body>
</html>
