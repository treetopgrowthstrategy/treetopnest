---
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ecofit Facility OpEx Assessment</title>
  <meta name="description" content="Find out how much operational spend your fitness facility could be recovering. Free 2-minute assessment." />
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@600;700&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      background: #14191f;
      color: #F2F3F8;
      font-family: 'Work Sans', sans-serif;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    /* PROGRESS */
    #progress-wrap {
      position: fixed; top: 0; left: 0; right: 0; height: 3px;
      background: rgba(132,188,65,0.15); z-index: 100;
      opacity: 0; transition: opacity 0.3s;
    }
    #progress-wrap.visible { opacity: 1; }
    #progress-bar { height: 100%; background: #84BC41; transition: width 0.4s ease; width: 0%; }

    /* NAV */
    .top-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 99;
      padding: 20px 32px; display: flex; align-items: center; justify-content: space-between;
      background: rgba(20,25,31,0.8); backdrop-filter: blur(12px);
    }
    .top-nav-logo img { height: 32px; display: block; }
    .top-nav-logo span {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: 22px; color: #84BC41;
    }
    .top-nav-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
      text-transform: uppercase; color: rgba(242,243,248,0.35);
    }

    /* STEP */
    .step {
      position: fixed; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 100px 32px 48px;
      opacity: 1; transition: opacity 0.32s ease, transform 0.32s ease;
      overflow-y: auto;
    }
    .step.hidden { opacity: 0; pointer-events: none; transform: translateY(18px); }
    .step.exit   { opacity: 0; transform: translateY(-18px); }
    .step-inner { width: 100%; max-width: 660px; }

    /* INTRO */
    .eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 11px; font-weight: 600; letter-spacing: 0.16em;
      text-transform: uppercase; color: #84BC41; margin-bottom: 28px;
    }
    .eyebrow::before { content: ''; width: 24px; height: 1px; background: #84BC41; }
    .intro-headline {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: clamp(2rem, 5vw, 3.2rem); line-height: 1.1;
      color: #F2F3F8; margin-bottom: 20px; letter-spacing: -0.01em;
    }
    .intro-headline .accent { color: #84BC41; }
    .intro-sub {
      font-size: 17px; font-weight: 300; color: #9699A2;
      line-height: 1.75; margin-bottom: 36px; max-width: 560px;
    }
    .stat-row { display: flex; gap: 32px; margin-bottom: 36px; flex-wrap: wrap; }
    .stat-item { display: flex; flex-direction: column; gap: 4px; }
    .stat-num {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: 2rem; color: #84BC41; line-height: 1;
    }
    .stat-label { font-size: 12px; color: #9699A2; max-width: 160px; line-height: 1.5; }

    /* BUTTONS */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: #84BC41; color: #14191f;
      border: none; padding: 14px 28px;
      font-family: 'Work Sans', sans-serif; font-size: 15px;
      font-weight: 600; cursor: pointer; border-radius: 4px;
      transition: background 0.2s, transform 0.15s; text-decoration: none;
    }
    .btn:hover { background: #9bd151; transform: translateY(-1px); }
    .btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
    .btn-ghost {
      background: transparent; color: #F2F3F8;
      border: 1px solid rgba(242,243,248,0.2); padding: 13px 26px;
    }
    .btn-ghost:hover { border-color: #84BC41; color: #84BC41; background: transparent; }
    .btn-note {
      display: block; margin-top: 12px; font-size: 12px;
      color: rgba(242,243,248,0.3); letter-spacing: 0.04em;
    }

    /* QUESTION STEPS */
    .q-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.16em;
      text-transform: uppercase; color: #84BC41; margin-bottom: 8px;
    }
    .q-context {
      font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(242,243,248,0.25); margin-bottom: 20px;
    }
    .q-text {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: clamp(1.4rem, 3.2vw, 2rem);
      line-height: 1.25; color: #F2F3F8; margin-bottom: 8px;
    }
    .q-hint {
      font-size: 13px; color: #9699A2; font-weight: 300;
      margin-bottom: 28px; line-height: 1.6;
    }

    /* SELECT */
    .select-wrap { position: relative; margin-bottom: 28px; }
    select {
      width: 100%; appearance: none; -webkit-appearance: none;
      background: #2F3535; border: 1px solid rgba(132,188,65,0.2);
      color: #F2F3F8; padding: 16px 48px 16px 20px;
      font-family: 'Work Sans', sans-serif; font-size: 16px;
      font-weight: 400; border-radius: 4px; cursor: pointer;
      outline: none; transition: border-color 0.2s;
    }
    select:focus { border-color: #84BC41; }
    select option { background: #2F3535; color: #F2F3F8; }
    .select-arrow {
      position: absolute; right: 18px; top: 50%; transform: translateY(-50%);
      pointer-events: none; color: #84BC41; font-size: 12px;
    }

    /* SCORE PREVIEW */
    .score-block {
      background: #2F3535; border: 1px solid rgba(132,188,65,0.2);
      border-left: 3px solid #84BC41; padding: 28px 32px; margin-bottom: 28px; border-radius: 4px;
    }
    .score-block-label {
      font-size: 10px; font-weight: 600; letter-spacing: 0.14em;
      text-transform: uppercase; color: rgba(242,243,248,0.4); margin-bottom: 10px;
    }
    .score-amount {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: 3rem; color: #84BC41; line-height: 1; display: block;
      margin-bottom: 6px;
    }
    .score-range-label { font-size: 13px; color: #9699A2; font-weight: 300; }

    /* LEAD FORM */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    .form-field { display: flex; flex-direction: column; gap: 6px; }
    .form-field.full { grid-column: 1 / -1; }
    .form-label {
      font-size: 10px; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: rgba(242,243,248,0.45);
    }
    .form-input {
      background: #2F3535; border: 1px solid rgba(132,188,65,0.15);
      color: #F2F3F8; padding: 14px 16px; font-family: 'Work Sans', sans-serif;
      font-size: 15px; font-weight: 300; border-radius: 4px; outline: none;
      transition: border-color 0.2s; width: 100%;
    }
    .form-input:focus { border-color: #84BC41; }
    .form-input::placeholder { color: rgba(242,243,248,0.25); }
    .form-note { font-size: 12px; color: rgba(242,243,248,0.3); margin-top: 12px; line-height: 1.5; }
    #submit-btn { width: 100%; justify-content: center; margin-top: 18px; padding: 16px; font-size: 16px; }
    #error-msg { color: #f87171; font-size: 13px; margin-top: 12px; display: none; }

    /* CONFIRM */
    .confirm-icon {
      width: 64px; height: 64px; border-radius: 50%;
      background: rgba(132,188,65,0.12); border: 1px solid #84BC41;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem; margin-bottom: 28px;
    }
    .confirm-headline {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: clamp(1.8rem, 4vw, 2.6rem); color: #F2F3F8;
      margin-bottom: 14px; line-height: 1.15;
    }
    .confirm-sub { font-size: 16px; color: #9699A2; line-height: 1.75; margin-bottom: 28px; max-width: 520px; }
    .confirm-stats { display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 28px; }
    .confirm-stat-label { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(242,243,248,0.35); }
    .confirm-stat-val { font-family: 'Raleway', sans-serif; font-weight: 700; font-size: 1.5rem; color: #84BC41; margin-top: 4px; }
    .back-link {
      margin-top: 24px; display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; color: rgba(242,243,248,0.3); text-decoration: none; transition: color 0.2s;
    }
    .back-link:hover { color: #9699A2; }

    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
      .stat-row { gap: 20px; }
      .top-nav { padding: 16px 20px; }
      .step { padding: 88px 20px 40px; }
    }
  </style>
</head>
<body>

<div id="progress-wrap"><div id="progress-bar"></div></div>

<nav class="top-nav">
  <div class="top-nav-logo">
    <img src="/assets/ecofit-logo-dark.png" alt="Ecofit" onerror="this.outerHTML='<span style=&quot;font-family:Raleway;font-weight:700;color:#84BC41;font-size:20px&quot;>ecofit</span>'">
  </div>
  <span class="top-nav-label">Facility OpEx Assessment</span>
</nav>

<!-- STEP 0: INTRO -->
<div class="step" id="step-0">
  <div class="step-inner">
    <div class="eyebrow">2-Minute Assessment · Free</div>
    <h1 class="intro-headline">
      Could your facility be<br>
      <span class="accent">squandering $250K+</span><br>
      every year?
    </h1>
    <p class="intro-sub">
      Multi-location fitness operators running without real equipment intelligence are absorbing enormous costs invisibly — in reactive maintenance, premature equipment replacement, and untracked floor performance. Eight questions tells you exactly how much is at stake for your network.
    </p>
    <div class="stat-row">
      <div class="stat-item">
        <span class="stat-num">40%</span>
        <span class="stat-label">reduction in equipment refresh costs with Ecofit intelligence</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">3.2x</span>
        <span class="stat-label">longer equipment lifespan on average across connected networks</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">200+</span>
        <span class="stat-label">assets networked per facility on average</span>
      </div>
    </div>
    <button class="btn" onclick="startAssessment()">
      Calculate My OpEx Risk →
    </button>
    <span class="btn-note">8 questions · No cost · Personalized report delivered to your inbox</span>
  </div>
</div>

<!-- QUESTIONS CONTAINER -->
<div id="questions-container"></div>

<!-- STEP LEAD: LEAD CAPTURE -->
<div class="step hidden" id="step-lead">
  <div class="step-inner">
    <div class="score-block">
      <div class="score-block-label">Estimated Annual OpEx at Risk</div>
      <span class="score-amount" id="score-display">—</span>
      <div class="score-range-label" id="score-sublabel"></div>
    </div>

    <h2 style="font-family:'Raleway',sans-serif;font-size:1.5rem;font-weight:700;margin-bottom:8px;color:#F2F3F8;">
      Get your full Facility Intelligence Report.
    </h2>
    <p style="font-size:14px;color:#9699A2;margin-bottom:24px;line-height:1.7;">
      Your personalized report breaks down OpEx exposure by category, benchmarks your network against comparable operators, and gives you three priority actions to close the gap.
    </p>

    <form id="lead-form">
      <div class="form-grid">
        <div class="form-field">
          <label class="form-label" for="f-name">First Name *</label>
          <input class="form-input" type="text" id="f-name" name="name" placeholder="Jordan" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="f-company">Company / Brand *</label>
          <input class="form-input" type="text" id="f-company" name="company" placeholder="Apex Fitness" required />
        </div>
        <div class="form-field full">
          <label class="form-label" for="f-email">Work Email *</label>
          <input class="form-input" type="email" id="f-email" name="email" placeholder="jordan@apexfitness.com" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="f-title">Your Title</label>
          <input class="form-input" type="text" id="f-title" name="title" placeholder="VP Operations, CEO..." />
        </div>
        <div class="form-field">
          <label class="form-label" for="f-phone">Phone</label>
          <input class="form-input" type="tel" id="f-phone" name="phone" placeholder="(555) 000-0000" />
        </div>
      </div>
      <p class="form-note">Your report arrives within 5 minutes. We don't share your information.</p>
      <button class="btn" id="submit-btn" type="submit">
        Send My Facility Report →
      </button>
      <div id="error-msg">Something went wrong. Please try again or email us directly.</div>
    </form>
  </div>
</div>

<!-- STEP CONFIRM -->
<div class="step hidden" id="step-confirm">
  <div class="step-inner">
    <div class="confirm-icon">✓</div>
    <h2 class="confirm-headline">Your report is on its way.</h2>
    <p class="confirm-sub">
      Check your inbox in the next few minutes. Your Ecofit Facility Intelligence Report includes a full OpEx exposure breakdown, benchmarks for your facility type, and three priority actions.
    </p>
    <div class="confirm-stats">
      <div>
        <div class="confirm-stat-label">Estimated at risk</div>
        <div class="confirm-stat-val" id="confirm-risk">—</div>
      </div>
      <div>
        <div class="confirm-stat-label">Network size</div>
        <div class="confirm-stat-val" id="confirm-network">—</div>
      </div>
    </div>
    <p style="font-size:14px;color:#9699A2;line-height:1.75;margin-bottom:24px;max-width:520px;">
      If the numbers raise questions or you want to see what the intelligence layer looks like for your specific network, an Ecofit analyst is available for a 30-minute no-commitment demo.
    </p>
    <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" class="btn" target="_blank">
      Book a Demo →
    </a>
    <a href="https://treetopgrowthstrategy.com" class="back-link">← Back to Treetop Growth Strategy</a>
  </div>
</div>

<script is:inline>
const QUESTIONS = [
  {
    id: 'locations',
    context: 'Your Network',
    text: 'How many locations do you currently operate?',
    hint: 'Include all active locations — owned, managed, or franchised.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: '1 location', value: '1' },
      { label: '2–5 locations', value: '2-5' },
      { label: '6–15 locations', value: '6-15' },
      { label: '16–50 locations', value: '16-50' },
      { label: '51–100 locations', value: '51-100' },
      { label: '100+ locations', value: '100+' },
    ]
  },
  {
    id: 'equipment',
    context: 'Your Network',
    text: 'Roughly how many pieces of equipment does your average location run?',
    hint: 'Count everything — cardio, strength, functional, specialty. Estimate is fine.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'Under 30 pieces', value: 'under-30' },
      { label: '30–75 pieces', value: '30-75' },
      { label: '76–150 pieces', value: '76-150' },
      { label: '151–300 pieces', value: '151-300' },
      { label: '300+ pieces', value: '300+' },
    ]
  },
  {
    id: 'tracking',
    context: 'Current Operations',
    text: 'How are you currently tracking equipment performance and utilization?',
    hint: 'Be honest — this is the single biggest driver of OpEx waste we see.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'Dedicated software or IoT-connected equipment', value: 'software' },
      { label: 'Service tickets and staff reports', value: 'tickets' },
      { label: 'Periodic manual audits', value: 'manual' },
      { label: 'We don\'t have a formal system', value: 'none' },
    ]
  },
  {
    id: 'maintenance',
    context: 'Current Operations',
    text: 'How much of your maintenance spend last year was reactive — unplanned repairs after something broke?',
    hint: 'Industry benchmark: best-in-class operators keep reactive spend under 20%.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'Mostly planned — under 25% reactive', value: 'planned' },
      { label: 'Roughly half and half', value: 'mixed' },
      { label: 'Mostly reactive — over 50% unplanned', value: 'reactive' },
      { label: 'We don\'t track this breakdown', value: 'unknown' },
    ]
  },
  {
    id: 'age',
    context: 'Equipment Profile',
    text: 'What\'s the average age of your primary cardio and strength equipment?',
    hint: 'Older fleets without visibility data carry compounding capex risk.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'Under 3 years — relatively new fleet', value: 'under-3' },
      { label: '3–6 years — starting to see more service calls', value: '3-6' },
      { label: '6–10 years — significant maintenance pressure', value: '6-10' },
      { label: '10+ years — major replacement cycle coming', value: '10+' },
    ]
  },
  {
    id: 'recovery',
    context: 'Equipment Profile',
    text: 'Do you have a dedicated recovery or wellness zone at your locations?',
    hint: 'Recovery zones are the fastest-growing capex category in fitness — and the least measured.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'No dedicated recovery area', value: 'none' },
      { label: 'Small zone — under 500 sq ft', value: 'small' },
      { label: 'Medium zone — 500–1,500 sq ft', value: 'medium' },
      { label: 'Large or premium recovery area — 1,500+ sq ft', value: 'large' },
    ]
  },
  {
    id: 'impact',
    context: 'Member Experience',
    text: 'In the last 12 months, how often has equipment downtime visibly impacted member experience?',
    hint: 'Out-of-order equipment, member complaints, or staff scrambling to respond.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'Rarely — equipment is mostly reliable', value: 'rarely' },
      { label: 'Occasionally — a few incidents per quarter', value: 'occasionally' },
      { label: 'Frequently — members notice and sometimes complain', value: 'frequently' },
      { label: 'It\'s a known pain point we haven\'t solved', value: 'known-pain' },
    ]
  },
  {
    id: 'data_confidence',
    context: 'Visibility & Analytics',
    text: 'How confident are you in the accuracy of your equipment ROI data right now?',
    hint: 'This is what Ecofit gives you. Most operators answer this question and feel the gap immediately.',
    type: 'select',
    options: [
      { label: 'Select your answer…', value: '' },
      { label: 'Very confident — we have real-time visibility', value: 'high' },
      { label: 'Somewhat confident — we track it but it\'s incomplete', value: 'medium' },
      { label: 'Not very confident — our data has significant gaps', value: 'low' },
      { label: 'We don\'t have equipment ROI data', value: 'none' },
    ]
  }
];

let answers = {};
let currentQ = 0;
const totalQ = QUESTIONS.length;

// Build question steps
const container = document.getElementById('questions-container');
QUESTIONS.forEach((q, i) => {
  const div = document.createElement('div');
  div.className = 'step hidden';
  div.id = `step-q${i}`;

  const inputHtml = `
    <div class="select-wrap">
      <select id="select-${q.id}" onchange="onSelectChange('${q.id}')">
        ${q.options.map(o => `<option value="${o.value}">${o.label}</option>`).join('')}
      </select>
      <span class="select-arrow">▼</span>
    </div>`;

  div.innerHTML = `
    <div class="step-inner">
      <div class="q-label">Question ${i + 1} of ${totalQ}</div>
      <div class="q-context">${q.context}</div>
      <div class="q-text">${q.text}</div>
      ${q.hint ? `<div class="q-hint">${q.hint}</div>` : ''}
      ${inputHtml}
      <div style="display:flex;gap:16px;align-items:center">
        <button class="btn" id="next-${i}" onclick="nextStep(${i})" disabled>
          ${i < totalQ - 1 ? 'Continue →' : 'See My Results →'}
        </button>
        ${i > 0 ? `<button class="btn btn-ghost" onclick="prevStep(${i})">← Back</button>` : ''}
      </div>
    </div>`;
  container.appendChild(div);
});

function onSelectChange(qId) {
  const sel = document.getElementById('select-' + qId);
  const qIdx = QUESTIONS.findIndex(q => q.id === qId);
  const btn = document.getElementById('next-' + qIdx);
  if (sel.value) {
    btn.disabled = false;
    answers[qId] = sel.value;
  } else {
    btn.disabled = true;
  }
}

function showStep(id) {
  document.querySelectorAll('.step').forEach(s => {
    if (!s.classList.contains('hidden')) {
      s.classList.add('exit');
      setTimeout(() => { s.classList.add('hidden'); s.classList.remove('exit'); }, 320);
    }
  });
  setTimeout(() => {
    const next = document.getElementById(id);
    if (next) { next.classList.remove('hidden'); next.scrollTop = 0; }
  }, 200);
}

function updateProgress(n) {
  const pct = Math.round((n / totalQ) * 100);
  document.getElementById('progress-bar').style.width = pct + '%';
  document.getElementById('progress-wrap').classList.toggle('visible', n > 0);
}

function startAssessment() {
  showStep('step-q0');
  updateProgress(0);
}

function nextStep(i) {
  if (i < totalQ - 1) {
    showStep(`step-q${i + 1}`);
    updateProgress(i + 1);
  } else {
    computeAndShowLead();
  }
}

function prevStep(i) {
  showStep(i === 0 ? 'step-0' : `step-q${i - 1}`);
  updateProgress(Math.max(0, i - 1));
}

// ─── SCORING ─────────────────────────────────────────────────────────────────
function computeRisk() {
  // Location scale
  const locMap = { '1': 1, '2-5': 3, '6-15': 10, '16-50': 30, '51-100': 75, '100+': 150 };
  const locations = locMap[answers.locations] || 1;

  // Equipment density: midpoint pieces per location
  const equipMap = { 'under-30': 18, '30-75': 50, '76-150': 110, '151-300': 220, '300+': 350 };
  const equipPerLoc = equipMap[answers.equipment] || 18;

  // Base equipment risk: $2,000/piece/year visibility gap
  const equipRisk = equipPerLoc * locations * 2000;

  // Tracking sophistication multiplier — the biggest lever
  const trackMult = { 'software': 0.55, 'tickets': 1.0, 'manual': 1.25, 'none': 1.5 };
  const tMult = trackMult[answers.tracking] || 1.0;

  // Maintenance posture multiplier
  const maintMult = { 'planned': 0.65, 'mixed': 1.0, 'reactive': 1.45, 'unknown': 1.25 };
  const mMult = maintMult[answers.maintenance] || 1.0;

  // Equipment age adds capex risk per location
  const ageRiskMap = { 'under-3': 0, '3-6': 12000, '6-10': 38000, '10+': 75000 };
  const capexRisk = (ageRiskMap[answers.age] || 0) * locations;

  // Recovery zone (untracked investment = waste)
  const recovMap = { 'none': 0, 'small': 10000, 'medium': 24000, 'large': 48000 };
  const recovRisk = (recovMap[answers.recovery] || 0) * locations;

  // Member experience impact multiplier
  const impactMult = { 'rarely': 0.85, 'occasionally': 1.0, 'frequently': 1.2, 'known-pain': 1.35 };
  const iMult = impactMult[answers.impact] || 1.0;

  // Data confidence multiplier — ends on the core value prop
  const dataMult = { 'high': 0.5, 'medium': 0.9, 'low': 1.2, 'none': 1.45 };
  const dMult = dataMult[answers.data_confidence] || 1.0;

  const total = (equipRisk * tMult * mMult * iMult * dMult) + (capexRisk * mMult) + (recovRisk * dMult);
  return Math.round(total);
}

function formatMoney(n) {
  if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
  if (n >= 1000) return '$' + Math.round(n / 1000) + 'K';
  return '$' + n.toLocaleString();
}

function getRiskLabel(n) {
  if (n < 100000) return 'Emerging exposure — targeted quick wins available';
  if (n < 300000) return 'Significant exposure — clear ROI opportunity at this scale';
  if (n < 750000) return 'High exposure — network-wide intelligence pays for itself fast';
  return 'Critical exposure — every quarter without visibility compounds the cost';
}

function getNetworkLabel() {
  const locMap = {
    '1': '1 location', '2-5': '2–5 locations', '6-15': '6–15 locations',
    '16-50': '16–50 locations', '51-100': '51–100 locations', '100+': '100+ locations'
  };
  return locMap[answers.locations] || 'your network';
}

function computeAndShowLead() {
  const risk = computeRisk();
  const lo = formatMoney(Math.round(risk * 0.75));
  const hi = formatMoney(Math.round(risk * 1.35));
  document.getElementById('score-display').textContent = `${lo}–${hi}`;
  document.getElementById('score-sublabel').textContent = getRiskLabel(risk);
  window._riskDisplay = `${lo}–${hi}`;
  showStep('step-lead');
  updateProgress(totalQ);
}

// ─── FORM SUBMIT ──────────────────────────────────────────────────────────────
document.getElementById('lead-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  const errEl = document.getElementById('error-msg');
  btn.disabled = true;
  btn.textContent = 'Generating your report…';
  errEl.style.display = 'none';

  const risk = computeRisk();
  const payload = {
    name: document.getElementById('f-name').value.trim(),
    email: document.getElementById('f-email').value.trim(),
    company: document.getElementById('f-company').value.trim(),
    title: document.getElementById('f-title').value.trim(),
    phone: document.getElementById('f-phone').value.trim(),
    answers,
    riskLow:  Math.round(risk * 0.75),
    riskHigh: Math.round(risk * 1.35),
    riskMid:  risk,
    networkLabel: getNetworkLabel(),
  };

  try {
    const res = await fetch('/api/ecofit-assessment-submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) throw new Error('Server error');

    document.getElementById('confirm-risk').textContent = window._riskDisplay || `${formatMoney(payload.riskLow)}–${formatMoney(payload.riskHigh)}`;
    document.getElementById('confirm-network').textContent = getNetworkLabel();
    showStep('step-confirm');
    document.getElementById('progress-wrap').classList.remove('visible');
  } catch (err) {
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Send My Facility Report →';
  }
});
</script>

