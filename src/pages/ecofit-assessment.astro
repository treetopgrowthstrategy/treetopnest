---
export const prerender = true;

const QUESTIONS = [
  {
    id: 'locations', context: 'Your Network',
    text: 'How many locations do you currently operate?',
    hint: 'Include all active locations — owned, managed, or franchised.',
    options: [
      { label: '1 location',       value: '1' },
      { label: '2–5 locations',    value: '2-5' },
      { label: '6–15 locations',   value: '6-15' },
      { label: '16–50 locations',  value: '16-50' },
      { label: '51–100 locations', value: '51-100' },
      { label: '100+ locations',   value: '100+' },
    ]
  },
  {
    id: 'equipment', context: 'Your Network',
    text: 'Roughly how many pieces of equipment does your average location run?',
    hint: 'Count everything — cardio, strength, functional, specialty. Estimate is fine.',
    options: [
      { label: 'Under 30 pieces',  value: 'under-30' },
      { label: '30–75 pieces',     value: '30-75' },
      { label: '76–150 pieces',    value: '76-150' },
      { label: '151–300 pieces',   value: '151-300' },
      { label: '300+ pieces',      value: '300+' },
    ]
  },
  {
    id: 'tracking', context: 'Current Operations',
    text: 'How are you currently tracking equipment performance and utilization?',
    hint: 'This is the single biggest driver of OpEx waste we see across operators.',
    options: [
      { label: 'Dedicated software or IoT-connected equipment', value: 'software' },
      { label: 'Service tickets and staff reports',             value: 'tickets' },
      { label: 'Periodic manual audits',                       value: 'manual' },
      { label: "We don't have a formal system",                value: 'none' },
    ]
  },
  {
    id: 'maintenance', context: 'Current Operations',
    text: 'How much of your maintenance spend last year was reactive — unplanned repairs after something broke?',
    hint: 'Industry benchmark: best-in-class operators keep reactive spend under 20%.',
    options: [
      { label: 'Mostly planned — under 25% reactive',    value: 'planned' },
      { label: 'Roughly half and half',                  value: 'mixed' },
      { label: 'Mostly reactive — over 50% unplanned',   value: 'reactive' },
      { label: "We don't track this breakdown",          value: 'unknown' },
    ]
  },
  {
    id: 'age', context: 'Equipment Profile',
    text: "What's the average age of your primary cardio and strength equipment?",
    hint: 'Older fleets without visibility data carry compounding capex risk.',
    options: [
      { label: 'Under 3 years — relatively new fleet',           value: 'under-3' },
      { label: '3–6 years — starting to see more service calls', value: '3-6' },
      { label: '6–10 years — significant maintenance pressure',  value: '6-10' },
      { label: '10+ years — major replacement cycle coming',     value: '10+' },
    ]
  },
  {
    id: 'recovery', context: 'Equipment Profile',
    text: 'Do you have a dedicated recovery or wellness zone at your locations?',
    hint: 'Recovery zones are the fastest-growing capex category in fitness — and the least measured.',
    options: [
      { label: 'No dedicated recovery area',                     value: 'none' },
      { label: 'Small zone — under 500 sq ft',                  value: 'small' },
      { label: 'Medium zone — 500–1,500 sq ft',                 value: 'medium' },
      { label: 'Large or premium recovery area — 1,500+ sq ft', value: 'large' },
    ]
  },
  {
    id: 'impact', context: 'Member Experience',
    text: 'In the last 12 months, how often has equipment downtime visibly impacted member experience?',
    hint: 'Out-of-order equipment, member complaints, or staff scrambling to respond.',
    options: [
      { label: 'Rarely — equipment is mostly reliable',              value: 'rarely' },
      { label: 'Occasionally — a few incidents per quarter',         value: 'occasionally' },
      { label: 'Frequently — members notice and sometimes complain', value: 'frequently' },
      { label: "It's a known pain point we haven't solved",         value: 'known-pain' },
    ]
  },
  {
    id: 'data_confidence', context: 'Visibility & Analytics',
    text: 'How confident are you in the accuracy of your equipment ROI data right now?',
    hint: 'This is what Ecofit gives you. Most operators feel the gap as soon as they answer this.',
    options: [
      { label: 'Very confident — we have real-time visibility',         value: 'high' },
      { label: "Somewhat confident — we track it but it's incomplete", value: 'medium' },
      { label: 'Not very confident — our data has significant gaps',    value: 'low' },
      { label: "We don't have equipment ROI data",                      value: 'none' },
    ]
  },
];

const totalQ = QUESTIONS.length;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ecofit Facility OpEx Assessment</title>
  <meta name="description" content="Find out how much operational spend your fitness facility could be recovering. Free 2-minute assessment." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/ecofit-assessment" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/ecofit-assessment" />
  <meta property="og:title" content="Ecofit Facility OpEx Assessment" />
  <meta property="og:description" content="Find out how much operational spend your fitness facility could be recovering. Free 2-minute assessment." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Ecofit Facility OpEx Assessment" />
  <meta name="twitter:description" content="Find out how much operational spend your fitness facility could be recovering. Free 2-minute assessment." />
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Ecofit Facility OpEx Assessment",
      "description": "Find out how much operational spend your fitness facility could be recovering. Free 2-minute assessment.",
      "url": "https://treetopgrowthstrategy.com/ecofit-assessment",
      "provider": {"@id": "https://treetopgrowthstrategy.com/#organization"},
      "areaServed": {"@type": "Country", "name": "United States"},
      "audience": {"@type": "Audience", "description": "B2B executives and small business owners"}
    },
    {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
  ]
}
  </script>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@600;700&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      background: #14191f;
      color: #F2F3F8;
      font-family: 'Work Sans', sans-serif;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    /* ── PROGRESS ── */
    #progress-wrap {
      position: fixed; top: 0; left: 0; right: 0;
      height: 3px; z-index: 300;
      background: rgba(132,188,65,0.12);
    }
    #progress-bar {
      height: 100%; width: 0%;
      background: #84BC41;
      transition: width 0.4s cubic-bezier(0.4,0,0.2,1);
    }

    /* ── NAV ── */
    .ec-nav {
      position: fixed; top: 0; left: 0; right: 0;
      height: 64px; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px;
      background: rgba(20,25,31,0.95);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(132,188,65,0.1);
    }
    .ec-nav img { height: 30px; display: block; }
    .ec-nav-fallback { font-family: 'Raleway', sans-serif; font-weight: 700; font-size: 20px; color: #84BC41; }
    .ec-nav-label { font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(242,243,248,0.3); }

    /* ── STEPS ── */
    /* Steps fill viewport below the nav */
    .ec-step {
      position: fixed;
      top: 64px; left: 0; right: 0; bottom: 0;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 52px 32px 60px;
      opacity: 1;
      transition: opacity 0.26s ease, transform 0.26s ease;
    }
    .ec-step.hidden { opacity: 0; pointer-events: none; transform: translateY(16px); }
    .ec-step.exit   { opacity: 0; pointer-events: none; transform: translateY(-16px); }

    .ec-inner { width: 100%; max-width: 620px; }

    /* centre content on taller steps */
    .ec-center {
      display: flex; flex-direction: column; justify-content: center;
      min-height: calc(100vh - 64px - 112px);
    }

    /* ── INTRO ── */
    .ec-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
      text-transform: uppercase; color: #84BC41; margin-bottom: 22px;
    }
    .ec-eyebrow::before { content: ''; width: 20px; height: 1px; background: #84BC41; }

    .ec-h1 {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: clamp(2rem, 5.5vw, 3.2rem); line-height: 1.08;
      color: #F2F3F8; letter-spacing: -0.015em; margin-bottom: 18px;
    }
    .ec-h1 em { color: #84BC41; font-style: normal; }

    .ec-intro-sub {
      font-size: 16px; font-weight: 300; color: #9699A2;
      line-height: 1.8; margin-bottom: 36px; max-width: 520px;
    }

    .ec-stats {
      display: grid; grid-template-columns: repeat(3, 1fr);
      border: 1px solid rgba(132,188,65,0.14);
      margin-bottom: 40px;
    }
    .ec-stat {
      padding: 18px 22px;
      border-right: 1px solid rgba(132,188,65,0.14);
    }
    .ec-stat:last-child { border-right: none; }
    .ec-stat-n {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: 1.75rem; color: #84BC41; line-height: 1; margin-bottom: 6px;
    }
    .ec-stat-l { font-size: 11px; color: rgba(242,243,248,0.38); line-height: 1.5; }

    /* ── BUTTONS ── */
    .ec-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: #84BC41; color: #14191f;
      border: none; padding: 14px 28px;
      font-family: 'Work Sans', sans-serif; font-size: 15px; font-weight: 600;
      cursor: pointer; border-radius: 3px; letter-spacing: 0.01em;
      transition: background 0.15s, transform 0.12s;
      text-decoration: none;
    }
    .ec-btn:hover  { background: #96d147; transform: translateY(-1px); }
    .ec-btn:active { transform: translateY(0); }
    .ec-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .ec-btn-ghost {
      background: transparent; color: #F2F3F8;
      border: 1px solid rgba(242,243,248,0.18);
    }
    .ec-btn-ghost:hover { border-color: rgba(132,188,65,0.5); color: #84BC41; background: transparent; }

    .ec-btn-note { display: block; margin-top: 12px; font-size: 12px; color: rgba(242,243,248,0.28); }

    /* ── QUESTION ── */
    .ec-q-meta {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 24px;
    }
    .ec-q-num {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: 12px; color: #84BC41; letter-spacing: 0.06em;
    }
    .ec-q-div { width: 1px; height: 12px; background: rgba(132,188,65,0.3); }
    .ec-q-cat {
      font-size: 10px; font-weight: 600; letter-spacing: 0.18em;
      text-transform: uppercase; color: rgba(242,243,248,0.28);
    }
    .ec-q-text {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: clamp(1.35rem, 3.2vw, 1.9rem);
      line-height: 1.25; color: #F2F3F8; margin-bottom: 12px;
    }
    .ec-q-hint {
      font-size: 13px; color: rgba(242,243,248,0.36); font-weight: 300;
      line-height: 1.65; padding-left: 14px;
      border-left: 2px solid rgba(132,188,65,0.22);
      margin-bottom: 28px;
    }

    /* ── OPTION CARDS ── */
    .ec-options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 28px;
    }
    .ec-opt {
      display: flex; align-items: flex-start; gap: 13px;
      background: rgba(47,53,53,0.6);
      border: 1.5px solid rgba(132,188,65,0.14);
      border-radius: 4px; padding: 15px 18px;
      cursor: pointer; text-align: left;
      transition: border-color 0.14s, background 0.14s, transform 0.1s;
      color: #D8DDE0;
      font-family: 'Work Sans', sans-serif;
      font-size: 14px; font-weight: 400; line-height: 1.45;
      -webkit-user-select: none; user-select: none;
      -webkit-appearance: none; appearance: none;
    }
    .ec-opt:hover {
      border-color: rgba(132,188,65,0.5);
      background: rgba(132,188,65,0.05);
      color: #F2F3F8;
    }
    .ec-opt.selected {
      border-color: #84BC41;
      background: rgba(132,188,65,0.1);
      color: #F2F3F8;
      transform: scale(1.01);
    }

    /* radio circle */
    .ec-opt-dot {
      width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px;
      border: 1.5px solid rgba(132,188,65,0.35); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.14s;
    }
    .ec-opt.selected .ec-opt-dot {
      background: #84BC41; border-color: #84BC41;
    }
    .ec-opt.selected .ec-opt-dot::after {
      content: '';
      width: 6px; height: 6px;
      background: #14191f; border-radius: 50%;
    }

    /* back */
    .ec-back {
      background: none; border: none; cursor: pointer;
      font-family: 'Work Sans', sans-serif; font-size: 13px;
      color: rgba(242,243,248,0.28); padding: 0;
      transition: color 0.14s; display: inline-flex; align-items: center; gap: 4px;
    }
    .ec-back:hover { color: rgba(242,243,248,0.55); }

    /* ── LEAD / FORM ── */
    .ec-risk-block {
      background: rgba(47,53,53,0.7);
      border: 1px solid rgba(132,188,65,0.2);
      border-left: 4px solid #84BC41;
      border-radius: 4px; padding: 26px 30px; margin-bottom: 28px;
    }
    .ec-risk-lbl {
      font-size: 10px; font-weight: 600; letter-spacing: 0.16em;
      text-transform: uppercase; color: rgba(242,243,248,0.36); margin-bottom: 8px;
    }
    .ec-risk-amt {
      font-family: 'Raleway', sans-serif; font-weight: 700;
      font-size: clamp(2rem, 6vw, 3.2rem);
      color: #84BC41; line-height: 1; display: block; margin-bottom: 6px;
    }
    .ec-risk-sub { font-size: 13px; color: #9699A2; font-weight: 300; }

    .ec-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 11px; margin-bottom: 11px; }
    .ec-form-field { display: flex; flex-direction: column; gap: 6px; }
    .ec-form-field.full { grid-column: 1 / -1; }
    .ec-form-label { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(242,243,248,0.36); }
    .ec-form-input {
      background: rgba(47,53,53,0.7);
      border: 1.5px solid rgba(132,188,65,0.14);
      color: #F2F3F8; padding: 12px 15px;
      font-family: 'Work Sans', sans-serif; font-size: 15px; font-weight: 300;
      border-radius: 4px; outline: none; width: 100%;
      transition: border-color 0.15s;
      -webkit-appearance: none;
    }
    .ec-form-input:focus { border-color: #84BC41; }
    .ec-form-input::placeholder { color: rgba(242,243,248,0.2); }
    .ec-form-note { font-size: 12px; color: rgba(242,243,248,0.24); margin-top: 10px; line-height: 1.5; }
    #submit-btn { width: 100%; justify-content: center; margin-top: 14px; padding: 15px; font-size: 15px; }
    #error-msg { color: #f87171; font-size: 13px; margin-top: 10px; display: none; }

    /* ── CONFIRM ── */
    .ec-check {
      width: 56px; height: 56px; border-radius: 50%;
      background: rgba(132,188,65,0.1); border: 1px solid rgba(132,188,65,0.5);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 24px;
    }
    .ec-confirm-h { font-family: 'Raleway', sans-serif; font-weight: 700; font-size: clamp(1.7rem,4vw,2.4rem); color: #F2F3F8; margin-bottom: 12px; line-height: 1.15; }
    .ec-confirm-sub { font-size: 15px; color: #9699A2; line-height: 1.8; margin-bottom: 28px; max-width: 480px; font-weight: 300; }
    .ec-confirm-stats {
      display: grid; grid-template-columns: 1fr 1fr;
      border: 1px solid rgba(132,188,65,0.14);
      margin-bottom: 32px;
    }
    .ec-confirm-stat {
      padding: 18px 22px;
      border-right: 1px solid rgba(132,188,65,0.14);
    }
    .ec-confirm-stat:last-child { border-right: none; }
    .ec-confirm-stat-l { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(242,243,248,0.3); margin-bottom: 8px; }
    .ec-confirm-stat-v { font-family: 'Raleway', sans-serif; font-weight: 700; font-size: 1.35rem; color: #84BC41; }
    .ec-back-link { margin-top: 22px; display: inline-flex; align-items: center; gap: 5px; font-size: 13px; color: rgba(242,243,248,0.22); text-decoration: none; transition: color 0.14s; }
    .ec-back-link:hover { color: rgba(242,243,248,0.45); }

    @media (max-width: 560px) {
      .ec-nav { padding: 0 20px; }
      .ec-step { padding: 36px 18px 48px; }
      .ec-options { grid-template-columns: 1fr; }
      .ec-form-grid { grid-template-columns: 1fr; }
      .ec-stats { grid-template-columns: 1fr; }
      .ec-stat { border-right: none; border-bottom: 1px solid rgba(132,188,65,0.14); }
      .ec-stat:last-child { border-bottom: none; }
      .ec-confirm-stats { grid-template-columns: 1fr; }
      .ec-confirm-stat { border-right: none; border-bottom: 1px solid rgba(132,188,65,0.14); }
      .ec-confirm-stat:last-child { border-bottom: none; }
    }
  </style>
</head>
<body>

<div id="progress-wrap"><div id="progress-bar"></div></div>

<nav class="ec-nav">
  <img src="/assets/ecofit-logo-dark.png" alt="Ecofit"
       onerror="this.outerHTML='<span class=&quot;ec-nav-fallback&quot;>ecofit</span>'" />
  <span class="ec-nav-label">Facility OpEx Assessment</span>
</nav>

<!-- ── INTRO ───────────────────────────────────────────────── -->
<div class="ec-step" id="step-0">
  <div class="ec-inner">
    <div class="ec-center">
      <div class="ec-eyebrow">Free · 2 Minutes · Personalized Report</div>
      <h1 class="ec-h1">
        Could your facility be<br>
        <em>squandering $250K+</em><br>
        every year?
      </h1>
      <p class="ec-intro-sub">
        Multi-location fitness operators running without real equipment intelligence are absorbing enormous costs invisibly. Eight questions tells you exactly how much is at stake — and where to start closing the gap.
      </p>
      <div class="ec-stats">
        <div class="ec-stat">
          <div class="ec-stat-n">40%</div>
          <div class="ec-stat-l">Reduction in equipment refresh costs</div>
        </div>
        <div class="ec-stat">
          <div class="ec-stat-n">3.2×</div>
          <div class="ec-stat-l">Longer equipment lifespan on average</div>
        </div>
        <div class="ec-stat">
          <div class="ec-stat-n">200+</div>
          <div class="ec-stat-l">Assets networked per facility</div>
        </div>
      </div>
      <div>
        <button class="ec-btn" onclick="startAssessment()">Calculate My OpEx Risk →</button>
        <span class="ec-btn-note">No cost · Personalized report delivered to your inbox</span>
      </div>
    </div>
  </div>
</div>

<!-- ── QUESTION STEPS (server-rendered) ─────────────────────── -->
{QUESTIONS.map((q, i) => (
  <div class="ec-step hidden" id={`step-q${i}`}>
    <div class="ec-inner">
      <div class="ec-q-meta">
        <span class="ec-q-num">{String(i + 1).padStart(2, '0')} / {String(totalQ).padStart(2, '0')}</span>
        <span class="ec-q-div"></span>
        <span class="ec-q-cat">{q.context}</span>
      </div>
      <div class="ec-q-text">{q.text}</div>
      {q.hint && <div class="ec-q-hint">{q.hint}</div>}
      <div class="ec-options">
        {q.options.map(o => (
          <button
            class="ec-opt"
            type="button"
            onclick={`selectOpt('${q.id}','${o.value}',${i},this)`}
          >
            <span class="ec-opt-dot"></span>
            <span>{o.label}</span>
          </button>
        ))}
      </div>
      {i > 0 && (
        <button class="ec-back" onclick={`prevStep(${i})`}>← Back</button>
      )}
    </div>
  </div>
))}

<!-- ── LEAD CAPTURE ──────────────────────────────────────────── -->
<div class="ec-step hidden" id="step-lead">
  <div class="ec-inner">
    <div class="ec-center">
      <div class="ec-risk-block">
        <div class="ec-risk-lbl">Estimated Annual OpEx at Risk</div>
        <span class="ec-risk-amt" id="score-display">—</span>
        <div class="ec-risk-sub" id="score-sublabel"></div>
      </div>
      <h2 style="font-family:'Raleway',sans-serif;font-size:1.4rem;font-weight:700;margin-bottom:8px;color:#F2F3F8;">Get your full Facility Intelligence Report.</h2>
      <p style="font-size:14px;color:#9699A2;margin-bottom:22px;line-height:1.75;font-weight:300;">Your personalized report breaks down OpEx exposure by category, benchmarks your network against comparable operators, and gives you three priority actions.</p>
      <form id="lead-form">
        <div class="ec-form-grid">
          <div class="ec-form-field">
            <label class="ec-form-label" for="f-name">First Name *</label>
            <input class="ec-form-input" type="text" id="f-name" placeholder="Jordan" required />
          </div>
          <div class="ec-form-field">
            <label class="ec-form-label" for="f-company">Company *</label>
            <input class="ec-form-input" type="text" id="f-company" placeholder="Apex Fitness" required />
          </div>
          <div class="ec-form-field full">
            <label class="ec-form-label" for="f-email">Work Email *</label>
            <input class="ec-form-input" type="email" id="f-email" placeholder="jordan@apexfitness.com" required />
          </div>
          <div class="ec-form-field">
            <label class="ec-form-label" for="f-title">Title</label>
            <input class="ec-form-input" type="text" id="f-title" placeholder="VP Operations, CEO…" />
          </div>
          <div class="ec-form-field">
            <label class="ec-form-label" for="f-phone">Phone</label>
            <input class="ec-form-input" type="tel" id="f-phone" placeholder="(555) 000-0000" />
          </div>
        </div>
        <p class="ec-form-note">Report arrives within 5 minutes. We don't share your information.</p>
        <button class="ec-btn" id="submit-btn" type="submit">Send My Facility Report →</button>
        <div id="error-msg">Something went wrong — please try again.</div>
      </form>
    </div>
  </div>
</div>

<!-- ── CONFIRM ───────────────────────────────────────────────── -->
<div class="ec-step hidden" id="step-confirm">
  <div class="ec-inner">
    <div class="ec-center">
      <div class="ec-check">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#84BC41" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h2 class="ec-confirm-h">Your report is on its way.</h2>
      <p class="ec-confirm-sub">Check your inbox in the next few minutes. Your Ecofit Facility Intelligence Report includes a full OpEx breakdown, benchmarks for your facility type, and three priority actions.</p>
      <div class="ec-confirm-stats">
        <div class="ec-confirm-stat">
          <div class="ec-confirm-stat-l">Estimated at risk</div>
          <div class="ec-confirm-stat-v" id="confirm-risk">—</div>
        </div>
        <div class="ec-confirm-stat">
          <div class="ec-confirm-stat-l">Network size</div>
          <div class="ec-confirm-stat-v" id="confirm-network">—</div>
        </div>
      </div>
      <p style="font-size:14px;color:#9699A2;line-height:1.8;margin-bottom:26px;max-width:460px;font-weight:300;">If you'd like to see what the intelligence layer looks like for your specific network, an Ecofit analyst is available for a 30-minute no-commitment demo.</p>
      <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" class="ec-btn" target="_blank" rel="noopener">Book a Demo →</a>
      <a href="https://treetopgrowthstrategy.com" class="ec-back-link">← Back to Treetop Growth Strategy</a>
    </div>
  </div>
</div>

<script is:inline>
  let answers = {};
  const totalQ = document.querySelectorAll('[id^="step-q"]').length;

  function showStep(id) {
    document.querySelectorAll('.ec-step').forEach(s => {
      if (!s.classList.contains('hidden')) {
        s.classList.add('exit');
        setTimeout(() => { s.classList.add('hidden'); s.classList.remove('exit'); }, 260);
      }
    });
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) { el.classList.remove('hidden'); el.scrollTop = 0; }
    }, 160);
  }

  function updateProgress(n) {
    document.getElementById('progress-bar').style.width = Math.round((n / totalQ) * 100) + '%';
  }

  function startAssessment() {
    showStep('step-q0');
    updateProgress(0);
  }

  function selectOpt(qId, value, stepIdx, el) {
    el.closest('.ec-options').querySelectorAll('.ec-opt').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    answers[qId] = value;
    setTimeout(() => {
      const next = stepIdx + 1;
      if (next < totalQ) {
        showStep('step-q' + next);
        updateProgress(next);
      } else {
        computeAndShowLead();
      }
    }, 340);
  }

  function prevStep(i) {
    showStep(i <= 0 ? 'step-0' : 'step-q' + (i - 1));
    updateProgress(Math.max(0, i - 1));
  }

  // ── SCORING ────────────────────────────────────────────────
  function computeRisk() {
    const locMap     = {'1':1,'2-5':3,'6-15':10,'16-50':30,'51-100':75,'100+':150};
    const equipMap   = {'under-30':18,'30-75':50,'76-150':110,'151-300':220,'300+':350};
    const trackMult  = {'software':0.55,'tickets':1.0,'manual':1.25,'none':1.5};
    const maintMult  = {'planned':0.65,'mixed':1.0,'reactive':1.45,'unknown':1.25};
    const ageRisk    = {'under-3':0,'3-6':12000,'6-10':38000,'10+':75000};
    const recovMap   = {'none':0,'small':10000,'medium':24000,'large':48000};
    const impactMult = {'rarely':0.85,'occasionally':1.0,'frequently':1.2,'known-pain':1.35};
    const dataMult   = {'high':0.5,'medium':0.9,'low':1.2,'none':1.45};

    const locs  = locMap[answers.locations]   || 1;
    const equip = equipMap[answers.equipment] || 18;
    const tM    = trackMult[answers.tracking] || 1.0;
    const mM    = maintMult[answers.maintenance] || 1.0;
    const capex = (ageRisk[answers.age]   || 0) * locs;
    const recov = (recovMap[answers.recovery] || 0) * locs;
    const iM    = impactMult[answers.impact] || 1.0;
    const dM    = dataMult[answers.data_confidence] || 1.0;

    return Math.round((equip * locs * 2000 * tM * mM * iM * dM) + (capex * mM) + (recov * dM));
  }

  function fmtM(n) {
    if (n >= 1000000) return '$' + (n/1000000).toFixed(1) + 'M';
    if (n >= 1000)    return '$' + Math.round(n/1000) + 'K';
    return '$' + n.toLocaleString();
  }

  function riskLabel(n) {
    if (n < 100000) return 'Emerging exposure — targeted quick wins available';
    if (n < 300000) return 'Significant exposure — clear ROI opportunity at this scale';
    if (n < 750000) return 'High exposure — network-wide intelligence pays for itself fast';
    return 'Critical exposure — every quarter without visibility compounds the cost';
  }

  function networkLabel() {
    return ({'1':'1 location','2-5':'2–5 locations','6-15':'6–15 locations',
             '16-50':'16–50 locations','51-100':'51–100 locations','100+':'100+ locations'}
            [answers.locations] || 'your network');
  }

  function computeAndShowLead() {
    const r = computeRisk();
    const lo = fmtM(Math.round(r * 0.75));
    const hi = fmtM(Math.round(r * 1.35));
    document.getElementById('score-display').textContent  = lo + '–' + hi;
    document.getElementById('score-sublabel').textContent = riskLabel(r);
    window._riskDisplay = lo + '–' + hi;
    showStep('step-lead');
    updateProgress(totalQ);
  }

  // ── SUBMIT ─────────────────────────────────────────────────
  document.getElementById('lead-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn   = document.getElementById('submit-btn');
    var errEl = document.getElementById('error-msg');
    btn.disabled = true;
    btn.textContent = 'Generating your report…';
    errEl.style.display = 'none';

    var r = computeRisk();
    var payload = {
      name:         document.getElementById('f-name').value.trim(),
      email:        document.getElementById('f-email').value.trim(),
      company:      document.getElementById('f-company').value.trim(),
      title:        document.getElementById('f-title').value.trim(),
      phone:        document.getElementById('f-phone').value.trim(),
      answers:      answers,
      riskLow:      Math.round(r * 0.75),
      riskHigh:     Math.round(r * 1.35),
      riskMid:      r,
      networkLabel: networkLabel(),
    };

    try {
      var res = await fetch('/api/ecofit-assessment-submit', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error();
      document.getElementById('confirm-risk').textContent    = window._riskDisplay || (fmtM(payload.riskLow) + '–' + fmtM(payload.riskHigh));
      document.getElementById('confirm-network').textContent = networkLabel();
      showStep('step-confirm');
      document.getElementById('progress-bar').style.width = '100%';
    } catch(_) {
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send My Facility Report →';
    }
  });
</script>

</body>
</html>
