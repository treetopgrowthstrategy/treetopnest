  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .compare-table { width: 100%; border-collapse: collapse; margin-top: 2rem; }
    .compare-table th { background: #1A3A1A; padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #8FAF8F; }
    .compare-table td { padding: 0.875rem 1.25rem; border-bottom: 1px solid #1A3A1A; font-size: 0.85rem; color: #8FAF8F; background: #0A1A0A; }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table td:first-child { font-weight: 500; color: #F0FFF0; }
    .winner-claude { color: #00C853; font-weight: 600; font-size: 0.78rem; }
    .winner-tie { color: #C8A000; font-weight: 600; font-size: 0.78rem; }
    .winner-other { color: #8FAF8F; font-weight: 500; font-size: 0.78rem; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .card { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; }
    .card-title { font-family: 'Instrument Serif', serif; font-size: 1.35rem; color: #F0FFF0; margin-bottom: 1rem; }
    .card-list { list-style: none; }
    .card-list li { font-size: 0.88rem; color: #8FAF8F; line-height: 1.7; padding: 0.4rem 0; border-bottom: 1px solid #1A3A1A; display: flex; gap: 0.75rem; }
    .card-list li:last-child { border-bottom: none; }
    .card-list li::before { content: "→"; color: #00C853; flex-shrink: 0; }
    .verdict-box { background: #0A1A0A; border: 1px solid #1A3A1A; border-left: 3px solid #00C853; padding: 2rem 2.5rem; margin-bottom: 3rem; }
    .verdict-box p { font-size: 1.05rem; color: #8FAF8F; line-height: 1.8; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} .compare-table{font-size:0.78rem} .compare-table th,.compare-table td{padding:0.6rem 0.75rem} .two-col{grid-template-columns:1fr} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Claude vs Copilot</div>
    <h1 class="hero-h">Claude vs Microsoft Copilot:<br/><em style="color:#00C853;font-style:italic;">An Honest Business Comparison</em></h1>
    <p class="hero-sub">These two tools aren't really competing. Copilot is an M365 add-on. Claude is a reasoning and writing engine. Understanding that difference will save you a lot of money and frustration.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Get Claude Implemented →</a>
      <a href="/claude-for-small-business" class="btn-g">Claude for Small Business</a>
    </div>
  </div>
</div>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Quick verdict</span>
    <h2 class="h2">The honest answer.</h2>
    <div class="verdict-box">
      <p>If your team runs on Microsoft 365 — Word, Excel, Outlook, Teams — Copilot is a no-brainer add-on that surfaces AI where you already work. But if you're looking for an AI that actually thinks, writes well, and handles complex business reasoning? That's Claude, and it's not close. The mistake most businesses make is buying Copilot expecting a general-purpose AI assistant and getting an M365 integration instead.</p>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">What each tool actually does</span>
    <h2 class="h2">Strengths, honestly.</h2>
    <p class="sub">Both tools are useful. They're just useful for different things.</p>
    <div class="two-col">
      <div class="card">
        <div class="card-title">Microsoft Copilot is great at…</div>
        <ul class="card-list">
          <li>Drafting emails directly inside Outlook</li>
          <li>Summarizing long Word documents in one click</li>
          <li>Generating Excel formulas and data analysis in-sheet</li>
          <li>Recapping Teams meetings with action items</li>
          <li>Creating PowerPoint decks from a brief</li>
          <li>Living inside apps your team already uses every day</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-title">Claude is great at…</div>
        <ul class="card-list">
          <li>Writing that actually sounds like a human wrote it</li>
          <li>Complex, multi-step reasoning and analysis</li>
          <li>Following detailed business instructions without drift</li>
          <li>Handling very long documents (200K token context)</li>
          <li>Building consistent workflows with Projects</li>
          <li>Anything that requires genuine thinking, not just summarizing</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Side by side</span>
    <h2 class="h2">Feature by feature.</h2>
    <p class="sub">From people who've used both tools to build real business workflows.</p>
    <div style="overflow-x:auto;">
      <table class="compare-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th>Microsoft Copilot</th>
            <th>Claude</th>
            <th>Winner</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Writing quality</td>
            <td>Functional, often stiff</td>
            <td>Nuanced, natural, polished</td>
            <td><span class="winner-claude">Claude ✓</span></td>
          </tr>
          <tr>
            <td>Reasoning depth</td>
            <td>Surface-level assistance</td>
            <td>Deep, structured thinking</td>
            <td><span class="winner-claude">Claude ✓</span></td>
          </tr>
          <tr>
            <td>Context window</td>
            <td>Varies by M365 app</td>
            <td>200K tokens</td>
            <td><span class="winner-claude">Claude ✓</span></td>
          </tr>
          <tr>
            <td>Microsoft 365 integration</td>
            <td>Native — built right in</td>
            <td>Not natively integrated</td>
            <td><span class="winner-other">Copilot ✓</span></td>
          </tr>
          <tr>
            <td>Pricing</td>
            <td>$30/user/mo (M365 add-on)</td>
            <td>$20/mo (Claude Pro)</td>
            <td><span class="winner-claude">Claude ✓</span></td>
          </tr>
          <tr>
            <td>Privacy / data handling</td>
            <td>Microsoft enterprise controls</td>
            <td>Anthropic — strong privacy defaults</td>
            <td><span class="winner-tie">Tie</span></td>
          </tr>
          <tr>
            <td>Customization</td>
            <td>Limited</td>
            <td>Projects, system prompts, knowledge bases</td>
            <td><span class="winner-claude">Claude ✓</span></td>
          </tr>
          <tr>
            <td>Learning curve</td>
            <td>Low — it's in your existing apps</td>
            <td>Low — conversational interface</td>
            <td><span class="winner-tie">Tie</span></td>
          </tr>
          <tr>
            <td>Best for</td>
            <td>M365-heavy teams, document workflows</td>
            <td>Writing, reasoning, business strategy</td>
            <td><span class="winner-claude">Claude ✓</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">Decision guide</span>
    <h2 class="h2">Who should pick which.</h2>
    <p class="sub">There's no wrong answer here — only the wrong tool for your actual situation.</p>
    <div class="two-col" style="margin-bottom:3rem;">
      <div class="card">
        <div class="card-title" style="color:#8FAF8F;">Pick Copilot if…</div>
        <ul class="card-list">
          <li>Your whole team already pays for Microsoft 365</li>
          <li>Document drafting in Word is a major bottleneck</li>
          <li>You need Teams meeting summaries automatically</li>
          <li>Your CFO wants one vendor for everything</li>
          <li>You need AI inside Excel, not alongside it</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-title" style="color:#00C853;">Pick Claude if…</div>
        <ul class="card-list">
          <li>Writing quality matters — proposals, reports, client comms</li>
          <li>You need an AI that follows complex instructions reliably</li>
          <li>You want to build repeatable business workflows</li>
          <li>Your stack isn't heavily M365-dependent</li>
          <li>You need genuine reasoning, not just auto-complete</li>
        </ul>
      </div>
    </div>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="/claude-for-small-business" class="btn-g">Claude for Small Business →</a>
      <a href="/services/implementation" class="btn-g">See How We Implement It →</a>
      <a href="/resources/claude-vs-chatgpt-small-business" class="btn-g">Claude vs ChatGPT →</a>
    </div>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The bottom line</span>
    <h2 class="h2">They're not really competing.</h2>
    <div>
      <div class="step-row">
        <div class="step-num">01</div>
        <div>
          <div class="step-title">Copilot is an M365 add-on, not an AI strategy</div>
          <div class="step-desc">Microsoft Copilot is most valuable when you're already paying for M365 and want AI to appear inside the apps you're already using. It doesn't require you to change how you work — which is both its strength and its ceiling.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">02</div>
        <div>
          <div class="step-title">Claude is a thinking tool, not an interface layer</div>
          <div class="step-desc">Claude works best when you give it hard problems — a brief to write from scratch, a proposal to sharpen, a strategy to stress-test. It's not embedded in your existing software. That's fine. The output quality makes the context switch worth it.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">03</div>
        <div>
          <div class="step-title">Most serious businesses end up with both</div>
          <div class="step-desc">A lot of teams buy Copilot because it's bundled into their M365 renewal and then start using Claude separately for the work that actually matters. That's not a bad outcome — they're solving different problems.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">04</div>
        <div>
          <div class="step-title">The tool is 20% of the ROI</div>
          <div class="step-desc">Whether you choose Claude, Copilot, or both — the tool choice is the easy part. The 80% that actually drives results is how you configure it, what workflows you build, and how you train your team. That's where we come in.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="contact" style="background:#050D05;">
  <div class="sec-inner" style="max-width:680px;">
    <span class="lbl">Get Claude Implemented</span>
    <h2 class="h2">Done comparing.<br/>Ready to actually use it?</h2>
    <p class="sub">We'll configure Claude for your specific business and build the workflows that make the ROI obvious — fast.</p>
    <div id="contact-form">
      <div class="form-grid">
        <div>
          <label class="form-label">First Name</label>
          <input class="input-field" type="text" id="first_name" placeholder="Jane" />
        </div>
        <div>
          <label class="form-label">Last Name</label>
          <input class="input-field" type="text" id="last_name" placeholder="Smith" />
        </div>
      </div>
      <div class="form-field">
        <label class="form-label">Work Email</label>
        <input class="input-field" type="email" id="email" placeholder="jane@company.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Company</label>
        <input class="input-field" type="text" id="company" placeholder="Acme Inc." />
      </div>
      <div class="form-field">
        <label class="form-label">What would you gain if Claude handled the work that's slowing your team down?</label>
        <textarea class="input-field" id="message" placeholder="Faster proposals, better client comms, more capacity..." style="min-height:100px;resize:vertical;"></textarea>
      </div>
      <button class="btn-p" id="submit-btn" style="width:100%;justify-content:center;" onclick="submitForm()">Get Claude Working →</button>
      <p style="font-size:0.75rem;color:#4A6A4A;margin-top:0.75rem;text-align:center;">We respond within one business day. Takes 3 min.</p>
    </div>
    <div class="thankyou" id="thankyou">
      <div class="thankyou-h">You're in good hands.</div>
      <p style="color:#8FAF8F;">We'll be in touch within one business day.</p>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, gain: document.getElementById('message').value, source: 'claude-vs-copilot' }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get Claude Working →'; btn.disabled = false; }
}
</script>
</body>
</html>
