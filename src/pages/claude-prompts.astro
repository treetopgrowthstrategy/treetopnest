---
export const prerender = true;
import GlobalFooter from '../components/GlobalFooter.astro';
import HubLinks from '../components/HubLinks.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Claude Prompts by Role and Function | Treetop Growth Strategy</title>
  <meta name="description" content="Battle-tested Claude prompts organized by role, from sales and marketing to finance, HR, and engineering. Copy, adapt, and put them to work today." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/claude-prompts" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/claude-prompts" />
  <meta property="og:title" content="Claude Prompts by Role and Function | Treetop Growth Strategy" />
  <meta property="og:description" content="Battle-tested Claude prompts organized by role, from sales and marketing to finance, HR, and engineering." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta name="twitter:title" content="Claude Prompts by Role and Function | Treetop Growth Strategy" />
  <meta name="twitter:description" content="Battle-tested Claude prompts organized by role and function." />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "name": "Claude Prompts by Role and Function",
        "description": "A library of practical Claude prompts organized by business role and function.",
        "url": "https://treetopgrowthstrategy.com/claude-prompts",
        "isPartOf": {"@type": "WebSite", "url": "https://treetopgrowthstrategy.com/", "name": "Treetop Growth Strategy"},
        "publisher": {"@id": "https://treetopgrowthstrategy.com/#organization"}
      },
      {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
    ]
  }
  </script>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://treetopgrowthstrategy.com/"},{"@type":"ListItem","position":2,"name":"Claude Prompts","item":"https://treetopgrowthstrategy.com/claude-prompts"}]}</script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; }
    .hero { min-height: 78vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 900px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 600px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 640px; margin-bottom: 3rem; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/how-to-use-claude" class="nav-link">How to use Claude</a>
      <a href="/claude-for-business" class="nav-link">Industries</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="/claude-training" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Claude Training →</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Claude Prompt Library</div>
    <h1 class="hero-h">Claude prompts for <em style="color:#00C853;font-style:italic;">every role on your team.</em></h1>
    <p class="hero-sub">Practical, battle-tested prompts organized by function. Copy one, adapt it to your context, and get a better result out of Claude in the next five minutes.</p>
    <div class="hero-actions">
      <a href="/how-to-use-claude" class="btn-g">How to use Claude →</a>
      <a href="/claude-training" class="btn-g">Team training</a>
    </div>
  </div>
</div>

<HubLinks cluster="claude-prompts-for" heading="Prompts by role and function" blurb="Pick your function and grab prompts built for the work you actually do." bg="#0A1A0A" />

<section style="background:#050D05;text-align:center;">
  <div class="sec-inner" style="max-width:720px;">
    <span class="lbl" style="text-align:center;">Go deeper</span>
    <h2 class="h2">Want your team fluent in Claude?</h2>
    <p class="sub" style="margin:0 auto 2.5rem;">Prompts are the start. Treetop runs hands-on Claude training that turns a whole team into confident, everyday operators.</p>
    <a href="/claude-training" class="btn-p">Explore Claude training →</a>
  </div>
</section>

<GlobalFooter />
</body>
</html>
