.price-sub{font-size:0.85rem;color:#8FAF8F}
.includes-title{font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#8FAF8F;margin:1.5rem 0 0.75rem}
