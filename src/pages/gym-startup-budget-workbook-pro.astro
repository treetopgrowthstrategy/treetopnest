<script>
async function checkout(){
  var btn = document.getElementById('buy-btn');
  var err = document.getElementById('err');
  err.style.display = 'none';
  btn.disabled = true;
  btn.innerText = 'Opening checkout...';
  try {
    var res = await fetch('/api/product-checkout', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({product: 'gym-startup-budget-workbook-pro'})
    });
    if (!res.ok) throw new Error('Network');
    var data = await res.json();
    if (data.url) {
      window.location.href = data.url;
    } else {
      throw new Error(data.error || 'No checkout URL');
    }
  } catch (e) {
    err.innerText = 'Something went wrong opening checkout. Please email bill@treetopgrowthstrategy.com and we will process the purchase manually.';
    err.style.display = 'block';
    btn.disabled = false;
    btn.innerText = 'Buy now — secure checkout →';
  }
}
</script>

<GlobalFooter />
</body></html>
