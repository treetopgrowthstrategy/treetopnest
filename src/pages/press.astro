.badge-dot{width:7px;height:7px;border-radius:50%;background:#00C853;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
section{padding:4rem 2.5rem;border-top:1px solid #1A3A1A}.sec-inner{max-width:880px;margin:0 auto}
.hero{min-height:42vh;display:flex;align-items:center;padding:7rem 2.5rem 3rem}.hero-inner{max-width:880px;margin:0 auto;width:100%}
.hero-h{font-family:'Instrument Serif',serif;font-size:clamp(2.4rem,4.6vw,3.6rem);font-weight:400;line-height:1.1;color:#F0FFF0;margin-bottom:1.25rem}
.hero-sub{font-size:1.05rem;color:#C0D8C0;line-height:1.75;max-width:760px}
.h2{font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3vw,2.2rem);font-weight:400;line-height:1.15;color:#F0FFF0;margin-bottom:1.5rem}
.h3{font-family:'Instrument Serif',serif;font-size:1.25rem;color:#F0FFF0;margin:1.5rem 0 0.75rem;font-weight:400}
.body{font-size:1rem;color:#C0D8C0;line-height:1.85;max-width:760px;margin-bottom:1rem}.body em{color:#F0FFF0;font-style:italic}.body strong{color:#F0FFF0}
.contact-card{background:#0A1A0A;border:1px solid #1A3A1A;padding:1.75rem;margin:1.5rem 0;max-width:760px}
.contact-card a{color:#00C853;text-decoration:none}
.topic-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin-top:1rem}
@media(max-width:760px){.topic-grid{grid-template-columns:1fr}}
.topic-card{background:#0A1A0A;border:1px solid #1A3A1A;padding:1.5rem}
.topic-card h4{font-family:'Instrument Serif',serif;font-size:1.15rem;color:#F0FFF0;font-weight:400;margin-bottom:0.5rem}
.topic-card p{font-size:0.88rem;color:#8FAF8F;line-height:1.6}
.ul{color:#C0D8C0;font-size:1rem;line-height:1.8;padding-left:1.25rem;margin:1rem 0 1.5rem;max-width:760px}
.ul li{margin-bottom:0.5rem}.ul li::marker{color:#00C853}
.ul li a{color:#00C853;text-decoration:none}
@media(max-width:900px){section{padding:3rem 1.5rem}.hide-mob{display:none!important}}
