<script is:inline>
  (function() {
    function fmt(n) {
      if (n >= 1000000) return '$' + (n/1000000).toFixed(2) + 'M';
      if (n >= 1000) return '$' + Math.round(n/1000) + 'K';
      return '$' + Math.round(n);
    }

    var inputs = {
      stage: document.getElementById('company-stage'),
      ceoHours: document.getElementById('ceo-hours'),
      ceoCost: document.getElementById('ceo-cost'),
      fractionalHours: document.getElementById('fractional-hours'),
    };
    var labels = {
      ceoHours: document.getElementById('ceo-hours-val'),
      ceoCost: document.getElementById('ceo-cost-val'),
      fractionalHours: document.getElementById('fractional-hours-val'),
    };

    function recalc() {
      var stage = inputs.stage.value;
      var ceoHrs = parseInt(inputs.ceoHours.value, 10);
      var ceoCost = parseInt(inputs.ceoCost.value, 10);
      var fracHrs = parseInt(inputs.fractionalHours.value, 10);

      labels.ceoHours.textContent = ceoHrs + ' hrs';
      labels.ceoCost.textContent = '$' + ceoCost + '/hr';
      labels.fractionalHours.textContent = fracHrs + ' hrs';

      // Fractional cost: $400/hr blended × hours × 12 months
      var fracMonthly = 400 * fracHrs;
      var fracAnnual = fracMonthly * 12;

      // Full-time stage-based estimates
      var ftBase = { seed: 250000, early: 320000, growth: 380000, scale: 450000 }[stage];
      var ftEquityVal = { seed: 30000, early: 50000, growth: 90000, scale: 150000 }[stage];
      var ftBenefits = 45000;
      var ftRecruiter = 75000;
      var ftAnnual = ftBase + ftEquityVal + ftBenefits + ftRecruiter;

      // DIY = CEO opportunity cost
      var diyHours = ceoHrs * 52;
      var diyAnnual = diyHours * ceoCost;

      // Update displays
      document.getElementById('frac-cost').textContent = fmt(fracAnnual);
      document.getElementById('frac-monthly').textContent = fmt(fracMonthly);
      document.getElementById('frac-hrs').textContent = fracHrs + ' hrs';

      document.getElementById('ft-cost').textContent = fmt(ftAnnual);
      document.getElementById('ft-base').textContent = fmt(ftBase);
      document.getElementById('ft-equity').textContent = fmt(ftEquityVal) + '+';

      document.getElementById('diy-cost').textContent = fmt(diyAnnual);
      document.getElementById('diy-hrs').textContent = diyHours.toLocaleString() + ' hrs';
      document.getElementById('diy-hourly').textContent = '$' + ceoCost + '/hr';

      // Determine recommended option
      var recommended;
      var verdictText;
      if (stage === 'seed') {
        recommended = 'diy';
        verdictText = 'Pre-PMF and seed stage usually do not justify CMO-level engagement. Founder-led marketing iteration with a marketing coordinator is typically the right answer until you have product-market fit signal. If you need help, engage an advisor (5-10 hrs/month) rather than a full fractional engagement.';
      } else if (stage === 'scale') {
        recommended = 'fulltime';
        verdictText = 'At $30M+ scaling stage, full-time CMO economics start to work and the marketing function typically needs 40+ hours/week of dedicated leadership. Continue with fractional only if you specifically want shorter-term flexibility or want to vet the role before hiring permanently.';
      } else {
        recommended = 'fractional';
        verdictText = stage === 'early'
          ? 'For early-growth companies ($2M-$10M), the fractional model captures the senior strategic value of a CMO without the dilution, recruiter risk, or 9-month onboarding ramp. Switch to full-time when you cross $25M-$30M and the function genuinely requires 40+ hours/week of leadership.'
          : 'Growth-stage companies ($10M-$30M) are in the fractional sweet spot. Senior marketing leadership for ~25% of full-time cost. Plan a 12-18 month fractional engagement, then evaluate whether full-time hire is justified.';
      }

      ['fractional', 'fulltime', 'diy'].forEach(function(opt) {
        var card = document.getElementById('card-' + opt);
        var tag = document.getElementById(opt === 'fulltime' ? 'ft-tag' : opt === 'fractional' ? 'fractional-tag' : 'diy-tag');
        if (opt === recommended) {
          card.classList.add('recommended');
          tag.textContent = 'Recommended';
        } else {
          card.classList.remove('recommended');
          tag.textContent = '';
        }
      });

      var hMap = { fractional: 'Recommended for your stage: Fractional CMO', fulltime: 'Recommended for your stage: Full-time CMO', diy: 'Recommended for your stage: CEO-led / Advisor' };
      document.getElementById('verdict-h').textContent = hMap[recommended];
      document.getElementById('verdict-p').textContent = verdictText;
    }

    Object.keys(inputs).forEach(function(k) {
      inputs[k].addEventListener('input', recalc);
      inputs[k].addEventListener('change', recalc);
    });
    recalc();
  })();
</script>

</body>
</html>
