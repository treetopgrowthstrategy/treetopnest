<script is:inline>
(function(){
  var answers={};var current=0;var total=10;
  var dimensions=['Leadership','Leadership','Governance','Governance','Tooling','Tooling','Workflows','Workflows','Team capability','Team capability'];

  var prog=document.getElementById('progress');
  for(var k=0;k<total;k++){var d=document.createElement('div');d.className='dot'+(k===0?' active':'');prog.appendChild(d);}

  function showQ(idx){
    document.querySelectorAll('.q').forEach(function(q){q.classList.remove('active');});
    var q=document.querySelector('[data-q="'+idx+'"]');if(q)q.classList.add('active');
    current=idx;
    var dots=document.querySelectorAll('.dot');
    dots.forEach(function(d,i){d.classList.remove('active','done');if(i<current)d.classList.add('done');if(i===current)d.classList.add('active');});
    document.getElementById('qcount').textContent='Question '+(current+1)+' of '+total;
    document.getElementById('back').style.visibility=current>0?'visible':'hidden';
  }

  document.querySelectorAll('.opt').forEach(function(b){b.addEventListener('click',function(){
    var qIdx=parseInt(b.closest('.q').dataset.q,10);
    answers[qIdx]=parseInt(b.dataset.score,10);
    if(qIdx<total-1)setTimeout(function(){showQ(qIdx+1);},150);else setTimeout(showResult,200);
  });});

  document.getElementById('back').addEventListener('click',function(){if(current>0)showQ(current-1);});

  function showResult(){
    document.querySelectorAll('.q').forEach(function(q){q.classList.remove('active');});
    document.getElementById('navrow').style.display='none';
    document.querySelectorAll('.dot').forEach(function(d){d.classList.add('done');d.classList.remove('active');});

    var total=0;var pillarScores={Leadership:0,Governance:0,Tooling:0,Workflows:0,'Team capability':0};
    for(var i=0;i<10;i++){total+=answers[i];pillarScores[dimensions[i]]+=answers[i];}

    var pct=total/40;var tierName,tierDesc;
    if(pct<0.4){tierName='Laggard';tierDesc='Your organization is in the bottom quartile of AI readiness. The good news: every move from here produces meaningful gains. The hard news: every quarter you wait, competitors who are further along pull further ahead. The right move is to start now, not to plan for next year.';}
    else if(pct<0.65){tierName='Transitional';tierDesc='Your organization is mid-pack — beyond curiosity but not yet operating AI-natively. You have some tools and some workflows but lack the governance, training, and measurement to capture full value. The path forward is structural: fix what you have before adding more.';}
    else if(pct<0.85){tierName='Competitive';tierDesc='Your organization is in the top third of AI readiness. You have working AI workflows, some measurement, and likely an internal owner. To pull ahead, focus on the lowest-scoring pillar below — that\'s where the next 20% of value lives.';}
    else{tierName='Leader';tierDesc='Your organization is genuinely AI-native. You have leadership commitment, governance, tooling, workflows, and team capability operating in concert. The risk now isn\'t falling behind — it\'s complacency. Quarterly review of what\'s degrading is essential.';}

    document.getElementById('tier-name').textContent=tierName;
    document.getElementById('tier-score').textContent='Score: '+total+'/40';
    document.getElementById('tier-desc').textContent=tierDesc;

    // Pillars
    var pHtml='';
    Object.keys(pillarScores).forEach(function(p){
      var s=pillarScores[p];var maxP=8;var fillPct=(s/maxP)*100;
      pHtml+='<div class="pillar"><div class="pillar-name">'+p+'</div><div class="pillar-bar"><div class="pillar-fill" style="width:'+fillPct+'%"></div></div><div class="pillar-score">'+s+'/'+maxP+'</div></div>';
    });
    document.getElementById('pillars').innerHTML=pHtml;

    // Next steps based on weakest pillar
    var weakest=Object.keys(pillarScores).reduce(function(a,b){return pillarScores[a]<pillarScores[b]?a:b;});
    var stepsMap={
      'Leadership':['Have the CEO personally commit to 30 min/day of real AI use for 6 weeks','Name an executive accountable for AI strategy with budget authority','Add AI as a permanent agenda item in leadership and board meetings'],
      'Governance':['Write a 1-page AI usage policy this week (start with our <a href="/ai-policy-template-for-small-business" style="color:#00C853;">template</a>)','Define what client data can and cannot be put through AI tools','Set a quarterly review cadence for the policy'],
      'Tooling':['Standardize on a primary AI tool for the team (Claude Team or ChatGPT Team)','Build at least one shared Project loaded with your ICP, voice, and reference content','Add Perplexity Pro for the 3-5 people who do significant research'],
      'Workflows':['Pick 1-2 high-frequency workflows in one function to deploy first','Build them as repeatable Claude Projects, not one-off chats','Define measurable outcomes (time saved, output increase) and measure them weekly'],
      'Team capability':['Schedule a multi-session cohort training (not single workshop)','Identify 1-2 internal AI champions and resource them','Add AI fluency to your hiring rubric and interview process']
    };

    document.getElementById('ns-h').textContent='What to do next — focus on '+weakest;
    document.getElementById('ns-intro').textContent='Your weakest pillar is '+weakest+' ('+pillarScores[weakest]+'/8). Three highest-leverage actions:';
    var ul=document.getElementById('ns-list');ul.innerHTML='';
    stepsMap[weakest].forEach(function(s){var li=document.createElement('li');li.innerHTML=s;ul.appendChild(li);});

    document.getElementById('result').classList.add('active');
  }
})();
</script>

</body>
</html>
