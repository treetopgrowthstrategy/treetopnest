      { href: '/what-is-multimodal-ai', title: 'What is multimodal AI?', desc: 'AI that handles text, image, audio, video.' },
      { href: '/what-is-an-ai-hallucination', title: 'What is an AI hallucination?', desc: 'When the AI confidently makes things up.' },
