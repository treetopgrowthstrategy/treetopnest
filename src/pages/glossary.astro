    ]
  },
  {
    label: 'Patterns &amp; products',
    items: [
      { href: '/what-is-an-ai-agent', title: 'What is an AI agent?', desc: 'AI that takes actions, not just responds.' },
      { href: '/what-is-agentic-ai', title: 'What is agentic AI?', desc: 'AI systems that pursue goals across multi-step workflows.' },
      { href: '/what-is-ai-orchestration', title: 'What is AI orchestration?', desc: 'Connecting AI workflows into systems.' },
      { href: '/what-is-an-ai-copilot', title: 'What is an AI copilot?', desc: 'The user-facing pattern for AI assistance.' },
      { href: '/what-is-computer-use-ai', title: 'What is computer use AI?', desc: 'AI that controls a computer like a human.' },
    ]
  },
  {
    label: 'Business &amp; market',
    items: [
      { href: '/what-is-ai-consulting', title: 'What is AI consulting?', desc: 'The category, who it\'s for, what to expect.' },
      { href: '/what-is-ai-implementation', title: 'What is AI implementation?', desc: 'Beyond strategy: actually shipping AI into production.' },
      { href: '/what-is-an-ai-audit', title: 'What is an AI audit?', desc: 'The diagnostic-first approach to AI rollout.' },
      { href: '/what-is-an-ai-native-company', title: 'What is an AI-native company?', desc: 'How AI-native companies are structurally different.' },
      { href: '/what-is-ai-native-gtm', title: 'What is AI-native GTM?', desc: 'Go-to-market for the AI era.' },
      { href: '/what-is-an-ai-rollup', title: 'What is an AI rollup?', desc: 'The acquisition pattern transforming mid-market.' },
      { href: '/what-is-a-fractional-executive', title: 'What is a fractional executive?', desc: 'Part-time C-level operators for mid-market.' },
      { href: '/what-is-gtm-strategy', title: 'What is GTM strategy?', desc: 'Go-to-market strategy, defined.' },
      { href: '/what-is-revops', title: 'What is RevOps?', desc: 'Revenue operations, explained.' },
      { href: '/what-is-product-led-growth', title: 'What is product-led growth?', desc: 'The PLG motion for B2B SaaS.' },
      { href: '/what-is-conversion-rate-optimization', title: 'What is conversion rate optimization?', desc: 'CRO, defined for B2B marketers.' },
      { href: '/what-is-customer-lifetime-value', title: 'What is customer lifetime value?', desc: 'LTV math for B2B and consumer businesses.' },
    ]
  },
];
