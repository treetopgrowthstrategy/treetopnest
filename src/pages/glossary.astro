<div class="hero"><div class="hero-inner">
<div class="badge"><span class="badge-dot"></span>35+ terms · plain English · citable</div>
<h1 class="hero-h">The AI &amp; GTM <em style="color:#00C853;font-style:italic;">glossary.</em></h1>
<p class="hero-sub">Plain-English definitions of the AI, go-to-market, and fractional executive vocabulary B2B buyers and operators encounter. Each term gets a citable definition; many include the practical implications for buyers and operators.</p>
</div></div>

{sections.map(s => (
<section id={s.label.toLowerCase().replace(/[^a-z]/g, '-')}><div class="sec-inner">
<span class="lbl">{s.label}</span>
<h2 class="sec-h">{s.label.replace('&amp;', '&')}</h2>
<div class="grid">
{s.items.map(item => (
  <a class="card" href={item.href}>
    <div class="card-h">{item.title}</div>
    <div class="card-d">{item.desc}</div>
  </a>
))}
</div>
</div></section>
))}

