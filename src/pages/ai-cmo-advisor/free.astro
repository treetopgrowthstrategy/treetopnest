---
import GlobalFooter from '../../components/GlobalFooter.astro';
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Free Competitive Snapshot | AI CMO Advisor</title>
  <meta name="description" content="Start free, no card. Your AI CMO sends you a competitive snapshot on your business: how you stack up against your competitors, and one thing worth doing about it." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; min-height: 100vh; display: flex; flex-direction: column; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .main { flex: 1; padding: 8rem 2rem 5rem; max-width: 620px; margin: 0 auto; width: 100%; }
    .badge { display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #00C853; border: 1px solid rgba(0,200,83,0.3); padding: 4px 10px; margin-bottom: 1.5rem; }
    .h1 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 400; color: #F0FFF0; line-height: 1.1; margin-bottom: 1rem; }
    .h1 em { color: #00C853; font-style: italic; }
    .sub { font-size: 1rem; color: #C0D8C0; line-height: 1.75; margin-bottom: 2.5rem; }
    .step-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #4A6A4A; margin-bottom: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-label { display: block; font-size: 0.78rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; letter-spacing: 0.03em; }
    .form-input { width: 100%; background: #0A1A0A; border: 1px solid #1A3A1A; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.95rem; padding: 0.85rem 1rem; outline: none; transition: border-color 0.15s; }
    .form-input:focus { border-color: rgba(0,200,83,0.5); }
    .form-input::placeholder { color: #2A4A2A; }
    .btn-p { display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%; background: #00C853; color: #050D05; padding: 1rem 1.75rem; font-size: 0.92rem; font-weight: 600; font-family: 'DM Sans', sans-serif; border: none; cursor: pointer; transition: opacity 0.15s; margin-top: 0.5rem; }
    .btn-p:hover { opacity: 0.88; }
    .btn-p:disabled { opacity: 0.5; cursor: not-allowed; }
    .note { font-size: 0.75rem; color: #4A6A4A; margin-top: 0.85rem; line-height: 1.6; }
    .note span { color: #00C853; }
    .err { font-size: 0.78rem; color: #E0A0A0; margin-top: 0.6rem; display: none; }
    .success-icon { width: 56px; height: 56px; background: rgba(0,200,83,0.1); border: 1px solid rgba(0,200,83,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.75rem; }
    .success-icon svg { width: 24px; height: 24px; stroke: #00C853; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
    .divider { border: none; border-top: 1px solid #1A3A1A; margin: 2.5rem 0; }
    .back-link { font-size: 0.82rem; color: #4A6A4A; text-decoration: none; }
    .back-link:hover { color: #8FAF8F; }
    .hp-wrap { position: absolute; left: -9999px; top: -9999px; width: 1px; height: 1px; overflow: hidden; }
    @media (max-width: 600px) { .main { padding: 7rem 1.5rem 4rem; } }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <a href="/ai-cmo-advisor" class="back-link" style="font-size:0.8rem;">Ready to buy? Get the $99 report &rarr;</a>
  </div>
</nav>

<div class="main">

  <!-- STEP 1: email + website -->
  <div id="step-1">
    <div class="badge">Free, no card</div>
    <h1 class="h1">A competitive snapshot from <em>your AI CMO.</em></h1>
    <p class="sub">Tell me where you play and I will send you a real read on how you stack up against your competitors, plus one thing worth doing about it. No card, no catch. Reply any time to talk it through.</p>
    <div class="hp-wrap" aria-hidden="true"><label for="hp-1">Leave empty</label><input type="text" id="hp-1" tabindex="-1" autocomplete="off" /></div>
    <div class="form-group">
      <label for="s1-email" class="form-label">Your email</label>
      <input id="s1-email" type="email" class="form-input" placeholder="you@company.com" autocomplete="email" />
    </div>
    <div class="form-group">
      <label for="s1-website" class="form-label">Company website</label>
      <input id="s1-website" type="text" class="form-input" placeholder="yourcompany.com" autocomplete="url" />
    </div>
    <button class="btn-p" id="s1-btn" onclick="submitStep1()">Continue &rarr;</button>
    <div id="s1-err" class="err"></div>
    <p class="note"><span>&#10003;</span> One more quick step, then your snapshot is on its way.</p>
  </div>

  <!-- STEP 2: LinkedIn unlock -->
  <div id="step-2" style="display:none;">
    <div class="step-label">Last step</div>
    <h1 class="h1">Who am I <em>advising?</em></h1>
    <p class="sub">Drop your LinkedIn so I know who is on the other side before I run your numbers. It is how I keep this genuinely useful instead of generic.</p>
    <div class="form-group">
      <label for="s2-linkedin" class="form-label">Your LinkedIn profile URL</label>
      <input id="s2-linkedin" type="text" class="form-input" placeholder="linkedin.com/in/yourname" autocomplete="url" />
    </div>
    <button class="btn-p" id="s2-btn" onclick="submitStep2()">Unlock my snapshot &rarr;</button>
    <div id="s2-err" class="err"></div>
    <p class="note">Used only to understand your role and company. Nothing gets posted anywhere.</p>
  </div>

  <!-- SUCCESS -->
  <div id="step-done" style="display:none;">
    <div class="success-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
    <h1 class="h1">You're all set.</h1>
    <p class="sub" id="done-msg">Your competitive snapshot is being put together right now. It should land in your inbox in a couple minutes. Reply to it any time to talk to your AI CMO.</p>
    <hr class="divider" />
    <p style="font-size:0.9rem;color:#8FAF8F;line-height:1.7;">Not the patient type? You can skip straight to the full $99 report with live data on up to 3 competitors and a 90-day roadmap.</p>
    <p style="margin-top:1rem;"><a href="/ai-cmo-advisor" class="back-link" style="color:#00C853;">Get the full report &rarr;</a></p>
  </div>

</div>

<GlobalFooter />

<script is:inline>
window._freeLoadTime = Date.now();
var freeEmail = '';

function showErr(id, msg) { var e = document.getElementById(id); e.textContent = msg; e.style.display = 'block'; }

async function submitStep1() {
  var btn = document.getElementById('s1-btn');
  var email = (document.getElementById('s1-email').value || '').trim();
  var website = (document.getElementById('s1-website').value || '').trim();
  var hp = document.getElementById('hp-1').value;
  if (!email || email.indexOf('@') === -1) { showErr('s1-err', 'Please enter a valid work email.'); return; }
  document.getElementById('s1-err').style.display = 'none';
  btn.disabled = true; btn.textContent = 'One sec...';
  freeEmail = email;
  try {
    await fetch('/api/cmo-free-start', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, website: website, hp: hp, _t: window._freeLoadTime })
    });
    document.getElementById('step-1').style.display = 'none';
    document.getElementById('step-2').style.display = 'block';
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Continue →';
    showErr('s1-err', 'Something went wrong. Email bill@treetopgrowthstrategy.com and we will sort it out.');
  }
}

async function submitStep2() {
  var btn = document.getElementById('s2-btn');
  var linkedin = (document.getElementById('s2-linkedin').value || '').trim();
  if (!linkedin || linkedin.toLowerCase().indexOf('linkedin.com') === -1) { showErr('s2-err', 'Please paste your LinkedIn profile URL.'); return; }
  document.getElementById('s2-err').style.display = 'none';
  btn.disabled = true; btn.textContent = 'Setting you up...';
  try {
    var res = await fetch('/api/cmo-free-qualify', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: freeEmail, linkedin: linkedin })
    });
    var data = await res.json();
    if (data && data.message) document.getElementById('done-msg').textContent = data.message;
    document.getElementById('step-2').style.display = 'none';
    document.getElementById('step-done').style.display = 'block';
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Unlock my snapshot →';
    showErr('s2-err', 'Something went wrong. Email bill@treetopgrowthstrategy.com and we will sort it out.');
  }
}
</script>
</body>
</html>
