---
export const prerender = true;
import GlobalFooter from '../components/GlobalFooter.astro';
import HubLinks from '../components/HubLinks.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>AI Consultant for B2B Companies | Treetop Growth Strategy</title>
  <meta name="description" content="An AI consultant who ships, not slideware. Bill Colbert helps B2B operators at $5M to $50M design and deploy AI across GTM, ops, and revenue. Available in 80+ US metros." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/ai-consultant" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/ai-consultant" />
  <meta property="og:title" content="AI Consultant for B2B Companies | Treetop Growth Strategy" />
  <meta property="og:description" content="An AI consultant who ships, not slideware. AI strategy and deployment for B2B operators at $5M to $50M, in 80+ US metros." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta name="twitter:title" content="AI Consultant for B2B Companies | Treetop Growth Strategy" />
  <meta name="twitter:description" content="AI strategy and deployment for B2B operators at $5M to $50M, in 80+ US metros." />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": "AI Consultant for B2B Companies",
        "description": "AI strategy and hands-on deployment for B2B operators at $5M to $50M in revenue. Bill Colbert designs the AI-native operating model and gives your team the roadmap to run it.",
        "url": "https://treetopgrowthstrategy.com/ai-consultant",
        "provider": {"@id": "https://treetopgrowthstrategy.com/#organization"},
        "areaServed": {"@type": "Country", "name": "United States"},
        "audience": {"@type": "Audience", "description": "CEOs, CROs, and operators at B2B companies between $5M and $50M in revenue"}
      },
      {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
    ]
  }
  </script>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://treetopgrowthstrategy.com/"},{"@type":"ListItem","position":2,"name":"AI Consultant","item":"https://treetopgrowthstrategy.com/ai-consultant"}]}</script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; }
    .hero { min-height: 82vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 900px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 600px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 640px; margin-bottom: 3rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell { background: #050D05; padding: 2rem; }
    .cell-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.5rem; }
    .cell-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.65; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-business" class="nav-link">Industries</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Book an AI Consult →</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>AI Consultant</div>
    <h1 class="hero-h">An AI consultant who <em style="color:#00C853;font-style:italic;">ships, not slideware.</em></h1>
    <p class="hero-sub">Most AI consulting ends at a deck. Bill Colbert designs the AI-native operating model for B2B companies at $5M to $50M, then builds it alongside your team so the capability stays in-house.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Book an AI Consult →</a>
      <a href="/services/ai-audit" class="btn-g">See the AI Audit</a>
    </div>
    <div style="border-left:3px solid #00C853;padding:1.25rem 1.5rem;background:rgba(0,200,83,0.05);margin-top:2rem;max-width:820px;">
      <div style="font-size:0.68rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.5rem;">The take</div>
      <p style="font-size:0.98rem;color:#F0FFF0;line-height:1.75;margin:0;">The reason "AI consultant" has become a slur in board rooms is that most of the category ends at a two-hundred-slide readout that names the seventeen use cases with the highest theoretical ROI, then walks away. My working definition is different: an AI consultant's job is to leave your company with a working system in production and a team who can extend it without me. That means the audit output is code, prompts, and rewired workflows (not a PowerPoint), and the engagement ends when your team is running it themselves. If a firm is quoting you a six-figure retainer "until AI is fully deployed," they're selling a tool-sprawl outcome. The right shape is a ninety-day intensive with a fixed price and a defined handoff.</p>
    </div>
  </div>
</div>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">What you actually get</span>
    <h2 class="h2">Strategy that ends in working systems.</h2>
    <p class="sub">Three moves, in order. No pilot purgatory, no tool sprawl, no dependency on an outside firm to keep the lights on.</p>
    <div class="grid-3">
      <div class="grid-cell">
        <div class="cell-title">1. Map the highest-leverage use cases</div>
        <p class="cell-desc">We start with your revenue motion and operations, not a tool list. You leave with a ranked backlog of AI use cases tied to dollars and hours.</p>
      </div>
      <div class="grid-cell">
        <div class="cell-title">2. Build the first ones with you</div>
        <p class="cell-desc">We stand up the top use cases end to end, wired into the tools you already run, so your team sees it work in weeks, not quarters.</p>
      </div>
      <div class="grid-cell">
        <div class="cell-title">3. Hand you the keys</div>
        <p class="cell-desc">You get the playbook, the prompts, and the internal ownership to run and extend it. The goal is your capability, not our retainer.</p>
      </div>
    </div>
  </div>
</section>

<HubLinks cluster="ai-consultant" heading="AI consulting, city by city" blurb="Local AI consulting across the US. Same operator, same hands-on approach, wherever your team sits." bg="#050D05" />

<section id="contact" style="background:#0A1A0A;text-align:center;">
  <div class="sec-inner" style="max-width:720px;">
    <span class="lbl" style="text-align:center;">Start here</span>
    <h2 class="h2">Find your highest-leverage AI use case.</h2>
    <p class="sub" style="margin:0 auto 2.5rem;">A short working session to pressure-test where AI moves the number for your business. No obligation, no slideware.</p>
    <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" class="btn-p" rel="noopener">Book an AI Consult →</a>
  </div>
</section>

<GlobalFooter />
</body>
</html>
