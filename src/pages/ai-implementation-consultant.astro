    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 900px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 580px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell { background: #0A1A0A; padding: 2rem; }
    .cell-tag { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #00C853; margin-bottom: 0.6rem; display: block; }
    .cell-title { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .cell-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.65; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .who-row { display: flex; gap: 1.5rem; padding: 1.5rem 0; border-bottom: 1px solid #1A3A1A; align-items: flex-start; }
    .who-row:last-child { border-bottom: none; }
    .who-icon { font-size: 1.5rem; flex-shrink: 0; }
    .who-title { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.35rem; }
    .who-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .stat-row { display: flex; gap: 1.5rem; margin: 2rem 0; flex-wrap: wrap; }
    .stat { flex: 1; min-width: 160px; background: #0A1A0A; border: 1px solid #1A3A1A; padding: 1.5rem; }
    .stat-num { font-family: 'Instrument Serif', serif; font-size: 2.5rem; color: #00C853; line-height: 1; margin-bottom: 0.4rem; }
    .stat-label { font-size: 0.78rem; color: #4A6A4A; line-height: 1.5; }
    .callout { background: rgba(0,200,83,0.05); border: 1px solid rgba(0,200,83,0.2); border-left: 3px solid #00C853; padding: 1.5rem 2rem; margin: 2rem 0; }
    .callout-h { font-family: 'Instrument Serif', serif; font-size: 1.1rem; color: #F0FFF0; font-weight: 400; margin-bottom: 0.5rem; }
    .callout p { font-size: 0.9rem; color: #8FAF8F; line-height: 1.75; }
    .outcome-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #1A3A1A; margin-top: 2rem; }
    .outcome-cell { background: #0A1A0A; padding: 1.75rem; }
    .outcome-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #4A6A4A; margin-bottom: 1rem; display: block; }
