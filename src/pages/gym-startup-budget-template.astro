<tr><td>Reformers (Pilates studios only)</td><td class="note-cell">$3K-$8K each</td><td>$0-$140K</td></tr>
<tr><td>Spin bikes (cycling studios)</td><td class="note-cell">$2K-$4K each</td><td>$0-$160K</td></tr>
<tr><td>Yoga props (blocks, straps, bolsters)</td><td>—</td><td>$0-$3K</td></tr>
<tr><td>Barre + barre studio props</td><td>—</td><td>$0-$5K</td></tr>
<tr><td>TRX / suspension trainers</td><td>—</td><td>$0-$5K</td></tr>
