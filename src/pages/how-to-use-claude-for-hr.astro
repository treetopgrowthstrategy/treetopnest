      <a href="/services/implementation" class="internal-link">Implementation Services →</a>
      <a href="/claude-training" class="internal-link">Claude Team Training →</a>
      <a href="/resources" class="internal-link">All Resources →</a>
    </div>
  </div>
</section>

<section id="contact">
  <div class="sec-inner" style="max-width:680px;">
    <span class="lbl">Get Started</span>
    <h2 class="h2">Want these workflows running<br/>in your HR function?</h2>
    <p class="sub">We configure Claude Projects for your company culture, role taxonomy, and team — and train your HR team to use them. Most teams reclaim 5–10 hours a week within the first month.</p>
    <div id="contact-form">
      <div class="form-grid">
        <div>
          <label class="form-label">First Name</label>
          <input class="input-field" type="text" id="first_name" placeholder="Jane" />
        </div>
        <div>
          <label class="form-label">Last Name</label>
          <input class="input-field" type="text" id="last_name" placeholder="Smith" />
        </div>
      </div>
      <div class="form-field">
        <label class="form-label">Work Email</label>
        <input class="input-field" type="email" id="email" placeholder="jane@company.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Company</label>
        <input class="input-field" type="text" id="company" placeholder="Acme Inc." />
      </div>
      <div class="form-field">
        <label class="form-label">What would you gain from getting Claude working in your HR workflows?</label>
        <textarea class="input-field" id="gain" placeholder="Better job descriptions, faster onboarding docs, consistent performance reviews..." style="min-height:100px;resize:vertical;"></textarea>
      </div>
      <button class="btn-p" id="submit-btn" style="width:100%;justify-content:center;" onclick="submitForm()">Deploy Claude in My HR Team →</button>
      <p style="font-size:0.75rem;color:#4A6A4A;margin-top:0.75rem;text-align:center;">We respond within one business day.</p>
    </div>
    <div class="thankyou" id="thankyou">
      <div class="thankyou-h">You're in good hands.</div>
      <p style="color:#8FAF8F;">We'll be in touch within one business day.</p>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        first_name: document.getElementById('first_name').value,
        last_name: document.getElementById('last_name').value,
        email: document.getElementById('email').value,
        company: document.getElementById('company').value,
        gain: document.getElementById('gain').value,
        source: 'claude-for-hr-workflows'
      })
    });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) {
    btn.textContent = 'Deploy Claude in My HR Team →';
    btn.disabled = false;
  }
}
</script>
