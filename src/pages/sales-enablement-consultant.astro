  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell { background: #050D05; padding: 2rem; }
    .grid-cell-alt { background: #0A1A0A; padding: 2rem; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .cell-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #00C853; margin-bottom: 0.6rem; display: block; }
    .cell-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.5rem; }
    .cell-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.65; }
    .break-item { display: flex; gap: 1rem; align-items: flex-start; padding: 1.25rem 0; border-bottom: 1px solid #1A3A1A; }
    .break-item:last-child { border-bottom: none; }
    .break-dot { width: 6px; height: 6px; border-radius: 50%; background: #00C853; flex-shrink: 0; margin-top: 0.5rem; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    .thankyou-p { color: #8FAF8F; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Arm Your Reps →</a>
  </div>
</nav>

<div class="hero" style="background:#050D05;">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Sales Enablement</div>
    <h1 class="hero-h">Sales Enablement Consulting: Give Your Reps<br/><em style="color:#00C853;font-style:italic;">What They Actually Need to Close.</em></h1>
    <p class="hero-sub">Sales enablement isn't a content library. It's the system that makes every rep consistently effective — regardless of how long they've been on the team or how well they know your product.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Arm Your Reps →</a>
      <a href="/how-to-use-claude-for-sales" class="btn-g">How to Use Claude for Sales</a>
    </div>
  </div>
</div>

<!-- What breaks without it -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The Problem</span>
    <h2 class="h2">What Happens When<br/>Enablement Doesn't Exist.</h2>
    <p class="sub">Most sales teams are losing deals they should win — not because reps aren't talented, but because they don't have the right materials at the right moment.</p>
    <div style="margin-top:1rem;">
      <div class="break-item">
        <div class="break-dot"></div>
        <div>
          <div class="step-title">Reps wing demos and discovery calls</div>
          <div class="step-desc" style="margin-top:0.3rem;">Every rep runs the demo differently. Your best rep knows the right questions. Your newest rep is still figuring out the product. The customer experience is inconsistent and the outcome is unpredictable.</div>
        </div>
      </div>
      <div class="break-item">
        <div class="break-dot"></div>
        <div>
          <div class="step-title">Messaging varies by rep — and by day</div>
          <div class="step-desc" style="margin-top:0.3rem;">What your reps say about your product doesn't match what marketing says. It doesn't even match what other reps say. Prospects are confused. Deals slow down because the story keeps changing.</div>
        </div>
      </div>
      <div class="break-item">
        <div class="break-dot"></div>
        <div>
          <div class="step-title">Competitive intel is stale or nonexistent</div>
          <div class="step-desc" style="margin-top:0.3rem;">A prospect asks "how are you different from Competitor X?" and your rep fumbles. They either undersell your advantages or get defensive. A battlecard that takes 3 minutes to read would have won that conversation.</div>
        </div>
      </div>
      <div class="break-item">
        <div class="break-dot"></div>
        <div>
          <div class="step-title">Proposals take 4 hours to write and still lose</div>
          <div class="step-desc" style="margin-top:0.3rem;">Your reps are spending half their week writing proposals from scratch. The proposals don't have a consistent format, they rarely reference the prospect's specific pain, and they often arrive late because they took so long to write.</div>
        </div>
      </div>
      <div class="break-item">
        <div class="break-dot"></div>
        <div>
          <div class="step-title">New reps take 6 months to ramp</div>
          <div class="step-desc" style="margin-top:0.3rem;">Onboarding is "shadow a senior rep for 2 weeks and figure it out." There's no documented playbook. No call library. No structured path from onboarding to first deal. The institutional knowledge lives in people's heads and walks out the door when they leave.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- What Bill builds -->
<section style="background:#050D05;">
  <div class="sec-inner">
    <span class="lbl">What We Build</span>
    <h2 class="h2">The Sales Enablement System<br/>That Makes Reps Effective.</h2>
    <p class="sub">Six deliverables. Built in 60 days. Every one of them is something a rep can open and use on their next call.</p>
    <div>
      <div class="step-row">
        <div class="step-num">01</div>
        <div>
          <div class="step-title">Competitive Battlecards</div>
          <div class="step-desc">One-page cards for your top 5–8 competitors. What they're strong at, where they're weak, what your prospects are hearing from them, and the specific responses that win. Updated quarterly. Built to be pulled up during a call, not read the night before.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">02</div>
        <div>
          <div class="step-title">Sales Playbook</div>
          <div class="step-desc">The full game plan: ICP definition, discovery questions that surface real pain, demo structure by use case, follow-up cadence, and stage-exit criteria. Specific enough to train a new rep. Flexible enough for a senior rep to add their own style.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">03</div>
        <div>
          <div class="step-title">Objection Handling Library</div>
          <div class="step-desc">Your 20 most common objections, documented with context and response frameworks. Not scripts — frameworks. "We're happy with our current vendor." "The timing isn't right." "We need to think about it." Each one handled with honesty, not pressure.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">04</div>
        <div>
          <div class="step-title">Claude-Powered Proposal System</div>
          <div class="step-desc">A custom Claude workflow that takes your discovery notes and generates a personalized proposal draft in under 10 minutes. Your reps fill in what they learned on the call. Claude handles the writing. Proposals that took 4 hours now take 30 minutes — and they're better.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">05</div>
        <div>
          <div class="step-title">New Rep Onboarding Track</div>
          <div class="step-desc">A structured 30-60-90 day ramp plan with milestones, a call shadow library, self-certification checkpoints, and the materials to get from "first day" to "first deal" without depending on a senior rep to babysit them the whole way.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">06</div>
        <div>
          <div class="step-title">Messaging Architecture</div>
          <div class="step-desc">Consistent language for your positioning, differentiators, and value props — across every rep, every channel, and every stage of the sale. What you say in a cold email, on a discovery call, and in a proposal should tell the same coherent story.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AI-native approach -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">AI-Native Sales Enablement</span>
    <h2 class="h2">Claude Inside Your<br/>Sales Motion.</h2>
    <p class="sub">The best sales enablement in 2025 is AI-native — not because it's trendy, but because it's the only way to keep materials current and proposals personalized at scale.</p>
    <div class="grid-2" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <span class="cell-label">Proposal Generation</span>
        <div class="cell-title">30-Minute Custom Proposals</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Rep fills in discovery notes. Claude drafts a proposal customized to that prospect's specific situation, in your voice, with your standard structure. Reviewed and sent in 30 minutes. Used to take half a day.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-label">Battlecard Updates</span>
        <div class="cell-title">Competitive Intel That Stays Current</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Claude monitors competitor positioning changes and flags when battlecards need updating. You're not relying on a quarterly manual review — you're reacting to what your competitors are actually saying right now.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-label">Call Prep</span>
        <div class="cell-title">Account Research in 5 Minutes</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Custom Claude workflow that takes a company name and generates a tailored call prep brief — company context, likely pain points, relevant case studies, and suggested discovery questions. Reps show up knowing the account.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-label">Objection Coaching</span>
        <div class="cell-title">Real-Time Objection Help</div>
        <div class="cell-desc" style="margin-top:0.75rem;">A Claude assistant reps can query mid-prep: "How do I respond when a prospect says our price is 30% higher than [Competitor]?" Gets them the right response in seconds, not a trip to the enablement wiki.</div>
      </div>
    </div>
    <div style="margin-top:2rem;">
      <a href="/how-to-use-claude-for-sales" class="btn-g">How to Use Claude for Sales →</a>
    </div>
  </div>
</section>

<!-- Who this is for -->
<section style="background:#050D05;">
  <div class="sec-inner">
    <span class="lbl">Who This Is For</span>
    <h2 class="h2">Sales Enablement Is Right<br/>for You If...</h2>
    <div class="grid-3" style="margin-top:2rem;">
      <div class="grid-cell">
        <span class="cell-label">Situation A</span>
        <div class="cell-title">You're adding headcount</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Hiring 2–3 new reps this year. Every month of slow ramp is revenue you're not making. Enablement cuts ramp time by 30–40% and makes every dollar of headcount work harder.</div>
      </div>
      <div class="grid-cell">
        <span class="cell-label">Situation B</span>
        <div class="cell-title">Your top rep is carrying everyone</div>
        <div class="cell-desc" style="margin-top:0.75rem;">One rep is 2x everyone else's quota. The difference isn't talent — it's knowledge that lives in their head. Enablement codifies what they know and distributes it to the whole team.</div>
      </div>
      <div class="grid-cell">
        <span class="cell-label">Situation C</span>
        <div class="cell-title">Win rate is inconsistent across reps</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Same ICP, same product, very different close rates. When reps are performing 2–3x differently against similar opportunities, it's a process and materials problem — not a talent problem.</div>
      </div>
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="/fractional-cmo" class="btn-g">Fractional CMO →</a>
      <a href="/fractional-cro" class="btn-g">Fractional CRO →</a>
      <a href="/services" class="btn-g">All Services →</a>
    </div>
  </div>
</section>

<!-- Timeline -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The Timeline</span>
    <h2 class="h2">60 Days to a Fully<br/>Enabled Sales Team.</h2>
    <div class="grid-3" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#00C853;margin-bottom:0.5rem;">Week 1–2</div>
        <div class="cell-title">Discovery & Audit</div>
        <div class="cell-desc" style="margin-top:0.4rem;">Call recordings reviewed, top reps interviewed, competitor intelligence gathered, existing materials audited. We learn your sales motion before we build anything.</div>
      </div>
      <div class="grid-cell-alt">
        <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#00C853;margin-bottom:0.5rem;">Week 3–6</div>
        <div class="cell-title">Build & Review</div>
        <div class="cell-desc" style="margin-top:0.4rem;">All six deliverables built in parallel, reviewed with your team, and iterated based on feedback. Rep testing is built into this phase — materials get stress-tested before they go live.</div>
      </div>
      <div class="grid-cell-alt">
        <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#00C853;margin-bottom:0.5rem;">Week 7–8</div>
        <div class="cell-title">Launch & Train</div>
        <div class="cell-desc" style="margin-top:0.4rem;">Team training sessions, manager enablement, Claude workflow setup and testing. You get a live library and the training to use it — not a Google Drive folder that gets ignored.</div>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" style="background:#050D05;">
  <div class="sec-inner" style="max-width:720px;">
    <span class="lbl">Get in Touch</span>
    <h2 class="h2">Give Your Reps What<br/>They Need to Close.</h2>
    <p class="sub">Tell us where your sales team is inconsistent. We'll tell you what an enablement engagement would look like and where you'd see results first.</p>

    <div id="se-form-wrap">
      <form id="se-form" style="margin-top:1.5rem;">
        <div class="form-grid">
          <div class="form-field">
            <label class="form-label" for="se-first">First Name</label>
            <input class="input-field" type="text" id="se-first" name="first_name" placeholder="Jane" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="se-last">Last Name</label>
            <input class="input-field" type="text" id="se-last" name="last_name" placeholder="Smith" required />
          </div>
        </div>
        <div class="form-field">
          <label class="form-label" for="se-email">Work Email</label>
          <input class="input-field" type="email" id="se-email" name="email" placeholder="jane@company.com" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="se-company">Company</label>
          <input class="input-field" type="text" id="se-company" name="company" placeholder="Acme Corp" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="se-gain">What revenue problem are you trying to solve?</label>
          <textarea class="input-field" id="se-gain" name="gain" rows="4" placeholder="Where is your sales team inconsistent? Long ramp times, low win rates, reps winging demos, no competitive intel — describe what's breaking."></textarea>
        </div>
        <input type="hidden" name="source" value="sales-enablement-consultant" />
        <button type="submit" class="btn-p" style="width:100%;justify-content:center;margin-top:0.5rem;">Send →</button>
      </form>
    </div>
    <div class="thankyou" id="se-thanks">
      <div class="thankyou-h">We'll be in touch.</div>
      <p class="thankyou-p">Expect a response within one business day. If you'd like to move faster, book directly at <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" style="color:#00C853;">calendar.app.google</a>.</p>
    </div>
  </div>
</section>

<!-- Cross-links -->
<div style="border-top:1px solid #1A3A1A;background:#050D05;padding:3rem 2.5rem;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="font-size:0.68rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#8FAF8F;margin-bottom:1.5rem;">More from Treetop</div>
