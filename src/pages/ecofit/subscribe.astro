---
export const prerender = true;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Website Management — Ecofit × Treetop Growth Strategy</title>
<meta name="description" content="Hosting, HubSpot CRM integration, and monthly site maintenance — managed by Treetop Growth Strategy. One invoice, zero headaches.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: #fff; color: #0d1117; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; }
  nav { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.97); border-bottom: 1px solid #e5e7eb; backdrop-filter: blur(8px); }
  .nav-inner { max-width: 1080px; margin: 0 auto; padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
  .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .nav-mark { width: 28px; height: 28px; background: #84BC41; border-radius: 5px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 800; font-size: 13px; }
  .nav-name { font-size: 15px; font-weight: 700; color: #0d1117; letter-spacing: -0.02em; }
  .nav-sep { color: #d1d5db; font-weight: 300; font-size: 18px; }
  .nav-partner { font-size: 13px; font-weight: 600; color: #6b7280; }
  .nav-back { font-size: 13px; font-weight: 500; color: #6b7280; text-decoration: none; display: flex; align-items: center; gap: 4px; }
  .nav-back:hover { color: #0d1117; }
  .hero { max-width: 1080px; margin: 0 auto; padding: 80px 32px 64px; display: grid; grid-template-columns: 1fr 420px; gap: 64px; align-items: start; }
  .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; background: rgba(132,188,65,0.08); border: 1px solid rgba(132,188,65,0.2); padding: 4px 12px; border-radius: 100px; margin-bottom: 20px; }
  .hero-tag-dot { width: 6px; height: 6px; background: #84BC41; border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:0.4 } }
  .hero h1 { font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 800; line-height: 1.12; letter-spacing: -0.03em; color: #0d1117; margin-bottom: 16px; }
  .hero h1 span { color: #84BC41; }
  .hero-sub { font-size: 16px; color: #6b7280; line-height: 1.7; max-width: 480px; margin-bottom: 32px; }
  .price-card { background: #0d1117; border-radius: 16px; padding: 40px 36px; color: #fff; position: sticky; top: 80px; }
  .price-label { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 20px; }
  .price-amount { font-size: 52px; font-weight: 800; letter-spacing: -0.03em; color: #fff; line-height: 1; }
  .price-period { font-size: 15px; color: #6b7280; margin-top: 4px; margin-bottom: 28px; }
  .price-divider { width: 100%; height: 1px; background: #1f2937; margin-bottom: 24px; }
  .price-features { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }
  .price-features li { font-size: 14px; color: rgba(255,255,255,0.8); padding-left: 24px; position: relative; line-height: 1.5; }
  .price-features li::before { content: ''; position: absolute; left: 0; top: 5px; width: 12px; height: 12px; border-radius: 50%; background: rgba(132,188,65,0.15); border: 2px solid #84BC41; }
  .price-btn { display: block; width: 100%; padding: 16px; border-radius: 10px; text-align: center; font-size: 15px; font-weight: 700; background: #84BC41; color: #fff; border: none; cursor: pointer; transition: background 0.2s; }
  .price-btn:hover { background: #75a838; }
  .price-note { font-size: 12px; color: #4b5563; text-align: center; margin-top: 12px; }
  .section { max-width: 1080px; margin: 0 auto; padding: 80px 32px; }
  .section-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 12px; }
  .section-h2 { font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.2; color: #0d1117; margin-bottom: 14px; }
  .section-sub { font-size: 15px; color: #6b7280; line-height: 1.7; max-width: 560px; margin-bottom: 48px; }
  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #e5e7eb; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .pillar { background: #fff; padding: 36px 28px; }
  .pillar-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(132,188,65,0.08); display: flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: 20px; }
  .pillar h3 { font-size: 16px; font-weight: 700; color: #0d1117; margin-bottom: 10px; }
  .pillar p { font-size: 14px; color: #6b7280; line-height: 1.65; }
  .pillar-details { list-style: none; margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .pillar-details li { font-size: 13px; color: #4b5563; padding-left: 18px; position: relative; line-height: 1.5; }
  .pillar-details li::before { content: '→'; position: absolute; left: 0; color: #84BC41; font-weight: 600; }
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .step-num { font-size: 48px; font-weight: 900; color: rgba(132,188,65,0.12); line-height: 1; margin-bottom: 12px; }
  .step h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .step p { font-size: 14px; color: #6b7280; line-height: 1.65; }
  .compare-section { background: #f8fafc; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; }
  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .compare-card { padding: 32px 28px; border-radius: 12px; }
  .compare-diy { background: #fff; border: 1px solid #e5e7eb; }
  .compare-managed { background: #0d1117; color: #fff; }
  .compare-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 20px; }
  .compare-managed h3 { color: #fff; }
  .compare-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .compare-list li { font-size: 14px; line-height: 1.6; padding-left: 24px; position: relative; }
  .compare-diy .compare-list li { color: #6b7280; }
  .compare-managed .compare-list li { color: rgba(255,255,255,0.75); }
  .compare-list li::before { position: absolute; left: 0; font-size: 13px; font-weight: 700; }
  .compare-diy .compare-list li::before { content: '✕'; color: #d1d5db; }
  .compare-managed .compare-list li::before { content: '✓'; color: #84BC41; }
  .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .faq-item { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px; padding: 24px; }
  .faq-item h4 { font-size: 14px; font-weight: 700; margin-bottom: 8px; color: #0d1117; }
  .faq-item p { font-size: 13px; line-height: 1.7; color: #6b7280; }
  .cta-section { background: #0d1117; padding: 80px 32px; text-align: center; }
  .cta-inner { max-width: 600px; margin: 0 auto; }
  .cta-section h2 { font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 800; color: #fff; letter-spacing: -0.02em; margin-bottom: 12px; }
  .cta-section p { font-size: 15px; color: #6b7280; line-height: 1.65; margin-bottom: 32px; }
  .cta-btn { display: inline-block; padding: 16px 36px; border-radius: 10px; font-size: 15px; font-weight: 700; background: #84BC41; color: #fff; text-decoration: none; transition: background 0.2s; }
  .cta-btn:hover { background: #75a838; }
  footer { padding: 32px; text-align: center; border-top: 1px solid #e5e7eb; }
  .footer-text { font-size: 12px; color: #9ca3af; }
  .footer-text a { color: #84BC41; text-decoration: none; }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; padding: 60px 24px 40px; gap: 40px; }
    .price-card { position: static; }
    .pillars { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; gap: 32px; }
    .compare-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
    .section { padding: 60px 24px; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <div class="nav-brand">
      <div class="nav-mark">E</div>
      <span class="nav-name">Ecofit</span>
      <span class="nav-sep">×</span>
      <span class="nav-partner">Treetop Growth Strategy</span>
    </div>
    <a href="/ecofit" class="nav-back">← Back to Ecofit</a>
  </div>
</nav>

<section class="hero">
  <div>
    <div class="hero-tag">
      <div class="hero-tag-dot"></div>
      Website Management
    </div>
    <h1>Your site, CRM, and<br>infrastructure —<br><span>managed for you.</span></h1>
    <p class="hero-sub">Treetop handles your hosting, HubSpot integration, and monthly site updates so your team can focus on selling Ecofit — not debugging forms or chasing SSL renewals.</p>
  </div>

  <div class="price-card">
    <div class="price-label">Website Management Retainer</div>
    <div class="price-amount">$199</div>
    <div class="price-period">per month</div>
    <div class="price-divider"></div>
    <ul class="price-features">
      <li>Firebase hosting &amp; CDN</li>
      <li>Custom domain &amp; SSL management</li>
      <li>Uptime monitoring &amp; error alerts</li>
      <li>HubSpot CRM integration</li>
      <li>Assessment &amp; demo forms → HubSpot contacts</li>
      <li>Lead tagging &amp; deal pipeline routing</li>
      <li>Monthly copy &amp; content updates</li>
      <li>New sections &amp; pages as product evolves</li>
      <li>Priority email support</li>
    </ul>
    <button class="price-btn" id="subscribe-btn">Subscribe — $199/mo</button>
    <div class="price-note">Month-to-month. Cancel anytime. No setup fee.</div>
  </div>
</section>

<section class="section">
  <div class="section-tag">What's Covered</div>
  <h2 class="section-h2">Three pillars. One retainer.</h2>
  <p class="section-sub">Everything that keeps the Ecofit site running, generating leads, and feeding your sales pipeline.</p>
  <div class="pillars">
    <div class="pillar">
      <div class="pillar-icon">☁</div>
      <h3>Hosting &amp; Infrastructure</h3>
      <p>Firebase hosting on Google's global CDN. Custom domain management, SSL certificates, DNS configuration, and 24/7 uptime monitoring.</p>
      <ul class="pillar-details">
        <li>Sub-100ms load times globally</li>
        <li>SSL auto-renewal &amp; DNS management</li>
        <li>Uptime monitoring with instant alerts</li>
        <li>Error tracking &amp; resolution</li>
      </ul>
    </div>
    <div class="pillar">
      <div class="pillar-icon">📋</div>
      <h3>HubSpot CRM Integration</h3>
      <p>Every assessment completion and demo request creates a tagged contact and deal in HubSpot, giving the sales team full pipeline visibility.</p>
      <ul class="pillar-details">
        <li>Assessment leads → HubSpot contacts</li>
        <li>Demo requests → deal creation</li>
        <li>Auto-tagging by lead source &amp; score</li>
        <li>Pipeline stage mapping for sales</li>
      </ul>
    </div>
    <div class="pillar">
      <div class="pillar-icon">🔧</div>
      <h3>Monthly Maintenance</h3>
      <p>Copy updates, new sections, content changes, and design tweaks as the Ecofit product evolves. No separate invoices for small changes.</p>
      <ul class="pillar-details">
        <li>Copy &amp; messaging updates</li>
        <li>New landing pages &amp; sections</li>
        <li>Seasonal campaign support</li>
        <li>Performance optimization</li>
      </ul>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="section-tag">How It Works</div>
  <h2 class="section-h2">Live in days, not weeks.</h2>
  <p class="section-sub">We handle the migration and setup. You just point us at the domain.</p>
  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <h3>Domain goes live</h3>
      <p>We point your domain to Firebase, configure SSL, and verify everything loads cleanly. Zero downtime.</p>
    </div>
    <div class="step">
      <div class="step-num">02</div>
      <h3>HubSpot connected</h3>
      <p>Assessment and demo form submissions route into HubSpot as tagged contacts with deal records. Sales sees every lead the site generates.</p>
    </div>
    <div class="step">
      <div class="step-num">03</div>
      <h3>Ongoing support</h3>
      <p>Need copy changes? New sections? A campaign landing page? Slack us or email us. Changes go live within 48 hours.</p>
    </div>
  </div>
</section>

<section class="compare-section">
  <div class="section" style="padding-top:80px;padding-bottom:80px;">
    <div class="section-tag">Why Managed?</div>
    <h2 class="section-h2">DIY vs. Treetop-managed.</h2>
    <p class="section-sub">What it looks like when your team handles infrastructure vs. when we do.</p>
    <div class="compare-grid">
      <div class="compare-card compare-diy">
        <h3>Managing It Yourself</h3>
        <ul class="compare-list">
          <li>Firebase, domain registrar, DNS — three dashboards</li>
          <li>SSL expires; you find out from a prospect</li>
          <li>Form breaks silently — leads vanish for days</li>
          <li>Every copy change requires a developer</li>
          <li>HubSpot integration is "on the roadmap"</li>
          <li>Nobody owns monitoring — things break quietly</li>
        </ul>
      </div>
      <div class="compare-card compare-managed">
        <h3>Treetop-Managed</h3>
        <ul class="compare-list">
          <li>One invoice, one point of contact</li>
          <li>SSL, DNS, and certs handled forever</li>
          <li>Every form submission hits HubSpot instantly</li>
          <li>Copy changes deployed within 48 hours</li>
          <li>HubSpot integration live from day one</li>
          <li>24/7 uptime monitoring with alert-and-fix SLA</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-tag">FAQ</div>
  <h2 class="section-h2">Common questions.</h2>
  <div class="faq-grid">
    <div class="faq-item">
      <h4>What if we need a major redesign?</h4>
      <p>The retainer covers ongoing updates and new sections. Full redesigns or major feature builds are scoped separately. Most months, the retainer covers everything you need.</p>
    </div>
    <div class="faq-item">
      <h4>Do we keep our domain?</h4>
      <p>Yes. We point your existing domain to Firebase. If you ever leave, we hand everything back — your domain, your site, your data.</p>
    </div>
    <div class="faq-item">
      <h4>How does the HubSpot integration work?</h4>
      <p>Assessment completions and demo requests submit to our API, which creates a HubSpot contact with tags (lead source, risk score, company size) and opens a deal in your pipeline.</p>
    </div>
    <div class="faq-item">
      <h4>What's the contract term?</h4>
      <p>Month-to-month. No long-term contract. Cancel anytime with 30 days notice. We earn your business every month.</p>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="cta-inner">
    <h2>Ready to hand off<br>the infrastructure?</h2>
    <p>Subscribe today. We'll have HubSpot connected and your site monitored within the week.</p>
    <a href="#" class="cta-btn" id="cta-subscribe-btn">Subscribe — $199/mo</a>
  </div>
</section>

<footer>
  <p class="footer-text">Managed by <a href="/stack">Treetop Growth Strategy</a> — marketing infrastructure, handled.</p>
</footer>

<script>
  document.querySelectorAll('#subscribe-btn, #cta-subscribe-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const el = e.currentTarget;
      const originalText = el.textContent;
      el.textContent = 'Loading...';
      el.style.pointerEvents = 'none';
      try {
        const res = await fetch('/api/ecofit-subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan: 'ecofit-website-management' }),
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert(data.error || 'Something went wrong. Please try again.');
          el.textContent = originalText;
          el.style.pointerEvents = 'auto';
        }
      } catch (err) {
        alert('Connection error. Please try again.');
        el.textContent = originalText;
        el.style.pointerEvents = 'auto';
      }
    });
  });
</script>

</body>
</html>
