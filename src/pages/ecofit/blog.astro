<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: #fff; color: #0d1117; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1); }
  .reveal.in { opacity: 1; transform: none; }
  @keyframes grad-flow { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
  .grad-text { background: linear-gradient(90deg,#84BC41,#c5e87a,#84BC41,#5a8a2a); background-size: 300%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: grad-flow 5s ease infinite; }
  .section-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 12px; }
  .btn-green { font-size: 14px; font-weight: 600; background: #84BC41; color: #fff; padding: 13px 26px; border-radius: 8px; text-decoration: none; display: inline-block; }
  .btn-green:hover { background: #75a838; }
  /* NAV */
  nav { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.97); border-bottom: 1px solid #e5e7eb; backdrop-filter: blur(8px); }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
  /* HERO */
  .hero-centered { text-align: center; padding: 80px 32px 60px; max-width: 680px; margin: 0 auto; }
  /* FEATURED ARTICLE */
  .featured-card { background: #0d1117; border-radius: 16px; padding: 56px; margin-bottom: 64px; }
  .featured-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #84BC41; background: rgba(132,188,65,0.12); border: 1px solid rgba(132,188,65,0.25); padding: 4px 10px; border-radius: 100px; display: inline-block; margin-bottom: 20px; }
  .featured-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; color: #f9fafb; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 16px; }
  .featured-meta { font-size: 12px; color: #6b7280; margin-bottom: 16px; }
  .featured-excerpt { font-size: 15px; color: #9ca3af; line-height: 1.7; margin-bottom: 28px; max-width: 640px; }
  .featured-link { font-size: 14px; font-weight: 600; color: #84BC41; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
  .featured-link:hover { color: #a0d655; }
  /* ARTICLE GRID */
  .articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .article-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 28px; display: flex; flex-direction: column; transition: border-color 0.2s, box-shadow 0.2s; }
  .article-card:hover { border-color: #84BC41; box-shadow: 0 4px 20px rgba(132,188,65,0.1); }
  .article-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 12px; }
  .article-title { font-size: 16px; font-weight: 700; color: #0d1117; line-height: 1.35; margin-bottom: 10px; flex-grow: 1; }
  .article-meta { font-size: 11.5px; color: #9ca3af; margin-bottom: 12px; }
  .article-excerpt { font-size: 13px; color: #6b7280; line-height: 1.65; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .article-link { font-size: 12.5px; font-weight: 600; color: #84BC41; text-decoration: none; margin-top: auto; }
  .article-link:hover { color: #5a8a2a; }
  /* CATEGORIES */
  .category-tabs { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 40px; }
  .cat-tab { font-size: 12.5px; font-weight: 600; padding: 6px 14px; border-radius: 100px; border: 1px solid #e5e7eb; color: #6b7280; cursor: pointer; background: #fff; transition: all 0.15s; }
  .cat-tab.active { background: #0d1117; color: #fff; border-color: #0d1117; }
  /* NEWSLETTER */
