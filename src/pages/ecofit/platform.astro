<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Platform | Ecofit — Features & Capabilities</title>
<meta name="description" content="Full inventory management, live equipment status, custom PM scheduling, service tracking, and analytics — all in one platform for fitness operators.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: #fff; color: #0d1117; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1); }
  .reveal.in { opacity: 1; transform: none; }
  @keyframes grad-flow { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
  .grad-text { background: linear-gradient(90deg,#84BC41,#c5e87a,#84BC41,#5a8a2a); background-size: 300%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: grad-flow 5s ease infinite; }
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  .section { padding: 80px 0; }
  .section-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 12px; }
  .section-h2 { font-size: clamp(1.8rem,3vw,2.6rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.2; color: #0d1117; margin-bottom: 14px; }
  .section-sub { font-size: 16px; color: #6b7280; line-height: 1.65; max-width: 560px; margin-bottom: 48px; }
  .btn-primary-dark { font-size: 14px; font-weight: 600; background: #0d1117; color: #fff; padding: 13px 26px; border-radius: 8px; text-decoration: none; display: inline-block; }
  .btn-green { font-size: 14px; font-weight: 600; background: #84BC41; color: #fff; padding: 13px 26px; border-radius: 8px; text-decoration: none; display: inline-block; }
  .btn-green:hover { background: #75a838; }
  /* NAV */
  nav { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.97); border-bottom: 1px solid #e5e7eb; backdrop-filter: blur(8px); }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
  /* HERO */
  .hero-centered { text-align: center; padding: 96px 32px 72px; max-width: 800px; margin: 0 auto; }
  .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #84BC41; background: rgba(132,188,65,0.08); border: 1px solid rgba(132,188,65,0.2); padding: 4px 10px; border-radius: 100px; margin-bottom: 20px; }
  .hero-tag-dot { width: 6px; height: 6px; background: #84BC41; border-radius: 50%; display: inline-block; }
  /* FEATURE GRID */
  .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #e5e7eb; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .feature-card { background: #fff; padding: 32px 28px; }
  .feature-card-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(132,188,65,0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
  .feature-card-icon svg { width: 20px; height: 20px; stroke: #84BC41; fill: none; stroke-width: 1.8; }
  .feature-card-title { font-size: 15px; font-weight: 700; color: #0d1117; margin-bottom: 10px; line-height: 1.3; }
  .feature-card-desc { font-size: 13.5px; color: #6b7280; line-height: 1.65; }
  /* COMPARISON TABLE */
  .comparison-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .compare-col { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .compare-col.featured { border-color: #84BC41; }
  .compare-header { padding: 24px 28px; border-bottom: 1px solid #e5e7eb; }
  .compare-header.featured { background: #84BC41; border-color: #84BC41; }
  .compare-tier { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9ca3af; margin-bottom: 6px; }
  .compare-tier.featured { color: rgba(255,255,255,0.8); }
  .compare-name { font-size: 20px; font-weight: 800; color: #0d1117; margin-bottom: 4px; }
  .compare-name.featured { color: #fff; }
  .compare-price { font-size: 13px; color: #6b7280; }
  .compare-price.featured { color: rgba(255,255,255,0.85); }
  .compare-items { padding: 20px 28px; }
  .compare-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid #f3f4f6; font-size: 13.5px; color: #374151; }
  .compare-item:last-child { border-bottom: none; }
  .compare-check { width: 18px; height: 18px; border-radius: 50%; background: rgba(132,188,65,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 10px; color: #84BC41; font-weight: 700; margin-top: 1px; }
  .compare-check.dark { background: rgba(13,17,23,0.08); }
  /* TESTIMONIALS DARK */
  .testimonials-dark { background: #0d1117; padding: 80px 32px; }
  .testimonials-dark-inner { max-width: 1200px; margin: 0 auto; }
  .testimonials-dark-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
  .testimonial-dark-card { background: #111827; border: 1px solid #1f2937; border-radius: 12px; padding: 32px; }
  .testimonial-dark-quote { font-size: 15px; color: #d1d5db; line-height: 1.7; margin-bottom: 24px; font-style: italic; }
  .testimonial-dark-author { font-size: 13px; font-weight: 700; color: #f9fafb; }
  .testimonial-dark-role { font-size: 12px; color: #6b7280; margin-top: 2px; }
  /* CTA */
  .cta-section { padding: 100px 32px; }
  .cta-inner { max-width: 1200px; margin: 0 auto; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 16px; padding: 72px; text-align: center; }
  /* EXIT */
  #exit-overlay { display: none; position: fixed; inset: 0; background: rgba(5,12,8,0.85); backdrop-filter: blur(10px); z-index: 10000; align-items: center; justify-content: center; padding: 24px; }
  #exit-card { background: #0d1117; border: 1px solid rgba(132,188,65,0.25); border-radius: 20px; max-width: 520px; width: 100%; padding: 48px 44px; position: relative; text-align: center; }
  #exit-card h3 { font-size: 26px; font-weight: 700; color: #f2f3f8; margin: 0 0 14px; }
  #exit-card p { color: #9699A2; font-size: 15px; line-height: 1.65; margin: 0 0 32px; }
  #exit-card .exit-cta { display: inline-block; background: #84BC41; color: #0d1117; font-weight: 700; font-size: 15px; padding: 15px 32px; border-radius: 10px; text-decoration: none; }
  #exit-card .exit-skip { display: block; margin-top: 16px; font-size: 13px; color: #6b6f7a; cursor: pointer; background: none; border: none; text-decoration: underline; }
  #exit-close { position: absolute; top: 14px; right: 18px; background: none; border: none; color: #9699A2; font-size: 24px; cursor: pointer; }
</style>
</head>
