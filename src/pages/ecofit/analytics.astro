<script>
(function(){
  var els = document.querySelectorAll('.reveal');
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);} });
    },{threshold:0.08});
    els.forEach(function(el){io.observe(el);});
  } else { els.forEach(function(el){el.classList.add('in');}); }

  document.querySelectorAll('a[style*="background:#84BC41"],.btn-green').forEach(function(btn){
    btn.addEventListener('mousemove',function(e){
      var r=btn.getBoundingClientRect();
      btn.style.transform='translate('+((e.clientX-r.left-r.width/2)*0.18)+'px,'+((e.clientY-r.top-r.height/2)*0.18)+'px)';
    });
    btn.addEventListener('mouseleave',function(){btn.style.transform='';});
  });

  // Stat counters
  document.querySelectorAll('.stat-num').forEach(function(el){
    var io2=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(!e.isIntersecting)return;
        var raw=el.textContent.trim();
        var m=raw.match(/^([\d.]+)([^0-9.]*)$/);
        if(!m)return;
        var num=parseFloat(m[1]),suf=m[2],isFloat=raw.indexOf('.')>-1;
        var dur=1800,t0=performance.now();
        (function tick(now){
          var p=Math.min((now-t0)/dur,1),ease=1-Math.pow(1-p,3);
          el.textContent=(isFloat?(num*ease).toFixed(1):Math.round(num*ease))+suf;
          if(p<1)requestAnimationFrame(tick);
        })(t0);
        io2.unobserve(el);
      });
    },{threshold:0.5});
    io2.observe(el);
  });

  if(!sessionStorage.getItem('ecf_exit')){
    var shown=false;
    document.addEventListener('mouseleave',function(e){
      if(e.clientY<10&&!shown){shown=true;sessionStorage.setItem('ecf_exit','1');var el=document.getElementById('exit-overlay');if(el)el.style.display='flex';}
    });
  }
  window.closeExit=function(){var el=document.getElementById('exit-overlay');if(el)el.style.display='none';};
  var eo=document.getElementById('exit-overlay');
  if(eo){eo.addEventListener('click',function(e){if(e.target===eo)closeExit();});}
  document.addEventListener('keydown',function(e){if(e.key==='Escape')closeExit();});
})();
</script>
</body>
</html>
