          <input id="d-email" type="email" required placeholder="jordan@apexfitness.com" style="width:100%;background:#1a2130;border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:10px 12px;color:#f2f3f8;font-size:14px;outline:none;box-sizing:border-box;">
        </div>
        <div style="margin-bottom:24px;">
          <label style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#9699A2;display:block;margin-bottom:6px;">Number of Locations</label>
          <select id="d-locations" style="width:100%;background:#1a2130;border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:10px 12px;color:#f2f3f8;font-size:14px;outline:none;box-sizing:border-box;appearance:none;">
            <option value="1">1 location</option>
            <option value="2-5">2–5 locations</option>
            <option value="6-15" selected>6–15 locations</option>
            <option value="16-50">16–50 locations</option>
            <option value="51-100">51–100 locations</option>
            <option value="100+">100+ locations</option>
          </select>
        </div>
        <button type="submit" id="demo-submit-btn" style="width:100%;background:#84BC41;color:#0d1117;font-weight:700;font-size:15px;padding:14px;border:none;border-radius:8px;cursor:pointer;">Book My Demo →</button>
        <p style="font-size:11px;color:#6b6f7a;text-align:center;margin:12px 0 0;">We'll reach out within one business day. No spam, ever.</p>
      </form>
    </div>
    <div id="demo-success" style="display:none;text-align:center;padding:20px 0;">
      <div style="font-size:40px;margin-bottom:16px;">✅</div>
      <h3 style="color:#f2f3f8;font-size:22px;margin:0 0 10px;">You're on the calendar.</h3>
      <p style="color:#9699A2;font-size:15px;margin:0 0 28px;line-height:1.6;">Check your inbox — we've sent a confirmation. Or grab a time directly:</p>
      <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" target="_blank" style="display:inline-block;background:#84BC41;color:#0d1117;font-weight:700;font-size:14px;padding:13px 28px;border-radius:8px;text-decoration:none;">Pick a Time on the Calendar →</a>
    </div>
  </div>
</div>

<script>
(function(){
  // Scroll reveals
  var els = document.querySelectorAll('.reveal');
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);} });
    },{threshold:0.08});
    els.forEach(function(el){io.observe(el);});
  } else { els.forEach(function(el){el.classList.add('in');}); }

  // Magnetic buttons
  document.querySelectorAll('.btn-nav-primary,.btn-hero-primary,.btn-cta-primary,.btn-green,.btn-primary-dark').forEach(function(btn){
    btn.addEventListener('mousemove',function(e){
      var r=btn.getBoundingClientRect();
      var x=(e.clientX-r.left-r.width/2)*0.18;
      var y=(e.clientY-r.top-r.height/2)*0.18;
      btn.style.transform='translate('+x+'px,'+y+'px)';
    });
    btn.addEventListener('mouseleave',function(){btn.style.transform='';});
  });

  // Demo modal
  var demoOverlay=document.getElementById('demo-overlay');
  window.openDemo=function(){demoOverlay.style.display='flex';};
  window.closeDemo=function(){demoOverlay.style.display='none';};
  demoOverlay.addEventListener('click',function(e){if(e.target===demoOverlay)closeDemo();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeDemo();closeExit();}});

  // Demo form submit
  window.submitDemo=async function(e){
    e.preventDefault();
    var btn=document.getElementById('demo-submit-btn');
    btn.disabled=true;btn.textContent='Sending…';
    try{
      var res=await fetch('/api/ecofit-demo-request',{
        method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({name:document.getElementById('d-name').value.trim(),email:document.getElementById('d-email').value.trim(),company:document.getElementById('d-company').value.trim(),locations:document.getElementById('d-locations').value})
      });
      document.getElementById('demo-form-wrap').style.display='none';
      document.getElementById('demo-success').style.display='block';
    }catch(err){btn.disabled=false;btn.textContent='Book My Demo →';alert('Something went wrong. Please try again.');}
  };

  // Exit intent (once per session)
  if(!sessionStorage.getItem('ecf_exit')){
    var shown=false;
    document.addEventListener('mouseleave',function(e){
      if(e.clientY<10&&!shown){
        shown=true;sessionStorage.setItem('ecf_exit','1');
        var el=document.getElementById('exit-overlay');
        if(el)el.style.display='flex';
      }
    });
  }
  window.closeExit=function(){
    var el=document.getElementById('exit-overlay');
    if(el)el.style.display='none';
  };
  var exitOverlay=document.getElementById('exit-overlay');
  if(exitOverlay){exitOverlay.addEventListener('click',function(e){if(e.target===exitOverlay)closeExit();});}

  // Stat counters
  var statEls=document.querySelectorAll('.stat-num');
  var statObs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting)return;
      var el=e.target;var raw=el.textContent.trim();
      var m=raw.match(/^([\d.]+)([%x+]?)$/);
      if(!m)return;
      var num=parseFloat(m[1]),suf=m[2],isFloat=raw.indexOf('.')>-1;
      var dur=1800,t0=performance.now();
      (function tick(now){
        var p=Math.min((now-t0)/dur,1),ease=1-Math.pow(1-p,3);
        el.textContent=(isFloat?(num*ease).toFixed(1):Math.round(num*ease))+suf;
        if(p<1)requestAnimationFrame(tick);
      })(t0);
      statObs.unobserve(el);
    });
  },{threshold:0.5});
  statEls.forEach(function(el){statObs.observe(el);});
})();
</script>
</body>
</html>
