<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ecofit — Equipment Intelligence Platform for Fitness Operators</title>
<meta name="description" content="Ecofit gives fitness operators real-time visibility into every asset across their network. Stop guessing. Start knowing.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: #fff; color: #0d1117; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1); }
  .reveal.in { opacity: 1; transform: none; }
  @keyframes grad-flow { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
  .grad-text { background: linear-gradient(90deg,#84BC41,#c5e87a,#84BC41,#5a8a2a); background-size: 300%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: grad-flow 5s ease infinite; }
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  .section { padding: 80px 0; }
  .section-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 12px; }
  .section-h2 { font-size: clamp(1.8rem,3vw,2.6rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.2; color: #0d1117; margin-bottom: 14px; }
  .section-sub { font-size: 16px; color: #6b7280; line-height: 1.65; max-width: 560px; margin-bottom: 48px; }
  .btn-primary-dark { font-size: 14px; font-weight: 600; background: #0d1117; color: #fff; padding: 13px 26px; border-radius: 8px; text-decoration: none; display: inline-block; }
  .btn-primary-dark:hover { background: #1f2937; }
  .btn-green { font-size: 14px; font-weight: 600; background: #84BC41; color: #fff; padding: 13px 26px; border-radius: 8px; text-decoration: none; display: inline-block; }
  .btn-green:hover { background: #75a838; }

  /* NAV */
  nav { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.97); border-bottom: 1px solid #e5e7eb; backdrop-filter: blur(8px); }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .nav-logo-mark { width: 28px; height: 28px; background: #84BC41; border-radius: 5px; display: flex; align-items: center; justify-content: center; }
  .nav-logo-mark svg { width: 16px; height: 16px; fill: #fff; }
  .nav-logo-text { font-size: 16px; font-weight: 700; color: #0d1117; letter-spacing: -0.02em; }
  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-links a { font-size: 13.5px; font-weight: 500; color: #374151; text-decoration: none; }
  .nav-links a:hover { color: #0d1117; }
  .nav-actions { display: flex; align-items: center; gap: 12px; }
  .btn-ghost { font-size: 13.5px; font-weight: 500; color: #374151; text-decoration: none; padding: 7px 14px; }
  .btn-nav-primary { font-size: 13.5px; font-weight: 600; background: #84BC41; color: #fff; text-decoration: none; padding: 8px 18px; border-radius: 6px; }
  .btn-nav-primary:hover { background: #75a838; }

  /* HERO */
  .hero { max-width: 1200px; margin: 0 auto; padding: 80px 32px 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #84BC41; background: rgba(132,188,65,0.08); border: 1px solid rgba(132,188,65,0.2); padding: 4px 10px; border-radius: 100px; margin-bottom: 20px; }
  .hero-tag-dot { width: 6px; height: 6px; background: #84BC41; border-radius: 50%; }
  .hero h1 { font-size: clamp(2.4rem, 3.5vw, 3.4rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; color: #0d1117; margin-bottom: 20px; }
  .hero p { font-size: 17px; font-weight: 400; color: #4b5563; line-height: 1.65; margin-bottom: 32px; max-width: 480px; }
  .hero-ctas { display: flex; align-items: center; gap: 16px; }
  .btn-hero-primary { font-size: 14px; font-weight: 600; background: #0d1117; color: #fff; padding: 12px 22px; border-radius: 7px; text-decoration: none; }
  .btn-hero-primary:hover { background: #1f2937; }
  .btn-hero-secondary { font-size: 14px; font-weight: 500; color: #374151; text-decoration: none; display: flex; align-items: center; gap: 6px; cursor: pointer; background: none; border: none; }
  .btn-hero-secondary:hover { color: #0d1117; }
  .hero-checklist { margin-top: 36px; display: flex; flex-direction: column; gap: 8px; }
  .hero-check { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #6b7280; }
  .hero-check-icon { width: 16px; height: 16px; background: rgba(132,188,65,0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 9px; color: #84BC41; font-weight: 700; }

  /* GLOW BORDER */
  @keyframes border-spin { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
  .glow-border { padding: 1.5px; background: linear-gradient(135deg,rgba(132,188,65,0.85),rgba(132,188,65,0.08),rgba(132,188,65,0.7),rgba(132,188,65,0.08),rgba(132,188,65,0.85)); background-size: 400% 400%; animation: border-spin 6s ease infinite; border-radius: 13px; }
  .hero-visual { background: #f8fafc; border-radius: 12px; overflow: hidden; }

  /* PARTNERS MARQUEE */
  .partners-section { padding: 32px 0; border-top: 1px solid rgba(128,128,128,0.1); border-bottom: 1px solid rgba(128,128,128,0.1); overflow: hidden; position: relative; background: #f5f6f7; }
  .partners-label { text-align: center; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #84BC41; margin: 0 0 24px; }
  .partners-track-wrap { overflow: hidden; width: 100%; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%); mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%); }
  .partners-track { display: flex; align-items: center; gap: 40px; width: max-content; animation: logo-scroll 30s linear infinite; }
  .partners-track:hover { animation-play-state: paused; }
  @keyframes logo-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
  .partner-logo { height: 44px; width: auto; object-fit: contain; flex-shrink: 0; filter: grayscale(1); opacity: 0.55; }

  /* LOGOS STRIP */
  .logos-strip { border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; padding: 22px 32px; background: #fafafa; }
  .logos-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
  .logos-label { font-size: 11px; font-weight: 500; color: #9ca3af; letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap; }
  .logos-list { display: flex; align-items: center; gap: 40px; flex-wrap: wrap; }
  .logo-item { font-size: 13px; font-weight: 700; color: #d1d5db; letter-spacing: 0.04em; text-transform: uppercase; }

  /* PROBLEM */
  .pain-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: #e5e7eb; border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; }
  .pain-card { background: #fff; padding: 28px 24px; }
  .pain-icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(132,188,65,0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
  .pain-icon svg { width: 18px; height: 18px; stroke: #84BC41; fill: none; stroke-width: 1.8; }
  .pain-title { font-size: 14px; font-weight: 700; color: #0d1117; margin-bottom: 8px; line-height: 1.3; }
  .pain-desc { font-size: 13px; color: #6b7280; line-height: 1.6; }

  /* FEATURES */
  .features-section { padding: 0 32px 80px; }
  .features-inner { max-width: 1200px; margin: 0 auto; }
  .feature-row { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; padding: 72px 0; border-top: 1px solid #e5e7eb; }
  .feature-row.reverse { direction: rtl; }
  .feature-row.reverse > * { direction: ltr; }
  .feature-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #84BC41; margin-bottom: 14px; }
  .feature-h3 { font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 14px; }
  .feature-desc { font-size: 15px; color: #6b7280; line-height: 1.7; margin-bottom: 24px; }
  .feature-link { font-size: 13.5px; font-weight: 600; color: #0d1117; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
  .feature-link:hover { color: #84BC41; }
  .feature-visual { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.04); }

  /* STATS */
  .stats-section { background: #0d1117; padding: 80px 32px; }
  .stats-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
  .stats-h2 { font-size: clamp(1.6rem,2.5vw,2rem); font-weight: 800; color: #fff; letter-spacing: -0.02em; margin-bottom: 12px; }
  .stats-sub { font-size: 15px; color: #6b7280; margin-bottom: 56px; }
  .stats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: #1f2937; border: 1px solid #1f2937; border-radius: 10px; overflow: hidden; }
  .stat-item { background: #111827; padding: 48px 32px; }
  .stat-num { font-size: 3.6rem; font-weight: 800; color: #84BC41; letter-spacing: -0.04em; line-height: 1; margin-bottom: 10px; }
  .stat-label { font-size: 13px; color: #6b7280; line-height: 1.5; }

  /* TESTIMONIALS */
  .testimonials-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
  .testimonial-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; padding: 32px; }
  .testimonial-quote { font-size: 15px; color: #374151; line-height: 1.7; margin-bottom: 24px; font-style: italic; }
  .testimonial-author { font-size: 13px; font-weight: 700; color: #0d1117; }
  .testimonial-role { font-size: 12px; color: #9ca3af; margin-top: 2px; }

  /* CTA */
  .cta-section { padding: 100px 32px; }
  .cta-inner { max-width: 1200px; margin: 0 auto; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 16px; padding: 72px; display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 48px; }
  .cta-h2 { font-size: clamp(1.8rem,3vw,2.4rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 12px; }
  .cta-sub { font-size: 15px; color: #6b7280; line-height: 1.65; max-width: 520px; }
  .cta-actions { display: flex; flex-direction: column; gap: 12px; align-items: flex-end; white-space: nowrap; }
  .btn-cta-primary { font-size: 14px; font-weight: 600; background: #0d1117; color: #fff; padding: 13px 26px; border-radius: 8px; text-decoration: none; }
  .btn-cta-secondary { font-size: 13.5px; color: #6b7280; text-decoration: none; cursor: pointer; }

  /* EXIT OVERLAY */
  #exit-overlay { display: none; position: fixed; inset: 0; background: rgba(5,12,8,0.85); backdrop-filter: blur(10px); z-index: 10000; align-items: center; justify-content: center; padding: 24px; }
  #exit-card { background: #0d1117; border: 1px solid rgba(132,188,65,0.25); border-radius: 20px; max-width: 520px; width: 100%; padding: 48px 44px; position: relative; text-align: center; box-shadow: 0 40px 100px rgba(0,0,0,0.6); }
  #exit-card .exit-icon { font-size: 36px; margin-bottom: 20px; }
  #exit-card h3 { font-size: 26px; font-weight: 700; color: #f2f3f8; margin: 0 0 14px; line-height: 1.2; }
  #exit-card p { color: #9699A2; font-size: 15px; line-height: 1.65; margin: 0 0 32px; }
  #exit-card .exit-cta { display: inline-block; background: #84BC41; color: #0d1117; font-weight: 700; font-size: 15px; padding: 15px 32px; border-radius: 10px; text-decoration: none; }
  #exit-card .exit-skip { display: block; margin-top: 16px; font-size: 13px; color: #6b6f7a; cursor: pointer; background: none; border: none; text-decoration: underline; }
  #exit-close { position: absolute; top: 14px; right: 18px; background: none; border: none; color: #9699A2; font-size: 24px; cursor: pointer; }

  /* DEMO MODAL */
  #demo-overlay { display: none; position: fixed; inset: 0; background: rgba(5,12,8,0.82); backdrop-filter: blur(8px); z-index: 9999; align-items: center; justify-content: center; padding: 24px; }

  /* METRIC CARDS GRID */
  .metric-cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
</style>
</head>
