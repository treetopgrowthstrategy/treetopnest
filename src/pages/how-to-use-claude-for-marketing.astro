        <div class="time-before">Before: 3–4 hours</div>
        <div class="time-after">After: 30 min</div>
      </div>
      <div class="time-cell">
        <div class="time-task">SEO content brief</div>
        <div class="time-before">Before: 2–3 hours</div>
        <div class="time-after">After: 20 min</div>
      </div>
      <div class="time-cell">
