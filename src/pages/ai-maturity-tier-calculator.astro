<GlobalFooter />

<script is:inline>
  (function() {
    var answers = {};
    var totalQuestions = 8;

    var tierData = {
      1: {
        name: 'Tier 1: Exploring',
        tagClass: 't1',
        tagText: 'Exploring',
        verdict: "You're early. AI is something a few people on your team are trying in their personal flow, but it hasn't reached the operating model yet. Most of the perceived productivity is from one or two power users. Nothing has been rebuilt at the workflow level, and nothing has been documented for others to inherit. This is by far the most common tier for mid-market teams in 2026, so you're not behind, you're at a starting line. The good news: the gap from Tier 1 to Tier 2 is the easiest jump and the highest leverage.",
        recs: [
          "Name an AI lead. One person, with a real title or at least a real protected calendar block (4 to 8 hours per week). Without an owner, nothing moves out of personal experiments and into team workflows.",
          "Pick three workflows worth rebuilding (not accelerating). Look for repetitive, high volume, low judgment work: weekly reporting, inbound qualification, first draft content, meeting notes. Rebuild those three end to end on AI, not just speed them up.",
          "Get the Treetop Gap Assessment to map which functions to start with. The free 15 minute diagnostic identifies your top 3 workflows by ROI and gives you a sequenced 90 day plan. That's the bridge to Tier 2."
        ]
      },
      2: {
        name: 'Tier 2: Piloting',
        tagClass: 't2',
        tagText: 'Piloting',
        verdict: "You're past curiosity. There are real workflows running on AI, real people getting real lift, and at least one named owner. But the pilots are still owner dependent. If the AI lead left tomorrow, the patterns would leave with them. The work hasn't been codified, new hires aren't inheriting it, and the tooling sprawl is starting to cost you. The jump from Tier 2 to Tier 3 is mostly about institutionalization: making AI part of how your team works, not just what a few people do.",
        recs: [
          "Protect the AI lead's calendar. 8 to 12 hours per week, on the calendar, defended like a sales pipeline meeting. Pilot owners get pulled into urgent work and progress stalls. Make the time non negotiable.",
          "Document the patterns you already have. Every successful pilot has 3 to 5 prompts or workflows behind it. Write them down in a shared doc (Notion, Coda, or a real wiki). The act of writing surfaces the assumptions that need to be made explicit before anyone else can run them.",
          "Ship the next workflow to a different function. If your wins are all in marketing, your next pilot belongs in sales, customer success, or ops. Cross functional reach is the signal that separates Tier 2 from Tier 3."
        ]
      },
      3: {
        name: 'Tier 3: Operationalizing',
        tagClass: 't3',
        tagText: 'Operationalizing',
        verdict: "You're operating, not piloting. AI is in production across multiple functions, the patterns are documented, and the team treats them as real infrastructure. You're in the top 15% of mid-market teams in 2026. The jump from Tier 3 to Tier 4 is the hardest one because it's not about adding more AI, it's about cutting drag. Tool sprawl, redundant workflows, and untrained new hires are the three things that prevent compounding. Fix those and the leverage starts to stack.",
        recs: [
          "Invest in tool consolidation. Audit every AI/LLM tool in use. Most Tier 3 teams have 6 to 9 tools where 2 to 3 would serve the same purpose better. Consolidate to your strongest two platforms, retire the rest, and reallocate the budget to seats and training.",
          "Train new hires on patterns in their first week, not their first quarter. The single biggest predictor of Tier 4 is that AI patterns are part of onboarding, not optional. Build a 90 minute onboarding session that walks new hires through your top 5 workflows on day 3.",
          "Measure productivity gains as a real KPI. Hours saved, throughput per worker, time to first draft. Pick two metrics, put them on the team dashboard, and review monthly. What gets measured gets defended in the budget cycle."
        ]
      },
      4: {
        name: 'Tier 4: Compounding',
        tagClass: 't4',
        tagText: 'Compounding',
        verdict: "You're in the rarest tier. Less than 5% of mid-market teams are here in 2026. AI is not a project, it's how your team works. CEO is in daily, workflows have been rebuilt and some have been deleted, new hires inherit the patterns, and you measure the gain. From here the work isn't about getting AI to stick, it's about extending the model to the parts of your business that have lagged and making your maturity legible to the market. Compounding teams are the ones competitors and acquirers study.",
        recs: [
          "Extend AI native to roles that have lagged. Legal review, finance ops, board reporting, vendor management. These functions get skipped because they're judgment heavy, but the same patterns apply with the right prompting. Pick one, rebuild it this quarter.",
          "Build the prompt pattern library publicly. Publish 5 to 10 of your best internal prompts as a public resource. This does two things: it forces your team to write them properly, and it builds the brand of an AI native operator (which compounds in hiring, sales, and PR).",
          "Mentor your peer set. The fastest way to lock in your tier is to teach it. Run a quarterly office hours for 5 to 8 peer companies, share what didn't work, and invite reciprocity. Teaching at the edge of your competence is how Tier 4 teams stay there."
        ]
      }
    };

    function getTier(score) {
      if (score <= 2) return 1;
      if (score <= 4) return 2;
      if (score <= 6) return 3;
      return 4;
    }

    function updateProgress() {
      var answered = Object.keys(answers).length;
      document.getElementById('progress-text').textContent = answered + ' of ' + totalQuestions + ' answered';
      document.getElementById('progress-fill').style.width = ((answered / totalQuestions) * 100) + '%';

      if (answered === totalQuestions) {
        renderResult();
      } else {
        document.getElementById('result-card').classList.remove('shown');
      }
    }

    function renderResult() {
      var score = 0;
      for (var k in answers) {
        if (answers[k] === 'yes') score++;
      }
      var tier = getTier(score);
      var data = tierData[tier];

      var tag = document.getElementById('tier-tag');
      tag.className = 'tier-tag ' + data.tagClass;
      tag.textContent = data.tagText;
      document.getElementById('tier-head').textContent = data.name;
      document.getElementById('tier-score').textContent = 'You scored ' + score + ' of 8.';
      document.getElementById('tier-verdict').textContent = data.verdict;

      var list = document.getElementById('rec-list');
      list.innerHTML = '';
      for (var i = 0; i < data.recs.length; i++) {
        var li = document.createElement('li');
        var num = document.createElement('span');
        num.className = 'rec-num';
        num.textContent = (i + 1) + '.';
        var txt = document.createElement('span');
        txt.textContent = data.recs[i];
        li.appendChild(num);
        li.appendChild(txt);
        list.appendChild(li);
      }

      var card = document.getElementById('result-card');
      card.classList.add('shown');
      card.scrollIntoView({behavior: 'smooth', block: 'start'});
    }

    function reset() {
      answers = {};
      var buttons = document.querySelectorAll('.ans-btn');
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].classList.remove('selected');
      }
      updateProgress();
      document.querySelector('.calc-inputs').scrollIntoView({behavior: 'smooth', block: 'start'});
    }

    // Wire up the answer buttons
    var allButtons = document.querySelectorAll('.ans-btn');
    for (var i = 0; i < allButtons.length; i++) {
      allButtons[i].addEventListener('click', function(e) {
        var btn = e.currentTarget;
        var q = btn.getAttribute('data-q');
        var a = btn.getAttribute('data-answer');
        answers[q] = a;
        // Clear siblings, set this one
        var siblings = document.querySelectorAll('.ans-btn[data-q="' + q + '"]');
        for (var j = 0; j < siblings.length; j++) {
          siblings[j].classList.remove('selected');
        }
        btn.classList.add('selected');
        updateProgress();
      });
    }

    document.getElementById('reset-btn').addEventListener('click', reset);

    document.getElementById('share-btn').addEventListener('click', function() {
      var url = 'https://treetopgrowthstrategy.com/ai-maturity-tier-calculator';
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function() {
          var btn = document.getElementById('share-btn');
          var original = btn.textContent;
          btn.textContent = 'Link copied!';
          setTimeout(function() { btn.textContent = original; }, 2000);
        });
      } else {
        // Fallback for older browsers
        var ta = document.createElement('textarea');
        ta.value = url;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        var btn = document.getElementById('share-btn');
        var original = btn.textContent;
        btn.textContent = 'Link copied!';
        setTimeout(function() { btn.textContent = original; }, 2000);
      }
    });

    updateProgress();
  })();
</script>

</body>
