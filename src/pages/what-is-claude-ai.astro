  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .hero { min-height: 85vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell-alt { background: #0A1A0A; padding: 2rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: #1A3A1A; }
    .cell-icon { font-size: 1.5rem; margin-bottom: 0.75rem; display: block; }
    .cell-title { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .cell-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.65; }
    .compare-table { width: 100%; border-collapse: collapse; margin-top: 2rem; }
    .compare-table th { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #4A6A4A; padding: 1rem 1.5rem; text-align: left; border-bottom: 1px solid #1A3A1A; background: #050D05; }
    .compare-table th:first-child { color: #4A6A4A; }
    .compare-table th.claude-col { color: #00C853; }
    .compare-table td { font-size: 0.85rem; color: #8FAF8F; padding: 1.1rem 1.5rem; border-bottom: 1px solid rgba(26,58,26,0.5); line-height: 1.6; }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table .attribute { color: #F0FFF0; font-weight: 500; }
    .compare-table .highlight { color: #F0FFF0; }
    .pricing-tier { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 1.75rem; }
    .pt-name { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #4A6A4A; margin-bottom: 0.5rem; }
    .pt-price { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #00C853; margin-bottom: 0.5rem; }
    .pt-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.6; margin-bottom: 1rem; }
    .pt-features { list-style: none; }
    .pt-features li { font-size: 0.82rem; color: #8FAF8F; padding: 0.35rem 0; border-bottom: 1px solid rgba(26,58,26,0.4); }
    .pt-features li:last-child { border-bottom: none; }
    .pt-features li::before { content: "✓ "; color: #00C853; }
    .use-case-row { padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .use-case-row:last-child { border-bottom: none; }
    .uc-biz { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #00C853; margin-bottom: 0.5rem; }
    .uc-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.5rem; }
    .uc-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} .compare-table{font-size:0.78rem} .compare-table th,.compare-table td{padding:0.875rem 1rem} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Plain-English Guide</div>
    <h1 class="hero-h">What Is Claude AI?<br/><em style="color:#00C853;font-style:italic;">(And Why Business Owners Should Pay Attention)</em></h1>
    <p class="hero-sub">Claude is Anthropic's AI assistant — and for a growing number of B2B companies, it's becoming core operating infrastructure. Here's what it is, what it's actually good at, and what you need to know.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Get Help Implementing Claude →</a>
      <a href="/claude-for-small-business" class="btn-g">Claude for SMB</a>
    </div>
  </div>
</div>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The Basics</span>
    <h2 class="h2">What Claude is,<br/>in plain English.</h2>
    <p class="sub" style="max-width:760px;">Claude is a large language model (LLM) built by Anthropic, an AI safety company founded in 2021 by former OpenAI researchers. Like ChatGPT, it's a conversational AI that can read, write, analyze, and reason across almost any domain. Where Claude differs is in its design philosophy: Anthropic built it with a focus on being genuinely helpful, harmless, and honest — which in practice means it handles nuanced, high-stakes business writing better than most competitors.</p>
    <div class="grid-4" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <span class="cell-icon">✍️</span>
        <div class="cell-title">Writing & Editing</div>
        <div class="cell-desc">Long-form content, proposal writing, client communication, thought leadership. Follows brand voice instructions unusually well.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">🔍</span>
        <div class="cell-title">Research & Synthesis</div>
        <div class="cell-desc">Analyze documents, synthesize research, pull patterns from messy inputs. Handles long documents without losing context.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">🧠</span>
        <div class="cell-title">Reasoning & Analysis</div>
        <div class="cell-desc">Works through complex problems step-by-step. Useful for strategy work, competitive analysis, and structured thinking on hard problems.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">💻</span>
        <div class="cell-title">Code & Automation</div>
        <div class="cell-desc">Write, debug, and explain code. Build automations. Increasingly used by non-technical business owners to create simple internal tools.</div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">Claude vs. ChatGPT</span>
    <h2 class="h2">How Claude compares to ChatGPT<br/>at a high level.</h2>
    <p class="sub">Both are capable. The differences that matter for business use are more nuanced than the marketing suggests.</p>
    <div style="overflow-x:auto;">
      <table class="compare-table">
        <thead>
          <tr>
            <th>Dimension</th>
            <th>ChatGPT (OpenAI)</th>
            <th class="claude-col">Claude (Anthropic)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="attribute">Long document handling</td>
            <td>Good, especially with GPT-4o</td>
            <td class="highlight">Excellent — 200K token context window on Claude 3 models</td>
          </tr>
          <tr>
            <td class="attribute">Writing quality</td>
            <td>Strong across most formats</td>
            <td class="highlight">Generally preferred for long-form, nuanced business writing</td>
          </tr>
          <tr>
            <td class="attribute">Following complex instructions</td>
            <td>Good</td>
            <td class="highlight">Very strong — especially multi-step, detailed system prompts</td>
          </tr>
          <tr>
            <td class="attribute">Coding</td>
            <td class="highlight">Very strong, especially with plugins</td>
            <td>Strong, slightly behind GPT-4o in some benchmarks</td>
          </tr>
          <tr>
            <td class="attribute">Web search</td>
            <td class="highlight">Yes, built-in</td>
            <td>Available in newer versions</td>
          </tr>
          <tr>
            <td class="attribute">Ecosystem & integrations</td>
            <td class="highlight">Larger plugin/API ecosystem</td>
            <td>Growing fast, API widely used</td>
          </tr>
          <tr>
            <td class="attribute">Pricing (Pro tier)</td>
            <td>$20/month (ChatGPT Plus)</td>
            <td>$20/month (Claude Pro)</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p style="font-size:0.82rem;color:#4A6A4A;margin-top:1.5rem;">The honest answer: both are excellent tools. We recommend Claude to our clients primarily because it handles business writing and complex document analysis better — the two tasks that create the most leverage in B2B operations.</p>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Claude Projects</span>
    <h2 class="h2">The feature that changes everything<br/>for small business owners.</h2>
    <p class="sub">Claude Projects let you create persistent, customized "versions" of Claude for specific use cases. This is where the real leverage lives.</p>
    <div class="grid-3" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <div class="cell-title">Persistent memory & context</div>
        <div class="cell-desc">Upload your brand guidelines, SOPs, client information, or company knowledge base. Claude remembers it across every conversation in that Project — no re-explaining required.</div>
      </div>
      <div class="grid-cell-alt">
        <div class="cell-title">Custom instructions per use case</div>
        <div class="cell-desc">Create one Project for proposal writing (with your templates and voice), another for sales research, another for customer emails. Each behaves differently, optimized for its job.</div>
      </div>
      <div class="grid-cell-alt">
        <div class="cell-title">Team access</div>
        <div class="cell-desc">Share Projects with your team on Claude for Teams. Everyone uses the same configured context — company knowledge is institutional, not in one person's head.</div>
      </div>
    </div>
    <div style="background:#050D05;border:1px solid #1A3A1A;padding:2rem;margin-top:2rem;">
      <div style="font-size:0.82rem;color:#8FAF8F;line-height:1.75;">Example: a 12-person professional services firm built a "Client Deliverable" Project with their methodology documents, brand voice guide, client context for each account, and their standard output formats. First drafts that used to take 4 hours take 30 minutes. Same quality, consistently on-brand, every time. The project paid for itself on day one.</div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">Pricing Tiers</span>
    <h2 class="h2">What Claude costs.</h2>
    <p class="sub">Simple, transparent pricing. No hidden fees.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;margin-top:2rem;">
      <div class="pricing-tier">
        <div class="pt-name">Claude Free</div>
        <div class="pt-price">$0<span style="font-size:1rem;color:#4A6A4A;">/mo</span></div>
        <div class="pt-desc">Access to Claude 3.5 Haiku with usage limits. Good for trying it out.</div>
        <ul class="pt-features">
          <li>Claude 3.5 Haiku access</li>
          <li>Limited daily messages</li>
          <li>Basic Claude.ai interface</li>
        </ul>
      </div>
      <div class="pricing-tier" style="border-color: rgba(0,200,83,0.3);">
        <div class="pt-name" style="color:#00C853;">Claude Pro · Recommended</div>
        <div class="pt-price">$20<span style="font-size:1rem;color:#4A6A4A;">/mo</span></div>
        <div class="pt-desc">Full access to Claude 3.5 Sonnet and Opus with higher limits. Projects included.</div>
        <ul class="pt-features">
          <li>Claude 3.5 Sonnet & Opus</li>
          <li>5x more usage than free</li>
          <li>Claude Projects</li>
          <li>Priority access</li>
        </ul>
      </div>
      <div class="pricing-tier">
        <div class="pt-name">Claude for Teams</div>
        <div class="pt-price">$25<span style="font-size:1rem;color:#4A6A4A;">/user/mo</span></div>
        <div class="pt-desc">Everything in Pro, plus shared Projects, admin controls, and higher usage limits.</div>
        <ul class="pt-features">
          <li>Shared Projects across team</li>
          <li>Admin dashboard</li>
          <li>Billing management</li>
          <li>Higher message limits</li>
        </ul>
      </div>
    </div>
    <p style="font-size:0.82rem;color:#4A6A4A;margin-top:1.5rem;">For business use, Claude Pro at $20/month is the obvious starting point. If you have 3+ people using it regularly, Claude for Teams pays for itself quickly through shared Project access.</p>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">How Small Businesses Are Using It</span>
    <h2 class="h2">Real use cases, not hypotheticals.</h2>
    <p class="sub">These are workflows we've seen B2B companies implement — not AI conference demos, actual operating change.</p>
    <div>
      <div class="use-case-row">
        <div class="uc-biz">Marketing Agency</div>
        <div class="uc-title">First-draft content at 5x previous output</div>
        <div class="uc-desc">A 6-person content agency built a Claude Project with their style guide, client brand voices, SEO standards, and topic clusters. Writers brief Claude, get a strong first draft, spend 30 minutes refining instead of 3 hours writing from scratch. Output tripled without adding headcount.</div>
      </div>
      <div class="use-case-row">
        <div class="uc-biz">B2B SaaS</div>
        <div class="uc-title">Sales proposals from 3 days to same day</div>
        <div class="uc-desc">A SaaS company built a proposal Project with their product documentation, pricing tiers, case studies, and proven proposal structures. Sales reps drop in a discovery call summary, get a 90% complete custom proposal. One rep closed a deal the same day they had the intro call.</div>
      </div>
      <div class="use-case-row">
        <div class="uc-biz">Consulting Firm</div>
        <div class="uc-title">Research synthesis in 1 hour instead of 2 days</div>
        <div class="uc-desc">A management consulting firm uses Claude to analyze competitor reports, industry research, and client data. What used to take a junior analyst two days of synthesis work now takes an hour of Claude-assisted analysis. The analysts do better work because they're analyzing, not formatting.</div>
      </div>
      <div class="use-case-row">
        <div class="uc-biz">Law Firm</div>
        <div class="uc-title">Client communication that doesn't sound like legalese</div>
        <div class="uc-desc">A boutique IP firm uses Claude to translate complex legal updates into clear client-readable summaries. Attorneys write the technical content; Claude rewrites it for the client. Clients are more informed, better prepared for decisions, and more satisfied with communication quality.</div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">The Implementation Gap</span>
    <h2 class="h2">Having Claude and having Claude<br/>actually work are different things.</h2>
    <p class="sub">Most companies that subscribe to Claude get about 20% of the available value. The difference is implementation — the setup, the training, the workflow design that makes AI output reliable enough to depend on.</p>
    <div style="background:#0A1A0A;border:1px solid #1A3A1A;padding:2.5rem;margin-top:2rem;">
      <div style="font-family:'Instrument Serif',serif;font-size:1.5rem;color:#F0FFF0;margin-bottom:1.5rem;">That's what Treetop does.</div>
      <p style="font-size:0.9rem;color:#8FAF8F;line-height:1.8;margin-bottom:1.5rem;">We implement Claude for B2B companies — building the Projects, system prompts, and workflows that make AI output consistent and useful. Then we train your team until they're actually using it every day.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/claude-for-small-business" class="btn-p">Claude for SMB →</a>
        <a href="/services/implementation" class="btn-g">Implementation Details →</a>
        <a href="/resources" class="btn-g">Resources →</a>
      </div>
    </div>
  </div>
</section>

<section id="contact" style="background:#050D05;">
  <div class="sec-inner" style="max-width:680px;">
    <span class="lbl">Get Help Implementing Claude</span>
    <h2 class="h2">Ready to get Claude actually<br/>working in your business?</h2>
    <p class="sub">Tell us what you're trying to do. We'll tell you whether we think implementation support is worth it for your situation — and what it would look like.</p>
    <div id="contact-form">
      <div class="form-grid">
        <div>
          <label class="form-label">First Name</label>
          <input class="input-field" type="text" id="first_name" placeholder="Jane" />
        </div>
        <div>
          <label class="form-label">Last Name</label>
          <input class="input-field" type="text" id="last_name" placeholder="Smith" />
        </div>
      </div>
      <div class="form-field">
        <label class="form-label">Work Email</label>
        <input class="input-field" type="email" id="email" placeholder="jane@company.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Company</label>
        <input class="input-field" type="text" id="company" placeholder="Acme Inc." />
      </div>
      <div class="form-field">
        <label class="form-label">What's your biggest AI or marketing challenge right now?</label>
        <textarea class="input-field" id="gain" placeholder="We have Claude but aren't using it systematically. Want to figure out where it can actually help..." style="min-height:100px;resize:vertical;"></textarea>
      </div>
      <input type="hidden" id="source" value="what-is-claude-ai" />
      <button class="btn-p" id="submit-btn" style="width:100%;justify-content:center;" onclick="submitForm()">Get Help Implementing Claude →</button>
      <p style="font-size:0.75rem;color:#4A6A4A;margin-top:0.75rem;text-align:center;">We respond within one business day.</p>
    </div>
    <div class="thankyou" id="thankyou">
      <div class="thankyou-h">Talk soon.</div>
      <p style="color:#8FAF8F;">We'll be in touch within one business day.</p>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, gain: document.getElementById('gain').value, source: document.getElementById('source').value }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get Help Implementing Claude →'; btn.disabled = false; }
}
</script>
</body>
</html>
