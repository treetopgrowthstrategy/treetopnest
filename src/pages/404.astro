---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import GlobalNav from '../components/GlobalNav.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
---

<Layout
  title="Page not found (404) | Treetop Growth Strategy"
  description="This page does not exist. Try one of the links below or head to the homepage."
  noindex={true}
>

<GlobalNav />

<section style="min-height:70vh;display:flex;flex-direction:column;justify-content:center;padding:7rem 2.5rem 4rem;background:#050D05;color:#F0FFF0;font-family:'DM Sans',sans-serif;">
  <div style="max-width:720px;margin:0 auto;width:100%;">
    <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:1.25rem;display:block;">404</span>
    <h1 style="font-family:'Instrument Serif',serif;font-size:clamp(2.2rem,5vw,3.6rem);font-weight:400;line-height:1.1;margin:0 0 1.5rem;">Page not found.</h1>
    <p style="font-size:1.05rem;color:#8FAF8F;line-height:1.7;margin-bottom:2rem;max-width:60ch;">The URL you followed does not exist on this site. It may have moved, or the link that sent you here might be out of date.</p>
    <div style="display:flex;flex-direction:column;gap:0.5rem;font-size:0.98rem;">
      <a href="/" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);padding:0.5rem 0;width:fit-content;">Home</a>
      <a href="/fractional-cmo" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);padding:0.5rem 0;width:fit-content;">Fractional CMO services</a>
      <a href="/ai-cmo-advisor" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);padding:0.5rem 0;width:fit-content;">AI CMO Advisor ($99 report)</a>
      <a href="/resources" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);padding:0.5rem 0;width:fit-content;">Resources and guides</a>
      <a href="/about" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);padding:0.5rem 0;width:fit-content;">About Bill Colbert</a>
    </div>
  </div>
</section>

<GlobalFooter />
</Layout>
