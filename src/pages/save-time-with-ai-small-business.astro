---
export const prerender = true;
import GlobalFooter from '../components/GlobalFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Save Time with AI | Treetop Growth Strategy</title>
  <meta name="description" content="Stop losing hours to work AI can handle. Treetop builds Claude workflows that save small business teams 8–15 hours per week — measurably." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/save-time-with-ai-small-business" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/save-time-with-ai-small-business" />
  <meta property="og:title" content="Save Time with AI | Treetop Growth Strategy" />
  <meta property="og:description" content="Stop losing hours to work AI can handle. Treetop builds Claude workflows that save small business teams 8–15 hours per week — measurably." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Save Time with AI | Treetop Growth Strategy" />
  <meta name="twitter:description" content="Stop losing hours to work AI can handle. Treetop builds Claude workflows that save small business teams 8–15 hours per week — measurably." />
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Save Time with AI | Treetop Growth Strategy",
      "description": "Stop losing hours to work AI can handle. Treetop builds Claude workflows that save small business teams 8–15 hours per week — measurably.",
      "url": "https://treetopgrowthstrategy.com/save-time-with-ai-small-business",
      "provider": {"@id": "https://treetopgrowthstrategy.com/#organization"},
      "areaServed": {"@type": "Country", "name": "United States"},
      "audience": {"@type": "Audience", "description": "B2B executives and small business owners"}
    },
    {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
  ]
}
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell-alt { background: #0A1A0A; padding: 2rem; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .cell-icon { font-size: 1.5rem; margin-bottom: 0.75rem; display: block; }
    .cell-title { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.25rem; }
    .cell-time { font-family: 'Instrument Serif', serif; font-size: 1.5rem; font-style: italic; color: #00C853; margin-bottom: 0.4rem; line-height: 1; }
    .cell-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.65; }
    .faq-item { padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .faq-item:last-child { border-bottom: none; }
    .faq-q { font-size: 1rem; font-weight: 500; color: #F0FFF0; margin-bottom: 0.75rem; }
    .faq-a { font-size: 0.88rem; color: #8FAF8F; line-height: 1.75; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Save Time with AI</div>
    <h1 class="hero-h">Get back 10 hours a week.<br/><em style="color:#00C853;font-style:italic;">We'll show you how.</em></h1>
    <p class="hero-sub">Treetop builds Claude workflows that save small business teams 8–15 hours per week — measurably, across writing, research, documentation, and communications.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Get Time Back →</a>
      <a href="/services" class="btn-g">Our Services</a>
    </div>
  </div>
</div>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Where the time goes</span>
    <h2 class="h2">Hours that leave every week.<br/>Work AI can handle.</h2>
    <div class="grid-4" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <span class="cell-icon">✍️</span>
        <div class="cell-time">5–8 hrs/wk</div>
        <div class="cell-title">Writing</div>
        <div class="cell-desc">Proposals, emails, reports, content — first drafts that Claude can produce in seconds.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">🔎</span>
        <div class="cell-time">3–5 hrs/wk</div>
        <div class="cell-title">Research</div>
        <div class="cell-desc">Market analysis, competitive research, synthesizing sources — Claude does this in minutes.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">📋</span>
        <div class="cell-time">2–4 hrs/wk</div>
        <div class="cell-title">Documentation</div>
        <div class="cell-desc">SOPs, process guides, meeting notes — always pushed to the bottom, always piling up.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">📬</span>
        <div class="cell-time">3–6 hrs/wk</div>
        <div class="cell-title">Communications</div>
        <div class="cell-desc">Customer responses, follow-ups, internal updates — routine writing with high volume and low leverage.</div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">How we get it back</span>
    <h2 class="h2">Six ways Claude reclaims<br/>your team's time.</h2>
    <div>
      <div class="step-row">
        <div class="step-num">01</div>
        <div>
          <div class="step-title">Identify the Time Sinks</div>
          <div class="step-desc">We audit your workflows and pinpoint exactly which tasks are consuming the most time relative to their value — and which Claude can take over.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">02</div>
        <div>
          <div class="step-title">Build Drafting Workflows</div>
          <div class="step-desc">First-draft generation for any writing-heavy task. Your team reviews and refines instead of starting from a blank page.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">03</div>
        <div>
          <div class="step-title">Automate Research</div>
          <div class="step-desc">Claude synthesizes sources, summarizes documents, and delivers research outputs your team can act on immediately.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">04</div>
        <div>
          <div class="step-title">Standardize Communications</div>
          <div class="step-desc">Templates and workflows for your most frequent communication types — consistent quality, dramatically less time per message.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">05</div>
        <div>
          <div class="step-title">Train the Whole Team</div>
          <div class="step-desc">Time savings only compound when everyone on your team is using Claude. We train everyone until adoption is real.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">06</div>
        <div>
          <div class="step-title">Measure It</div>
          <div class="step-desc">Before-and-after time tracking on your specific workflows. You'll have real numbers — hours saved per person per week.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Common questions</span>
    <h2 class="h2">What people ask before<br/>getting started.</h2>
    <div>
      <div class="faq-item">
        <div class="faq-q">How many hours can we realistically save?</div>
        <div class="faq-a">Most teams see 8–15 hours per person per week on the workflows we target — writing, research, and communications. The range depends on your role and how much of your current work fits those categories.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How quickly will we see results?</div>
        <div class="faq-a">Most clients see meaningful time savings within the first week of using the workflows we build. The compounding happens as the team adopts more workflows over 30–60 days.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Will the quality be as good?</div>
        <div class="faq-a">With properly configured system prompts and workflows, Claude produces outputs that require less editing than what most teams produce manually. The quality bar goes up, not down.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What if my team doesn't adopt it?</div>
        <div class="faq-a">We don't stop at setup. We train your team with hands-on sessions until everyone is using the workflows confidently. Adoption is part of what we're hired to deliver.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How do you measure the time savings?</div>
        <div class="faq-a">We baseline time-per-task on your specific workflows before implementation and measure again 30 days after. You get a clear before-and-after report with real numbers.</div>
      </div>
    </div>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;padding-top:3rem;">
      <a href="/claude-for-small-business" class="btn-g">Claude for Small Business →</a>
      <a href="/services" class="btn-g">Explore All Services →</a>
    </div>
  </div>
</section>

<section id="contact" style="background:#050D05;">
  <div class="sec-inner" style="max-width:680px;">
    <span class="lbl">Get Time Back</span>
    <h2 class="h2">Tell us where your team's<br/>time is going.</h2>
    <p class="sub">We'll show you exactly how many hours Claude can reclaim — and build the workflows to prove it.</p>
    <div id="contact-form">
      <div class="form-grid">
        <div>
          <label class="form-label">First Name</label>
          <input class="input-field" type="text" id="first_name" placeholder="Jane" />
        </div>
        <div>
          <label class="form-label">Last Name</label>
          <input class="input-field" type="text" id="last_name" placeholder="Smith" />
        </div>
      </div>
      <div class="form-field">
        <label class="form-label">Work Email</label>
        <input class="input-field" type="email" id="email" placeholder="jane@company.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Company</label>
        <input class="input-field" type="text" id="company" placeholder="Acme Inc." />
      </div>
      <div class="form-field">
        <label class="form-label">What would you gain if Claude handled the work that's slowing your team down?</label>
        <textarea class="input-field" id="message" placeholder="Time for strategy, faster delivery, less overtime..." style="min-height:100px;resize:vertical;"></textarea>
      </div>
      <button class="btn-p" id="submit-btn" style="width:100%;justify-content:center;" onclick="submitForm()">Get Time Back →</button>
      <p style="font-size:0.75rem;color:#4A6A4A;margin-top:0.75rem;text-align:center;">We respond within one business day. Takes 3 min.</p>
    </div>
    <div class="thankyou" id="thankyou">
      <div class="thankyou-h">You're in good hands.</div>
      <p style="color:#8FAF8F;">We'll be in touch within one business day.</p>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, message: document.getElementById('message').value, source: 'save-time-ai' }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get Time Back →'; btn.disabled = false; }
}
</script>
</body>
</html>
