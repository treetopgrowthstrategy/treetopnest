<script is:inline>
async function submitWaitlist(e){
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  const success = document.getElementById('wl-success');
  const errorEl = document.getElementById('wl-error');
  success.style.display='none'; errorEl.style.display='none';
  btn.disabled=true; btn.textContent='Adding you...';
  const payload = {
    first_name: document.getElementById('wl-name').value.trim(),
    email: document.getElementById('wl-email').value.trim(),
    company: document.getElementById('wl-company').value.trim(),
    role: document.getElementById('wl-role').value.trim(),
    source: 'ai-native-gtm-course-waitlist',
  };
  try {
    const res = await fetch('/api/lead-capture', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(payload),
    });
    if(!res.ok) throw new Error('server');
    success.style.display='block';
    btn.textContent='✓ You\'re on the list';
    e.target.querySelectorAll('input').forEach(i => i.disabled=true);
  } catch(err){
    errorEl.style.display='block';
    btn.disabled=false; btn.textContent='Lock in $1,997 →';
  }
  return false;
}
</script>

