<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, gain: document.getElementById('message').value, source: 'best-ai-for-business' }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get AI Working for Your Business →'; btn.disabled = false; }
}
</script>
