    .tool-verdict { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.25rem 0.75rem; border: 1px solid; }
    .verdict-winner { color: #00C853; border-color: #00C853; }
    .verdict-strong { color: #C8A000; border-color: #C8A000; }
    .verdict-contextual { color: #8FAF8F; border-color: #4A6A4A; }
