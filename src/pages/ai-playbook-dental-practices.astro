<script is:inline>
async function submitPreorder(e){
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  const success = document.getElementById('po-success');
  const errorEl = document.getElementById('po-error');
  success.style.display='none'; errorEl.style.display='none';
  btn.disabled=true; btn.textContent='Reserving...';
  const payload = {
    first_name: document.getElementById('po-name').value.trim(),
    email: document.getElementById('po-email').value.trim(),
    company: document.getElementById('po-company').value.trim(),
    source: 'ai-playbook-dental-practices-preorder',
    product: 'AI Playbook PRO — Dental Practices',
    preorderPrice: 129,
  };
  try {
    const res = await fetch('/api/lead-capture', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(payload),
    });
    if(!res.ok) throw new Error('server');
    success.style.display='block';
    btn.textContent='✓ Reserved';
    e.target.querySelectorAll('input').forEach(i => i.disabled=true);
  } catch(err){
    errorEl.style.display='block';
    btn.disabled=false; btn.textContent='Reserve at $129 →';
  }
  return false;
}
</script>
