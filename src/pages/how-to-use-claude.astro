  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; }
    .btn-p:hover { opacity: 0.88; }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .hero { min-height: 50vh; display: flex; align-items: center; padding: 7rem 2.5rem 4rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; margin-bottom: 1.25rem; }
    .hero-sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 640px; }
    .grid-fn { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    @media(max-width:900px){ .grid-fn { grid-template-columns: 1fr; } section{padding:3.5rem 1.5rem} .hide-mob{display:none!important} }
    .fn-card { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; display: flex; flex-direction: column; gap: 0.85rem; text-decoration: none; transition: border-color 0.2s; }
    .fn-card:hover { border-color: rgba(0,200,83,0.4); }
    .fn-cat { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; }
    .fn-title { font-family: 'Instrument Serif', serif; font-size: 1.3rem; color: #F0FFF0; font-weight: 400; line-height: 1.25; }
    .fn-desc { font-size: 0.88rem; color: #8FAF8F; line-height: 1.65; flex: 1; }
    .fn-read { font-size: 0.82rem; color: #00C853; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; max-width: 760px; }
    .cta-box { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
    .cta-text { font-family: 'Instrument Serif', serif; font-size: 1.5rem; color: #F0FFF0; }
    .cta-sub { font-size: 0.88rem; color: #8FAF8F; margin-top: 0.5rem; }
  </style>

<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://treetopgrowthstrategy.com/"},{"@type":"ListItem","position":2,"name":"How To Use Claude","item":"https://treetopgrowthstrategy.com/how-to-use-claude"}]}</script>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-business" class="nav-link">Claude for Business</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="/quiz" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Take the Gap Assessment →</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Function-by-function guides</div>
    <h1 class="hero-h">How to Use Claude<br/><em style="color:#00C853;font-style:italic;">in Your Business.</em></h1>
    <p class="hero-sub">
      Generic "AI for business" content is useless. What matters is what Claude does inside the specific function you're trying to improve. These guides walk through the actual workflows — what to deploy, in what order, with what prompts — for seven core business functions.
    </p>
  </div>
</div>

<section>
  <div class="sec-inner">
    <div class="grid-fn">

      <a href="/how-to-use-claude-for-sales" class="fn-card">
        <div class="fn-cat">Sales</div>
        <div class="fn-title">How to Use Claude for Sales</div>
        <div class="fn-desc">Prospect research, account briefs, sequence personalization, call prep, follow-up generation. The Claude workflows that compress a rep's prep time from 90 minutes to 10.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

      <a href="/how-to-use-claude-for-marketing" class="fn-card">
        <div class="fn-cat">Marketing</div>
        <div class="fn-title">How to Use Claude for Marketing</div>
        <div class="fn-desc">Content production, campaign briefs, ICP research, messaging frameworks, repurposing. Where Claude amplifies a small marketing team without flattening the voice.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

      <a href="/how-to-use-claude-for-customer-service" class="fn-card">
        <div class="fn-cat">Customer service</div>
        <div class="fn-title">How to Use Claude for Customer Service</div>
        <div class="fn-desc">Ticket triage, response drafting, knowledge base authoring, escalation routing. Cut average handle time without losing the human voice in your replies.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

      <a href="/how-to-use-claude-for-operations" class="fn-card">
        <div class="fn-cat">Operations</div>
        <div class="fn-title">How to Use Claude for Operations</div>
        <div class="fn-desc">SOP authoring, process documentation, vendor management, internal comms. The operational workflows that finally get written when Claude does the first draft.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

      <a href="/how-to-use-claude-for-finance" class="fn-card">
        <div class="fn-cat">Finance</div>
        <div class="fn-title">How to Use Claude for Finance</div>
        <div class="fn-desc">Board-deck prep, variance analysis narration, vendor review, policy authoring. Where Claude replaces the painful "make this make sense" step in finance work.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

      <a href="/how-to-use-claude-for-hr" class="fn-card">
        <div class="fn-cat">HR & People</div>
        <div class="fn-title">How to Use Claude for HR</div>
        <div class="fn-desc">Job descriptions, interview kits, performance review drafts, onboarding docs, handbook updates. The Claude workflows that make a one-person People team feel like five.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

      <a href="/how-to-use-claude-for-project-management" class="fn-card">
        <div class="fn-cat">Project management</div>
        <div class="fn-title">How to Use Claude for Project Management</div>
        <div class="fn-desc">Status reports, scope documents, risk logs, retrospectives. The Claude workflows for PMs who need the documentation done but don't want to write it from scratch.</div>
        <div class="fn-read">Read the guide →</div>
      </a>

    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <h2 class="h2">Want the prompts that power these?</h2>
    <p class="body-text">Most of these guides reference our system-prompt library — twenty production-grade prompts for the functions above. Each one is annotated with the structure, the failure modes, and how to customize it for your business.</p>
    <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="/resources/claude-system-prompts-library" class="btn-p">Open the Prompts Library →</a>
      <a href="/resources/how-to-build-claude-prompts-for-your-business" style="display:inline-flex;align-items:center;gap:6px;background:transparent;color:#F0FFF0;padding:0.875rem 1.75rem;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:600;text-decoration:none;border:1px solid #1A3A1A;">Learn the prompt-writing method</a>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <div class="cta-box">
      <div>
        <div class="cta-text">Want us to set these up for your team?</div>
        <div class="cta-sub">We deploy Claude end-to-end for small businesses — system prompts, projects, training, the works.</div>
      </div>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/services/implementation" class="btn-p">See Implementation →</a>
        <a href="/services/ai-audit" style="display:inline-flex;align-items:center;gap:6px;background:transparent;color:#F0FFF0;padding:0.875rem 1.75rem;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:600;text-decoration:none;border:1px solid #1A3A1A;">Start with an Audit</a>
      </div>
    </div>
  </div>
</section>

<!-- treetop-linker-related-START -->
<section style="padding:3.5rem 2.5rem;border-top:1px solid #1A3A1A;background:#050D05;">
  <div style="max-width:780px;margin:0 auto;">
    <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;display:block;">Related</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.5rem,2.8vw,2rem);font-weight:400;line-height:1.2;color:#F0FFF0;margin-bottom:1.5rem;">Explore more from Treetop</h2>
    <ul style="list-style:none;padding:0;font-size:0.96rem;line-height:1.9;color:#C0D8C0;">
    <li><a href="/fractional-cmo" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Fractional CMO services &rarr;</a></li>
    <li><a href="/ai-for-cmos" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">AI for CMOs &rarr;</a></li>
    <li><a href="/the-ai-native-gtm-framework" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">The AI-native GTM framework &rarr;</a></li>
    <li><a href="/what-is-ai-native-gtm" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">What is AI-native GTM? &rarr;</a></li>
    <li><a href="/how-to-use-ai-in-your-business" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">How to use AI in your business &rarr;</a></li>
    <li><a href="/glossary" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">AI &amp; GTM glossary &rarr;</a></li>
    <li><a href="/resources" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Treetop resources &rarr;</a></li>
    <li><a href="/ai-agents-for-business" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">AI agents for business &rarr;</a></li>
    </ul>
  </div>
</section>
<!-- treetop-linker-related-END -->

<GlobalFooter />

</body>
</html>
