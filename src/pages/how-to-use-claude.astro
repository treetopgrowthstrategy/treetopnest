---
import GlobalFooter from '../components/GlobalFooter.astro';
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>How to Use Claude in Your Business | Treetop</title>
  <meta name="description" content="The complete hub of how-to guides for using Claude in sales, marketing, customer service, operations, finance, HR, and project management. Practical, tested workflows from real implementations." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/how-to-use-claude" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/how-to-use-claude" />
  <meta property="og:title" content="How to Use Claude in Your Business — Complete Guide" />
  <meta property="og:description" content="The complete hub of how-to guides for using Claude in sales, marketing, customer service, operations, finance, HR, and project management." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og/how-to-use-claude.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://treetopgrowthstrategy.com/og/how-to-use-claude.png" />
  <meta name="twitter:title" content="How to Use Claude in Your Business" />
  <meta name="twitter:description" content="Sales, marketing, customer service, ops, finance, HR, and project management — practical Claude playbooks for each." />
