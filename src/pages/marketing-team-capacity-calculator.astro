---
import GlobalFooter from '../components/GlobalFooter.astro';
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Marketing Team Capacity Calculator (AI-Enabled vs Hiring) | Treetop</title>
  <meta name="description" content="A free interactive calculator that estimates your marketing team\'s capacity in AI-enabled vs traditional mode — and what hiring another person would actually add. 60 seconds." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/marketing-team-capacity-calculator" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/marketing-team-capacity-calculator" />
  <meta property="og:title" content="Marketing Team Capacity Calculator" />
  <meta property="og:description" content="What would AI vs hiring actually add to your marketing capacity? Calculator." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og/marketing-team-capacity-calculator.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://treetopgrowthstrategy.com/og/marketing-team-capacity-calculator.png" />
  <meta name="twitter:title" content="Marketing Team Capacity Calculator" />
  <meta name="twitter:description" content="AI vs hiring — what actually adds capacity." />
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {"@type": "WebApplication", "name": "Marketing Team Capacity Calculator", "url": "https://treetopgrowthstrategy.com/marketing-team-capacity-calculator", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "offers": {"@type": "Offer", "price": "0", "priceCurrency": "USD"}},
    {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
  ]
}
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
    body{background:#050D05;color:#F0FFF0;font-family:'DM Sans',sans-serif;font-weight:300;-webkit-font-smoothing:antialiased}
    nav{position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(5,13,5,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #1A3A1A}
    .nav-inner{max-width:1200px;margin:0 auto;padding:0 2.5rem;height:64px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Instrument Serif',serif;font-size:1.3rem;font-style:italic;color:#F0FFF0;text-decoration:none}
    .nav-link{font-size:0.82rem;color:rgba(240,255,240,0.5);text-decoration:none}.nav-link:hover{color:#F0FFF0}
    .btn-p{display:inline-flex;align-items:center;gap:6px;background:#00C853;color:#050D05;padding:0.875rem 1.75rem;font-size:0.85rem;font-weight:600;text-decoration:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}.btn-p:hover{opacity:0.88}
    .btn-g{display:inline-flex;align-items:center;gap:6px;background:transparent;color:#F0FFF0;padding:0.875rem 1.75rem;font-size:0.85rem;font-weight:600;text-decoration:none;border:1px solid #1A3A1A}
    .badge{display:inline-flex;align-items:center;gap:8px;font-size:0.72rem;font-weight:500;color:#00C853;letter-spacing:0.06em;margin-bottom:1.5rem}
    .badge-dot{width:7px;height:7px;border-radius:50%;background:#00C853;animation:pulse 2s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
    .lbl{font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;display:block}
    section{padding:5rem 2.5rem;border-top:1px solid #1A3A1A}.sec-inner{max-width:1100px;margin:0 auto}
    .hero{min-height:45vh;display:flex;align-items:center;padding:7rem 2.5rem 4rem}.hero-inner{max-width:1100px;margin:0 auto;width:100%}
    .hero-h{font-family:'Instrument Serif',serif;font-size:clamp(2.5rem,5vw,3.75rem);font-weight:400;line-height:1.1;color:#F0FFF0;margin-bottom:1.25rem}
    .hero-sub{font-size:1rem;color:#C0D8C0;line-height:1.75;max-width:720px}
    .h2{font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;line-height:1.15;color:#F0FFF0;margin-bottom:1.25rem}
    .body{font-size:0.98rem;color:#C0D8C0;line-height:1.85;max-width:760px;margin-bottom:1rem}.body em{color:#F0FFF0;font-style:italic}
    .calc-inputs{background:#0A1A0A;border:1px solid #1A3A1A;padding:2rem;margin-bottom:2rem}
    .field{margin-bottom:1.25rem}
    .field label{display:block;font-size:0.85rem;color:#C0D8C0;margin-bottom:0.4rem;font-weight:500}
    .field .helper{display:block;font-size:0.75rem;color:#8FAF8F;margin-bottom:0.5rem;font-style:italic}
    .field input[type="range"]{width:100%;accent-color:#00C853}
    .slider-row{display:flex;align-items:center;gap:1rem}
    .slider-row input[type="range"]{flex:1}
    .slider-val{font-family:'Instrument Serif',serif;color:#00C853;font-size:1.1rem;min-width:90px;text-align:right}
    .compare-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:1.5rem}
    @media(max-width:900px){.compare-grid{grid-template-columns:1fr}section{padding:3.5rem 1.5rem}.hide-mob{display:none!important}}
    .scenario{background:#0A1A0A;border:1px solid #1A3A1A;padding:1.75rem;display:flex;flex-direction:column}
    .scenario.winner{border-color:rgba(0,200,83,0.4);background:rgba(0,200,83,0.04)}
    .scen-tag{font-size:0.65rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.6rem;min-height:0.65rem}
    .scen-name{font-family:'Instrument Serif',serif;font-size:1.4rem;color:#F0FFF0;font-weight:400;margin-bottom:1rem}
    .scen-output{font-family:'Instrument Serif',serif;font-size:2.4rem;color:#00C853;font-style:italic;line-height:1;margin-bottom:0.3rem}
    .scen-output-label{font-size:0.78rem;color:#8FAF8F;margin-bottom:1.5rem}
    .scen-row{padding:0.5rem 0;border-bottom:1px solid #1A3A1A;font-size:0.82rem;color:#C0D8C0;display:flex;justify-content:space-between}
    .scen-row:last-child{border-bottom:none}
    .scen-row span:last-child{color:#F0FFF0;font-weight:500}
    .verdict{background:rgba(0,200,83,0.06);border-left:3px solid #00C853;padding:1.5rem 1.75rem;margin-top:2rem;max-width:780px}
    .verdict h3{font-family:'Instrument Serif',serif;color:#F0FFF0;font-size:1.3rem;font-weight:400;margin-bottom:0.5rem}
    .verdict p{color:#C0D8C0;font-size:0.92rem;line-height:1.7;margin:0}
    .cta-box{background:#0A1A0A;border:1px solid #1A3A1A;padding:3rem;display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap}
    .cta-text{font-family:'Instrument Serif',serif;font-size:1.5rem;color:#F0FFF0}.cta-sub{font-size:0.88rem;color:#8FAF8F;margin-top:0.5rem}
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/pricing" class="nav-link">Pricing</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="/quiz" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Take the Gap Assessment →</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Free calculator · 60 seconds</div>
    <h1 class="hero-h">Marketing team capacity <em style="color:#00C853;font-style:italic;">calculator.</em></h1>
    <p class="hero-sub">
      Compare three scenarios side by side: your current capacity, your AI-enabled capacity (same team), and your capacity after hiring one more person. Tells you which move actually adds output — and what it costs.
    </p>
  </div>
</div>

<section>
  <div class="sec-inner">
    <div class="calc-inputs">
      <span class="lbl">Your team today</span>

      <div class="field">
        <label for="team">Marketing team size</label>
        <span class="helper">Full-time-equivalent people on the marketing team</span>
        <div class="slider-row">
          <input type="range" id="team" min="1" max="30" value="5" />
          <span class="slider-val" id="team-val">5</span>
        </div>
      </div>

      <div class="field">
        <label for="output">Current monthly content output (pieces)</label>
        <span class="helper">Count substantive output: blog posts, emails, ads, landing pages, social campaigns. Each counts as 1.</span>
        <div class="slider-row">
          <input type="range" id="output" min="2" max="100" value="12" />
          <span class="slider-val" id="output-val">12 pieces</span>
        </div>
      </div>

      <div class="field">
        <label for="salary">Average loaded annual cost per marketer ($)</label>
        <span class="helper">Salary + benefits + overhead. Typical mid-market: $90K-$140K</span>
        <div class="slider-row">
          <input type="range" id="salary" min="60000" max="200000" step="5000" value="110000" />
          <span class="slider-val" id="salary-val">$110K</span>
        </div>
      </div>
    </div>

    <span class="lbl">Capacity comparison</span>
    <div class="compare-grid">

      <div class="scenario">
        <div class="scen-tag">Today</div>
        <div class="scen-name">Current capacity</div>
        <div class="scen-output" id="current-output">12</div>
        <div class="scen-output-label">pieces per month</div>
        <div class="scen-row"><span>Team size</span><span id="current-team">5 FTE</span></div>
        <div class="scen-row"><span>Annual team cost</span><span id="current-cost">$550K</span></div>
        <div class="scen-row"><span>Cost per piece</span><span id="current-per">$3,819</span></div>
        <div class="scen-row"><span>AI overhead</span><span>—</span></div>
        <div class="scen-row"><span>Setup time</span><span>n/a</span></div>
      </div>

      <div class="scenario" id="ai-scenario">
        <div class="scen-tag">AI-enabled</div>
        <div class="scen-name">Same team + AI</div>
        <div class="scen-output" id="ai-output">30</div>
        <div class="scen-output-label">pieces per month</div>
        <div class="scen-row"><span>Team size</span><span id="ai-team">5 FTE</span></div>
        <div class="scen-row"><span>Annual team cost</span><span id="ai-team-cost">$550K</span></div>
        <div class="scen-row"><span>AI cost (year 1)</span><span id="ai-cost">$8K</span></div>
        <div class="scen-row"><span>Cost per piece</span><span id="ai-per">$1,551</span></div>
        <div class="scen-row"><span>Setup time</span><span>4-6 weeks</span></div>
      </div>

      <div class="scenario" id="hire-scenario">
        <div class="scen-tag">Alternative</div>
        <div class="scen-name">Hire one more person</div>
        <div class="scen-output" id="hire-output">14</div>
        <div class="scen-output-label">pieces per month</div>
        <div class="scen-row"><span>Team size</span><span id="hire-team">6 FTE</span></div>
        <div class="scen-row"><span>Annual team cost</span><span id="hire-cost">$660K</span></div>
        <div class="scen-row"><span>Marginal cost</span><span id="hire-marginal">+$110K</span></div>
        <div class="scen-row"><span>Cost per piece</span><span id="hire-per">$3,929</span></div>
        <div class="scen-row"><span>Onboarding time</span><span>~90 days</span></div>
      </div>
    </div>

    <div class="verdict" id="verdict">
      <h3 id="verdict-h">AI is the clear win for this team</h3>
      <p id="verdict-p"></p>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">How the math works</span>
    <h2 class="h2">What\'s behind the calculation</h2>
    <p class="body"><strong style="color:#F0FFF0;">Current capacity</strong> uses your reported monthly output as baseline.</p>
    <p class="body"><strong style="color:#F0FFF0;">AI-enabled capacity</strong> applies a 2.5x multiplier (the typical lift from properly-implemented AI workflows: first-draft work compresses 4-5x while editorial work stays roughly the same, blending to ~2.5x overall output gain). AI cost assumes Claude Team ($30/seat × team size × 12 months) plus a one-time $3,500 implementation engagement.</p>
    <p class="body"><strong style="color:#F0FFF0;">Hire-one-more capacity</strong> applies a 1.15x output multiplier (a new mid-level hire produces about 15% of team output once ramped, accounting for coordination overhead and ramp time).</p>
    <p class="body">For the deeper version of why AI usually wins this comparison see <a href="/how-to-scale-marketing-without-hiring" style="color:#00C853;text-decoration:none;">how to scale marketing without hiring</a>.</p>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">Related</span>
    <h2 class="h2">Related resources</h2>
    <ul style="list-style:none;padding:0;color:#C0D8C0;font-size:0.95rem;line-height:1.85;">
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/ai-roi-calculator" style="color:#00C853;text-decoration:none;">AI ROI calculator →</a></li>
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-to-scale-marketing-without-hiring" style="color:#00C853;text-decoration:none;">How to scale marketing without hiring →</a></li>
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/why-is-my-marketing-team-so-slow" style="color:#00C853;text-decoration:none;">Why is my marketing team so slow? →</a></li>
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-to-use-claude-for-marketing" style="color:#00C853;text-decoration:none;">How to use Claude for marketing →</a></li>
      <li style="padding:0.5rem 0;"><a href="/claude-prompts-for-marketing" style="color:#00C853;text-decoration:none;">12 Claude prompts for marketing →</a></li>
    </ul>
  </div>
</section>

<section>
  <div class="sec-inner">
    <div class="cta-box">
      <div>
        <div class="cta-text">Want this set up for your team?</div>
        <div class="cta-sub">Implementation: $3,500 fixed. Typical capture is what the calculator above models.</div>
      </div>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/services/implementation" class="btn-p">See Implementation →</a>
        <a href="/services/ai-audit" class="btn-g">Start with an Audit</a>
      </div>
    </div>
  </div>
</section>

<GlobalFooter />

<script is:inline>
  (function() {
    function fmt(n) {
      if (n >= 1000000) return '$' + (n/1000000).toFixed(2) + 'M';
      if (n >= 1000) return '$' + Math.round(n/1000) + 'K';
      return '$' + Math.round(n);
    }

    var inputs = {
      team: document.getElementById('team'),
      output: document.getElementById('output'),
      salary: document.getElementById('salary'),
    };
    var labels = {
      team: document.getElementById('team-val'),
      output: document.getElementById('output-val'),
      salary: document.getElementById('salary-val'),
    };

    function recalc() {
      var team = parseInt(inputs.team.value, 10);
      var output = parseInt(inputs.output.value, 10);
      var salary = parseInt(inputs.salary.value, 10);

      labels.team.textContent = team;
      labels.output.textContent = output + ' pieces';
      labels.salary.textContent = '$' + Math.round(salary/1000) + 'K';

      // Current
      var currentCost = team * salary;
      var currentPerPiece = currentCost / (output * 12);

      // AI-enabled
      var aiMultiplier = 2.5;
      var aiOutput = Math.round(output * aiMultiplier);
      var aiCostYearOne = (team * 30 * 12) + 3500; // Claude Team + implementation
      var aiTotalAnnualCost = currentCost + aiCostYearOne;
      var aiPerPiece = aiTotalAnnualCost / (aiOutput * 12);

      // Hire one more
      var hireMultiplier = 1.15;
      var hireOutput = Math.round(output * hireMultiplier);
      var hireCost = (team + 1) * salary;
      var hireMarginal = hireCost - currentCost;
      var hirePerPiece = hireCost / (hireOutput * 12);

      // Update display
      document.getElementById('current-output').textContent = output;
      document.getElementById('current-team').textContent = team + ' FTE';
      document.getElementById('current-cost').textContent = fmt(currentCost);
      document.getElementById('current-per').textContent = fmt(currentPerPiece);

      document.getElementById('ai-output').textContent = aiOutput;
      document.getElementById('ai-team').textContent = team + ' FTE';
      document.getElementById('ai-team-cost').textContent = fmt(currentCost);
      document.getElementById('ai-cost').textContent = fmt(aiCostYearOne);
      document.getElementById('ai-per').textContent = fmt(aiPerPiece);

      document.getElementById('hire-output').textContent = hireOutput;
      document.getElementById('hire-team').textContent = (team + 1) + ' FTE';
      document.getElementById('hire-cost').textContent = fmt(hireCost);
      document.getElementById('hire-marginal').textContent = '+' + fmt(hireMarginal);
      document.getElementById('hire-per').textContent = fmt(hirePerPiece);

      // Determine winner (lowest cost per piece)
      var winner;
      if (aiPerPiece <= hirePerPiece && aiPerPiece <= currentPerPiece) winner = 'ai';
      else if (hirePerPiece < currentPerPiece) winner = 'hire';
      else winner = 'current';

      document.getElementById('ai-scenario').classList.remove('winner');
      document.getElementById('hire-scenario').classList.remove('winner');
      if (winner === 'ai') document.getElementById('ai-scenario').classList.add('winner');
      if (winner === 'hire') document.getElementById('hire-scenario').classList.add('winner');

      var verdictText;
      if (winner === 'ai') {
        var savings = (hireMarginal - aiCostYearOne);
        verdictText = 'AI deployment produces ' + aiOutput + ' pieces/month at ' + fmt(aiPerPiece) + ' per piece — vs. ' + fmt(hirePerPiece) + ' per piece if you hire one more person. AI adds ' + (aiOutput - output) + ' pieces of capacity (vs. ' + (hireOutput - output) + ' from a new hire) at ' + fmt(aiCostYearOne) + ' annual cost (vs. ' + fmt(hireMarginal) + ' for the hire). Net savings if you pick AI over hiring: ' + fmt(savings) + ' year one, plus dramatically more capacity.';
      } else {
        verdictText = 'In this configuration, hiring produces lower cost per piece than AI deployment. This is unusual — typically AI wins on the unit economics. Re-check the inputs: if your team is very small or current output is very low, the AI multiplier may not fully apply.';
      }
      document.getElementById('verdict-h').textContent = winner === 'ai' ? 'AI is the clear win for this team' : 'Hiring beats AI in this specific configuration';
      document.getElementById('verdict-p').textContent = verdictText;
    }

    Object.keys(inputs).forEach(function(k) { inputs[k].addEventListener('input', recalc); });
    recalc();
  })();
</script>

</body>
</html>
