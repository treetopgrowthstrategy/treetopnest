      "provider": {"@id": "https://treetopgrowthstrategy.com/#organization"},
      "areaServed": {"@type": "Country", "name": "United States"},
      "audience": {"@type": "Audience", "description": "B2B executives and small business owners"}
    },
    {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
  ]
}
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
    .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s; }
    .card-mid:hover { border-color: rgba(0,200,83,0.35); }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    @media(max-width:768px){ .mob-col{flex-direction:column!important} .hide-mob{display:none!important} section{padding:3.5rem 1.5rem} }

    /* Page-specific */
    .hero {
      min-height: 70vh;
      display: flex;
      align-items: center;
      padding-top: 7rem;
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 400;
      line-height: 1.08;
      color: #F0FFF0;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: 1.05rem;
      color: #8FAF8F;
      line-height: 1.75;
      max-width: 540px;
    }

    /* About Bill */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
    @media(max-width:768px){ .about-grid { grid-template-columns: 1fr; gap: 3rem; } }

    .about-para { font-size: 0.95rem; color: #8FAF8F; line-height: 1.8; margin-bottom: 1.25rem; }
    .about-para:last-child { margin-bottom: 0; }

    .cred-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    .cred-title { font-size: 0.78rem; font-weight: 600; color: #00C853; margin-bottom: 0.4rem; letter-spacing: 0.04em; }
    .cred-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.6; }

    /* Why Treetop */
    .statement-block {
      border-left: 3px solid rgba(0,200,83,0.4);
      padding-left: 1.5rem;
      margin-bottom: 2rem;
    }
    .statement-title {
      font-family: 'Instrument Serif', serif;
      font-size: 1.45rem;
      color: #F0FFF0;
      margin-bottom: 0.6rem;
      font-weight: 400;
    }
    .statement-body { font-size: 0.93rem; color: #8FAF8F; line-height: 1.75; }

    /* Services links */
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    @media(max-width:768px){ .services-grid { grid-template-columns: 1fr; } }

    .svc-card { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s; display: flex; flex-direction: column; gap: 0.75rem; text-decoration: none; }
    .svc-card:hover { border-color: rgba(0,200,83,0.35); }
    .svc-name { font-family: 'Instrument Serif', serif; font-size: 1.25rem; color: #F0FFF0; font-weight: 400; }
    .svc-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.6; flex: 1; }
    .svc-price { font-size: 0.78rem; color: #00C853; font-weight: 600; }
    .svc-arrow { font-size: 0.82rem; color: rgba(240,255,240,0.4); margin-top: 0.5rem; }

    /* Contact */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    @media(max-width:768px){ .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    @media(max-width:768px){ .form-row { grid-template-columns: 1fr; } }

    .form-field { margin-bottom: 1rem; }
    .form-label { display: block; font-size: 0.75rem; font-weight: 600; color: rgba(240,255,240,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.4rem; }

    .success-msg { display: none; background: rgba(0,200,83,0.08); border: 1px solid rgba(0,200,83,0.3); padding: 1.5rem; text-align: center; }
    .success-msg p { color: #00C853; font-size: 0.9rem; }

    .about-section { background: #0A1A0A; }
  </style>

<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebPage","url":"https://treetopgrowthstrategy.com/about","name":"About | Treetop","description":"Bill Colbert is the founder of Treetop Growth Strategy \u2014 a boutique AI implementation consultancy helping small businesses get real results from Claude.","isPartOf":{"@type":"WebSite","url":"https://treetopgrowthstrategy.com/","name":"Treetop Growth Strategy"},"publisher":{"@id":"https://treetopgrowthstrategy.com/#organization"},"inLanguage":"en-US"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://treetopgrowthstrategy.com/"},{"@type":"ListItem","position":2,"name":"About","item":"https://treetopgrowthstrategy.com/about"}]}</script>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<!-- Hero -->
<div class="hero">
  <div class="hero-inner">
    <div class="badge">
      <span class="badge-dot"></span>
      About Treetop
    </div>
    <h1 class="hero-h">
      Built by someone who<br/>
      <em style="color:#00C853;font-style:italic;">does the work.</em>
    </h1>
    <p class="hero-sub">
      Treetop Growth Strategy is a boutique AI implementation consultancy. We don't train. We implement. We build Claude workflows inside your business and prove they work before we leave.
    </p>
  </div>
</div>

<!-- About Bill -->
<section class="about-section">
  <div class="sec-inner">
    <div class="about-grid">
      <div>
        <img src="/img/bill-colbert.jpg" alt="Bill Colbert, founder of Treetop Growth Strategy" width="140" height="140" style="border-radius:50%;border:2px solid #1A3A1A;margin-bottom:1.5rem;" />
        <span class="lbl">Bill Colbert · Founder</span>
        <h2 class="h2">20 years building<br/>revenue systems.</h2>
        <p class="about-para">
          I've spent two decades in B2B sales, marketing, and revenue operations — building the systems that make businesses grow. Before founding Treetop, I was CMO at Factor_ (acquired by HelloFresh, INC 5000 in 2017 and 2018) and VP Sales & Marketing at amSTATZ (acquired by NASM in 2016). Since 2016, I've run Treetop as a fractional GTM / CMO practice, working with B2B SaaS, DTC, fitness, enterprise hardware, and PE-backed portfolio companies across more than a dozen named engagements.
        </p>
        <p class="about-para">
          The work I do now lives at the intersection of two things: senior marketing leadership for $2M–$50M companies that aren't ready for a full-time CMO, and AI-native operating systems that make modern marketing functions 1–2 FTE leaner than the 2020 norm. The two compound — that's the practice.
        </p>
        <p class="about-para">
          Treetop's smaller, gym-operator-focused content cluster exists because I co-founded <a href="https://fitagentic.ai" style="color:#00C853;">fitagentic.ai</a> — the AI agent platform for fitness operators — and I write about the operator problems I'm solving daily there. The fractional consulting practice and the platform sit alongside each other.
        </p>
      </div>

      <div class="cred-grid">
        <div class="card-mid">
          <div class="cred-title">CMO at Factor_</div>
          <div class="cred-desc">Acquired by HelloFresh. INC 5000 in 2017 + 2018. Scaled paid acquisition $0 → $4K+/day; CAC $129 → $64; 1,100% email revenue lift.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">VP at amSTATZ</div>
          <div class="cred-desc">Acquired by NASM in 2016. Took the B2B SaaS function from pre-concept to mid-six-figure ARR. Cut churn 11.7% → 3.9%.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">Hapana — 150 → 1,200+ locations</div>
          <div class="cred-desc">Six-year fractional Head of Marketing & GTM engagement. 800% revenue growth across NA / EMEA / APAC.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">EZO.io — RevOps + GTM systems</div>
          <div class="cred-desc">Ongoing fractional Revenue & Systems Lead. 100+ executive dashboards, +40% forecasting accuracy, +24% enterprise opps.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">Synchrony Financial</div>
          <div class="cred-desc">Cold LinkedIn pitch to an SVP → $200K enterprise lead-gen engagement → six-year client relationship.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">HubSpot Gold-tier · 47 deals closed</div>
          <div class="cred-desc">8-year HubSpot agency partner. $3.38M in attributed LTV. 65+ HubSpot accounts touched.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">Treetop Growth Strategy</div>
          <div class="cred-desc">Founded 2016. Fractional GTM/CMO + AI-native operating systems for $2M-$50M companies.</div>
        </div>
        <div class="card-mid">
          <div class="cred-title">Chicago, IL</div>
          <div class="cred-desc">Serving clients across North America remotely, with quarterly in-person sessions and additional travel as engagements require.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why Treetop -->
<section>
  <div class="sec-inner">
    <span class="lbl">Our approach</span>
    <h2 class="h2" style="max-width:560px;">We don't hand you<br/>a prompt sheet.</h2>
    <div style="max-width:720px;margin-top:3rem;">
      <div class="statement-block">
        <div class="statement-title">Implementation, not training.</div>
        <p class="statement-body">
          Trainers teach you what's possible. We build what's possible. There's a significant difference between knowing Claude can help and having Claude actually integrated into your daily workflows — doing real work, producing real output, saving real hours.
        </p>
      </div>
      <div class="statement-block">
        <div class="statement-title">Measured outcomes, not vibes.</div>
        <p class="statement-body">
          Every engagement starts with baselines and ends with data. Hours saved. Output volume. Quality metrics. You know exactly what the investment returned — not because we say so, but because you can see it in the numbers.
        </p>
      </div>
      <div class="statement-block">
        <div class="statement-title">Your business, not a template.</div>
        <p class="statement-body">
          We configure Claude with your brand voice, your product knowledge, your SOPs. The output sounds like you — not a generic AI that could belong to any company. Every system we build is specific to how your business actually operates.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Selected Treetop engagements -->
<section>
  <div class="sec-inner">
    <span class="lbl">Selected engagements</span>
    <h2 class="h2" style="max-width:680px;">A few of the named<br/>Treetop case studies.</h2>
    <p style="font-size:1rem;color:#C0D8C0;line-height:1.85;max-width:760px;margin:1.25rem 0 2rem;">Each links to a full case study with the engagement context, what we built, and the quantified outcomes. Published with client consent; specific revenue figures aggregated for confidentiality.</p>
    <ul style="list-style:none;padding:0;color:#C0D8C0;font-size:0.98rem;line-height:1.8;max-width:780px;">
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-factor-hellofresh-dtc-meal-kit-acquisition" style="color:#00C853;text-decoration:none;font-weight:500;">Factor_ (acquired by HelloFresh)</a> — fractional CMO during the hyper-growth year. 66% revenue growth in 6 months, INC 5000 ×2.</li>
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-hapana-fitness-saas-150-to-1200-locations" style="color:#00C853;text-decoration:none;font-weight:500;">Hapana — global fitness SaaS</a> — six-year fractional Head of Marketing & GTM. 150 → 1,200+ operator locations (800% growth) across NA / EMEA / APAC.</li>
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-ezo-io-enterprise-saas-revenue-systems" style="color:#00C853;text-decoration:none;font-weight:500;">EZO.io — enterprise SaaS revenue systems</a> — ongoing fractional Revenue & Systems Lead. 100+ executive dashboards, +40% forecasting accuracy, +24% enterprise opps.</li>
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-axle-workout-covid-pivot-dtc-400-percent-growth" style="color:#00C853;text-decoration:none;font-weight:500;">The Axle Workout — COVID B2B-to-DTC pivot</a> — 3-year CMRO engagement. 400% YoY revenue, Shopify CVR 0.45% → 1.27%, $400K virtual coaching ARR.</li>
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-stack-system-dtc-fitness-product-245-percent-growth" style="color:#00C853;text-decoration:none;font-weight:500;">The Stack System — DTC specialty product</a> — 12-month fractional engagement. 245% YoY revenue, 20-36x ROAS on Meta, 200% ROI evergreen influencer partnership.</li>
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-synchrony-financial-enterprise-lead-gen-200k-deal" style="color:#00C853;text-decoration:none;font-weight:500;">Synchrony Financial — enterprise lead-gen</a> — $200K custom engagement won via cold LinkedIn pitch. Six-year client relationship.</li>
      <li style="padding:0.85rem 0;border-bottom:1px solid #1A3A1A;"><a href="/case-study-connected-fitness-hardware-portfolio-b2b-gtm" style="color:#00C853;text-decoration:none;font-weight:500;">Connected fitness hardware portfolio</a> — cross-portfolio fractional GTM across Styku, Ecofit, Vertimax, Core Health & Fitness.</li>
    </ul>
    <p style="font-size:0.92rem;color:#8FAF8F;margin-top:1.5rem;"><a href="/case-studies" style="color:#00C853;">Browse all case studies &rarr;</a></p>
  </div>
</section>

<!-- Services Quick Links -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Work with Treetop</span>
    <h2 class="h2" style="margin-bottom:3rem;">Three ways to get started.</h2>
    <div class="services-grid">
      <a href="/fractional-cmo" class="svc-card">
        <div class="svc-name">Fractional CMO</div>
        <div class="svc-desc">AI-native fractional marketing leadership for $2M-$50M B2B SaaS, DTC, fitness operators, and PE-backed portfolios. 1-3 days/week, 9-18 month engagements.</div>
        <div class="svc-price">$8K-$25K/month</div>
        <div class="svc-arrow">Explore the service →</div>
      </a>
      <a href="/services" class="svc-card">
        <div class="svc-name">AI Implementation</div>
        <div class="svc-desc">Full-service implementation of AI agent workflows inside your marketing function — configured, trained, and measured. Audit + build packages available.</div>
        <div class="svc-price">Starting at $2,500</div>
        <div class="svc-arrow">Read more →</div>
      </a>
      <a href="/gym-startup-budget-workbook-pro" class="svc-card">
        <div class="svc-name">Gym Budget Workbook — PRO</div>
        <div class="svc-desc">The interactive 12-sheet editable spreadsheet version of the free /gym-startup-budget-workbook. Live formulas, scenario toggles, capital-stack builder. For aspiring gym operators.</div>
        <div class="svc-price">$99 — one-time</div>
        <div class="svc-arrow">Buy now →</div>
      </a>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact">
  <div class="sec-inner">
    <div class="contact-grid">
      <div>
        <span class="lbl">Get in Touch</span>
        <h2 class="h2">Let's talk about<br/>your business.</h2>
        <p class="body-text" style="margin-top:1rem;">
          Direct form — no Calendly friction, no intake form maze. Tell us what you're working on and we'll respond within a business day.
        </p>
        <p style="margin-top:2rem;font-size:0.85rem;color:#4A6A4A;">
          Or email directly:<br/>
          <a href="mailto:bill@treetopgrowthstrategy.com" style="color:#00C853;text-decoration:none;">bill@treetopgrowthstrategy.com</a>
        </p>
      </div>

      <div>
        <form id="contact-form">
          <div class="form-row">
            <div>
              <label class="form-label" for="first_name">First name</label>
              <input class="input-field" type="text" id="first_name" name="first_name" placeholder="Jane" required />
            </div>
            <div>
              <label class="form-label" for="last_name">Last name</label>
              <input class="input-field" type="text" id="last_name" name="last_name" placeholder="Smith" required />
            </div>
          </div>
          <div class="form-field">
            <label class="form-label" for="email">Email</label>
            <input class="input-field" type="email" id="email" name="email" placeholder="jane@company.com" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="company">Company</label>
            <input class="input-field" type="text" id="company" name="company" placeholder="Your company name" />
          </div>
          <div class="form-field">
            <label class="form-label" for="message">What are you trying to solve?</label>
            <textarea class="input-field" id="message" name="message" rows="5" placeholder="Tell us what's on your mind — the problem you're trying to solve, the workflows eating your time, or the team capacity you wish you had." required></textarea>
          </div>
          <button type="submit" class="btn-p" style="width:100%;justify-content:center;">
            Send message →
          </button>
        </form>

        <div class="success-msg" id="success-msg" style="margin-top:1rem;">
          <p>Message received. We'll be in touch within one business day. If you don't hear back, email <a href="mailto:bill@treetopgrowthstrategy.com" style="color:#00C853;">bill@treetopgrowthstrategy.com</a> directly.</p>
        </div>

        <div class="error-msg" id="error-msg" style="margin-top:1rem;display:none;background:rgba(255,180,0,0.08);border:1px solid rgba(255,180,0,0.35);padding:1.5rem;">
