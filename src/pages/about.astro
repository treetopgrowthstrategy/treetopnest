---
import GlobalFooter from '../components/GlobalFooter.astro';
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>About | Treetop</title>
  <meta name="description" content="Bill Colbert is the founder of Treetop Growth Strategy — a boutique AI implementation consultancy helping small businesses get real results from Claude." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/about" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/about" />
  <meta property="og:title" content="About | Treetop" />
  <meta property="og:description" content="Bill Colbert is the founder of Treetop Growth Strategy — a boutique AI implementation consultancy helping small businesses get real results from Claude." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og/about.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://treetopgrowthstrategy.com/og/about.png" />
  <meta name="twitter:title" content="About | Treetop" />
  <meta name="twitter:description" content="Bill Colbert is the founder of Treetop Growth Strategy — a boutique AI implementation consultancy helping small businesses get real results from Claude." />
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "About | Treetop",
