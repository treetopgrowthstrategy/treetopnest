---
import Layout from '../../layouts/Layout.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
---

<Layout
  title="Claude Implementation | Treetop Growth Strategy"
  description="End-to-end Claude implementation for your business. Custom workflows, team training, measured ROI. Starting at $3,500. Most engagements complete in 3–4 weeks."
  canonicalUrl="https://treetopgrowthstrategy.com/services/implementation"
  pageType="service"
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">Treetop</a>
      <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
        <a href="/services" class="nav-link">Services</a>
        <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
        <a href="/about" class="nav-link">About</a>
      </div>
      <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Start the Conversation</a>
    </div>
  </nav>

  <!-- Hero -->
  <section style="min-height:70vh;display:flex;align-items:center;padding-top:7rem;padding-bottom:4rem;">
    <div class="section-inner" style="max-width:820px;">
      <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:1.5rem;">
        <a href="/services" style="font-size:0.8rem;color:#4A6A4A;text-decoration:none;">Services</a>
        <span style="color:#1A3A1A;font-size:0.8rem;">/</span>
        <span style="font-size:0.8rem;color:#8FAF8F;">Claude Implementation</span>
      </div>
      <span class="lbl">Claude Implementation</span>
      <h1 class="h2" style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2.5rem,5vw,3.75rem);margin-bottom:1.5rem;">
        Claude, implemented.<br/><em style="color:#00C853">Results, measured.</em>
      </h1>
      <p class="body-text" style="font-size:1.05rem;max-width:560px;margin-bottom:2rem;">
        We don't hand you a roadmap and walk away. We build the workflows, train your team, and set up the measurement framework so you know exactly what AI is saving you.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;margin-bottom:1.5rem;">
        <a href="#contact" class="btn-p">Get a quote →</a>
        <a href="/services" class="btn-g">All services</a>
      </div>
      <p style="font-size:0.85rem;color:#4A6A4A;letter-spacing:0.03em;">Starting at $3,500 · 3–4 weeks · Fixed price</p>
    </div>
  </section>

  <!-- Deliverables -->
  <section style="padding-top:0;padding-bottom:5rem;border-top:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">What's Included</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:3rem;">Six deliverables. Every engagement.</h2>

      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { n: '01', title: 'AI Audit (included)', desc: 'Every Implementation starts with a full Audit — process mapping, opportunity ranking, and strategic roadmap — so we build the right things.' },
          { n: '02', title: 'Custom Claude Workflows', desc: 'We build the specific Claude-powered workflows identified in your Audit. Each workflow is documented, tested, and handed off with instructions.' },
          { n: '03', title: 'Prompt Library', desc: 'A curated library of tested prompts for your most common tasks, organized by use case and ready to use immediately.' },
          { n: '04', title: 'Playbooks & SOPs', desc: 'Updated standard operating procedures that incorporate your new AI workflows so your team knows exactly what to do.' },
          { n: '05', title: 'Team Training Session', desc: 'A live session (up to 2 hours) walking your team through every workflow, how to use the prompt library, and how to prompt Claude effectively.' },
          { n: '06', title: 'ROI Measurement Framework', desc: 'A simple tracking system so you can measure time saved, output quality, and business impact — and report results to stakeholders.' },
        ].map(({ n, title, desc }) => (
          <div style="display:flex;gap:0;border-top:1px solid #1A3A1A;padding:2rem 0;align-items:stretch;">
            <div style="width:3px;background:rgba(0,200,83,0.4);flex-shrink:0;align-self:stretch;margin-right:2rem;"></div>
            <div style="display:flex;gap:2rem;flex:1;flex-wrap:wrap;">
              <div style="font-family:'Instrument Serif',serif;font-size:1.5rem;color:rgba(0,200,83,0.4);flex-shrink:0;width:2rem;">{n}</div>
              <div style="flex:1;min-width:200px;">
                <div class="h3" style="margin-bottom:0.5rem;">{title}</div>
                <p class="body-text">{desc}</p>
              </div>
            </div>
          </div>
        ))}
        <div style="border-top:1px solid #1A3A1A;"></div>
      </div>
    </div>
  </section>

  <!-- Scope tiers -->
  <section style="padding:5rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">Pricing</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">Three scope tiers.</h2>
      <div style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:stretch;" class="mob-col">

        <div style="flex:1;min-width:240px;background:#050D05;border:1px solid #1A3A1A;padding:2rem;display:flex;flex-direction:column;gap:1rem;">
          <div>
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#8FAF8F;margin-bottom:0.5rem;">Focused</div>
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#F0FFF0;">$3,500</div>
          </div>
          <p class="body-text" style="font-size:0.88rem;">1–2 core workflows. Best for solo operators or small teams with one clear pain point.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;flex:1;">
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Full Audit included</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 1–2 custom workflows</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Prompt library (focused)</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 1-hour team training</li>
          </ul>
          <a href="#contact" class="btn-g" style="text-align:center;justify-content:center;margin-top:auto;">Get a quote</a>
        </div>

        <div style="flex:1;min-width:240px;background:#050D05;border:1px solid #00C853;padding:2rem;display:flex;flex-direction:column;gap:1rem;position:relative;">
          <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#00C853;color:#050D05;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;padding:0.3rem 1rem;text-transform:uppercase;white-space:nowrap;">Most Popular</div>
          <div style="margin-top:0.75rem;">
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#00C853;margin-bottom:0.5rem;">Standard</div>
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#F0FFF0;">$5,500</div>
          </div>
          <p class="body-text" style="font-size:0.88rem;">3–5 workflows across your core operations. Right for most small business teams.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;flex:1;">
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Full Audit included</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 3–5 custom workflows</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Full prompt library</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Updated SOPs</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 2-hour team training</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> ROI measurement setup</li>
          </ul>
          <a href="#contact" class="btn-p" style="text-align:center;justify-content:center;margin-top:auto;">Get a quote</a>
        </div>

        <div style="flex:1;min-width:240px;background:#050D05;border:1px solid #1A3A1A;padding:2rem;display:flex;flex-direction:column;gap:1rem;">
          <div>
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#8FAF8F;margin-bottom:0.5rem;">Full</div>
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#F0FFF0;">$8,500</div>
          </div>
          <p class="body-text" style="font-size:0.88rem;">6+ workflows, multi-department rollout. Best for teams ready to transform operations at scale.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;flex:1;">
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Everything in Standard</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 6+ custom workflows</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Multi-department training</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 30-day post-launch support</li>
          </ul>
          <a href="#contact" class="btn-g" style="text-align:center;justify-content:center;margin-top:auto;">Get a quote</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Week-by-week process -->
  <section style="padding:5rem 2.5rem;">
    <div class="section-inner">
      <span class="lbl">The Process</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:3rem;">Four weeks, end to end.</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;">
        {[
          { week: 'Week 1', title: 'Audit & Discovery', desc: 'Kickoff call, process mapping, AI opportunity analysis, and roadmap finalization. You get the Audit deliverable at end of week.' },
          { week: 'Week 2', title: 'Build', desc: 'We build your priority workflows, write the prompt library, and draft updated SOPs. Daily check-ins available.' },
          { week: 'Week 3', title: 'Test & Refine', desc: 'Workflows are tested against real business scenarios. We refine based on your feedback and edge cases.' },
          { week: 'Week 4', title: 'Train & Hand Off', desc: 'Team training session, final documentation, ROI measurement setup, and go-live. 30-day check-in scheduled.' },
        ].map(({ week, title, desc }) => (
          <div style="background:#0A1A0A;border:1px solid #1A3A1A;padding:1.75rem;">
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;">{week}</div>
            <div class="h3" style="margin-bottom:0.5rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Differentiators -->
  <section style="padding:5rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">Why Treetop</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">What makes this different.</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;">
        {[
          { title: 'Fixed price, always', desc: "You get a quote before work starts. No hourly billing, no scope creep invoices, no surprises. The price we agree on is the price you pay." },
          { title: 'We build it with you', desc: "We don't hand off a strategy deck and leave. We build the actual workflows in your actual tools with your actual team's input." },
          { title: 'Measured results', desc: "Every engagement includes ROI tracking setup. You'll know exactly how many hours AI saved in month one, and be able to show it." },
          { title: 'We know Claude cold', desc: "We work exclusively with Anthropic's Claude — not generic AI consulting. We know its limits, strengths, and how to prompt it for consistent business results." },
        ].map(({ title, desc }) => (
          <div class="card-mid">
            <div class="h3" style="font-size:1rem;margin-bottom:0.6rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Right for you if -->
  <section style="padding:5rem 2.5rem;">
    <div class="section-inner">
      <span class="lbl">Is This Right for You?</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">Claude Implementation is right for you if…</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;">
        {[
          { title: "You know AI can help — you just haven't done it yet", desc: "You've used ChatGPT a bit, you've thought about what to do with AI, but nothing systematic has been built. This changes that." },
          { title: "You're ready to invest in the outcome", desc: "You're not looking for a course or a template. You want something built for your specific business, handed off ready to use." },
          { title: "Your team needs to be on board", desc: "You want AI adopted company-wide, not just by you. Team training and documented playbooks make that happen." },
          { title: "You want to measure what you build", desc: "You need to be able to show leadership (or yourself) that this investment paid off. The ROI framework makes that possible." },
        ].map(({ title, desc }) => (
          <div class="card-mid">
            <div class="h3" style="font-size:1rem;margin-bottom:0.6rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section id="contact" style="padding:5rem 2.5rem;background:#050D05;border-top:1px solid #1A3A1A;">
    <div class="section-inner" style="max-width:680px;margin:0 auto;">
      <span class="lbl">Get a Quote</span>
      <h2 class="h2" style="margin-bottom:0.75rem;">Let's build something.</h2>
      <p class="body-text" style="margin-bottom:2.5rem;">Tell us about your business and we'll put together a custom scope and fixed price within two business days.</p>

      <form id="impl-form" style="display:flex;flex-direction:column;gap:1rem;">
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <input class="input-field" type="text" name="first_name" placeholder="First name" required style="flex:1;min-width:200px;" />
          <input class="input-field" type="text" name="last_name" placeholder="Last name" style="flex:1;min-width:200px;" />
        </div>
        <input class="input-field" type="email" name="email" placeholder="Email address" required />
        <input class="input-field" type="text" name="company" placeholder="Company name" />
        <select class="input-field" name="team_size" style="cursor:pointer;">
          <option value="" disabled selected>Team size</option>
          <option value="Solo">Solo / just me</option>
          <option value="2–5">2–5 people</option>
          <option value="6–15">6–15 people</option>
          <option value="16–50">16–50 people</option>
          <option value="50+">50+ people</option>
        </select>
        <select class="input-field" name="gain" style="cursor:pointer;">
          <option value="" disabled selected>Which scope tier interests you?</option>
          <option value="Focused ($3,500)">Focused — $3,500 (1–2 workflows)</option>
          <option value="Standard ($5,500)">Standard — $5,500 (3–5 workflows)</option>
          <option value="Full ($8,500)">Full — $8,500 (6+ workflows)</option>
          <option value="Not sure yet">Not sure yet — help me figure it out</option>
        </select>
        <textarea class="input-field" name="message" rows="4" placeholder="Tell us about your business and what you want to automate or improve."></textarea>
        <div id="form-error" style="display:none;color:#ff6b6b;font-size:0.85rem;"></div>
        <button type="submit" class="btn-p" id="submit-btn" style="align-self:flex-start;">Get a quote →</button>
      </form>

      <div id="form-success" style="display:none;padding:2rem;background:#0A1A0A;border:1px solid rgba(0,200,83,0.4);margin-top:1rem;">
        <p style="color:#00C853;font-weight:600;margin-bottom:0.5rem;">Got it — thanks!</p>
        <p class="body-text">We'll put together a custom scope and get back to you within two business days.</p>
      </div>
    </div>
  </section>

  <GlobalFooter />
</Layout>

<script>
  const form = document.getElementById('impl-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending…';
    btn.disabled = true;
    errorEl.style.display = 'none';

    const data = Object.fromEntries(new FormData(form).entries());
    const payload = {
      first_name: data.first_name,
      last_name: data.last_name,
      email: data.email,
      company: data.company,
      team_size: data.team_size,
      gain: `Scope: ${data.gain || ''}. Notes: ${data.message || ''}`,
      source: 'implementation',
    };

    try {
      const res = await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'block';
      } else throw new Error();
    } catch {
      errorEl.textContent = 'Something went wrong. Please email us at bill@treetopgrowthstrategy.com.';
      errorEl.style.display = 'block';
      btn.textContent = 'Get a quote →';
      btn.disabled = false;
    }
  });
</script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
  .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
  .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: #F0FFF0; }
  .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; white-space: nowrap; }
  .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s, background 0.2s; cursor: pointer; }
  .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
  .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s, background 0.2s; }
  .card-mid:hover { border-color: rgba(0,200,83,0.35); background: #0f200f; }
  section { padding: 5rem 2.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
  .h3 { font-size: 1.1rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.75rem; }
  .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
  .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
  .input-field:focus { border-color: rgba(0,200,83,0.5); }
  .input-field::placeholder { color: #4A6A4A; }
  @media (max-width: 768px) { .mob-col { flex-direction: column !important; } .hide-mob { display: none !important; } section { padding: 3.5rem 1.5rem; } }
</style>
