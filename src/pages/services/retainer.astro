---
import Layout from '../../layouts/Layout.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
---

<Layout
  title="Monthly Retainer | Treetop Growth Strategy"
  description="The Treetop Monthly Retainer keeps your Claude implementation current and expanding. New workflows, optimization, and priority support. Starting at $1,200/mo."
  canonicalUrl="https://treetopgrowthstrategy.com/services/retainer"
  pageType="service"
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">Treetop</a>
      <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
        <a href="/services" class="nav-link">Services</a>
        <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
        <a href="/about" class="nav-link">About</a>
      </div>
      <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Start the Conversation</a>
    </div>
  </nav>

  <!-- Hero -->
  <section style="min-height:70vh;display:flex;align-items:center;padding-top:7rem;padding-bottom:4rem;">
    <div class="section-inner" style="max-width:820px;">
      <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:1.5rem;">
        <a href="/services" style="font-size:0.8rem;color:#4A6A4A;text-decoration:none;">Services</a>
        <span style="color:#1A3A1A;font-size:0.8rem;">/</span>
        <span style="font-size:0.8rem;color:#8FAF8F;">Monthly Retainer</span>
      </div>
      <span class="lbl">Monthly Retainer</span>
      <h1 class="h2" style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2.5rem,5vw,3.75rem);margin-bottom:1.5rem;">
        Claude that keeps getting<br/><em style="color:#00C853">better every month.</em>
      </h1>
      <p class="body-text" style="font-size:1.05rem;max-width:560px;margin-bottom:2rem;">
        Your business changes. Your Claude implementation should too. The retainer keeps everything current, adds new workflows as you grow, and gives you a partner to think through what comes next.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;margin-bottom:1.5rem;">
        <a href="#contact" class="btn-p">Start the conversation →</a>
        <a href="/services" class="btn-g">All services</a>
      </div>
      <p style="font-size:0.85rem;color:#4A6A4A;letter-spacing:0.03em;">Starting at $1,200/mo · Month-to-month · Cancel anytime</p>
    </div>
  </section>

  <!-- Monthly deliverables -->
  <section style="padding-top:0;padding-bottom:5rem;border-top:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">What You Get Each Month</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:3rem;">Five things, every month.</h2>

      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { n: '01', title: 'New Workflow Build', desc: 'Each month we build at least one new Claude workflow for your business — a new use case, a new department, or a new tool integration.' },
          { n: '02', title: 'Prompt Optimization', desc: 'Existing prompts tuned based on what you\'ve learned using them. Edge cases handled. Output quality improved. Your library gets better every month.' },
          { n: '03', title: 'Monthly Strategy Call', desc: 'A 45-minute call to review what\'s working, what to build next, and how to think about AI as your business evolves.' },
          { n: '04', title: 'Async Support', desc: 'Questions answered via Slack or email, typically same day. Use us as a resource whenever you hit something you can\'t figure out.' },
          { n: '05', title: 'Priority Response Time', desc: 'Retainer clients move to the front of the queue. New workflow requests are scoped and started within the same week.' },
        ].map(({ n, title, desc }) => (
          <div style="display:flex;gap:0;border-top:1px solid #1A3A1A;padding:2rem 0;align-items:stretch;">
            <div style="width:3px;background:rgba(0,200,83,0.4);flex-shrink:0;align-self:stretch;margin-right:2rem;"></div>
            <div style="display:flex;gap:2rem;flex:1;flex-wrap:wrap;">
              <div style="font-family:'Instrument Serif',serif;font-size:1.5rem;color:rgba(0,200,83,0.4);flex-shrink:0;width:2rem;">{n}</div>
              <div style="flex:1;min-width:200px;">
                <div class="h3" style="margin-bottom:0.5rem;">{title}</div>
                <p class="body-text">{desc}</p>
              </div>
            </div>
          </div>
        ))}
        <div style="border-top:1px solid #1A3A1A;"></div>
      </div>
    </div>
  </section>

  <!-- Right for you if -->
  <section style="padding:5rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">Is This Right for You?</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">The retainer is right for you if…</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;">
        {[
          { title: "You've already implemented Claude and want to keep going", desc: "You have working workflows and want to expand them, add new use cases, and keep your implementation ahead of your business growth." },
          { title: "You want a dedicated AI partner, not just a vendor", desc: "You're making AI decisions every month and want someone who knows your business deeply to think through them with you." },
          { title: "Your prompts need tuning and you don't have time to do it", desc: "You know the outputs could be better, but optimizing prompts isn't how you want to spend your time." },
          { title: "You want support when you need it, not just when you schedule it", desc: "Async access means when you hit something confusing or want a second opinion, you can ask without waiting for the next call." },
        ].map(({ title, desc }) => (
          <div class="card-mid">
            <div class="h3" style="font-size:1rem;margin-bottom:0.6rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What this isn't -->
  <section style="padding:5rem 2.5rem;">
    <div class="section-inner">
      <span class="lbl">What This Isn't</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">Let's be direct.</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
        {[
          { title: "Not a coaching program", desc: "We're not teaching you how to use AI — we're using it for you. Every month you get built deliverables, not lessons about building them." },
          { title: "Not a software subscription", desc: "You're paying for expert time and custom work, not a SaaS tool. Everything built is yours, documented, and works independently of us." },
          { title: "Not a long-term commitment", desc: "Month-to-month means you can cancel anytime. We'd rather earn your retention every month than lock you into a contract." },
        ].map(({ title, desc }) => (
          <div style="background:#050D05;border:1px solid #1A3A1A;padding:2rem;">
            <div style="font-size:1.25rem;margin-bottom:0.75rem;color:rgba(240,255,240,0.2);">×</div>
            <div class="h3" style="font-size:1rem;margin-bottom:0.6rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing tiers -->
  <section style="padding:5rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">Pricing</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">Two tiers. No surprises.</h2>
      <div style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:stretch;max-width:800px;" class="mob-col">

        <div style="flex:1;min-width:260px;background:#050D05;border:1px solid #1A3A1A;padding:2rem;display:flex;flex-direction:column;gap:1rem;">
          <div>
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#8FAF8F;margin-bottom:0.5rem;">Core</div>
            <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#F0FFF0;">$1,200<span style="font-size:1.25rem;color:#4A6A4A;">/mo</span></div>
          </div>
          <p class="body-text" style="font-size:0.88rem;">For small teams with an established implementation who want steady progress and support.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;flex:1;">
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 1 new workflow/month</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Prompt optimization</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Monthly strategy call (45 min)</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Async support (email)</li>
          </ul>
          <a href="#contact" class="btn-g" style="text-align:center;justify-content:center;margin-top:auto;">Get started</a>
        </div>

        <div style="flex:1;min-width:260px;background:#050D05;border:1px solid #00C853;padding:2rem;display:flex;flex-direction:column;gap:1rem;position:relative;">
          <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#00C853;color:#050D05;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;padding:0.3rem 1rem;text-transform:uppercase;white-space:nowrap;">Most Popular</div>
          <div style="margin-top:0.75rem;">
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#00C853;margin-bottom:0.5rem;">Growth</div>
            <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#F0FFF0;">$2,000<span style="font-size:1.25rem;color:#4A6A4A;">/mo</span></div>
          </div>
          <p class="body-text" style="font-size:0.88rem;">For growing teams who want more workflows, faster execution, and deeper strategic involvement.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;flex:1;">
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> 2–3 new workflows/month</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Deep prompt optimization</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Monthly strategy call (60 min)</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Async support (Slack + email)</li>
            <li style="font-size:0.85rem;color:#8FAF8F;display:flex;gap:0.5rem;"><span style="color:#00C853;">✓</span> Priority same-week start on requests</li>
          </ul>
          <a href="#contact" class="btn-p" style="text-align:center;justify-content:center;margin-top:auto;">Get started</a>
        </div>

      </div>
    </div>
  </section>

  <!-- How to start -->
  <section style="padding:5rem 2.5rem;">
    <div class="section-inner">
      <span class="lbl">How to Get Started</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:3rem;">Three steps.</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;">
        {[
          { step: '1', title: 'Fill out the form below', desc: 'Tell us where you are with Claude right now and what you want to accomplish. Takes 2 minutes.' },
          { step: '2', title: 'Discovery call (30 min)', desc: 'We confirm the right tier, agree on month-one priorities, and set up shared communication channels.' },
          { step: '3', title: 'Month one begins', desc: 'We start building immediately. By end of week one you\'ll have your first deliverable underway.' },
        ].map(({ step, title, desc }) => (
          <div style="background:#0A1A0A;border:1px solid #1A3A1A;padding:2rem;">
            <div style="font-family:'Instrument Serif',serif;font-size:3rem;font-style:italic;color:rgba(0,200,83,0.25);line-height:1;margin-bottom:1rem;">{step}</div>
            <div class="h3" style="margin-bottom:0.5rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section id="contact" style="padding:5rem 2.5rem;background:#050D05;border-top:1px solid #1A3A1A;">
    <div class="section-inner" style="max-width:680px;margin:0 auto;">
      <span class="lbl">Get Started</span>
      <h2 class="h2" style="margin-bottom:0.75rem;">Start the conversation.</h2>
      <p class="body-text" style="margin-bottom:2.5rem;">Tell us where you are with Claude and we'll schedule a quick call to figure out the right tier and month-one focus.</p>

      <form id="retainer-form" style="display:flex;flex-direction:column;gap:1rem;">
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <input class="input-field" type="text" name="first_name" placeholder="First name" required style="flex:1;min-width:200px;" />
          <input class="input-field" type="text" name="last_name" placeholder="Last name" style="flex:1;min-width:200px;" />
        </div>
        <input class="input-field" type="email" name="email" placeholder="Email address" required />
        <input class="input-field" type="text" name="company" placeholder="Company name" />
        <textarea class="input-field" name="context" rows="4" placeholder="Where are you with Claude right now? (Existing workflows? Just getting started? What do you want to build next?)"></textarea>
        <select class="input-field" name="gain" style="cursor:pointer;">
          <option value="" disabled selected>Which tier interests you?</option>
          <option value="Core ($1,200/mo)">Core — $1,200/mo</option>
          <option value="Growth ($2,000/mo)">Growth — $2,000/mo</option>
          <option value="Not sure yet">Not sure yet — help me figure it out</option>
        </select>
        <div id="form-error" style="display:none;color:#ff6b6b;font-size:0.85rem;"></div>
        <button type="submit" class="btn-p" id="submit-btn" style="align-self:flex-start;">Start the conversation →</button>
      </form>

      <div id="form-success" style="display:none;padding:2rem;background:#0A1A0A;border:1px solid rgba(0,200,83,0.4);margin-top:1rem;">
        <p style="color:#00C853;font-weight:600;margin-bottom:0.5rem;">We got it — thanks!</p>
        <p class="body-text">We'll reach out within one business day to schedule a quick discovery call.</p>
      </div>
    </div>
  </section>

  <GlobalFooter />
</Layout>

<script>
  const form = document.getElementById('retainer-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending…';
    btn.disabled = true;
    errorEl.style.display = 'none';

    const data = Object.fromEntries(new FormData(form).entries());
    const payload = {
      first_name: data.first_name,
      last_name: data.last_name,
      email: data.email,
      company: data.company,
      team_size: '',
      gain: `Tier: ${data.gain || ''}. Context: ${data.context || ''}`,
      source: 'retainer',
    };

    try {
      const res = await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'block';
      } else throw new Error();
    } catch {
      errorEl.textContent = 'Something went wrong. Please email us at bill@treetopgrowthstrategy.com.';
      errorEl.style.display = 'block';
      btn.textContent = 'Start the conversation →';
      btn.disabled = false;
    }
  });
</script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
  .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
  .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: #F0FFF0; }
  .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; white-space: nowrap; }
  .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s, background 0.2s; cursor: pointer; }
  .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
  .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s, background 0.2s; }
  .card-mid:hover { border-color: rgba(0,200,83,0.35); background: #0f200f; }
  section { padding: 5rem 2.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
  .h3 { font-size: 1.1rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.75rem; }
  .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
  .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
  .input-field:focus { border-color: rgba(0,200,83,0.5); }
  .input-field::placeholder { color: #4A6A4A; }
  @media (max-width: 768px) { .mob-col { flex-direction: column !important; } .hide-mob { display: none !important; } section { padding: 3.5rem 1.5rem; } }
</style>
