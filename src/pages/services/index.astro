---
import Layout from '../../layouts/Layout.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
---

<Layout
  title="Services | Treetop Growth Strategy"
  description="Three ways to work with Treetop — AI Audit, Claude Implementation, and Monthly Retainer. Fixed scopes, clear outcomes, starting prices shown."
  canonicalUrl="https://treetopgrowthstrategy.com/services"
  pageType="service"
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">Treetop</a>
      <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
        <a href="/services" class="nav-link">Services</a>
        <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
        <a href="/about" class="nav-link">About</a>
      </div>
      <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Start the Conversation</a>
    </div>
  </nav>

  <!-- Hero -->
  <section style="min-height:60vh;display:flex;align-items:center;padding-top:6rem;padding-bottom:4rem;">
    <div class="section-inner" style="text-align:center;max-width:760px;margin:0 auto;">
      <span class="lbl">How We Work Together</span>
      <h1 class="h2" style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2.5rem,5vw,3.75rem);margin-bottom:1.5rem;">
        Three ways to work<br/><em style="color:#00C853">with Treetop.</em>
      </h1>
      <p class="body-text" style="font-size:1.05rem;max-width:540px;margin:0 auto;">
        Fixed scopes. Defined outcomes. Pricing you know before we start. No hourly billing, no scope creep.
      </p>
    </div>
  </section>

  <!-- Packages -->
  <section style="padding-top:0;padding-bottom:5rem;">
    <div class="section-inner">
      <div style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:stretch;" class="mob-col">

        <!-- Card 1: AI Audit -->
        <div style="flex:1;min-width:280px;background:#0A1A0A;border:1px solid #1A3A1A;padding:2.5rem;display:flex;flex-direction:column;gap:1.25rem;transition:border-color 0.2s;">
          <div>
            <div class="badge" style="margin-bottom:1rem;"><span class="badge-dot"></span> Start Here</div>
            <div style="font-family:'Instrument Serif',serif;font-size:1.75rem;font-style:italic;color:#F0FFF0;margin-bottom:0.5rem;">AI Audit</div>
            <div style="font-size:1.5rem;font-weight:600;color:#00C853;margin-bottom:0.75rem;">Starting at $1,500</div>
            <p class="body-text" style="font-size:0.9rem;">A one-week deep dive into your business to find your highest-leverage AI opportunities.</p>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem;flex:1;">
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Business process mapping</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> AI opportunity identification</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Prioritized roadmap (quick wins first)</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Tool and workflow recommendations</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> 60-min readout call + Q&A</li>
          </ul>
          <div style="font-size:0.8rem;color:#4A6A4A;margin-top:0.25rem;">Timeline: 1 week</div>
          <a href="/services/ai-audit" class="btn-g" style="text-align:center;justify-content:center;">Learn more →</a>
        </div>

        <!-- Card 2: Implementation (dominant) -->
        <div style="flex:1;min-width:280px;background:#0A1A0A;border:1px solid #00C853;padding:2.5rem;display:flex;flex-direction:column;gap:1.25rem;position:relative;">
          <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#00C853;color:#050D05;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;padding:0.3rem 1rem;text-transform:uppercase;">Most Popular</div>
          <div style="margin-top:1rem;">
            <div style="font-family:'Instrument Serif',serif;font-size:1.75rem;font-style:italic;color:#F0FFF0;margin-bottom:0.5rem;">Claude Implementation</div>
            <div style="font-size:1.5rem;font-weight:600;color:#00C853;margin-bottom:0.75rem;">Starting at $3,500</div>
            <p class="body-text" style="font-size:0.9rem;">End-to-end Claude implementation — custom workflows built, tested, and handed off with your team trained on them.</p>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem;flex:1;">
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Everything in the AI Audit</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Custom Claude workflow builds</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Prompt library + playbooks</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Team training session</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> ROI measurement framework</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> 30-day post-launch check-in</li>
          </ul>
          <div style="font-size:0.8rem;color:#4A6A4A;margin-top:0.25rem;">Timeline: 3–4 weeks</div>
          <a href="/services/implementation" class="btn-p" style="text-align:center;justify-content:center;">Learn more →</a>
        </div>

        <!-- Card 3: Retainer -->
        <div style="flex:1;min-width:280px;background:#0A1A0A;border:1px solid #1A3A1A;padding:2.5rem;display:flex;flex-direction:column;gap:1.25rem;transition:border-color 0.2s;">
          <div>
            <div class="badge" style="margin-bottom:1rem;"><span class="badge-dot"></span> Ongoing</div>
            <div style="font-family:'Instrument Serif',serif;font-size:1.75rem;font-style:italic;color:#F0FFF0;margin-bottom:0.5rem;">Monthly Retainer</div>
            <div style="font-size:1.5rem;font-weight:600;color:#00C853;margin-bottom:0.75rem;">Starting at $1,200/mo</div>
            <p class="body-text" style="font-size:0.9rem;">Keep your implementation current and expanding with new workflows, optimization, and priority support each month.</p>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem;flex:1;">
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Monthly workflow additions</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Prompt optimization + tuning</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Async support (Slack / email)</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Monthly strategy call</li>
            <li style="font-size:0.88rem;color:#8FAF8F;display:flex;gap:0.6rem;"><span style="color:#00C853;flex-shrink:0;">✓</span> Priority response time</li>
          </ul>
          <div style="font-size:0.8rem;color:#4A6A4A;margin-top:0.25rem;">Timeline: Month-to-month</div>
          <a href="/services/retainer" class="btn-g" style="text-align:center;justify-content:center;">Learn more →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Not sure where to start -->
  <section style="padding:4rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner" style="display:flex;align-items:center;justify-content:space-between;gap:3rem;flex-wrap:wrap;">
      <div style="max-width:520px;">
        <span class="lbl">Where to Begin</span>
        <h2 class="h2" style="font-size:clamp(1.5rem,3vw,2rem);margin-bottom:1rem;">Not sure where to start?</h2>
        <p class="body-text">Most clients begin with the AI Audit. It maps your business, identifies the best opportunities, and gives you a clear roadmap — and the $1,500 fee is fully credited toward any Implementation engagement.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;min-width:220px;">
        <a href="/services/ai-audit" class="btn-p">Start with the Audit →</a>
        <a href="#contact" class="btn-g">Book a discovery call</a>
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section id="contact" style="padding:5rem 2.5rem;background:#050D05;border-top:1px solid #1A3A1A;">
    <div class="section-inner" style="max-width:680px;margin:0 auto;">
      <span class="lbl">Get Started</span>
      <h2 class="h2" style="margin-bottom:0.75rem;">Book a discovery call.</h2>
      <p class="body-text" style="margin-bottom:2.5rem;">Tell us a bit about your business and what you're hoping to solve. We'll respond within one business day.</p>

      <form id="services-form" style="display:flex;flex-direction:column;gap:1rem;">
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <input class="input-field" type="text" name="first_name" placeholder="First name" required style="flex:1;min-width:200px;" />
          <input class="input-field" type="text" name="last_name" placeholder="Last name" style="flex:1;min-width:200px;" />
        </div>
        <input class="input-field" type="email" name="email" placeholder="Email address" required />
        <input class="input-field" type="text" name="company" placeholder="Company name" />
        <select class="input-field" name="gain" style="cursor:pointer;">
          <option value="" disabled selected>Which service interests you?</option>
          <option value="AI Audit">AI Audit — $1,500</option>
          <option value="Claude Implementation">Claude Implementation — from $3,500</option>
          <option value="Monthly Retainer">Monthly Retainer — from $1,200/mo</option>
          <option value="Not sure">Not sure yet</option>
        </select>
        <textarea class="input-field" name="message" rows="4" placeholder="Tell us about your business and what you're hoping to solve."></textarea>
        <div id="form-error" style="display:none;color:#ff6b6b;font-size:0.85rem;"></div>
        <button type="submit" class="btn-p" id="submit-btn" style="align-self:flex-start;">Book my call →</button>
      </form>

      <div id="form-success" style="display:none;padding:2rem;background:#0A1A0A;border:1px solid rgba(0,200,83,0.4);margin-top:1rem;">
        <p style="color:#00C853;font-weight:600;margin-bottom:0.5rem;">We got it — thanks!</p>
        <p class="body-text">We'll be in touch within one business day.</p>
      </div>
    </div>
  </section>

  <GlobalFooter />
</Layout>

<script>
  const form = document.getElementById('services-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending…';
    btn.disabled = true;
    errorEl.style.display = 'none';

    const data = Object.fromEntries(new FormData(form).entries());
    const payload = {
      first_name: data.first_name,
      last_name: data.last_name,
      email: data.email,
      company: data.company,
      gain: data.gain,
      team_size: '',
      source: 'services-hub',
    };

    try {
      const res = await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'block';
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorEl.textContent = 'Something went wrong. Please email us directly at bill@treetopgrowthstrategy.com.';
      errorEl.style.display = 'block';
      btn.textContent = 'Book my call →';
      btn.disabled = false;
    }
  });
</script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
  .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
  .rule { width: 100%; height: 1px; background: #1A3A1A; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; }
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
  .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: #F0FFF0; }
  .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; white-space: nowrap; }
  .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s, background 0.2s; cursor: pointer; }
  .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
  .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .card-dark { background: #050D05; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s; }
  .card-dark:hover { border-color: rgba(0,200,83,0.35); }
  .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s, background 0.2s; }
  .card-mid:hover { border-color: rgba(0,200,83,0.35); background: #0f200f; }
  section { padding: 5rem 2.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
  .h3 { font-size: 1.1rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.75rem; }
  .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
  .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
  .input-field:focus { border-color: rgba(0,200,83,0.5); }
  .input-field::placeholder { color: #4A6A4A; }
  @media (max-width: 768px) { .mob-col { flex-direction: column !important; } .hide-mob { display: none !important; } section { padding: 3.5rem 1.5rem; } .container { padding: 0 1.5rem; } }
</style>
