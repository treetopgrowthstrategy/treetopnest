---
import Layout from '../../layouts/Layout.astro';
import GlobalNav from '../../components/GlobalNav.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
export const prerender = true;
---

<Layout
  title="Revenue Engine Audit | $1,500, 5 days | Treetop"
  description="The Revenue Engine Audit diagnoses your current growth motion in 5 business days. Written roadmap, interview-driven, $1,500 fixed price. Credited toward implementation."
  canonicalUrl="https://treetopgrowthstrategy.com/services/ai-audit"
  pageType="service"
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <GlobalNav active="" />

  <!-- Hero -->
  <section style="min-height:70vh;display:flex;align-items:center;padding-top:7rem;padding-bottom:4rem;">
    <div class="section-inner" style="max-width:820px;">
      <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:1.5rem;">
        <a href="/pricing" style="font-size:0.8rem;color:#4A6A4A;text-decoration:none;">Pricing</a>
        <span style="color:#1A3A1A;font-size:0.8rem;">/</span>
        <a href="/pricing#diagnose" style="font-size:0.8rem;color:#4A6A4A;text-decoration:none;">Diagnose</a>
        <span style="color:#1A3A1A;font-size:0.8rem;">/</span>
        <span style="font-size:0.8rem;color:#8FAF8F;">Revenue Engine Audit</span>
      </div>
      <span class="lbl">Revenue Engine Audit &middot; Diagnose (Memory)</span>
      <h1 class="h2" style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2.5rem,5vw,3.75rem);margin-bottom:1.5rem;">
        A written diagnosis of<br/><em style="color:#00C853">your revenue engine.</em>
      </h1>
      <p class="body-text" style="font-size:1.05rem;max-width:620px;margin-bottom:2rem;">
        Five business days. Interviews with your team, a full data pull, and a written roadmap ranked by leverage. You leave knowing exactly what to fix first and in what order, whether or not we keep working together.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;margin-bottom:1.5rem;">
        <a href="#contact" class="btn-p">Start my Audit &rarr;</a>
        <a href="/pricing" class="btn-g">See the full ladder</a>
      </div>
      <p style="font-size:0.8rem;color:#4A6A4A;">Fixed price. 5 business days. Audit fee credited toward any implementation engagement.</p>
    </div>
  </section>

  <!-- Deliverables -->
  <section style="padding-top:0;padding-bottom:5rem;border-top:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">What you get</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:3rem;">Five deliverables. One week.</h2>

      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { n: '01', title: 'Revenue engine map', desc: 'A structured picture of your current growth motion. Where time goes, where handoffs happen, and where the compounding breaks down.' },
          { n: '02', title: 'Leverage analysis', desc: 'Every part of your motion scored by leverage: time savings, revenue upside, and implementation effort. Ranked by return.' },
          { n: '03', title: 'Prioritized 90-day roadmap', desc: 'Quick wins for week one. Medium-term builds for month one. A strategic horizon for the next six months.' },
          { n: '04', title: 'Tool and system recommendations', desc: 'Specific AI use cases, prompt approaches, and system changes recommended for your exact business context.' },
          { n: '05', title: '60-minute readout call', desc: 'A live walkthrough of the findings, Q and A on the roadmap, and a clear decision point: what to do first, and whether you should own it or hand it off.' },
        ].map(({ n, title, desc }) => (
          <div style="display:flex;gap:0;border-top:1px solid #1A3A1A;padding:2rem 0;align-items:stretch;">
            <div style="width:3px;background:rgba(0,200,83,0.4);flex-shrink:0;align-self:stretch;margin-right:2rem;"></div>
            <div style="display:flex;gap:2rem;flex:1;flex-wrap:wrap;">
              <div style="font-family:'Instrument Serif',serif;font-size:1.5rem;color:rgba(0,200,83,0.4);flex-shrink:0;width:2rem;">{n}</div>
              <div style="flex:1;min-width:200px;">
                <div class="h3" style="margin-bottom:0.5rem;">{title}</div>
                <p class="body-text">{desc}</p>
              </div>
            </div>
          </div>
        ))}
        <div style="border-top:1px solid #1A3A1A;"></div>
      </div>
    </div>
  </section>

  <!-- Right for you if -->
  <section style="padding:5rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner">
      <span class="lbl">Is this right for you?</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:2.5rem;">The Revenue Engine Audit is right for you if...</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;">
        {[
          { title: "You know something is off but not what", desc: "Growth feels random. Some months work. Some months do not. You want a written diagnosis, not a sales pitch." },
          { title: "You are about to spend serious money", desc: "You are about to hire a VP or CMO, sign a six-figure agency retainer, or greenlight a rebrand. A $1,500 audit before you commit is cheap insurance." },
          { title: "The $99 report was useful but not enough", desc: "The Starter Report gave you a snapshot. The Audit gives you the interview-driven diagnosis with a plan your team can act on." },
          { title: "You need something to show your team", desc: "Leadership wants to see a roadmap before committing budget. The Audit produces that document." },
        ].map(({ title, desc }) => (
          <div class="card-mid">
            <div class="h3" style="font-size:1rem;margin-bottom:0.6rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process timeline -->
  <section style="padding:5rem 2.5rem;">
    <div class="section-inner">
      <span class="lbl">How it works</span>
      <h2 class="h2" style="font-size:clamp(1.75rem,3vw,2.25rem);margin-bottom:3rem;">Five business days, start to finish.</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;">
        {[
          { day: 'Monday', title: 'Kickoff call', desc: '45 minutes. We map your motion, understand your team, and identify what matters most.' },
          { day: 'Tues and Wed', title: 'Deep analysis', desc: 'Interviews with your team, live data pulls, and scoring every opportunity.' },
          { day: 'Thurs and Fri', title: 'Roadmap build', desc: 'We write the prioritized roadmap, tool recommendations, and readout deck.' },
          { day: 'Following Mon', title: 'Readout call', desc: '60 minutes. Walk through every finding, answer every question, decide what to do next.' },
        ].map(({ day, title, desc }) => (
          <div style="background:#050D05;border:1px solid #1A3A1A;padding:1.75rem;position:relative;">
            <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;">{day}</div>
            <div class="h3" style="margin-bottom:0.5rem;">{title}</div>
            <p class="body-text" style="font-size:0.88rem;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section style="padding:5rem 2.5rem;background:#0A1A0A;border-top:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
    <div class="section-inner" style="max-width:680px;">
      <span class="lbl">Pricing</span>
      <div style="font-family:'Instrument Serif',serif;font-size:clamp(3rem,6vw,4.5rem);font-style:italic;color:#F0FFF0;margin-bottom:0.5rem;">$1,500</div>
      <p class="body-text" style="margin-bottom:2rem;">Fixed price. No hourly billing. No surprises.</p>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2rem;">
        {[
          'Kickoff call and interviews with your team',
          'Live data pull and competitive review',
          'Prioritized 90-day roadmap',
          'Prompt and tool recommendations',
          '60-minute readout call with Q and A',
          'Written deliverable you keep forever',
        ].map(item => (
          <li style="display:flex;gap:0.75rem;font-size:0.9rem;color:#8FAF8F;align-items:flex-start;">
            <span style="color:#00C853;flex-shrink:0;margin-top:0.1em;">&#10003;</span> {item}
          </li>
        ))}
      </ul>
      <div style="background:rgba(0,200,83,0.08);border:1px solid rgba(0,200,83,0.2);padding:1.25rem 1.5rem;margin-bottom:2rem;">
        <p style="font-size:0.88rem;color:#8FAF8F;">The $1,500 Audit fee is <strong style="color:#F0FFF0;">fully credited</strong> toward any Fractional CMO or CRO engagement.</p>
      </div>
      <a href="#contact" class="btn-p">Start my Audit &rarr;</a>
    </div>
  </section>

  <!-- Contact form -->
  <section id="contact" style="padding:5rem 2.5rem;background:#050D05;border-top:1px solid #1A3A1A;">
    <div class="section-inner" style="max-width:680px;margin:0 auto;">
      <span class="lbl">Get started</span>
      <h2 class="h2" style="margin-bottom:0.75rem;">Start your Revenue Engine Audit.</h2>
      <p class="body-text" style="margin-bottom:2.5rem;">Tell us a bit about your business. We confirm availability and send a link to book the kickoff call.</p>

      <form id="audit-form" style="display:flex;flex-direction:column;gap:1rem;">
        <div style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
          <label for="f-hp-audit">Leave this empty</label>
          <input type="text" id="f-hp-audit" name="hp" tabindex="-1" autocomplete="off" />
        </div>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <input class="input-field" type="text" name="first_name" placeholder="First name" required style="flex:1;min-width:200px;" />
          <input class="input-field" type="text" name="last_name" placeholder="Last name" style="flex:1;min-width:200px;" />
        </div>
        <input class="input-field" type="email" name="email" placeholder="Email address" required />
        <input class="input-field" type="text" name="company" placeholder="Company name" />
        <select class="input-field" name="team_size" style="cursor:pointer;">
          <option value="" disabled selected>Team size</option>
          <option value="Solo">Solo, just me</option>
          <option value="2 to 5">2 to 5 people</option>
          <option value="6 to 15">6 to 15 people</option>
          <option value="16 to 50">16 to 50 people</option>
          <option value="50+">50+ people</option>
        </select>
        <textarea class="input-field" name="gain" rows="4" placeholder="What is the biggest thing you want the Audit to tell you?"></textarea>
        <div id="form-error" style="display:none;color:#ff6b6b;font-size:0.85rem;"></div>
        <button type="submit" class="btn-p" id="submit-btn" style="align-self:flex-start;">Start my Audit &rarr;</button>
      </form>

      <div id="form-success" style="display:none;padding:2rem;background:#0A1A0A;border:1px solid rgba(0,200,83,0.4);margin-top:1rem;">
        <p style="color:#00C853;font-weight:600;margin-bottom:0.5rem;">We got it, thanks.</p>
        <p class="body-text">We will be in touch within one business day to confirm availability and send you a booking link.</p>
      </div>
    </div>
  </section>

  <!-- treetop-linker-related-START -->
<section style="padding:3.5rem 2.5rem;border-top:1px solid #1A3A1A;background:#050D05;">
  <div style="max-width:780px;margin:0 auto;">
    <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;display:block;">Related</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.5rem,2.8vw,2rem);font-weight:400;line-height:1.2;color:#F0FFF0;margin-bottom:1.5rem;">Explore more from Treetop</h2>
    <ul style="list-style:none;padding:0;font-size:0.96rem;line-height:1.9;color:#C0D8C0;">
    <li><a href="/methodology" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">The Revenue Engine Method: Memory, Intelligence, Motion &rarr;</a></li>
    <li><a href="/pricing" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">The full ladder: Diagnose, Run, Lead &rarr;</a></li>
    <li><a href="/fractional-cmo" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">What a fractional CMO does &rarr;</a></li>
    <li><a href="/ai-cmo-advisor" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">The $99 Starter Report &rarr;</a></li>
    <li><a href="/ai-for-cmos" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">The AI toolkit for marketing leaders &rarr;</a></li>
    <li><a href="/what-is-ai-native-gtm" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">AI-native GTM, defined &rarr;</a></li>
    <li><a href="/glossary" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Treetop's glossary &rarr;</a></li>
    </ul>
  </div>
</section>
<!-- treetop-linker-related-END -->

<GlobalFooter />
</Layout>

<script>
  (window as any)._auditLoadTime = Date.now();
  const form = document.getElementById('audit-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending...';
    btn.disabled = true;
    errorEl.style.display = 'none';

    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...data, source: 'revenue-engine-audit', _t: (window as any)._auditLoadTime }),
      });
      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'block';
      } else throw new Error();
    } catch {
      errorEl.textContent = 'Something went wrong. Please email us at bill@treetopgrowthstrategy.com.';
      errorEl.style.display = 'block';
      btn.textContent = 'Start my Audit →';
      btn.disabled = false;
    }
  });
</script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
  .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
  .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; white-space: nowrap; }
  .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s, background 0.2s; cursor: pointer; }
  .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
  .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s, background 0.2s; }
  .card-mid:hover { border-color: rgba(0,200,83,0.35); background: #0f200f; }
  section { padding: 5rem 2.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
  .h3 { font-size: 1.1rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.75rem; }
  .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
  .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
  .input-field:focus { border-color: rgba(0,200,83,0.5); }
  .input-field::placeholder { color: #4A6A4A; }
  @media (max-width: 768px) { section { padding: 3.5rem 1.5rem; } }
</style>
