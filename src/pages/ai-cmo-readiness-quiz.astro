<script is:inline>
const QUESTIONS = [
  { q: "What's your annual revenue stage?",
    a: [
      { t: "Pre-revenue or under $1M ARR", k: "stage_early" },
      { t: "$1M–$5M ARR", k: "stage_early_growth" },
      { t: "$5M–$30M ARR", k: "stage_growth" },
      { t: "$30M+ ARR", k: "stage_scale" },
    ]},
  { q: "Do you have a written GTM strategy you'd commit to for 6+ months?",
    a: [
      { t: "Yes, written down and stable", k: "strategy_clear" },
      { t: "Roughly clear but evolving", k: "strategy_evolving" },
      { t: "Not really — we're still figuring it out", k: "strategy_unclear" },
    ]},
  { q: "What's your current marketing team size?",
    a: [
      { t: "Just me / the founder", k: "team_zero" },
      { t: "1–3 marketers", k: "team_small" },
      { t: "4–10 marketers", k: "team_mid" },
      { t: "10+ marketers", k: "team_large" },
    ]},
  { q: "How technical is your team — would someone build a DIY Claude setup?",
    a: [
      { t: "Yes — we have someone willing to do 30–50 hours of setup", k: "tech_yes" },
      { t: "Maybe — we'd need to find them", k: "tech_maybe" },
      { t: "No — we want polished tooling without building", k: "tech_no" },
    ]},
  { q: "What's the biggest bottleneck right now?",
    a: [
      { t: "Execution capacity — strategy is clear, we can't produce enough", k: "bottleneck_capacity" },
      { t: "Strategic direction — we don't know what to do", k: "bottleneck_strategy" },
      { t: "Accountability — no one owns marketing outcomes", k: "bottleneck_accountability" },
      { t: "All three", k: "bottleneck_all" },
    ]},
  { q: "What's your monthly marketing-leadership budget?",
    a: [
      { t: "Under $1K/month (tooling only)", k: "budget_micro" },
      { t: "$1K–$10K/month", k: "budget_small" },
      { t: "$10K–$30K/month", k: "budget_mid" },
      { t: "$30K+/month", k: "budget_large" },
    ]},
];

const answers = [];
const container = document.getElementById('quiz-container');

function render() {
  container.innerHTML = '';
  QUESTIONS.forEach((q, i) => {
    if (i > answers.length) return;
    const card = document.createElement('div');
    card.className = 'question-card';
    card.innerHTML = `
      <div class="q-meta">Question ${i+1} of ${QUESTIONS.length}</div>
      <div class="q-text">${q.q}</div>
      <div class="answers">
        ${q.a.map((a, j) => `
          <button class="answer-btn ${answers[i]?.k === a.k ? 'selected' : ''}" onclick="pick(${i}, ${j})">
            <span class="answer-letter">${String.fromCharCode(65+j)}</span>
            <span>${a.t}</span>
          </button>
        `).join('')}
      </div>
    `;
    container.appendChild(card);
  });
  document.getElementById('progress').style.width = Math.round((answers.length / QUESTIONS.length) * 100) + '%';
}

function pick(qi, ai) {
  answers[qi] = QUESTIONS[qi].a[ai];
  if (answers.length === QUESTIONS.length) {
    setTimeout(showResult, 250);
  } else {
    render();
    setTimeout(() => {
      const next = container.querySelectorAll('.question-card')[qi + 1];
      if (next) next.scrollIntoView({behavior:'smooth', block:'center'});
    }, 200);
  }
}

function showResult() {
  render();
  const keys = answers.map(a => a.k);
  const has = k => keys.includes(k);

  let rec, body, detail, actions;

  // Decision logic
  if (has('stage_early') && has('budget_micro')) {
    rec = "DIY Claude — you're not ready to spend on tooling yet.";
    body = "At your stage and budget, building a simple Claude-based AI CMO setup is the right call. Claude Pro is $20/month, and you can be productive within a week with Claude Projects.";
    detail = "Next steps: subscribe to Claude Pro, set up Projects for Strategy, Content, and Reporting. Don't add complexity until revenue justifies it. Skip fractional CMO until $1M+ ARR.";
    actions = [['/build-your-own-ai-cmo-with-claude', 'See the DIY guide →'], ['/ai-tool-stack-auditor', 'Audit your current stack']];
  }
  else if (has('strategy_unclear') || has('bottleneck_strategy') || has('bottleneck_accountability')) {
    rec = "Hire a fractional CMO first — AI tooling won't fix this.";
    body = "Your bottleneck isn't execution capacity — it's strategic direction or accountability. An AI CMO will execute whatever you point it at, which means it'll execute the wrong things faster. Strategy and ownership come first.";
    detail = "Next steps: book a fractional CMO conversation. Most engagements at $5M-$30M ARR run $10K-$25K/month. AI tooling becomes the execution layer underneath, not the primary investment.";
    actions = [['/fractional-cmo', 'See fractional CMO services →'], ['/services/ai-audit', 'Book the $1,500 AI Audit']];
  }
  else if (has('stage_scale') && has('team_large')) {
    rec = "Full-time CMO + AI tooling distributed across the team.";
    body = "At your scale, you need permanent in-house leadership and the institutional knowledge that comes with it. The AI layer goes underneath — distributed across your team, with a marketing-ops or Marketing AI Lead owning the configuration.";
    detail = "Next steps: if you don't have a full-time CMO, that's the priority hire. If you do, focus on the operating model redesign: who owns AI tooling configuration across the team, what's centralized vs distributed, how do you measure ROI?";
    actions = [['/cmo-ai-adoption-playbook', "See the CMO's AI adoption playbook →"], ['/services/ai-audit', 'Book the $1,500 AI Audit']];
  }
  else if ((has('stage_growth') || has('stage_early_growth')) && (has('bottleneck_capacity') || has('bottleneck_all'))) {
    if (has('tech_yes')) {
      rec = "Fractional CMO + DIY Claude AI CMO — the highest-ROI combination.";
      body = "You have a strategy, you have someone technical, you have execution bottlenecks. The right move: fractional CMO ($10K-$20K/month) for strategy and accountability + DIY Claude setup (~$100/month) for execution leverage. Combined cost ~$10K-$20K/month vs $40K+/month for full-time.";
      detail = "Next steps: book a fractional CMO conversation and start the DIY build in parallel. The fractional CMO will help shape what the DIY setup should do. Don't pay for Okara or Lindy yet — your tech-fluent team can build it cheaper.";
      actions = [['/fractional-cmo', 'See fractional CMO services →'], ['/build-your-own-ai-cmo-with-claude', 'See the DIY guide']];
    } else if (has('tech_no')) {
      rec = "Fractional CMO + Okara (or similar dedicated AI CMO product).";
      body = "You have a strategy and need execution leverage, but no one to build DIY. The right move: fractional CMO ($10K-$20K/month) + dedicated AI CMO product like Okara ($500-$2,000/month). Combined cost ~$11K-$22K/month — well below a full-time CMO.";
      detail = "Next steps: book a fractional CMO conversation. Evaluate Okara, Lindy, and 1-2 others against your specific stack. The fractional CMO will help select and integrate.";
      actions = [['/fractional-cmo', 'See fractional CMO services →'], ['/best-ai-cmo-tools-2026', 'See AI CMO tool comparison']];
    } else {
      rec = "Fractional CMO + AI CMO tooling (decide DIY vs product later).";
      body = "Strong fit for the fractional + AI combination. Lock in the fractional CMO first; decide DIY vs product in the first 30 days of the engagement based on what your team can support.";
      detail = "Next steps: book a fractional CMO conversation. In parallel, take the AI Tool Stack Auditor to see what you already have.";
      actions = [['/fractional-cmo', 'See fractional CMO services →'], ['/ai-tool-stack-auditor', 'Run the stack auditor']];
    }
  }
  else if (has('team_zero') && has('budget_small')) {
    rec = "DIY Claude or Lindy — you're the strategy, AI is the execution.";
    body = "Founder-led with limited budget. Don't pay for a fractional CMO yet (you're being the CMO). Get AI tooling working underneath you. Lindy is a good middle ground if you don't want to build DIY.";
    detail = "Next steps: start with Claude Pro ($20/month) and a few core Skills. If you need more polish without building, evaluate Lindy CMO Agent ($100-$500/month tier).";
    actions = [['/build-your-own-ai-cmo-with-claude', 'See DIY guide →'], ['/lindy-ai-cmo-review', 'See Lindy review']];
  }
  else {
    // Default: middle of the road
    rec = "Pair an AI CMO with a fractional CMO — the most common right answer.";
    body = "Your situation fits the pattern most B2B mid-market companies are in: clear enough strategy, execution bottlenecks, ready to invest. The right move is pairing strategic leadership (fractional CMO) with execution leverage (AI CMO tooling).";
    detail = "Next steps: book a fractional CMO conversation. Evaluate which AI CMO category fits — DIY if technically fluent, dedicated product (Okara) if not. Combined monthly cost typically $9K-$22K vs $40K+/month for full-time hire.";
    actions = [['/fractional-cmo', 'See fractional CMO services →'], ['/best-ai-cmo-tools-2026', 'See AI CMO tool comparison']];
  }

  document.getElementById('rec-headline').textContent = rec;
  document.getElementById('rec-body').textContent = body;
  document.getElementById('rec-detail').textContent = detail;

  const actionsEl = document.getElementById('rec-actions');
  actionsEl.innerHTML = actions.map(([url, text]) => `<a href="${url}" class="btn-p">${text}</a>`).join('');

  document.getElementById('result').classList.add('show');
  document.getElementById('result').scrollIntoView({behavior:'smooth', block:'start'});
}

async function submitGate(e) {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  const success = document.getElementById('gate-success');
  const errorEl = document.getElementById('gate-error');
  success.style.display = 'none'; errorEl.style.display = 'none';
  btn.disabled = true; btn.textContent = 'Sending...';
  const payload = {
    first_name: document.getElementById('g-name').value.trim(),
    email: document.getElementById('g-email').value.trim(),
    company: document.getElementById('g-company').value.trim(),
    source: 'ai-cmo-readiness-quiz',
    quizAnswers: answers.map(a => a.k),
    recommendation: document.getElementById('rec-headline').textContent,
  };
  try {
    const res = await fetch('/api/lead-capture', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) throw new Error('server');
    success.style.display = 'block';
    btn.textContent = '✓ Sent';
    e.target.querySelectorAll('input').forEach(i => i.disabled = true);
  } catch (err) {
    errorEl.style.display = 'block';
    btn.disabled = false; btn.textContent = 'Email me the PDF →';
  }
  return false;
}

render();
</script>

</body></html>
