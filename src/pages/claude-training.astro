<!-- INQUIRY FORM -->
<div class="rule"></div>
<section class="section-alt" id="inquire">
  <div class="container">
    <span class="lbl">Request Training</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;max-width:560px;margin-bottom:0.75rem;">
      Tell us about your team.<br/>We'll take it from there.
    </h2>
    <p style="font-size:0.92rem;color:#8FAF8F;line-height:1.8;margin-bottom:0;max-width:520px;">No commitment. Just a quick conversation to figure out the right format, scope, and timing for your organization.</p>

    <div class="form-wrap">
      <div id="success-msg">
        <div style="font-size:2rem;margin-bottom:1rem;">✓</div>
        <h3>Got it — we'll be in touch shortly.</h3>
        <p>Bill will follow up within one business day to discuss your team's situation and the right training format.</p>
      </div>

      <form id="training-form">
        <div class="form-grid">
          <div class="form-field">
            <label class="form-label" for="t-name">Your Name</label>
            <input class="form-input" type="text" id="t-name" placeholder="Alex Johnson" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="t-title">Your Title</label>
            <input class="form-input" type="text" id="t-title" placeholder="CMO, Head of Marketing..." />
          </div>
          <div class="form-field">
            <label class="form-label" for="t-email">Work Email</label>
            <input class="form-input" type="email" id="t-email" placeholder="alex@company.com" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="t-company">Company</label>
            <input class="form-input" type="text" id="t-company" placeholder="Acme Corp" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="t-size">Team Size</label>
            <select class="form-select" id="t-size">
              <option value="">Select...</option>
              <option>Just me (1:1 executive session)</option>
              <option>2–10 people</option>
              <option>11–25 people</option>
              <option>26–50 people</option>
              <option>50+ people</option>
            </select>
          </div>
          <div class="form-field">
            <label class="form-label" for="t-format">Training Format</label>
            <select class="form-select" id="t-format">
              <option value="">Not sure yet</option>
              <option>Half-Day Team Workshop</option>
              <option>1:1 Executive Intensive</option>
              <option>Company-Wide Training Program</option>
              <option>Not sure — want a recommendation</option>
            </select>
          </div>
          <div class="form-field full">
            <label class="form-label" for="t-context">What does your team need most?</label>
            <textarea class="form-textarea" id="t-context" placeholder="What's the main use case, challenge, or goal? What tools does your team currently use? What would success look like?"></textarea>
          </div>
        </div>

        <p class="form-note">We'll follow up within one business day. No sales pitch — just an honest conversation about whether this is a fit.</p>
        <button type="submit" class="btn-p" id="submit-btn" style="width:100%;justify-content:center;">
          Send Inquiry →
        </button>
        <div id="error-msg">Something went wrong. Email bill@treetopgrowthstrategy.com directly.</div>
      </form>
    </div>
  </div>
</section>

