---
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Claude Training for Teams & Executives | Treetop Growth Strategy</title>
  <meta name="description" content="Hands-on Claude training for marketing teams, GTM orgs, leadership teams, and agencies. Go from basic prompting to AI-native workflows in a single session." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/claude-training" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/claude-training" />
  <meta property="og:title" content="Claude Training for Teams & Executives | Treetop Growth Strategy" />
  <meta property="og:description" content="Hands-on Claude training for marketing teams, GTM orgs, leadership teams, and agencies. Go from basic prompting to AI-native workflows in a single session." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og-default.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Claude Training for Teams & Executives | Treetop Growth Strategy" />
  <meta name="twitter:description" content="Hands-on Claude training for marketing teams, GTM orgs, leadership teams, and agencies. Go from basic prompting to AI-native workflows in a single session." />
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Claude Training for Teams & Executives | Treetop Growth Strategy",
      "description": "Hands-on Claude training for marketing teams, GTM orgs, leadership teams, and agencies. Go from basic prompting to AI-native workflows in a single session.",
      "url": "https://treetopgrowthstrategy.com/claude-training",
      "provider": {"@id": "https://treetopgrowthstrategy.com/#organization"},
      "areaServed": {"@type": "Country", "name": "United States"},
      "audience": {"@type": "Audience", "description": "B2B executives and small business owners"}
    },
    {"@type": "Organization", "@id": "https://treetopgrowthstrategy.com/#organization", "name": "Treetop Growth Strategy", "url": "https://treetopgrowthstrategy.com"}
  ]
}
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }

    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    .rule { width: 100%; height: 1px; background: #1A3A1A; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }

    /* BUTTONS */
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; white-space: nowrap; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s, background 0.2s; cursor: pointer; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }

    /* BADGE */
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* HERO */
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; background: #050D05; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; letter-spacing: -0.01em; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }

    /* AUDIENCE PILLS */
    .audience-row { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 3rem; }
    .audience-pill { display: inline-flex; align-items: center; gap: 6px; border: 1px solid #1A3A1A; padding: 0.4rem 1rem; font-size: 0.78rem; color: #8FAF8F; }
    .audience-pill::before { content: '✓'; color: #00C853; font-size: 0.7rem; }

    /* STAT ROW */
    .stat-row { display: flex; gap: 0; flex-wrap: wrap; border: 1px solid #1A3A1A; margin-top: 3rem; }
    .stat-item { flex: 1; min-width: 160px; padding: 1.5rem; border-right: 1px solid #1A3A1A; }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-family: 'Instrument Serif', serif; font-size: 2.4rem; font-style: italic; color: #00C853; line-height: 1; display: block; margin-bottom: 0.4rem; }
    .stat-label { font-size: 0.78rem; color: #8FAF8F; line-height: 1.5; }

    /* SECTIONS */
    section { padding: 5rem 2.5rem; }
    .section-alt { background: #0A1A0A; }

    /* FORMAT CARDS */
    .format-grid { display: flex; gap: 1.25rem; flex-wrap: wrap; margin-top: 2rem; }
    .format-card { flex: 1; min-width: 240px; background: #050D05; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s; position: relative; overflow: hidden; }
    .format-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 0; background: #00C853; transition: height 0.3s ease; }
    .format-card:hover { border-color: rgba(0,200,83,0.35); }
    .format-card:hover::before { height: 100%; }
    .format-tag { display: inline-block; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #00C853; border: 1px solid rgba(0,200,83,0.3); padding: 3px 10px; margin-bottom: 1rem; }
    .format-title { font-family: 'Instrument Serif', serif; font-size: 1.4rem; font-weight: 400; color: #F0FFF0; margin-bottom: 0.75rem; line-height: 1.2; }
    .format-desc { font-size: 0.84rem; color: #8FAF8F; line-height: 1.75; margin-bottom: 1.25rem; }
    .format-meta { font-size: 0.75rem; color: #4A6A4A; display: flex; flex-direction: column; gap: 0.3rem; }
    .format-meta span::before { content: '→ '; color: #00C853; }

    /* WHAT YOU BUILD */
    .build-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1px; background: #1A3A1A; border: 1px solid #1A3A1A; margin-top: 2rem; }
    .build-item { background: #0A1A0A; padding: 1.75rem; }
    .build-num { font-family: 'Instrument Serif', serif; font-size: 2rem; font-style: italic; color: rgba(0,200,83,0.25); line-height: 1; margin-bottom: 0.75rem; }
    .build-title { font-size: 0.88rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.5rem; }
    .build-desc { font-size: 0.8rem; color: #8FAF8F; line-height: 1.7; }

    /* WHO IT'S FOR */
    .who-grid { display: flex; gap: 1.25rem; flex-wrap: wrap; margin-top: 2rem; }
    .who-card { flex: 1; min-width: 200px; background: #0A1A0A; border: 1px solid #1A3A1A; padding: 1.75rem; transition: border-color 0.2s; }
    .who-card:hover { border-color: rgba(0,200,83,0.3); }
    .who-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .who-title { font-size: 0.92rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.5rem; }
    .who-desc { font-size: 0.8rem; color: #8FAF8F; line-height: 1.7; }

    /* DIFFERENTIATOR */
    .diff-row { display: flex; gap: 4rem; flex-wrap: wrap; align-items: flex-start; }
    .diff-list { flex: 1; min-width: 260px; display: flex; flex-direction: column; gap: 0; }
    .diff-item { display: flex; gap: 1rem; align-items: flex-start; padding: 1.25rem 0; border-bottom: 1px solid #1A3A1A; }
    .diff-item:last-child { border-bottom: none; }
    .diff-check { color: #00C853; flex-shrink: 0; margin-top: 2px; font-size: 0.85rem; }
    .diff-text { font-size: 0.88rem; color: #8FAF8F; line-height: 1.7; }
    .diff-text strong { color: #F0FFF0; font-weight: 600; }

    /* INQUIRY FORM */
    .form-wrap { background: #0A1A0A; border: 1px solid rgba(0,200,83,0.2); padding: 3rem; max-width: 680px; margin: 2rem auto 0; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
    .form-field { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-field.full { grid-column: 1 / -1; }
    .form-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #4A6A4A; }
    .form-input, .form-select, .form-textarea { background: #050D05; border: 1px solid #1A3A1A; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.88rem; font-weight: 300; padding: 0.75rem 1rem; width: 100%; outline: none; transition: border-color 0.2s; -webkit-appearance: none; }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: rgba(0,200,83,0.4); }
    .form-input::placeholder, .form-textarea::placeholder { color: #2A3A2A; }
    .form-select option { background: #050D05; }
    .form-textarea { resize: vertical; min-height: 100px; }
    .form-note { font-size: 0.75rem; color: #4A6A4A; margin-bottom: 1.25rem; line-height: 1.6; }
    #success-msg { display: none; text-align: center; padding: 2rem; }
    #success-msg h3 { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: #F0FFF0; margin-bottom: 0.5rem; }
    #success-msg p { font-size: 0.88rem; color: #8FAF8F; line-height: 1.7; }
    #error-msg { display: none; color: #ef4444; font-size: 0.82rem; margin-top: 0.75rem; text-align: center; }

    /* FOOTER */
    footer { border-top: 1px solid #1A3A1A; padding: 3rem 2.5rem; background: #050D05; }
    .footer-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }

    @media (max-width: 768px) {
      .form-grid { grid-template-columns: 1fr; }
      .diff-row { flex-direction: column; gap: 2rem; }
      .stat-item { border-right: none; border-bottom: 1px solid #1A3A1A; }
      .stat-item:last-child { border-bottom: none; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#inquire" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Request Training</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="badge" style="margin-bottom:2rem;">
      <span class="badge-dot"></span>
      Claude Training · Live & Hands-On
    </div>

    <h1 class="hero-h">
      Your team is using Claude.<br/>
      <span style="font-style:italic;color:#00C853;">Are they using it well?</span>
    </h1>

    <p class="hero-sub">
      Most teams are getting 20% of what Claude can actually do. This training closes that gap — with real workflows, live practice, and systems your team will actually use the next day.
    </p>

    <div class="audience-row">
      <span class="audience-pill">Marketing & GTM Teams</span>
      <span class="audience-pill">Leadership & Executives</span>
      <span class="audience-pill">Full Company Rollouts</span>
      <span class="audience-pill">Agencies & Consultants</span>
    </div>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="#inquire" class="btn-p">Request Training →</a>
      <a href="#formats" class="btn-g">See Training Formats</a>
    </div>

    <div class="stat-row">
      <div class="stat-item">
        <span class="stat-num">3–4x</span>
        <span class="stat-label">output per person for teams with structured Claude workflows</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">1 day</span>
        <span class="stat-label">from zero to functional AI-native workflows in your team's context</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">80%</span>
        <span class="stat-label">of teams using Claude are leaving most of its capability untouched</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">Live</span>
        <span class="stat-label">hands-on sessions — not recorded courses, not slide decks</span>
      </div>
    </div>
  </div>
</section>

<!-- FORMATS -->
<div class="rule"></div>
<section class="section-alt" id="formats">
  <div class="container">
    <span class="lbl">Training Formats</span>
    <div style="display:flex;gap:3rem;flex-wrap:wrap;align-items:flex-start;margin-bottom:1rem;">
      <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;flex:1;min-width:240px;">
        Three ways to run it.<br/>All of them hands-on.
      </h2>
      <p style="font-size:0.92rem;color:#8FAF8F;line-height:1.8;flex:1.2;min-width:240px;padding-top:0.5rem;">Every format is built around your team's actual work — not generic AI demos. We use your real use cases, your real content, your real workflows.</p>
    </div>
    <div class="format-grid">
      <div class="format-card">
        <div class="format-tag">Most Popular</div>
        <div class="format-title">Half-Day Team Workshop</div>
        <div class="format-desc">4 hours with your team. We build real workflows in the session — by the end, everyone leaves with working prompts and systems in their actual Claude account.</div>
        <div class="format-meta">
          <span>4 hours, remote or in-person</span>
          <span>Up to 20 participants</span>
          <span>Custom to your team's function</span>
          <span>Prompt library delivered post-session</span>
        </div>
      </div>
      <div class="format-card">
        <div class="format-tag">Executive Track</div>
        <div class="format-title">1:1 Executive Intensive</div>
        <div class="format-desc">A focused 90-minute session for CMOs, CROs, and CEOs. We build your personal Claude operating system — how you think, write, decide, and delegate with AI.</div>
        <div class="format-meta">
          <span>90 minutes, 1:1</span>
          <span>C-suite and VP level</span>
          <span>Strategic + hands-on</span>
          <span>Follow-up 30-min check-in included</span>
        </div>
      </div>
      <div class="format-card">
        <div class="format-tag">Full Rollout</div>
        <div class="format-title">Company-Wide Training Program</div>
        <div class="format-desc">A structured multi-session program for organizations going AI-native. We train in layers — leadership first, then function leads, then full teams — with consistent frameworks throughout.</div>
        <div class="format-meta">
          <span>Multi-session over 2–4 weeks</span>
          <span>50+ person organizations</span>
          <span>Department-specific customization</span>
          <span>Internal champion training included</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT YOU BUILD -->
<div class="rule"></div>
<section style="padding:5rem 2.5rem;background:#050D05;">
  <div class="container">
    <span class="lbl">What Gets Built</span>
    <div style="display:flex;gap:3rem;flex-wrap:wrap;align-items:flex-start;margin-bottom:0.5rem;">
      <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;flex:1;min-width:240px;">
        Not a course.<br/>A working system.
      </h2>
      <p style="font-size:0.92rem;color:#8FAF8F;line-height:1.8;flex:1.2;min-width:240px;padding-top:0.5rem;">Every session ends with something tangible. Here's what teams typically leave with.</p>
    </div>
    <div class="build-grid">
      <div class="build-item">
        <div class="build-num">01</div>
        <div class="build-title">A Team Prompt Library</div>
        <div class="build-desc">30–50 production-ready prompts built specifically for your team's function — content, outreach, analysis, reporting, strategy.</div>
      </div>
      <div class="build-item">
        <div class="build-num">02</div>
        <div class="build-title">Custom Claude Projects</div>
        <div class="build-desc">Configured Claude Projects with your brand voice, ICP, style guides, and context baked in — so every output is on-brand from the first draft.</div>
      </div>
      <div class="build-item">
        <div class="build-num">03</div>
        <div class="build-title">AI-Native Workflows</div>
        <div class="build-desc">Documented step-by-step workflows for your highest-leverage tasks — the ones where Claude compresses hours of work into minutes.</div>
      </div>
      <div class="build-item">
        <div class="build-num">04</div>
        <div class="build-title">Prompting Fundamentals</div>
        <div class="build-desc">Every participant leaves understanding how Claude actually works — so they can adapt and build on their own, not just copy-paste prompts.</div>
      </div>
      <div class="build-item">
        <div class="build-num">05</div>
        <div class="build-title">Use Case Playbook</div>
        <div class="build-desc">A prioritized map of where AI creates the most leverage in your specific role and organization — with a roadmap for what to tackle first.</div>
      </div>
      <div class="build-item">
        <div class="build-num">06</div>
        <div class="build-title">Internal Adoption Framework</div>
        <div class="build-desc">For full rollouts: a framework for sustaining adoption, tracking usage, and expanding AI-native practices across the organization over time.</div>
      </div>
    </div>
  </div>
</section>

<!-- WHO IT'S FOR -->
<div class="rule"></div>
<section class="section-alt" id="who">
  <div class="container">
    <span class="lbl">Who It's For</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;max-width:560px;margin-bottom:2rem;">
      Built for teams that are serious about AI — not just experimenting.
    </h2>
    <div class="who-grid">
      <div class="who-card">
        <div class="who-icon">📣</div>
        <div class="who-title">Marketing & GTM Teams</div>
        <div class="who-desc">Content, campaigns, outbound copy, competitive research, SEO briefs, brand voice — Claude can compress your team's highest-volume work by 60–80%.</div>
      </div>
      <div class="who-card">
        <div class="who-icon">🎯</div>
        <div class="who-title">Executives & Leaders</div>
        <div class="who-desc">Think faster, write sharper, prepare better. Build a personal AI operating system that makes you a more effective decision-maker and communicator.</div>
      </div>
      <div class="who-card">
        <div class="who-icon">🏢</div>
        <div class="who-title">Leadership Teams</div>
        <div class="who-desc">Align your entire leadership team on how AI gets used — with a consistent framework, shared vocabulary, and department-specific training for each function.</div>
      </div>
      <div class="who-card">
        <div class="who-icon">⚡</div>
        <div class="who-title">Agencies & Consultants</div>
        <div class="who-desc">Deliver more for clients with less overhead. Build Claude workflows into your service delivery — faster research, faster drafts, faster iteration at scale.</div>
      </div>
    </div>
  </div>
</section>

<!-- WHY THIS IS DIFFERENT -->
<div class="rule"></div>
<section style="padding:5rem 2.5rem;background:#050D05;">
  <div class="container">
    <span class="lbl">Why It's Different</span>
    <div class="diff-row">
      <div style="flex:1;min-width:260px;">
        <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;margin-bottom:1rem;">
          Not a course.<br/>Not a demo.<br/><span style="font-style:italic;color:#00C853;">Your actual work.</span>
        </h2>
        <p style="font-size:0.92rem;color:#8FAF8F;line-height:1.8;">Most AI training shows you what's possible. This training builds what you'll actually use — starting from your team's real content, real workflows, and real challenges.</p>
      </div>
      <div class="diff-list" style="flex:1.4;min-width:260px;">
        <div class="diff-item">
          <span class="diff-check">→</span>
          <span class="diff-text"><strong>Built on your context.</strong> We use your brand voice, your ICP, your existing content — not fictional examples. Every prompt we build works in your actual environment.</span>
        </div>
        <div class="diff-item">
          <span class="diff-check">→</span>
          <span class="diff-text"><strong>Live practice, not slides.</strong> Participants spend the majority of time inside Claude, building and testing — not watching someone else present.</span>
        </div>
        <div class="diff-item">
          <span class="diff-check">→</span>
          <span class="diff-text"><strong>Operator mindset, not hype.</strong> No promises about AGI or abstract AI futures. This is practical, workflow-first training from someone who uses Claude daily to run multiple businesses.</span>
        </div>
        <div class="diff-item">
          <span class="diff-check">→</span>
          <span class="diff-text"><strong>You leave with working systems.</strong> Prompt libraries, Claude Projects, workflows — all configured and ready to use the next day. Not ideas. Not homework.</span>
        </div>
        <div class="diff-item">
          <span class="diff-check">→</span>
          <span class="diff-text"><strong>Delivered by someone who's actually AI-native.</strong> Bill runs four businesses with AI as the operational backbone — this training comes from daily practice, not a curriculum.</span>
        </div>
      </div>
    </div>
  </div>
</section>

