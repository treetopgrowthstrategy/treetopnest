  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Site brand tokens (matches tailwind.config.mjs + rest of site) */
      --bg:        #050D05;
      --bg-alt:    #0A1A0A;
      --green:     #00C853;
      --green-dim: rgba(0,200,83,0.12);
      --green-glow:rgba(0,200,83,0.18);
      --text:      #F0FFF0;
      --sub:       #8FAF8F;
      --muted:     #4A6A4A;
      --border:    #1A3A1A;
    }

    html, body { height: 100%; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    /* PROGRESS BAR */
    #progress-bar-wrap {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--border);
      z-index: 100;
      opacity: 0;
      transition: opacity 0.3s;
    }
    #progress-bar-wrap.visible { opacity: 1; }
    #progress-bar {
      height: 100%;
      background: var(--green);
      transition: width 0.4s ease;
      width: 0%;
    }

    /* LOGO (matches site nav-logo: italic Instrument Serif) */
    .logo {
      position: fixed;
      top: 24px; left: 32px;
      font-family: 'Instrument Serif', serif;
      font-size: 1.3rem;
      font-style: italic;
      font-weight: 400;
      color: var(--text);
      letter-spacing: 0;
      z-index: 100;
      text-decoration: none;
    }
    .logo:hover { color: var(--green); }

    /* STEP CONTAINER */
    .step {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      opacity: 1;
      transition: opacity 0.35s ease, transform 0.35s ease;
      overflow-y: auto;
    }

    .step.hidden {
      opacity: 0;
      pointer-events: none;
      transform: translateY(16px);
    }

    .step.exit {
      opacity: 0;
      transform: translateY(-16px);
    }

    .step-inner {
      width: 100%;
      max-width: 680px;
    }

    /* INTRO */
    .intro-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 2rem;
    }
    .intro-eyebrow::before {
      content: '';
      width: 24px; height: 1px;
      background: var(--green);
    }

    /* Site-standard serif: italic, weight 400, NOT bold */
    .intro-headline {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      font-weight: 400;
      line-height: 1.08;
      color: var(--text);
      margin-bottom: 1.5rem;
      letter-spacing: -0.01em;
    }

    .intro-headline .highlight { color: var(--green); }

    .intro-sub {
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 300;
      color: var(--sub);
      line-height: 1.75;
      margin-bottom: 2.5rem;
      max-width: 560px;
    }

    .stat-row {
      display: flex;
      gap: 2.5rem;
      margin-bottom: 2.75rem;
      flex-wrap: wrap;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .stat-num {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: 2.2rem;
      font-weight: 400;
      color: var(--green);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.74rem;
      color: var(--muted);
      letter-spacing: 0.02em;
      max-width: 160px;
      line-height: 1.5;
    }

    /* BUTTONS — match site btn-p (square, bright green on dark text) */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--green);
      color: var(--bg);
      border: none;
      padding: 0.95rem 1.75rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0;
      text-transform: none;
      cursor: pointer;
      border-radius: 0;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.15s;
    }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

    .btn-note {
      display: block;
      margin-top: 1rem;
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0;
    }

    /* QUESTION */
    .q-step-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 0.6rem;
    }

    .q-pillar {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .q-text {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 400;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 2rem;
      letter-spacing: -0.005em;
    }

    .answers {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .answer-btn {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      background: rgba(240,255,240,0.02);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 1rem 1.25rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.92rem;
      font-weight: 300;
      line-height: 1.55;
      cursor: pointer;
      border-radius: 0;
      text-align: left;
      transition: border-color 0.18s, background 0.18s;
    }

    .answer-btn:hover {
      border-color: rgba(0,200,83,0.5);
      background: var(--green-dim);
    }

    .answer-btn.selected {
      border-color: var(--green);
      background: var(--green-glow);
    }

    .answer-letter {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--green);
      padding-top: 3px;
      min-width: 14px;
    }

    /* LEAD FORM */
    .score-preview {
      background: var(--bg-alt);
      border: 1px solid var(--border);
      border-left: 2px solid var(--green);
      padding: 1.5rem;
      margin-bottom: 2rem;
      border-radius: 0;
    }

    .score-preview-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }

    .score-preview-num {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: 3.5rem;
      font-weight: 400;
      color: var(--green);
      line-height: 1;
      display: inline-block;
    }

    .score-preview-tier {
      display: inline-block;
      margin-left: 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.35rem 0.85rem;
      border-radius: 0;
      vertical-align: middle;
      border: 1px solid currentColor;
    }

    /* Tier colors stay semantic but use brand-aligned saturation */
    .tier-absent    { color: #ff6b6b; background: rgba(255,107,107,0.08); }
    .tier-adjacent  { color: #fbbf24; background: rgba(251,191,36,0.08); }
    .tier-augmented { color: #60a5fa; background: rgba(96,165,250,0.08); }
    .tier-native    { color: var(--green); background: var(--green-dim); }

    .score-preview-blurb {
      font-size: 0.88rem;
      color: var(--sub);
      margin-top: 0.85rem;
      line-height: 1.65;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    @media (max-width: 480px) { .form-grid { grid-template-columns: 1fr; } }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .form-field.full { grid-column: 1 / -1; }

    .form-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .form-input {
      background: rgba(240,255,240,0.04);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 0.875rem 1rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 300;
      border-radius: 0;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }

    .form-input:focus { border-color: rgba(0,200,83,0.5); }
    .form-input::placeholder { color: var(--muted); }

    .form-note {
      font-size: 0.74rem;
      color: var(--muted);
      margin-top: 0.75rem;
      line-height: 1.55;
    }

    #submit-btn {
      width: 100%;
      justify-content: center;
      margin-top: 1.25rem;
      padding: 1.1rem;
    }

    #submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* CONFIRM */
    .confirm-icon {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--green-dim);
      border: 1px solid var(--green);
      color: var(--green);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem;
      margin-bottom: 2rem;
    }

    .confirm-headline {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: clamp(1.9rem, 4vw, 2.6rem);
      font-weight: 400;
      color: var(--text);
      margin-bottom: 1rem;
      line-height: 1.15;
    }

    .confirm-sub {
      font-size: 0.95rem;
      color: var(--sub);
      line-height: 1.75;
      margin-bottom: 2rem;
      max-width: 520px;
    }

    .confirm-score-block {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .confirm-score-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .confirm-score-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .confirm-score-val {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: 1.7rem;
      font-weight: 400;
      color: var(--green);
    }

    .back-link {
      margin-top: 2rem;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.82rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0;
      transition: color 0.2s;
    }
    .back-link:hover { color: var(--sub); }

    #error-msg {
      color: #ff6b6b;
      font-size: 0.82rem;
      margin-top: 0.75rem;
      display: none;
    }
  </style>

<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebPage","url":"https://treetopgrowthstrategy.com/quiz","name":"AI-Native GTM Gap Assessment | Treetop","description":"Find out exactly how much pipeline you","isPartOf":{"@type":"WebSite","url":"https://treetopgrowthstrategy.com/","name":"Treetop Growth Strategy"},"publisher":{"@id":"https://treetopgrowthstrategy.com/#organization"},"inLanguage":"en-US"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://treetopgrowthstrategy.com/"},{"@type":"ListItem","position":2,"name":"Quiz","item":"https://treetopgrowthstrategy.com/quiz"}]}</script>
</head>
<body>

<div id="progress-bar-wrap">
  <div id="progress-bar"></div>
</div>

<a href="/" class="logo">Treetop</a>

<!-- STEP 0: INTRO -->
<div class="step" id="step-0">
  <div class="step-inner">
    <div class="intro-eyebrow">3-Minute Assessment · Free</div>
    <h1 class="intro-headline">
      How much pipeline are you<br>
      <span class="highlight">losing to competitors</span><br>
      who've already gone AI-native?
    </h1>
    <p class="intro-sub">
      Companies that rebuilt their GTM motion around AI are running leaner teams and generating significantly more qualified pipeline. This assessment reveals exactly where your gaps are — and what they're costing you.
    </p>
    <div class="stat-row">
      <div class="stat-item">
        <span class="stat-num">61%</span>
        <span class="stat-label">quota attainment at AI-native GTM companies vs. 56% traditional</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">51%</span>
        <span class="stat-label">of B2B orgs can't measure ROI from their AI investments</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">5 wks</span>
        <span class="stat-label">faster average sales cycle for AI-native GTM teams</span>
      </div>
    </div>
    <button class="btn-primary" onclick="startQuiz()">
      Reveal my AI-GTM gap
      <span>→</span>
    </button>
    <span class="btn-note">8 questions · No fluff · Personalized gap report delivered to your inbox</span>
  </div>
</div>

<!-- STEPS 1-8: QUESTIONS -->
<div id="questions-container"></div>

<!-- STEP LEAD: LEAD CAPTURE -->
<div class="step hidden" id="step-lead">
  <div class="step-inner">
    <div class="score-preview">
      <div class="score-preview-label">Your AI-Native GTM Gap Score</div>
      <span class="score-preview-num" id="score-display">—</span>
      <span class="score-preview-tier" id="tier-display">Calculating...</span>
      <p class="score-preview-blurb" id="tier-blurb"></p>
    </div>

    <h2 style="font-family:'Instrument Serif',serif;font-style:italic;font-size:1.5rem;font-weight:400;margin-bottom:0.5rem;color:var(--text);line-height:1.2;">
      Get your full Gap Report.
    </h2>
    <p style="font-size:0.9rem;color:var(--sub);margin-bottom:1.5rem;line-height:1.65;">
      Your personalized report includes a pillar-by-pillar breakdown, what AI-native competitors are doing differently, and your top 3 priority actions.
    </p>

    <form id="lead-form">
      <div class="form-grid">
        <div class="form-field">
          <label class="form-label" for="f-name">First Name</label>
          <input class="form-input" type="text" id="f-name" name="name" placeholder="Alex" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="f-company">Company</label>
          <input class="form-input" type="text" id="f-company" name="company" placeholder="Acme Corp" required />
        </div>
        <div class="form-field full">
          <label class="form-label" for="f-email">Work Email</label>
          <input class="form-input" type="email" id="f-email" name="email" placeholder="alex@company.com" required />
        </div>
        <div class="form-field full">
          <label class="form-label" for="f-title">Your Title</label>
          <input class="form-input" type="text" id="f-title" name="title" placeholder="CMO, CRO, CEO..." />
        </div>
      </div>
      <p class="form-note">Your report will arrive within 2 minutes. We don't share your information.</p>
      <button class="btn-primary" id="submit-btn" type="submit">
        Send my Gap Report →
      </button>
      <div id="error-msg">Something went wrong. Please try again or email bill@treetopgrowthstrategy.com</div>
    </form>
  </div>
</div>

<!-- STEP CONFIRM -->
<div class="step hidden" id="step-confirm">
  <div class="step-inner">
    <div class="confirm-icon">✓</div>
    <h2 class="confirm-headline">Your Gap Report is on its way.</h2>
    <p class="confirm-sub">
      Check your inbox in the next 2–3 minutes. The report includes your full pillar breakdown, competitive gap analysis, and your top 3 priority actions for moving toward AI-native GTM.
    </p>
    <div class="confirm-score-block">
      <div class="confirm-score-item">
        <span class="confirm-score-label">Your Score</span>
        <span class="confirm-score-val" id="confirm-score">—</span>
      </div>
      <div class="confirm-score-item">
        <span class="confirm-score-label">Assessment</span>
        <span class="confirm-score-val" id="confirm-tier" style="font-size:1rem;padding-top:0.5rem;font-style:normal;letter-spacing:0.1em;text-transform:uppercase;">—</span>
      </div>
    </div>
    <p style="font-size:0.9rem;color:var(--sub);line-height:1.7;margin-bottom:1.5rem;max-width:520px;">
      If the report raises questions or you want to talk through what the transformation would look like for your organization, Bill's available for a 30-minute conversation.
    </p>
    <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8"
       class="btn-primary" target="_blank" rel="noopener">
      Schedule a conversation →
    </a>
    <a href="/" class="back-link">← Back to Treetop Growth Strategy</a>
  </div>
</div>

<script is:inline>
  const QUESTIONS = [
    {
      pillar: "ICP & Data Foundation",
      text: "How would you describe your Ideal Customer Profile (ICP) today?",
      answers: [
        "We have a general sense of who we sell to but it's not formally defined",
        "We have a written ICP but it's over a year old and rarely referenced",
        "We have a defined ICP that we refine quarterly using win/loss data",
        "Our ICP updates dynamically from live signal and conversion data — it's always current"
      ]
    },
    {
      pillar: "ICP & Data Foundation",
      text: "How does your team decide which accounts to prioritize?",
      answers: [
        "Reps choose based on personal preference and past relationships",
        "We use static purchased lists filtered by company size and industry",
        "We layer in intent signals and enrichment tools to score accounts",
        "AI aggregates signals across 10+ sources to surface in-market accounts automatically"
      ]
    },
    {
      pillar: "Outbound & Prospecting",
      text: "How would you describe your outbound prospecting motion?",
      answers: [
        "We don't have a systematic outbound motion — growth comes from inbound and referrals",
        "SDRs do manual research and write personalized messages one account at a time",
        "We use tools like Apollo or Outreach but personalization is still mostly manual",
        "AI handles enrichment, personalization at scale, and triggers outreach based on intent signals"
      ]
    },
    {
      pillar: "Outbound & Prospecting",
      text: "When a target account shows buying intent signals, what happens?",
      answers: [
        "We typically miss these signals entirely",
        "A rep eventually follows up when they happen to notice — timing is inconsistent",
        "We have alerts set up but the response is still manual and often delayed",
        "An automated workflow fires immediate, contextually relevant outreach within minutes"
      ]
    },
    {
      pillar: "Pipeline Intelligence",
      text: "How do you measure the ROI of your GTM investments?",
      answers: [
        "We track activities: calls made, emails sent, meetings booked",
        "We have pipeline reporting but revenue attribution is unclear",
        "We have multi-touch attribution but it's manual and hard to keep current",
        "AI automatically connects every GTM activity to closed revenue outcomes"
      ]
    },
    {
      pillar: "Pipeline Intelligence",
      text: "How quickly can you identify and respond to pipeline health problems?",
      answers: [
        "Usually after the quarter closes — by then it's too late to course-correct",
        "Monthly during pipeline review meetings",
        "Weekly with dashboards, but investigation and response are still manual",
        "Real-time AI alerts flag at-risk deals before they go cold"
      ]
    },
    {
      pillar: "Team & Scalability",
      text: "How dependent is your pipeline growth on headcount?",
      answers: [
        "Every pipeline increase requires proportional headcount increase",
        "We could optimize some, but adding pipeline essentially means adding people",
        "We have some automation but still need significant people per new account tier",
        "Our AI architecture lets the same team handle significantly more pipeline without adding headcount"
      ]
    },
    {
      pillar: "Team & Scalability",
      text: "Where does AI currently sit in your GTM motion?",
      answers: [
        "We've discussed it but haven't moved beyond basic or disconnected tools",
        "We use some AI tools but they're siloed and not connected to each other",
        "We have several AI tools integrated but haven't rebuilt our motion around them",
        "AI is foundational — ICP, outbound, pipeline, and reporting are all AI-native by design"
      ]
    }
  ];

  const PILLARS = ["ICP & Data Foundation", "Outbound & Prospecting", "Pipeline Intelligence", "Team & Scalability"];

  let currentStep = 0;
  let answers = [];
  let totalScore = 0;

  // Build question HTML
  const container = document.getElementById('questions-container');
  QUESTIONS.forEach((q, i) => {
    const div = document.createElement('div');
    div.className = 'step hidden';
    div.id = `step-q${i + 1}`;
    div.innerHTML = `
      <div class="step-inner">
        <div class="q-step-label">Question ${i + 1} of ${QUESTIONS.length}</div>
        <div class="q-pillar">${q.pillar}</div>
        <div class="q-text">${q.text}</div>
        <div class="answers">
          ${q.answers.map((a, j) => `
            <button class="answer-btn" data-q="${i}" data-score="${j}" onclick="selectAnswer(${i}, ${j})">
              <span class="answer-letter">${String.fromCharCode(65 + j)}</span>
              <span>${a}</span>
            </button>
          `).join('')}
        </div>
      </div>
    `;
    container.appendChild(div);
  });

  function getStep(id) {
    return document.getElementById(id);
  }

  function showStep(newId) {
    // Find current visible step
    const allSteps = document.querySelectorAll('.step');
    allSteps.forEach(s => {
      if (!s.classList.contains('hidden')) {
        s.classList.add('exit');
        setTimeout(() => {
          s.classList.add('hidden');
          s.classList.remove('exit');
        }, 350);
      }
    });
    setTimeout(() => {
      const next = document.getElementById(newId);
      if (next) {
        next.classList.remove('hidden');
        next.scrollTop = 0;
      }
    }, 200);
  }

  function updateProgress(step) {
    const pct = Math.round((step / QUESTIONS.length) * 100);
    document.getElementById('progress-bar').style.width = pct + '%';
    const wrap = document.getElementById('progress-bar-wrap');
    wrap.classList.toggle('visible', step > 0);
  }

  function startQuiz() {
    showStep('step-q1');
    updateProgress(0);
  }

  function selectAnswer(qIndex, score) {
    answers[qIndex] = score;

    // Visual feedback
    const btns = document.querySelectorAll(`[data-q="${qIndex}"]`);
    btns.forEach(b => b.classList.remove('selected'));
    document.querySelector(`[data-q="${qIndex}"][data-score="${score}"]`).classList.add('selected');

    // Advance after brief pause
    setTimeout(() => {
      if (qIndex < QUESTIONS.length - 1) {
        showStep(`step-q${qIndex + 2}`);
        updateProgress(qIndex + 1);
      } else {
        // All questions answered — show lead capture
        totalScore = answers.reduce((sum, s) => sum + s, 0);
        showLeadStep();
      }
    }, 420);
  }

  function getTier(score) {
    if (score <= 6) return { label: 'AI-Absent', cls: 'tier-absent', blurb: 'Your GTM motion has significant gaps vs. competitors who have already made the transition. The revenue impact is likely material and growing.' };
    if (score <= 12) return { label: 'AI-Adjacent', cls: 'tier-adjacent', blurb: 'You\'re using AI tools but haven\'t rebuilt your motion around them. Competitors with AI-native architecture are pulling ahead.' };
    if (score <= 18) return { label: 'AI-Augmented', cls: 'tier-augmented', blurb: 'You have a solid foundation. A targeted transformation of your weakest pillars would close the remaining competitive gap.' };
    return { label: 'AI-Native', cls: 'tier-native', blurb: 'Strong position. Your GTM architecture is competitive. Refinement and optimization are the next frontier.' };
  }

  function showLeadStep() {
    const tier = getTier(totalScore);
    document.getElementById('score-display').textContent = `${totalScore}/24`;
    const tierEl = document.getElementById('tier-display');
    tierEl.textContent = tier.label;
    tierEl.className = `score-preview-tier ${tier.cls}`;
    document.getElementById('tier-blurb').textContent = tier.blurb;
    showStep('step-lead');
    updateProgress(QUESTIONS.length);
  }

  function getPillarScores() {
    return {
      icp: (answers[0] || 0) + (answers[1] || 0),
      outbound: (answers[2] || 0) + (answers[3] || 0),
      pipeline: (answers[4] || 0) + (answers[5] || 0),
      team: (answers[6] || 0) + (answers[7] || 0),
    };
  }

  // Form submission
  document.getElementById('lead-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const errEl = document.getElementById('error-msg');
    btn.disabled = true;
    btn.textContent = 'Generating your report...';
    errEl.style.display = 'none';

    const payload = {
      name: document.getElementById('f-name').value.trim(),
      email: document.getElementById('f-email').value.trim(),
      company: document.getElementById('f-company').value.trim(),
      title: document.getElementById('f-title').value.trim(),
      answers,
      pillarScores: getPillarScores(),
      totalScore,
      tier: getTier(totalScore).label,
    };

    try {
      const res = await fetch('/api/quiz-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error('Server error');

      // Show confirmation
      const tier = getTier(totalScore);
      document.getElementById('confirm-score').textContent = `${totalScore}/24`;
      document.getElementById('confirm-tier').textContent = tier.label;
      showStep('step-confirm');
      document.getElementById('progress-bar-wrap').classList.remove('visible');
    } catch (err) {
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send my Gap Report →';
    }
  });
</script>

