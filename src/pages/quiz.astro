  <meta name="description" content="Find out exactly how much pipeline you're leaving to competitors who've already gone AI-native. Free 3-minute assessment." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/quiz" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://treetopgrowthstrategy.com/quiz" />
  <meta property="og:title" content="AI-Native GTM Gap Assessment | Treetop" />
  <meta property="og:description" content="Find out exactly how much pipeline you're leaving to competitors who've already gone AI-native. Free 3-minute assessment." />
  <meta property="og:image" content="https://treetopgrowthstrategy.com/og/quiz.png" />
  <meta property="og:site_name" content="Treetop Growth Strategy" />
