---
export const prerender = true;
import GlobalFooter from '../components/GlobalFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Claude for Real Estate | AI for Agents, Teams & Brokerages | Treetop</title>
  <meta name="description" content="Claude helps real estate agents, teams, and brokerages list more, follow up better, and close faster. Treetop implements AI for real estate businesses." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell-alt { background: #0A1A0A; padding: 2rem; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .cell-icon { font-size: 1.5rem; margin-bottom: 0.75rem; display: block; }
    .cell-title { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .cell-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.65; }
    .chip { display: inline-flex; align-items: center; background: #0A1A0A; border: 1px solid #1A3A1A; padding: 0.5rem 1rem; font-size: 0.8rem; color: #8FAF8F; }
    .chip-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Claude for Real Estate</div>
    <h1 class="hero-h">List More, Follow Up Better,<br/><em style="color:#00C853;font-style:italic;">Close Faster.</em></h1>
    <p class="hero-sub">Top-producing agents and teams don't have time to write everything by hand. Claude handles listing descriptions, follow-up sequences, market reports, and content — so you can focus on clients and closings.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Get Claude Implemented →</a>
      <a href="/services/implementation" class="btn-g">How It Works</a>
    </div>
  </div>
</div>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The real estate production problem</span>
    <h2 class="h2">You're in the relationship business.<br/>Manual production work is stealing your time.</h2>
    <div class="grid-4" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <span class="cell-icon">🏠</span>
        <div class="cell-title">Listing descriptions take forever</div>
        <div class="cell-desc">Every listing needs a unique, compelling description. You know what to say — writing it from scratch every time is what takes the hour.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">📧</span>
        <div class="cell-title">Follow-up sequences are inconsistent</div>
        <div class="cell-desc">Buyer and seller follow-up depends on whoever has time. There's no system — just a mix of good intentions and dropped balls.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">📊</span>
        <div class="cell-title">Market reports are manual</div>
        <div class="cell-desc">Monthly market updates are a full afternoon of pulling data, writing commentary, and formatting. They get skipped more than they get sent.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">📱</span>
        <div class="cell-title">Social content is sporadic</div>
        <div class="cell-desc">You know you should be posting consistently. The content ideas are there — the time to write and schedule them isn't.</div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">What Claude handles</span>
    <h2 class="h2">Six high-leverage Claude workflows<br/>for real estate businesses.</h2>
    <div>
      <div class="step-row">
        <div class="step-num">01</div>
        <div>
          <div class="step-title">Listing Description Generation</div>
          <div class="step-desc">Feed Claude the property details and it writes a compelling listing description — MLS format, full narrative, or both — in minutes. Consistent quality across every listing.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">02</div>
        <div>
          <div class="step-title">Buyer & Seller Follow-Up Sequences</div>
          <div class="step-desc">Multi-touch follow-up sequences for buyers, sellers, and past clients — built by Claude, personalized by stage, running automatically in your CRM.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">03</div>
        <div>
          <div class="step-title">Market Update Newsletters</div>
          <div class="step-desc">Claude turns your market data into a readable, engaging monthly newsletter your sphere actually opens — drafted fast, sent consistently.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">04</div>
        <div>
          <div class="step-title">Offer Summary Documents</div>
          <div class="step-desc">Structured offer comparison summaries for your sellers — Claude organizes the key terms into a clean side-by-side your clients can actually read.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">05</div>
        <div>
          <div class="step-title">Neighborhood Guides</div>
          <div class="step-desc">Evergreen neighborhood content for your website and buyer packets — schools, walkability, local amenities, market stats — drafted by Claude and updated as things change.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">06</div>
        <div>
          <div class="step-title">Social Media Content Calendar</div>
          <div class="step-desc">A month of posts drafted at once — listings, market stats, tips, testimonials — so you're not staring at a blank caption box every morning.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">How it works</span>
    <h2 class="h2">Audit. Build. Optimize.</h2>
    <p class="sub">Three steps from scattered manual production to Claude running your content and communication engine.</p>
    <div>
      <div class="step-row">
        <div class="step-num">1</div>
        <div>
          <div class="step-title">AI Audit — $1,500</div>
          <div class="step-desc">We map where your time goes and where Claude creates the most leverage for your business. You get a clear, prioritized plan. <a href="/services/ai-audit" style="color:#00C853;text-decoration:none;">Learn about the Audit →</a></div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">2</div>
        <div>
          <div class="step-title">Implementation — from $3,500</div>
          <div class="step-desc">We build the Claude workflows, prompts, and systems your team will actually use — integrated with your CRM and existing tools. <a href="/services/implementation" style="color:#00C853;text-decoration:none;">See Implementation details →</a></div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">3</div>
        <div>
          <div class="step-title">Retainer — $1,200/mo</div>
          <div class="step-desc">Ongoing optimization as your market shifts and your team grows. New workflows added, existing ones refined. <a href="/services/retainer" style="color:#00C853;text-decoration:none;">Retainer details →</a></div>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;padding-top:3rem;">
      <a href="/services/ai-audit" class="btn-g">Start with an AI Audit →</a>
      <a href="/claude-for-small-business" class="btn-g">Claude for Small Business →</a>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">Common use cases</span>
    <h2 class="h2">What real estate businesses use Claude for.</h2>
    <div class="chip-grid">
      <span class="chip">Listing Descriptions</span>
      <span class="chip">Buyer Follow-Up</span>
      <span class="chip">Seller Follow-Up</span>
      <span class="chip">Market Reports</span>
      <span class="chip">Offer Summaries</span>
      <span class="chip">Neighborhood Guides</span>
      <span class="chip">Social Content</span>
      <span class="chip">Past Client Newsletters</span>
      <span class="chip">CMA Narratives</span>
    </div>
  </div>
</section>

<section id="contact" style="background:#0A1A0A;">
  <div class="sec-inner" style="max-width:680px;">
    <span class="lbl">Get Started</span>
    <h2 class="h2">Let's build Claude into<br/>your real estate business.</h2>
    <p class="sub">Tell us where you're spending time that Claude should handle — and we'll show you exactly how to build it.</p>
    <div id="contact-form">
      <div class="form-grid">
        <div>
          <label class="form-label">First Name</label>
          <input class="input-field" type="text" id="first_name" placeholder="Jane" />
        </div>
        <div>
          <label class="form-label">Last Name</label>
          <input class="input-field" type="text" id="last_name" placeholder="Smith" />
        </div>
      </div>
      <div class="form-field">
        <label class="form-label">Work Email</label>
        <input class="input-field" type="email" id="email" placeholder="jane@smithrealty.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Brokerage / Team Name</label>
        <input class="input-field" type="text" id="company" placeholder="Smith Realty Group" />
      </div>
      <div class="form-field">
        <label class="form-label">What would you gain from getting Claude working in your real estate business?</label>
        <textarea class="input-field" id="gain" placeholder="Faster listings, consistent follow-up, more time with clients instead of writing..." style="min-height:100px;resize:vertical;"></textarea>
      </div>
      <button class="btn-p" id="submit-btn" style="width:100%;justify-content:center;" onclick="submitForm()">Get Claude Implemented →</button>
      <p style="font-size:0.75rem;color:#4A6A4A;margin-top:0.75rem;text-align:center;">We respond within one business day. Takes 3 min.</p>
    </div>
    <div class="thankyou" id="thankyou">
      <div class="thankyou-h">You're in good hands.</div>
      <p style="color:#8FAF8F;">We'll be in touch within one business day.</p>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, gain: document.getElementById('gain').value, source: 'claude-for-real-estate' }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get Claude Implemented →'; btn.disabled = false; }
}
</script>
</body>
</html>
