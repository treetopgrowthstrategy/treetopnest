---
export const prerender = true;
import GlobalFooter from '../components/GlobalFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>How to Use AI in Your Business | Treetop Growth Strategy</title>
  <meta name="description" content="Not sure how to use AI in your business? Treetop moves you from curious to fully implemented — Claude workflows built for your team, with real results." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell-alt { background: #0A1A0A; padding: 2rem; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .cell-icon { font-size: 1.5rem; margin-bottom: 0.75rem; display: block; }
    .cell-title { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .cell-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.65; }
    .editorial-block { padding: 2.5rem 0; border-bottom: 1px solid #1A3A1A; max-width: 740px; }
    .editorial-block:last-child { border-bottom: none; }
    .editorial-lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 0.75rem; display: block; }
    .editorial-h { font-family: 'Instrument Serif', serif; font-size: 1.4rem; font-weight: 400; color: #F0FFF0; margin-bottom: 0.75rem; line-height: 1.3; }
    .editorial-p { font-size: 0.92rem; color: #8FAF8F; line-height: 1.8; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>How to Use AI</div>
    <h1 class="hero-h">Stop wondering how to use AI.<br/><em style="color:#00C853;font-style:italic;">We'll just do it for you.</em></h1>
    <p class="hero-sub">Treetop moves you from "I know AI should help somehow" to a fully implemented Claude setup your whole team uses — with real workflows and measured results.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Get It Implemented →</a>
      <a href="/services" class="btn-g">Our Services</a>
    </div>
  </div>
</div>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Where most businesses get stuck</span>
    <h2 class="h2">The gap between knowing AI helps<br/>and actually using it.</h2>
    <div class="grid-4" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <span class="cell-icon">🤔</span>
        <div class="cell-title">Know it should help, but not how</div>
        <div class="cell-desc">You read the articles. You understand the potential. You can't translate that into actual changes to how your team works.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">🗺️</span>
        <div class="cell-title">Don't know where to start</div>
        <div class="cell-desc">Too many use cases, too many tools, too many opinions. Without a clear starting point, you don't start.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">🏝️</span>
        <div class="cell-title">Started, but not systematic</div>
        <div class="cell-desc">You're using it occasionally, for some things, inconsistently. Helpful, but nowhere near transformative.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-icon">🧑‍🤝‍🧑</span>
        <div class="cell-title">Team not on board</div>
        <div class="cell-desc">You're the only one using it. The rest of your team is waiting for training, direction, or a reason to change.</div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">The Basics</span>
    <h2 class="h2">What actually matters about<br/>AI for your business.</h2>
    <div>
      <div class="editorial-block">
        <span class="editorial-lbl">01 — The Mental Model</span>
        <div class="editorial-h">AI is a writing and thinking assistant — not a replacement for judgment.</div>
        <p class="editorial-p">The businesses getting real value from AI aren't automating decisions. They're accelerating production work — first drafts, research summaries, structured thinking. Claude is exceptionally good at taking your knowledge and turning it into output. Your expertise is still what makes the output useful.</p>
      </div>
      <div class="editorial-block">
        <span class="editorial-lbl">02 — Why Configuration Matters</span>
        <div class="editorial-h">The value is in how you set it up, not just how you use it.</div>
        <p class="editorial-p">Out of the box, Claude is a powerful general tool. Configured correctly — with your business context, brand voice, and standard operating procedures loaded as system prompts — it becomes something your whole team can run consistently and rely on. The setup is what most businesses skip, and it's why most AI experiments don't stick.</p>
      </div>
      <div class="editorial-block">
        <span class="editorial-lbl">03 — The Real Unlock</span>
        <div class="editorial-h">Implementation beats experimentation every time.</div>
        <p class="editorial-p">Experimenting with prompts is interesting. Building repeatable workflows is transformative. The difference is structure — clear inputs, configured Claude Projects, team training, and a process your team can run without thinking about it. That's implementation, and it's what we do.</p>
      </div>
    </div>
  </div>
</section>

<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">What we do</span>
    <h2 class="h2">From "I know it should help"<br/>to "I can't imagine working without it."</h2>
    <div>
      <div class="step-row">
        <div class="step-num">01</div>
        <div>
          <div class="step-title">Workflow Audit</div>
          <div class="step-desc">We map your current work and identify the specific tasks Claude should handle — prioritized by time saved and quality impact.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">02</div>
        <div>
          <div class="step-title">Claude Configuration</div>
          <div class="step-desc">Full setup — account, Projects, system prompts, knowledge base — everything done before your team touches it.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">03</div>
        <div>
          <div class="step-title">Workflow Build</div>
          <div class="step-desc">Working processes your team can run repeatedly — not templates, actual workflows with inputs, prompts, and outputs defined.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">04</div>
        <div>
          <div class="step-title">Documentation</div>
          <div class="step-desc">Simple playbooks for each workflow so anyone on your team can run them without coming back to us.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">05</div>
        <div>
          <div class="step-title">Team Training</div>
          <div class="step-desc">Hands-on sessions until everyone is using the workflows confidently — not slides, actual practice on your actual work.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">06</div>
        <div>
          <div class="step-title">ROI Measurement</div>
          <div class="step-desc">Before-and-after tracking on the specific workflows we built. Real numbers that show what implementation is worth.</div>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;padding-top:3rem;">
      <a href="/claude-for-small-business" class="btn-g">Claude for Small Business →</a>
      <a href="/services" class="btn-g">All Services →</a>
    </div>
  </div>
</section>

<section id="contact" style="background:#050D05;">
  <div class="sec-inner" style="max-width:680px;">
    <span class="lbl">Get Started</span>
    <h2 class="h2">Stop wondering how.<br/>Let us just do it.</h2>
    <p class="sub">Tell us where you are with AI and we'll show you exactly what implementation looks like for your team.</p>
    <div id="contact-form">
      <div class="form-grid">
        <div>
          <label class="form-label">First Name</label>
          <input class="input-field" type="text" id="first_name" placeholder="Jane" />
        </div>
        <div>
          <label class="form-label">Last Name</label>
          <input class="input-field" type="text" id="last_name" placeholder="Smith" />
        </div>
      </div>
      <div class="form-field">
        <label class="form-label">Work Email</label>
        <input class="input-field" type="email" id="email" placeholder="jane@company.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Company</label>
        <input class="input-field" type="text" id="company" placeholder="Acme Inc." />
      </div>
      <div class="form-field">
        <label class="form-label">What would you gain if Claude handled the work that's slowing your team down?</label>
        <textarea class="input-field" id="message" placeholder="Time for strategy, faster client turnaround, real adoption..." style="min-height:100px;resize:vertical;"></textarea>
      </div>
      <button class="btn-p" id="submit-btn" style="width:100%;justify-content:center;" onclick="submitForm()">Get It Implemented →</button>
      <p style="font-size:0.75rem;color:#4A6A4A;margin-top:0.75rem;text-align:center;">We respond within one business day. Takes 3 min.</p>
    </div>
    <div class="thankyou" id="thankyou">
      <div class="thankyou-h">You're in good hands.</div>
      <p style="color:#8FAF8F;">We'll be in touch within one business day.</p>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, message: document.getElementById('message').value, source: 'how-to-use-ai' }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get It Implemented →'; btn.disabled = false; }
}
</script>
</body>
</html>
