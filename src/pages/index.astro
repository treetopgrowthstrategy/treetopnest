---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Treetop Growth Strategy | Fix the System. Fix the Growth."
  description="From first touch to retained customer — Treetop owns marketing, sales, and customer success as one connected revenue engine."
>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-brand-border bg-brand-dark/95 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <span class="font-display font-bold text-lg text-white tracking-widest uppercase">Treetop</span>
      <div class="hidden md:flex items-center gap-8 text-sm text-gray-400 font-body">
        <a href="#how-it-works" class="hover:text-brand-green transition-colors">How It Works</a>
        <a href="#capabilities" class="hover:text-brand-green transition-colors">Capabilities</a>
      </div>
      <a href="#contact" class="bg-brand-green text-brand-dark font-body font-bold text-sm px-5 py-2.5 rounded-full hover:brightness-110 transition-all">
        Book a Call
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center pt-16 px-6 text-center">
    <div class="max-w-4xl mx-auto w-full py-24">
      <h1 class="font-display font-black text-5xl md:text-7xl leading-[1.05] tracking-tight mb-6 text-white">
        You Don't Have a<br />Growth Problem.<br />You Have a System Problem.
      </h1>
      <p class="text-gray-400 text-lg md:text-xl font-body font-light max-w-2xl mx-auto mb-10 leading-relaxed">
        From first touch to retained customer — I own marketing, sales, and customer success as one connected revenue engine.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <a href="#contact" class="bg-brand-green text-brand-dark font-body font-bold text-base px-8 py-4 rounded-full hover:brightness-110 transition-all">Book a Call</a>
        <a href="#how-it-works" class="border border-brand-border text-white font-body font-bold text-base px-8 py-4 rounded-full hover:border-brand-green/50 transition-all">See How It Works</a>
      </div>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        {["Marketing", "Sales", "Customer Success"].map((label, i) => (
          <div class="flex items-center gap-4">
            <div class="border border-brand-green/40 text-brand-green text-sm font-body font-semibold px-6 py-3 rounded-lg">{label}</div>
            {i < 2 && <span class="text-brand-green/40 text-xl">→</span>}
          </div>
        ))}
      </div>
      <p class="text-brand-green/60 text-xs font-body mt-4 uppercase tracking-widest">Revenue Loop</p>
    </div>
  </section>

  <!-- THE CHALLENGE -->
  <section class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand-green font-body font-semibold text-xs uppercase tracking-widest mb-4">— The Challenge</p>
      <h2 class="font-display font-black text-4xl md:text-5xl mb-6 text-white max-w-2xl">Most Teams Are Fragmented. Revenue Suffers.</h2>
      <p class="text-gray-400 text-lg max-w-xl mb-6 leading-relaxed">
        Marketing generates leads. Sales tries to close them. CS deals with what's left. No alignment. No ownership. Growth stalls.
      </p>
      <p class="text-brand-green font-body font-semibold text-lg">I don't optimize pieces. I build and run the entire system.</p>
    </div>
  </section>

  <!-- FULL LIFECYCLE OWNERSHIP -->
  <section class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display font-black text-4xl md:text-5xl mb-4 text-white">Full Customer Lifecycle Ownership</h2>
      <p class="text-gray-400 text-lg max-w-xl mb-16 leading-relaxed">Growth comes from how functions work together — not how hard each one works alone.</p>
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        {[
          { title: "Marketing", body: "Positioning, demand generation, architecture, competitive positioning, brand narrative" },
          { title: "Sales", body: "Conversion systems, deal velocity, pipeline management" },
          { title: "Customer Success", body: "Onboarding, activation, retention, expansion revenue" }
        ].map(item => (
          <div class="bg-brand-card border border-brand-border rounded-xl p-8 hover:border-brand-green/30 transition-colors">
            <div class="w-6 h-px bg-brand-green mb-4"></div>
            <h3 class="font-display font-bold text-xl mb-3 text-white">{item.title}</h3>
            <p class="text-gray-400 font-body text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
      <p class="text-brand-green font-body font-semibold text-center">When these three run as one system, revenue compounds.</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display font-black text-4xl md:text-5xl mb-16 text-white">Built Like an Operator Would Run It</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {[
          { step: "01", title: "Diagnose", body: "Map the full lifecycle. Find where revenue leaks." },
          { step: "02", title: "Prioritize", body: "Identify the highest-impact constraint." },
          { step: "03", title: "Build", body: "Hands-on implementation across all three functions." },
          { step: "04", title: "Scale", body: "Double down on what drives revenue. Cut the rest." }
        ].map(item => (
          <div>
            <p class="font-display font-black text-4xl text-brand-green mb-2">{item.step}</p>
            <div class="w-full h-px bg-brand-border mb-4"></div>
            <h3 class="font-body font-bold text-white mb-2">{item.title}</h3>
            <p class="text-gray-400 font-body text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section id="capabilities" class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand-green font-body font-semibold text-xs uppercase tracking-widest mb-4">Capabilities</p>
      <h2 class="font-display font-black text-4xl md:text-5xl mb-16 text-white">What Gets Built</h2>
      <div class="grid md:grid-cols-4 gap-6">
        {[
          { title: "Lifecycle Positioning", body: "ICP definition, messaging architecture, competitive positioning, brand narrative" },
          { title: "Pipeline + Conversion Engine", body: "Demand gen, outbound systems, deal results, CRM architecture, lead scoring" },
          { title: "Revenue Operations", body: "Dashboards, automations, attribution, closed-loop reporting, ops infrastructure" },
          { title: "Retention + Expansion", body: "Onboarding activation, churn prediction, expansion playbooks, NPS-to-revenue loops" }
        ].map(item => (
          <div class="bg-brand-card border border-brand-border rounded-xl p-6 hover:border-brand-green/30 transition-colors">
            <div class="w-6 h-6 rounded-full bg-brand-green/10 border border-brand-green/30 flex items-center justify-center mb-4">
              <div class="w-2 h-2 rounded-full bg-brand-green"></div>
            </div>
            <h3 class="font-body font-bold text-white mb-3 text-sm">{item.title}</h3>
            <p class="text-gray-400 font-body text-xs leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FIT CHECK -->
  <section class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-brand-green font-body font-semibold text-xs uppercase tracking-widest mb-4">Fit Check</p>
        <h2 class="font-display font-black text-4xl mb-8 text-white">For Founders Who Want a Real Revenue Engine</h2>
        <ul class="space-y-3">
          {[
            "You have traction but growth is inconsistent",
            "Your GTM feels disconnected across functions",
            "No one owns the full customer lifecycle",
            "You need predictable, scalable revenue — not more campaigns"
          ].map(item => (
            <li class="flex items-start gap-3 text-gray-400 font-body text-sm">
              <span class="text-brand-green mt-0.5">→</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-brand-card border border-brand-border rounded-xl p-8">
        <p class="text-gray-400 font-body mb-4 leading-relaxed">If you want someone to run campaigns, this isn't it.</p>
        <p class="text-brand-green font-body font-semibold text-lg leading-relaxed">If you want someone to own revenue, let's talk.</p>
      </div>
    </div>
  </section>

  <!-- THE OPERATOR -->
  <section class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="text-brand-green font-body font-semibold text-xs uppercase tracking-widest mb-4">The Operator</p>
        <h2 class="font-display font-black text-4xl mb-4 text-white">End-to-End Operator</h2>
        <p class="text-gray-400 font-body leading-relaxed">Most GTM leaders specialize in one function. I've operated across all three and built the systems that connect them.</p>
      </div>
      <ul class="space-y-3 pt-8">
        {[
          "Full lifecycle experience — marketing, sales, CS",
          "Built GTM systems, not just campaigns",
          "Revenue-focused, not activity-focused",
          "Operator mindset — I build, not advise"
        ].map(item => (
          <li class="flex items-start gap-3 text-gray-400 font-body text-sm">
            <span class="text-brand-green mt-0.5">→</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- AI NATIVE -->
  <section class="px-6 py-24 border-t border-brand-border text-center">
    <div class="max-w-2xl mx-auto">
      <p class="text-brand-green font-body font-semibold text-xs uppercase tracking-widest mb-4">— AI-Native</p>
      <h2 class="font-display font-black text-4xl md:text-5xl mb-6 text-white">AI-Native From Day One</h2>
      <p class="text-gray-400 text-lg font-body leading-relaxed">
        I design AI-native systems across the lifecycle — from prospecting to follow-up to retention. More output. Better conversion. Less headcount dependency.
      </p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section id="contact" class="px-6 py-24 border-t border-brand-border text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display font-black text-5xl md:text-6xl mb-6 text-white">Fix the System.<br />Fix the Growth.</h2>
      <p class="text-gray-400 text-lg mb-10 leading-relaxed">Inconsistent growth isn't bad luck. It's a system problem.<br />Let's find it and fix it.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSferFXOK9Car63jMGfEceATp5WdpgxzVUNqU2EL-HOgS613TQ/viewform?usp=header" class="bg-brand-green text-brand-dark font-body font-bold text-lg px-10 py-5 rounded-full hover:brightness-110 transition-all">Book a Call</a>
        <a href="mailto:bill@treetopgrowthstrategy.com" class="border border-brand-border text-white font-body font-bold text-lg px-10 py-5 rounded-full hover:border-brand-green/50 transition-all">Send a Note</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-brand-border px-6 py-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-gray-500 text-sm">
      <span class="font-display font-bold text-white uppercase tracking-widest">Treetop</span>
      <p>© {new Date().getFullYear()} Treetop Growth Strategy. All rights reserved.</p>
    </div>
  </footer>

</Layout>
