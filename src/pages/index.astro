---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import GlobalNav from '../components/GlobalNav.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
---

<Layout
  title="Treetop Growth Strategy: Fractional CMO Leadership and an AI-Native Revenue Engine"
  description="A real fractional CMO plus the AI-native revenue engine we build in-house, installed in your company. Try the AI CMO free, or book a strategy call to see the fit."
  canonicalUrl="https://treetopgrowthstrategy.com/"
>
<script type="application/ld+json" slot="schema">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Treetop Growth Strategy",
  "description": "Fractional CMO leadership plus an AI-native revenue engine for growing B2B companies at $2M to $50M.",
  "url": "https://treetopgrowthstrategy.com/",
  "brand": { "@type": "Brand", "name": "Treetop Growth Strategy" },
  "founder": { "@type": "Person", "name": "Bill Colbert" },
  "offers": [
    { "@type": "Offer", "name": "Starter Report", "price": "99", "priceCurrency": "USD", "description": "One-time competitive teardown and 90-day roadmap, same day.", "url": "https://treetopgrowthstrategy.com/ai-cmo-advisor" },
    { "@type": "Offer", "name": "Revenue Engine Audit", "price": "1500", "priceCurrency": "USD", "description": "Five-day written diagnosis and roadmap, credited toward implementation.", "url": "https://treetopgrowthstrategy.com/services/ai-audit" },
    { "@type": "Offer", "name": "Monitor", "price": "249", "priceCurrency": "USD", "description": "Monthly competitive refresh and what-changed memo.", "url": "https://treetopgrowthstrategy.com/pricing" },
    { "@type": "Offer", "name": "Guided", "price": "999", "priceCurrency": "USD", "description": "Monthly working call plus asset review.", "url": "https://treetopgrowthstrategy.com/pricing" },
    { "@type": "Offer", "name": "Embedded", "price": "2500", "priceCurrency": "USD", "description": "Part-time CMO who produces the work with you.", "url": "https://treetopgrowthstrategy.com/pricing" },
    { "@type": "Offer", "name": "Fractional CMO", "priceCurrency": "USD", "description": "Retainer, custom scope. Marketing leadership that owns the number.", "url": "https://treetopgrowthstrategy.com/fractional-cmo" },
    { "@type": "Offer", "name": "Fractional CRO", "priceCurrency": "USD", "description": "Retainer, custom scope. Full revenue lifecycle leadership.", "url": "https://treetopgrowthstrategy.com/fractional-cro" }
  ]
}
</script>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim { animation: fadeUp 0.65s ease forwards; opacity: 0; }
  .d1{animation-delay:0.05s} .d2{animation-delay:0.18s} .d3{animation-delay:0.32s}
  .d4{animation-delay:0.46s} .d5{animation-delay:0.6s}

  .badge { display:inline-flex; align-items:center; gap:8px; font-size:0.72rem; font-weight:500; color:#00C853; letter-spacing:0.06em; }
  .badge-dot { width:7px; height:7px; border-radius:50%; background:#00C853; flex-shrink:0; }

  .btn-p { display:inline-flex; align-items:center; gap:6px; background:#00C853; color:#050D05; padding:0.875rem 1.75rem; font-family:'DM Sans',sans-serif; font-size:0.85rem; font-weight:600; text-decoration:none; border:none; cursor:pointer; transition:opacity 0.2s,transform 0.15s; white-space:nowrap; }
  .btn-p:hover { opacity:0.88; transform:translateY(-1px); }

  .btn-g { display:inline-flex; align-items:center; gap:6px; background:transparent; color:#F0FFF0; padding:0.875rem 1.75rem; font-family:'DM Sans',sans-serif; font-size:0.85rem; font-weight:600; text-decoration:none; border:1px solid #1A3A1A; transition:border-color 0.2s,background 0.2s; }
  .btn-g:hover { border-color:rgba(0,200,83,0.4); background:rgba(0,200,83,0.05); }

  .lbl { font-size:0.68rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#00C853; margin-bottom:1.25rem; display:block; }

  .rule { width:100%; height:1px; background:#1A3A1A; }

  .card-dark { background:#050D05; border:1px solid #1A3A1A; padding:2rem; flex:1; min-width:0; transition:border-color 0.2s; }
  .card-dark:hover { border-color:rgba(0,200,83,0.35); }

  .card-outline { background:#0A1A0A; border:1px solid #1A3A1A; padding:1.75rem; transition:border-color 0.2s; }
  .card-outline:hover { border-color:rgba(0,200,83,0.35); }

  /* Outcome tiles */
  .tiles { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-top:2rem; }
  .tile { background:#050D05; border:1px solid #1A3A1A; padding:1.75rem; transition:border-color 0.2s,background 0.2s; }
  .tile:hover { border-color:rgba(0,200,83,0.35); background:#071307; }
  .tile-num { font-family:'Instrument Serif',serif; font-size:1.8rem; font-style:italic; color:rgba(0,200,83,0.35); line-height:1; margin-bottom:1rem; }
  .tile-name { font-family:'Instrument Serif',serif; font-size:1.15rem; color:#F0FFF0; font-weight:400; margin-bottom:0.5rem; line-height:1.3; }
  .tile-body { font-size:0.84rem; color:#8FAF8F; line-height:1.65; }

  /* Plan steps */
  .plan { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-top:2rem; }
  .step { background:#0A1A0A; border:1px solid #1A3A1A; padding:2rem 1.75rem; }
  .step-num { font-family:'Instrument Serif',serif; font-size:2.2rem; font-style:italic; color:#00C853; line-height:1; margin-bottom:1rem; }
  .step-name { font-family:'Instrument Serif',serif; font-size:1.25rem; color:#F0FFF0; font-weight:400; margin-bottom:0.5rem; }
  .step-body { font-size:0.9rem; color:#8FAF8F; line-height:1.7; }

  /* Guide + method */
  .method-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-top:2rem; }
  .m-card { background:#050D05; border:1px solid #1A3A1A; padding:1.75rem; transition:border-color 0.2s; }
  .m-card:hover { border-color:rgba(0,200,83,0.35); }
  .m-label { font-size:0.6rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#00C853; margin-bottom:0.75rem; }
  .m-name { font-family:'Instrument Serif',serif; font-size:1.35rem; color:#F0FFF0; font-weight:400; margin-bottom:0.5rem; }
  .m-body { font-size:0.86rem; color:#8FAF8F; line-height:1.7; }

  /* Proof strip */
  .proof-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:#1A3A1A; margin-top:1.5rem; }
  .proof-cell { background:#050D05; padding:1.5rem 1.25rem; text-align:center; }
  .proof-mark { font-family:'Instrument Serif',serif; font-size:1.05rem; color:#F0FFF0; font-weight:400; font-style:italic; margin-bottom:0.35rem; line-height:1.25; }
  .proof-sub { font-size:0.72rem; color:#8FAF8F; letter-spacing:0.03em; line-height:1.5; }

  /* AI-native vs AI-decorated comparison */
  .compare { display:grid; grid-template-columns:180px 1fr 1fr; gap:1px; background:#1A3A1A; margin-top:1.75rem; }
  .compare-cell { background:#050D05; padding:1.1rem 1.25rem; font-size:0.88rem; line-height:1.55; }
  .compare-head { background:#0A1A0A; font-family:'DM Sans',sans-serif; font-size:0.68rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#4A6A4A; padding:0.9rem 1.25rem; }
  .compare-head.decorated { color:#8FAF8F; }
  .compare-head.native { color:#00C853; }
  .compare-key { color:#F0FFF0; font-weight:500; }
  .compare-neg { color:#8FAF8F; }
  .compare-pos { color:#C0D8C0; }

  /* Cost anchor */
  .cost-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:#1A3A1A; margin-top:1.75rem; }
  .cost-col { background:#050D05; padding:1.75rem 1.5rem; display:flex; flex-direction:column; gap:0.6rem; }
  .cost-col.featured { background:#071407; border-top:2px solid #00C853; }
  .cost-name { font-family:'Instrument Serif',serif; font-size:1.2rem; color:#F0FFF0; font-weight:400; }
  .cost-price { font-family:'Instrument Serif',serif; font-size:1.5rem; color:#00C853; line-height:1.1; }
  .cost-price.gray { color:#8FAF8F; }
  .cost-line { font-size:0.85rem; color:#8FAF8F; line-height:1.6; }
  .cost-line strong { color:#F0FFF0; font-weight:500; }

  /* Deliverable preview */
  .memo { background:#0A1A0A; border:1px solid #1A3A1A; margin-top:1.75rem; overflow:hidden; }
  .memo-head { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.5rem; border-bottom:1px solid #1A3A1A; background:#050D05; flex-wrap:wrap; gap:0.75rem; }
  .memo-title { font-family:'Instrument Serif',serif; font-size:1.15rem; color:#F0FFF0; font-style:italic; }
  .memo-meta { font-size:0.72rem; color:#4A6A4A; letter-spacing:0.06em; }
  .memo-body { padding:1.75rem; display:grid; grid-template-columns:repeat(2,1fr); gap:1.25rem 2rem; }
  .memo-block { }
  .memo-block-label { font-size:0.62rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#00C853; margin-bottom:0.5rem; }
  .memo-block-body { font-size:0.88rem; color:#C0D8C0; line-height:1.65; }
  .memo-block-body em { font-style:italic; color:#F0FFF0; }

  /* Fit filter */
  .fit-row { display:grid; grid-template-columns:repeat(2,1fr); gap:1rem; margin-top:1.75rem; }
  .fit-col { background:#050D05; border:1px solid #1A3A1A; padding:2rem 1.75rem; }
  .fit-col.yes { border-color:rgba(0,200,83,0.35); }
  .fit-head { font-family:'Instrument Serif',serif; font-size:1.3rem; color:#F0FFF0; font-weight:400; margin-bottom:1.25rem; }
  .fit-head.yes { color:#00C853; }
  .fit-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.65rem; }
  .fit-list li { font-size:0.92rem; color:#C0D8C0; line-height:1.6; padding-left:1.5rem; position:relative; }
  .fit-list li::before { content:''; position:absolute; left:0; top:0.55rem; width:8px; height:8px; border-radius:50%; }
  .fit-list.yes li::before { background:#00C853; }
  .fit-list.no li::before { background:#4A6A4A; }

  /* FAQ */
  .faq { border-top:1px solid #1A3A1A; margin-top:1.75rem; }
  .faq-item { border-bottom:1px solid #1A3A1A; padding:1.5rem 0; }
  .faq-q { font-family:'Instrument Serif',serif; font-size:1.15rem; color:#F0FFF0; font-weight:400; margin-bottom:0.75rem; line-height:1.35; }
  .faq-a { font-size:0.94rem; color:#8FAF8F; line-height:1.75; }
  .faq-a a { color:#00C853; text-decoration:none; border-bottom:1px solid rgba(0,200,83,0.3); }

  /* Ladder (three grouped rows) */
  .lgroup { border:1px solid #1A3A1A; margin-bottom:1rem; }
  .lgroup-head { display:flex; align-items:baseline; justify-content:space-between; gap:1rem; padding:1.1rem 1.5rem; background:#0A1A0A; border-bottom:1px solid #1A3A1A; flex-wrap:wrap; }
  .lgroup-title { font-family:'Instrument Serif',serif; font-size:1.35rem; color:#F0FFF0; font-weight:400; }
  .lgroup-title em { font-style:italic; color:#00C853; }
  .lgroup-tag { font-size:0.65rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#4A6A4A; }
  .lgroup-rungs { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:#1A3A1A; }
  .lrung { background:#050D05; padding:1.4rem 1.35rem; display:flex; flex-direction:column; }
  .lrung.featured { background:#071407; }
  .lrung-name { font-family:'Instrument Serif',serif; font-size:1.1rem; color:#F0FFF0; font-weight:400; margin-bottom:0.35rem; }
  .lrung-name .tag { display:inline-block; font-family:'DM Sans',sans-serif; font-size:0.55rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; background:rgba(0,200,83,0.14); color:#00C853; padding:2px 6px; margin-left:0.4rem; vertical-align:middle; }
  .lrung-price { font-family:'Instrument Serif',serif; font-size:1.55rem; color:#00C853; line-height:1; margin-bottom:0.6rem; }
  .lrung-price small { font-family:'DM Sans',sans-serif; font-size:0.62rem; color:#4A6A4A; font-weight:400; }
  .lrung-desc { font-size:0.8rem; color:#8FAF8F; line-height:1.6; flex:1; margin-bottom:0.9rem; }
  .lrung-link { font-size:0.78rem; color:#00C853; text-decoration:none; }
  .lrung.two-up { grid-column:span 1; }
  .lgroup.two-cols .lgroup-rungs { grid-template-columns:repeat(2,1fr); }
  .lgroup.floor .lgroup-rungs { grid-template-columns:repeat(2,1fr); }

  @media(max-width:900px){
    .tiles { grid-template-columns:repeat(2,1fr); }
    .plan { grid-template-columns:1fr; }
    .method-row { grid-template-columns:1fr; }
    .lgroup-rungs, .lgroup.two-cols .lgroup-rungs, .lgroup.floor .lgroup-rungs { grid-template-columns:1fr !important; }
    .proof-row { grid-template-columns:repeat(2,1fr); }
    .cost-row { grid-template-columns:1fr; }
    .compare { grid-template-columns:1fr; }
    .compare-cell.compare-key { background:#0A1A0A; }
    .memo-body { grid-template-columns:1fr; }
    .fit-row { grid-template-columns:1fr; }
  }
  @media(max-width:768px){
    .mob-col { flex-direction:column !important; }
  }
  @media(max-width:520px){
    .tiles { grid-template-columns:1fr; }
    .proof-row { grid-template-columns:1fr; }
  }
</style>

<GlobalNav active="" />

<!-- HERO -->
<section style="min-height:92vh;display:flex;flex-direction:column;justify-content:center;padding:7rem 2.5rem 5rem;background:#050D05;">
  <div style="max-width:1200px;margin:0 auto;width:100%;">
    <div class="badge anim d1" style="margin-bottom:2rem;"><span class="badge-dot"></span>Fractional CMO leadership, AI-native</div>
    <h1 class="anim d2" style="font-family:'Instrument Serif',serif;font-size:clamp(2.8rem,6vw,5rem);font-weight:400;line-height:1.08;color:#F0FFF0;max-width:960px;margin-bottom:1.75rem;letter-spacing:-0.01em;">
      Stop doing random acts of marketing. Start running a <span style="font-style:italic;color:#00C853;">revenue engine.</span>
    </h1>
    <p class="anim d3" style="font-size:1.1rem;font-weight:300;color:#8FAF8F;max-width:680px;line-height:1.8;margin-bottom:2.5rem;">
      Treetop pairs a real fractional CMO with the AI-native revenue engine we build in-house. Not another agency, not another slide deck. The same system we run inside Billy and Fitagentic, installed in your company, with Bill leading the work.
    </p>
    <div class="anim d4 mob-col" style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;">
      <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" class="btn-p">Book a strategy call &rarr;</a>
      <a href="/ai-cmo-advisor/free" class="btn-g">Or try the AI CMO free &rarr;</a>
    </div>
    <p class="anim d5" style="font-size:0.75rem;color:rgba(240,255,240,0.4);letter-spacing:0.04em;">30-minute call &middot; no deck, no pitch &middot; you leave with a read on where to start</p>
  </div>
</section>

<div class="rule"></div>

<!-- PROOF STRIP -->
<section style="padding:3rem 2.5rem;background:#0A1A0A;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
      <span class="lbl" style="margin-bottom:0;">Operator track record</span>
      <a href="/about" style="font-size:0.78rem;color:#00C853;text-decoration:none;">Read the full story &rarr;</a>
    </div>
    <div class="proof-row">
      <div class="proof-cell">
        <div class="proof-mark">Factor_</div>
        <div class="proof-sub">Former CMO. Acquired by HelloFresh. INC 5000 two years running.</div>
      </div>
      <div class="proof-cell">
        <div class="proof-mark">amSTATZ</div>
        <div class="proof-sub">Former VP Sales &amp; Marketing. Acquired by NASM.</div>
      </div>
      <div class="proof-cell">
        <div class="proof-mark">HubSpot Partner</div>
        <div class="proof-sub">12+ years running a HubSpot partner agency.</div>
      </div>
      <div class="proof-cell">
        <div class="proof-mark">Billy &amp; Fitagentic</div>
        <div class="proof-sub">AI-native revenue products we build in-house, in production today.</div>
      </div>
    </div>
    <p style="font-size:0.82rem;color:#4A6A4A;line-height:1.7;margin-top:1.25rem;max-width:820px;">
      Named client stories and Clutch reviews land here as the current cohort agrees to be featured. Every engagement is under NDA by default; nothing goes on the page without written sign-off.
    </p>
  </div>
</section>

<div class="rule"></div>

<!-- AI-NATIVE VS AI-DECORATED CALLOUT -->
<section style="padding:5rem 2.5rem;background:#050D05;">
  <div style="max-width:1080px;margin:0 auto;">
    <span class="lbl">Why this is different</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.9rem,3.8vw,2.8rem);font-weight:400;color:#F0FFF0;line-height:1.15;margin-bottom:1rem;max-width:820px;">
      AI-native is a build order. AI-decorated is a coat of paint.
    </h2>
    <p style="font-size:0.98rem;color:#8FAF8F;line-height:1.8;max-width:720px;">
      Every agency now claims AI. Here is the difference between building the engine that way and bolting a chatbot onto the old one.
    </p>

    <div class="compare">
      <div class="compare-cell compare-head">Dimension</div>
      <div class="compare-cell compare-head decorated">AI-decorated agency</div>
      <div class="compare-cell compare-head native">AI-native Treetop</div>

      <div class="compare-cell compare-key">Memory</div>
      <div class="compare-cell compare-neg">Slack threads, ad-hoc notes, whatever the current strategist remembers.</div>
      <div class="compare-cell compare-pos">Persistent competitor, ICP, and revenue memory the system keeps current on its own.</div>

      <div class="compare-cell compare-key">Learning</div>
      <div class="compare-cell compare-neg">Humans re-brief the tool every campaign.</div>
      <div class="compare-cell compare-pos">The system retrains on your data every month. What worked in October informs November on its own.</div>

      <div class="compare-cell compare-key">Method</div>
      <div class="compare-cell compare-neg">The old playbook plus a GPT wrapper in the sales flow.</div>
      <div class="compare-cell compare-pos">Engine designed around AI as a first-class team member, not a bolt-on.</div>

      <div class="compare-cell compare-key">What you get</div>
      <div class="compare-cell compare-neg">Slide decks, tactic lists, and a monthly status call.</div>
      <div class="compare-cell compare-pos">A priority move for the month, shipped assets, and a system you own.</div>
    </div>

    <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
      <a href="/ai-cmo-advisor/free" class="btn-p">Try the AI CMO free &rarr;</a>
      <span style="font-size:0.8rem;color:#4A6A4A;">See what the engine actually produces before you talk to anyone.</span>
    </div>
  </div>
</section>

<div class="rule"></div>

<!-- STAKES -->
<section style="padding:5rem 2.5rem;background:#0A1A0A;">
  <div style="max-width:1080px;margin:0 auto;">
    <span class="lbl">Where most companies get stuck</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.9rem,3.8vw,2.8rem);font-weight:400;color:#F0FFF0;line-height:1.15;margin-bottom:1.5rem;max-width:820px;">
      When no one truly leads marketing, growth becomes a gamble.
    </h2>
    <p style="font-size:1.05rem;color:#8FAF8F;line-height:1.85;max-width:820px;margin-bottom:1.25rem;">
      You have a freelancer, a few tools, maybe an agency on retainer, and a stack of dashboards nobody trusts. Spend goes out. Results are murky. Every quarter you get asked where growth will come from, and the honest answer is you are not sure.
    </p>
    <p style="font-size:1.05rem;color:#C0D8C0;line-height:1.85;max-width:820px;font-weight:500;">
      That is not a budget problem. It is a leadership problem, and it compounds.
    </p>
  </div>
</section>

<div class="rule"></div>

<!-- VALUE: 4 OUTCOME TILES -->
<section style="padding:5rem 2.5rem;background:#050D05;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="lbl">What you get with Treetop</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.9rem,3.8vw,2.8rem);font-weight:400;color:#F0FFF0;line-height:1.15;margin-bottom:1rem;max-width:820px;">
      A leader in the room. A system underneath. Growth you can predict.
    </h2>
    <p style="font-size:0.98rem;color:#8FAF8F;line-height:1.8;max-width:720px;">Four outcomes we install, in that order. The engine follows from the leadership, not the other way around.</p>

    <div class="tiles">
      <div class="tile">
        <div class="tile-num">01</div>
        <div class="tile-name">A leader in the room</div>
        <div class="tile-body">Strategy and ownership, not just more execution. Someone accountable for the number who has run one before.</div>
      </div>
      <div class="tile">
        <div class="tile-num">02</div>
        <div class="tile-name">An engine that compounds</div>
        <div class="tile-body">Built on the Revenue Engine Method: Memory, then Intelligence, then Motion. Each month makes the next month easier.</div>
      </div>
      <div class="tile">
        <div class="tile-num">03</div>
        <div class="tile-name">Clarity in every growth conversation</div>
        <div class="tile-body">The numbers, the plan, and one owner of the number. You walk in prepared, not defensive.</div>
      </div>
      <div class="tile">
        <div class="tile-num">04</div>
        <div class="tile-name">Senior leadership without the seven-figure bet</div>
        <div class="tile-body">A proven CMO on your terms. Not a $300K hire you have to figure out how to manage.</div>
      </div>
    </div>
  </div>
</section>

<div class="rule"></div>

<!-- COST ANCHOR -->
<section style="padding:5rem 2.5rem;background:#0A1A0A;">
