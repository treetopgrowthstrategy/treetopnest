---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
---

<Layout
  title="AI CMO Advisor: $99 Competitive Analysis & 90-Day Roadmap | Treetop"
  description="Get a competitive analysis and 90-day marketing roadmap built on real CMO judgment for $99. Live Ahrefs data, delivered same day. Climb to Monitor, Guided, Embedded, or a custom Enterprise engagement whenever you're ready."
  canonicalUrl="https://treetopgrowthstrategy.com/"
>
<script type="application/ld+json" slot="schema">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "AI CMO Advisor",
  "description": "Competitive analysis and 90-day marketing roadmap built on real CMO judgment, powered by live Ahrefs data.",
  "url": "https://treetopgrowthstrategy.com/",
  "brand": { "@type": "Brand", "name": "Treetop Growth Strategy" },
  "offers": [
    { "@type": "Offer", "price": "99", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "Starter Report: one-time competitive analysis and 90-day roadmap", "url": "https://treetopgrowthstrategy.com/ai-cmo-advisor" },
    { "@type": "Offer", "price": "249", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "Monitor: monthly competitive refresh and what-changed memo", "url": "https://treetopgrowthstrategy.com/pricing" },
    { "@type": "Offer", "price": "999", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "Guided: monthly working call, deeper analysis, we shape your assets", "url": "https://treetopgrowthstrategy.com/pricing" },
    { "@type": "Offer", "price": "2500", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "Embedded: part-time CMO who produces the work with you", "url": "https://treetopgrowthstrategy.com/pricing" },
    { "@type": "Offer", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "Enterprise: custom-scoped AI-native GTM transformation", "url": "https://treetopgrowthstrategy.com/fractional-cmo" }
  ]
}
</script>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim { animation: fadeUp 0.65s ease forwards; opacity: 0; }
  .d1{animation-delay:0.05s} .d2{animation-delay:0.18s} .d3{animation-delay:0.32s}
  .d4{animation-delay:0.46s} .d5{animation-delay:0.6s}

  .nav-link { font-size:0.82rem; font-weight:400; color:rgba(240,255,240,0.5); text-decoration:none; transition:color 0.2s; }
  .nav-link:hover { color:#F0FFF0; }

  .badge { display:inline-flex; align-items:center; gap:8px; font-size:0.72rem; font-weight:500; color:#00C853; letter-spacing:0.06em; }
  .badge-dot { width:7px; height:7px; border-radius:50%; background:#00C853; flex-shrink:0; }

  .btn-p { display:inline-flex; align-items:center; gap:6px; background:#00C853; color:#050D05; padding:0.875rem 1.75rem; font-family:'DM Sans',sans-serif; font-size:0.85rem; font-weight:600; text-decoration:none; border:none; cursor:pointer; transition:opacity 0.2s,transform 0.15s; white-space:nowrap; }
  .btn-p:hover { opacity:0.88; transform:translateY(-1px); }

  .btn-g { display:inline-flex; align-items:center; gap:6px; background:transparent; color:#F0FFF0; padding:0.875rem 1.75rem; font-family:'DM Sans',sans-serif; font-size:0.85rem; font-weight:600; text-decoration:none; border:1px solid #1A3A1A; transition:border-color 0.2s,background 0.2s; }
  .btn-g:hover { border-color:rgba(0,200,83,0.4); background:rgba(0,200,83,0.05); }

  .lbl { font-size:0.68rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#00C853; margin-bottom:1.25rem; display:block; }

  .card-dark { background:#050D05; border:1px solid #1A3A1A; padding:2rem; flex:1; min-width:0; transition:border-color 0.2s; }
  .card-dark:hover { border-color:rgba(0,200,83,0.35); }

  .card-mid { background:#0A1A0A; border:1px solid #1A3A1A; padding:2rem; flex:1; min-width:0; transition:border-color 0.2s,background 0.2s; }
  .card-mid:hover { border-color:rgba(0,200,83,0.35); background:#0f200f; }

  .rule { width:100%; height:1px; background:#1A3A1A; }

  .who-card { background:#050D05; border:1px solid #1A3A1A; padding:2rem; flex:1; min-width:240px; transition:border-color 0.2s; }
  .who-card:hover { border-color:rgba(0,200,83,0.35); }

  .quiz-box { border:1px solid rgba(0,200,83,0.25); background:#0A1A0A; padding:2.5rem; display:flex; flex-direction:column; gap:1rem; align-items:flex-start; }

  /* Ladder */
  .ladder { display:grid; grid-template-columns:repeat(5,1fr); gap:1px; background:#1A3A1A; border:1px solid #1A3A1A; }
  .rung { background:#050D05; padding:1.6rem 1.4rem; display:flex; flex-direction:column; position:relative; }
  .rung.featured { background:#071407; }
  .rung-step { font-size:0.6rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#4A6A4A; margin-bottom:0.75rem; }
  .rung-step em { color:#00C853; font-style:normal; }
  .rung-name { font-family:'Instrument Serif',serif; font-size:1.15rem; color:#F0FFF0; font-weight:400; margin-bottom:0.3rem; }
  .rung-price { font-family:'Instrument Serif',serif; font-size:1.7rem; color:#00C853; line-height:1; margin-bottom:0.6rem; }
  .rung-price small { font-family:'DM Sans',sans-serif; font-size:0.66rem; color:#4A6A4A; font-weight:400; }
  .rung-desc { font-size:0.8rem; color:#8FAF8F; line-height:1.55; flex:1; }

  @media(max-width:768px){
    .mob-col { flex-direction:column !important; }
    .hide-mob { display:none !important; }
    .ladder { grid-template-columns:1fr; }
  }
</style>

<!-- NAV -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(5,13,5,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #1A3A1A;">
  <div style="max-width:1200px;margin:0 auto;padding:0 2.5rem;height:64px;display:flex;align-items:center;justify-content:space-between;">
    <a href="/" style="font-family:'Instrument Serif',serif;font-size:1.3rem;font-style:italic;color:#F0FFF0;text-decoration:none;">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2.5rem;align-items:center;">
      <a href="/ai-cmo-advisor" class="nav-link">AI CMO Advisor</a>
      <a href="/pricing" class="nav-link">Pricing</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="/ai-cmo-advisor" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get my report &rarr;</a>
  </div>
</nav>

<!-- HERO -->
<section style="min-height:92vh;display:flex;flex-direction:column;justify-content:center;padding:7rem 2.5rem 5rem;background:#050D05;">
  <div style="max-width:1200px;margin:0 auto;width:100%;">
    <div class="badge anim d1" style="margin-bottom:2rem;"><span class="badge-dot"></span>AI CMO Advisor · $99 to start</div>
    <h1 class="anim d2" style="font-family:'Instrument Serif',serif;font-size:clamp(2.8rem,6vw,5rem);font-weight:400;line-height:1.08;color:#F0FFF0;max-width:920px;margin-bottom:1.75rem;letter-spacing:-0.01em;">
      A fractional CMO's read<br/>on your <span style="font-style:italic;color:#00C853;">competitors,</span><br/>for $99.
    </h1>
    <p class="anim d3" style="font-size:1.05rem;font-weight:300;color:#8FAF8F;max-width:620px;line-height:1.8;margin-bottom:2.5rem;">
      Live Ahrefs data on the companies you're actually competing with, a keyword gap analysis, and a 90-day roadmap. Delivered same day. Most people start here. Some climb to a monthly plan. If you ever want us to actually run it with you, that's on the table too.
    </p>
    <div class="anim d4 mob-col" style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;">
      <a href="/ai-cmo-advisor" class="btn-p">Get my report &rarr;</a>
      <a href="/ai-cmo-advisor/sample-report" class="btn-g">See a sample report &rarr;</a>
    </div>
    <p class="anim d5" style="font-size:0.75rem;color:rgba(240,255,240,0.4);letter-spacing:0.04em;">$99 to start &middot; live Ahrefs data &middot; same-day delivery &middot; no subscription required</p>
  </div>
</section>

<!-- WHAT YOU GET -->
<div class="rule"></div>
<section style="padding:5rem 2.5rem;background:#0A1A0A;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="lbl">What you get</span>
    <div class="mob-col" style="display:flex;gap:4rem;align-items:flex-start;margin-bottom:2.5rem;">
      <div style="flex:1;min-width:260px;">
        <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;margin-bottom:1.25rem;">
          Not another tool.<br/>An actual answer.
        </h2>
        <p style="font-size:1rem;color:#8FAF8F;line-height:1.8;">Most AI marketing tools draft content for you to post. This tells you what to prioritize in the first place, built on your specific competitors and your specific numbers.</p>
      </div>
      <div style="flex:1.4;min-width:260px;display:flex;flex-direction:column;gap:1rem;">
        <div class="card-dark">
          <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:rgba(0,200,83,0.2);margin-bottom:0.75rem;">01</div>
          <div style="font-size:0.92rem;font-weight:600;color:#F0FFF0;margin-bottom:0.6rem;">Competitive snapshot</div>
          <p style="font-size:0.84rem;color:#8FAF8F;line-height:1.7;">Live Ahrefs data on up to 3 competitors you name. Domain authority, organic traffic, top pages. Where you actually stand.</p>
        </div>
        <div class="card-dark">
          <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:rgba(0,200,83,0.2);margin-bottom:0.75rem;">02</div>
          <div style="font-size:0.92rem;font-weight:600;color:#F0FFF0;margin-bottom:0.6rem;">Keyword gap and growth levers</div>
          <p style="font-size:0.84rem;color:#8FAF8F;line-height:1.7;">The high-value terms your competitors win that you don't, and the three moves that matter most for your stage and budget.</p>
        </div>
        <div class="card-dark">
          <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:rgba(0,200,83,0.2);margin-bottom:0.75rem;">03</div>
          <div style="font-size:0.92rem;font-weight:600;color:#F0FFF0;margin-bottom:0.6rem;">A 90-day roadmap</div>
          <p style="font-size:0.84rem;color:#8FAF8F;line-height:1.7;">Month 1, month 2, month 3. Concrete milestones, not themes. Plus what I'd tell you to do this week if we were sitting across the table.</p>
        </div>
      </div>
    </div>
    <a href="/ai-cmo-advisor" class="btn-g" style="font-size:0.85rem;">See all six sections in the report &rarr;</a>
  </div>
</section>

<!-- THE LADDER -->
<div class="rule"></div>
<section style="padding:5rem 2.5rem;background:#050D05;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="lbl">How this works</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;max-width:640px;margin-bottom:1rem;">Start at $99. Climb only as far as you need.</h2>
    <p style="font-size:0.95rem;color:#8FAF8F;line-height:1.8;max-width:640px;margin-bottom:2.5rem;">Five steps, and each one does more of the work for you. The axis is simple: the higher you climb, the more we do instead of you. Most people never leave the first step, and no step locks you into the next.</p>

    <div class="ladder">
      <div class="rung">
        <div class="rung-step">Step <em>01</em> &middot; Diagnose</div>
        <div class="rung-name">Starter Report</div>
        <div class="rung-price">$99<small> once</small></div>
        <div class="rung-desc">Live competitive data, keyword gaps, and a 90-day roadmap. Same day.</div>
      </div>
      <div class="rung">
        <div class="rung-step">Step <em>02</em> &middot; Monitor</div>
        <div class="rung-name">Monitor</div>
        <div class="rung-price">$249<small>/mo</small></div>
        <div class="rung-desc">The report kept current every month, with a what-changed memo.</div>
      </div>
      <div class="rung featured">
        <div class="rung-step">Step <em>03</em> &middot; Guide</div>
        <div class="rung-name">Guided</div>
        <div class="rung-price">$999<small>/mo</small></div>
        <div class="rung-desc">A monthly working call and a strategist who shapes your assets.</div>
      </div>
      <div class="rung">
        <div class="rung-step">Step <em>04</em> &middot; Embed</div>
        <div class="rung-name">Embedded</div>
        <div class="rung-price">$2,500<small>/mo</small></div>
        <div class="rung-desc">A part-time CMO who produces the work with you, not just advice.</div>
      </div>
      <div class="rung">
        <div class="rung-step">Step <em>05</em> &middot; Transform</div>
        <div class="rung-name">Enterprise</div>
        <div class="rung-price">Custom</div>
        <div class="rung-desc">The whole revenue motion rebuilt around AI. Custom-scoped.</div>
      </div>
    </div>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem;align-items:center;">
      <a href="/ai-cmo-advisor" class="btn-p">Get my report &rarr;</a>
      <a href="/pricing" class="btn-g">Compare all five steps &rarr;</a>
    </div>
  </div>
</section>

<!-- READY FOR MORE -->
<div class="rule"></div>
<section id="fractional" style="padding:5rem 2.5rem;background:#0A1A0A;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="lbl">For when you want it run, not just advised</span>
    <div class="mob-col" style="display:flex;gap:4rem;align-items:flex-start;">
      <div style="flex:1;min-width:260px;">
        <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;color:#F0FFF0;line-height:1.2;margin-bottom:1.25rem;">
          Some companies need<br/>more than a report.
        </h2>
        <p style="font-size:1rem;color:#8FAF8F;line-height:1.8;margin-bottom:0.75rem;">If the roadmap is right but you don't have anyone to actually build it, that's a fractional CMO engagement: dynamic ICP, AI-augmented outbound, pipeline intelligence, and the workflows that tie them together, built and run alongside your team over 90 days.</p>
        <p style="font-size:1rem;color:#00C853;font-weight:500;margin-bottom:1.5rem;">Most clients start with the $99 report. A few graduate here.</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="/fractional-cmo" class="btn-p">See fractional CMO &rarr;</a>
          <a href="/quiz" class="btn-g">Take the free Gap Assessment &rarr;</a>
        </div>
      </div>
      <div style="flex:1.2;min-width:260px;background:#050D05;border:1px solid #1A3A1A;padding:2rem;">
        <div style="display:flex;flex-wrap:wrap;">
          <div style="flex:1;min-width:120px;padding:1rem;border-right:1px solid #1A3A1A;border-bottom:1px solid #1A3A1A;">
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#00C853;line-height:1;margin-bottom:0.25rem;">$127M+</div>
            <div style="font-size:0.75rem;color:#8FAF8F;line-height:1.4;">Pipeline Generated</div>
          </div>
          <div style="flex:1;min-width:120px;padding:1rem;border-bottom:1px solid #1A3A1A;">
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#F0FFF0;line-height:1;margin-bottom:0.25rem;">38</div>
            <div style="font-size:0.75rem;color:#8FAF8F;line-height:1.4;">GTM Systems Built</div>
          </div>
          <div style="flex:1;min-width:120px;padding:1rem;border-right:1px solid #1A3A1A;">
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#F0FFF0;line-height:1;margin-bottom:0.25rem;">4.2x</div>
            <div style="font-size:0.75rem;color:#8FAF8F;line-height:1.4;">Avg Revenue Multiple</div>
          </div>
          <div style="flex:1;min-width:120px;padding:1rem;">
            <div style="font-family:'Instrument Serif',serif;font-size:2rem;font-style:italic;color:#00C853;line-height:1;margin-bottom:0.25rem;">90</div>
            <div style="font-size:0.75rem;color:#8FAF8F;line-height:1.4;">Days to Velocity</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FREE TOOLS & RESOURCES -->
<div class="rule"></div>
<section id="resources" style="padding:5rem 2.5rem;background:#050D05;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="lbl" style="font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;display:block;">Free tools &amp; resources</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(2rem,4vw,2.75rem);font-weight:400;line-height:1.12;color:#F0FFF0;margin-bottom:1rem;">Open-source thinking, <em style="color:#00C853;font-style:italic;">free.</em></h2>
    <p style="font-size:0.95rem;color:#8FAF8F;line-height:1.75;max-width:680px;margin-bottom:2.5rem;">
      250+ resources: calculators, playbooks, prompt libraries, frameworks, composite case studies, and industry-specific AI playbooks that we use with clients. Free. No email gates. Use them whether you ever hire us or not.
    </p>

    <!-- 3-column tier showcase -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:2.5rem;" class="resources-grid">

      <!-- Calculators column -->
      <div style="background:#0A1A0A;border:1px solid #1A3A1A;padding:1.75rem;">
        <div style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;">🧮 Interactive Calculators · 9</div>
        <h3 style="font-family:'Instrument Serif',serif;font-size:1.25rem;color:#F0FFF0;font-weight:400;margin-bottom:1rem;line-height:1.3;">Move sliders. Get answers.</h3>
        <ul style="list-style:none;padding:0;font-size:0.85rem;line-height:1.7;">
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/ai-roi-calculator" style="color:#C0D8C0;text-decoration:none;">→ AI ROI Calculator</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/fractional-cmo-roi-calculator" style="color:#C0D8C0;text-decoration:none;">→ Fractional CMO ROI</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/pipeline-coverage-calculator" style="color:#C0D8C0;text-decoration:none;">→ Pipeline Coverage</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/ai-readiness-scorecard" style="color:#C0D8C0;text-decoration:none;">→ AI Readiness Scorecard</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/cac-payback-calculator" style="color:#C0D8C0;text-decoration:none;">→ CAC Payback</a></li>
          <li style="padding:0.35rem 0;"><a href="/marketing-team-capacity-calculator" style="color:#C0D8C0;text-decoration:none;">→ Marketing Capacity</a></li>
        </ul>
        <a href="/resources#calculators" style="display:inline-block;margin-top:1rem;font-size:0.82rem;color:#00C853;text-decoration:none;">See all 9 calculators →</a>
      </div>

      <!-- Playbooks column -->
      <div style="background:#0A1A0A;border:1px solid #1A3A1A;padding:1.75rem;">
        <div style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;">📖 Long-form Playbooks · 4</div>
        <h3 style="font-family:'Instrument Serif',serif;font-size:1.25rem;color:#F0FFF0;font-weight:400;margin-bottom:1rem;line-height:1.3;">How we think, in writing.</h3>
        <ul style="list-style:none;padding:0;font-size:0.85rem;line-height:1.7;">
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/the-90-day-ai-rollout-playbook" style="color:#C0D8C0;text-decoration:none;">→ 90-Day AI Rollout Playbook</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/the-ai-native-gtm-framework" style="color:#C0D8C0;text-decoration:none;">→ AI-Native GTM Framework</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-to-build-an-ai-native-sales-team" style="color:#C0D8C0;text-decoration:none;">→ Build an AI-Native Sales Team</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-to-evaluate-an-ai-consultant" style="color:#C0D8C0;text-decoration:none;">→ Evaluate an AI Consultant</a></li>
          <li style="padding:0.35rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-we-work" style="color:#C0D8C0;text-decoration:none;">→ How We Work (engagement arc)</a></li>
          <li style="padding:0.35rem 0;"><a href="/why-most-ai-implementations-fail" style="color:#C0D8C0;text-decoration:none;">→ Why Most AI Implementations Fail</a></li>
        </ul>
        <a href="/resources#playbooks" style="display:inline-block;margin-top:1rem;font-size:0.82rem;color:#00C853;text-decoration:none;">See all playbooks →</a>
      </div>

      <!-- Prompt libraries column -->
      <div style="background:#0A1A0A;border:1px solid #1A3A1A;padding:1.75rem;">
        <div style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;">⚡ Prompt Libraries · 50+</div>
