<script is:inline>
window._cmoFormLoadTime = Date.now();

async function callSignup(email, hp, website) {
  return fetch('/api/cmo-signup', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, hp, website: website || '', _t: window._cmoFormLoadTime })
  });
}

async function submitHero() {
  var btn = document.getElementById('hero-btn');
  var email = document.getElementById('hero-email').value.trim();
  var err = document.getElementById('err-msg');
  var hp = document.getElementById('hp-hero').value;
  var website = document.getElementById('hero-website').value.trim();
  if (!email || email.indexOf('@') === -1) {
    err.textContent = 'Please enter a valid work email.';
    err.style.display = 'block';
    return;
  }
  err.style.display = 'none';
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await callSignup(email, hp, website);
    document.getElementById('signup-form').style.display = 'none';
    document.getElementById('sent-to').textContent = email;
    document.getElementById('signup-success').style.display = 'block';
  } catch (e) {
    btn.textContent = 'Get my CMO report →'; btn.disabled = false;
    err.textContent = 'Something went wrong. Email bill@treetopgrowthstrategy.com and we will sort it out.';
    err.style.display = 'block';
  }
}

async function submitCta() {
  var btn = document.getElementById('cta-btn');
  var email = document.getElementById('cta-email').value.trim();
  var err = document.getElementById('cta-err');
  var hp = document.getElementById('hp-cta').value;
  if (!email || email.indexOf('@') === -1) {
    err.textContent = 'Please enter a valid work email.';
    err.style.display = 'block';
    return;
  }
  err.style.display = 'none';
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await callSignup(email, hp, '');
    document.getElementById('cta-form').style.display = 'none';
    document.getElementById('cta-sent-to').textContent = email;
    document.getElementById('cta-success').style.display = 'block';
  } catch (e) {
    btn.textContent = 'Get my report →'; btn.disabled = false;
    err.textContent = 'Something went wrong. Email bill@treetopgrowthstrategy.com and we will sort it out.';
    err.style.display = 'block';
  }
}

function toggleFaq(el) {
  var ans = el.nextElementSibling;
  el.classList.toggle('open');
  ans.classList.toggle('open');
}

// Scroll hero email form into view when pricing CTA clicked
document.querySelectorAll('a[href="#signup-form"]').forEach(function(a) {
  a.addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('hero-email').scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(function() { document.getElementById('hero-email').focus(); }, 500);
  });
});
</script>
