---
// Treetop Growth Strategy — Managed Marketing Infrastructure
export const prerender = true;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Managed Marketing Stack — Treetop Growth Strategy</title>
<meta name="description" content="Hosting, CRM routing, transactional email, analytics, and monthly site updates — all managed for you. One invoice, zero headaches.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fraunces:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #FAFAF8;
    --surface: #FFFFFF;
    --forest: #1B3A2D;
    --forest-light: #2D5A45;
    --canopy: #3D8B6A;
    --leaf: #4CAF7D;
    --gold: #C49A3C;
    --gold-light: #D4AD55;
    --bark: #5C4A3A;
    --text: #1A1A1A;
    --text-secondary: #5A5A5A;
    --text-muted: #8A8A8A;
    --border: rgba(0,0,0,0.08);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.06);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.08);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 16px 48px;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(250,250,248,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-brand {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--forest);
  }
  .nav-logo {
    width: 32px; height: 32px; background: var(--forest);
    border-radius: 8px; display: flex; align-items: center; justify-content: center;
    color: white; font-weight: 800; font-size: 16px;
  }
  .nav-name { font-weight: 700; font-size: 15px; letter-spacing: -0.3px; }
  .nav-links { display: flex; gap: 32px; align-items: center; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--text-secondary);
    font-size: 14px; font-weight: 500; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    background: var(--forest) !important; color: white !important;
    padding: 10px 20px; border-radius: 8px;
    font-weight: 600 !important; transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--canopy) !important; }

  /* ── HERO ── */
  .hero {
    padding: 160px 48px 100px;
    max-width: 1100px; margin: 0 auto;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(29,58,45,0.06); border: 1px solid rgba(29,58,45,0.1);
    border-radius: 100px; padding: 6px 16px;
    font-size: 13px; font-weight: 600; color: var(--forest);
    margin-bottom: 28px;
  }
  .hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--leaf); animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
  }
  .hero h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(40px, 5.5vw, 64px);
    font-weight: 800; line-height: 1.08;
    letter-spacing: -2px; margin-bottom: 24px;
    color: var(--forest);
  }
  .hero h1 em {
    font-style: italic; color: var(--canopy);
  }
  .hero-sub {
    font-size: 18px; line-height: 1.7; color: var(--text-secondary);
    max-width: 600px; margin: 0 auto 40px;
  }
  .hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 16px 32px; border-radius: 10px;
    text-decoration: none; font-size: 15px; font-weight: 600;
    transition: all 0.2s; border: none; cursor: pointer;
  }
  .btn-primary {
    background: var(--forest); color: white;
  }
  .btn-primary:hover { background: var(--canopy); transform: translateY(-1px); box-shadow: var(--shadow-md); }
  .btn-outline {
    background: transparent; color: var(--forest);
    border: 1.5px solid var(--border);
  }
  .btn-outline:hover { border-color: var(--forest); background: rgba(29,58,45,0.03); }

  /* ── LOGO BAR ── */
  .logo-bar {
    padding: 48px;
    text-align: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .logo-bar-label {
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-muted); margin-bottom: 24px;
  }
  .logo-bar-items {
    display: flex; justify-content: center; align-items: center;
    gap: 48px; flex-wrap: wrap;
    font-size: 14px; font-weight: 600; color: var(--text-secondary);
  }
  .logo-bar-items span { opacity: 0.5; font-size: 20px; }

  /* ── SECTIONS ── */
  .section {
    padding: 100px 48px;
    max-width: 1100px; margin: 0 auto;
  }
  .section-label {
    font-size: 12px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--canopy); margin-bottom: 12px;
  }
  .section-headline {
    font-family: 'Fraunces', serif;
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700; line-height: 1.15; letter-spacing: -1px;
    margin-bottom: 16px; color: var(--forest);
  }
  .section-sub {
    font-size: 16px; line-height: 1.7;
    color: var(--text-secondary); max-width: 560px;
  }
  .section-center { text-align: center; }
  .section-center .section-sub { margin: 0 auto; }

  /* ── WHAT'S INCLUDED ── */
  .stack-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 20px; margin-top: 48px;
  }
  .stack-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px; padding: 32px 28px;
    transition: all 0.2s;
  }
  .stack-card:hover {
    border-color: rgba(29,58,45,0.15);
    box-shadow: var(--shadow-md); transform: translateY(-2px);
  }
  .stack-icon {
    width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; margin-bottom: 20px;
  }
  .icon-green { background: rgba(76,175,125,0.1); }
  .icon-gold { background: rgba(196,154,60,0.1); }
  .icon-forest { background: rgba(29,58,45,0.08); }
  .stack-card h3 {
    font-size: 16px; font-weight: 700; margin-bottom: 8px;
    color: var(--text);
  }
  .stack-card p {
    font-size: 14px; line-height: 1.6; color: var(--text-secondary);
  }

  /* ── HOW IT WORKS ── */
  .steps {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 40px; margin-top: 56px;
  }
  .step { position: relative; }
  .step-num {
    font-family: 'Fraunces', serif;
    font-size: 56px; font-weight: 800;
    color: rgba(29,58,45,0.06); line-height: 1;
    margin-bottom: 12px;
  }
  .step h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
  .step p { font-size: 14px; line-height: 1.7; color: var(--text-secondary); }

  /* ── PRICING ── */
  .pricing-section {
    padding: 100px 48px;
    background: var(--forest);
    color: white;
  }
  .pricing-inner {
    max-width: 1100px; margin: 0 auto;
    text-align: center;
  }
  .pricing-section .section-label { color: var(--leaf); }
  .pricing-section .section-headline { color: white; }
  .pricing-section .section-sub { color: rgba(255,255,255,0.6); margin: 0 auto; }

  .pricing-cards {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px; margin-top: 56px;
    max-width: 1000px; margin-left: auto; margin-right: auto;
  }
  .price-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px; padding: 40px 32px;
    text-align: left; position: relative;
    transition: all 0.2s;
  }
  .price-card:hover {
    background: rgba(255,255,255,0.07);
    transform: translateY(-4px);
  }
  .price-card.featured {
    background: rgba(255,255,255,0.1);
    border-color: var(--leaf);
    box-shadow: 0 0 0 1px var(--leaf), 0 12px 40px rgba(0,0,0,0.2);
  }
  .price-card-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--leaf); color: white;
    padding: 4px 16px; border-radius: 100px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .price-tier {
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: rgba(255,255,255,0.5); margin-bottom: 16px;
  }
  .price-amount {
    font-family: 'Fraunces', serif;
    font-size: 48px; font-weight: 800;
    color: white; margin-bottom: 4px;
  }
  .price-period { font-size: 14px; color: rgba(255,255,255,0.4); margin-bottom: 24px; }
  .price-desc {
    font-size: 14px; line-height: 1.6;
    color: rgba(255,255,255,0.5); margin-bottom: 28px;
    padding-bottom: 28px; border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .price-features {
    list-style: none; display: flex;
    flex-direction: column; gap: 12px; margin-bottom: 32px;
  }
  .price-features li {
    font-size: 14px; color: rgba(255,255,255,0.8);
    padding-left: 24px; position: relative; line-height: 1.5;
  }
  .price-features li::before {
    content: ''; position: absolute; left: 0; top: 6px;
    width: 12px; height: 12px; border-radius: 50%;
    background: rgba(76,175,125,0.2); border: 2px solid var(--leaf);
  }
  .price-btn {
    display: block; width: 100%; padding: 14px;
    border-radius: 10px; text-align: center;
    text-decoration: none; font-size: 14px; font-weight: 600;
    transition: all 0.2s; cursor: pointer; border: none;
  }
  .price-btn-outline {
    background: transparent; color: white;
    border: 1.5px solid rgba(255,255,255,0.2);
  }
  .price-btn-outline:hover { border-color: white; background: rgba(255,255,255,0.05); }
  .price-btn-primary {
    background: var(--leaf); color: white;
  }
  .price-btn-primary:hover { background: var(--canopy); }
  .price-btn-gold {
    background: var(--gold); color: white;
  }
  .price-btn-gold:hover { background: var(--gold-light); }

  /* ── COST BREAKDOWN ── */
  .breakdown {
    margin-top: 56px; max-width: 600px; margin-left: auto; margin-right: auto;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px; padding: 32px;
  }
  .breakdown h4 {
    font-size: 14px; font-weight: 700;
    color: rgba(255,255,255,0.5); letter-spacing: 0.06em;
    text-transform: uppercase; margin-bottom: 20px; text-align: center;
  }
  .breakdown-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 14px;
  }
  .breakdown-row:last-child { border-bottom: none; }
  .breakdown-label { color: rgba(255,255,255,0.6); }
  .breakdown-value { color: rgba(255,255,255,0.9); font-weight: 600; }
  .breakdown-total {
    margin-top: 16px; padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.15);
    display: flex; justify-content: space-between; align-items: center;
  }
  .breakdown-total .breakdown-label {
    color: white; font-weight: 700; font-size: 15px;
  }
  .breakdown-total .breakdown-value {
    color: var(--leaf); font-weight: 800; font-size: 20px;
    font-family: 'Fraunces', serif;
  }

  /* ── COMPARISON ── */
  .compare-section { padding: 100px 48px; }
  .compare-inner { max-width: 900px; margin: 0 auto; }
  .compare-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 32px; margin-top: 48px;
  }
  .compare-card {
    padding: 36px 32px; border-radius: 14px;
  }
  .compare-diy {
    background: #FBF5F0; border: 1px solid rgba(184,92,56,0.15);
  }
  .compare-managed {
    background: rgba(29,58,45,0.04); border: 1px solid rgba(29,58,45,0.1);
  }
  .compare-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 20px; font-weight: 700; margin-bottom: 20px;
  }
  .compare-diy h3 { color: #8B4513; }
  .compare-managed h3 { color: var(--forest); }
  .compare-list {
    list-style: none; display: flex; flex-direction: column; gap: 12px;
  }
  .compare-list li {
    font-size: 14px; line-height: 1.6; padding-left: 24px;
    position: relative; color: var(--text-secondary);
  }
  .compare-list li::before {
    position: absolute; left: 0; font-size: 14px; font-weight: 700;
  }
  .compare-diy .compare-list li::before { content: '✕'; color: #C0856E; }
  .compare-managed .compare-list li::before { content: '✓'; color: var(--canopy); }

  /* ── FAQ ── */
  .faq-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 24px; margin-top: 48px;
  }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 28px;
  }
  .faq-item h4 {
    font-size: 15px; font-weight: 700; margin-bottom: 8px;
  }
  .faq-item p {
    font-size: 14px; line-height: 1.7; color: var(--text-secondary);
  }

  /* ── CTA ── */
  .final-cta-section {
    padding: 120px 48px; text-align: center;
    background: linear-gradient(180deg, var(--bg) 0%, rgba(29,58,45,0.04) 100%);
  }
  .final-cta-section .section-headline {
    max-width: 600px; margin: 0 auto 16px;
  }
  .final-cta-section .section-sub {
    margin: 0 auto 40px;
  }

  /* ── FOOTER ── */
  footer {
    padding: 40px 48px;
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid var(--border); flex-wrap: wrap; gap: 16px;
    max-width: 1200px; margin: 0 auto;
  }
  .footer-brand {
    display: flex; align-items: center; gap: 10px;
    font-weight: 700; font-size: 14px; color: var(--text-secondary);
  }
  .footer-brand-mark {
    width: 24px; height: 24px; border-radius: 6px;
    background: var(--forest); color: white;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 12px;
  }
  .footer-links { display: flex; gap: 24px; list-style: none; }
  .footer-links a { font-size: 13px; color: var(--text-muted); text-decoration: none; }
  .footer-links a:hover { color: var(--text); }
  .footer-copy { font-size: 12px; color: var(--text-muted); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 14px 24px; }
    .nav-links { gap: 20px; }
    .hero { padding: 120px 24px 64px; }
    .section { padding: 64px 24px; }
    .pricing-section { padding: 64px 24px; }
    .stack-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; gap: 32px; }
    .pricing-cards { grid-template-columns: 1fr; max-width: 400px; }
    .price-card.featured { transform: none; }
    .compare-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
    .final-cta-section { padding: 80px 24px; }
    footer { padding: 32px 24px; }
    .logo-bar { padding: 32px 24px; }
    .logo-bar-items { gap: 24px; }
    .compare-section { padding: 64px 24px; }
  }
  @media (max-width: 640px) {
    .nav-links .hide-mobile { display: none; }
    .hero h1 { letter-spacing: -1px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="/stack" class="nav-brand">
    <div class="nav-logo">T</div>
    <span class="nav-name">Treetop Growth Strategy</span>
  </a>
  <ul class="nav-links">
    <li><a href="#whats-included" class="hide-mobile">What's Included</a></li>
    <li><a href="#pricing" class="hide-mobile">Pricing</a></li>
    <li><a href="#faq" class="hide-mobile">FAQ</a></li>
    <li><a href="#pricing" class="nav-cta">Get Started</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">
    <div class="hero-badge-dot"></div>
    Managed Marketing Infrastructure
  </div>
  <h1>Your website, email,<br>analytics &amp; CRM &mdash;<br><em>managed for you.</em></h1>
  <p class="hero-sub">Stop paying five different vendors and duct-taping tools together. We run your entire marketing stack &mdash; hosting, email, forms, analytics, and monthly updates &mdash; for one flat monthly fee.</p>
  <div class="hero-actions">
    <a href="#pricing" class="btn btn-primary">See Plans &amp; Pricing</a>
    <a href="#whats-included" class="btn btn-outline">What's Included</a>
  </div>
</section>

<!-- LOGO BAR -->
<div class="logo-bar">
  <div class="logo-bar-label">Your stack, powered by</div>
  <div class="logo-bar-items">
    <div>Vercel</div>
    <span>&middot;</span>
    <div>Resend</div>
    <span>&middot;</span>
    <div>Airtable</div>
    <span>&middot;</span>
    <div>Stripe</div>
    <span>&middot;</span>
    <div>Cloudflare</div>
    <span>&middot;</span>
    <div>Google Analytics</div>
  </div>
</div>

<!-- WHAT'S INCLUDED -->
<section class="section" id="whats-included">
  <div class="section-label">What's Included</div>
  <h2 class="section-headline">Everything you need.<br>Nothing you don't.</h2>
  <p class="section-sub">Six systems that usually cost $300+ to cobble together yourself &mdash; plus the 10 hours a month to keep them running. We handle all of it.</p>

  <div class="stack-grid">
    <div class="stack-card">
      <div class="stack-icon icon-green">&#127760;</div>
      <h3>Hosting &amp; Domain</h3>
      <p>Lightning-fast site on a global CDN. Custom domain, SSL certificate, and DNS management. 99.9% uptime, zero config on your end.</p>
    </div>
    <div class="stack-card">
      <div class="stack-icon icon-gold">&#9993;</div>
      <h3>Transactional Email</h3>
      <p>Form confirmations, order receipts, lead notifications &mdash; all sent from your domain with proper DKIM/SPF. No more Gmail relay hacks.</p>
    </div>
    <div class="stack-card">
      <div class="stack-icon icon-forest">&#128203;</div>
      <h3>Form &rarr; CRM Routing</h3>
      <p>Every form submission lands in your database automatically. Contact forms, lead magnets, quiz completions &mdash; captured and organized.</p>
    </div>
    <div class="stack-card">
      <div class="stack-icon icon-green">&#128200;</div>
      <h3>Analytics &amp; Reporting</h3>
      <p>Page views, traffic sources, conversion funnels, and top content &mdash; delivered in a monthly report you can actually understand.</p>
    </div>
    <div class="stack-card">
      <div class="stack-icon icon-gold">&#128736;</div>
      <h3>Monthly Site Updates</h3>
      <p>New landing pages, copy changes, seasonal campaigns, blog posts. Up to 4 hours of hands-on updates every month, included.</p>
    </div>
    <div class="stack-card">
      <div class="stack-icon icon-forest">&#128274;</div>
      <h3>Uptime &amp; Security</h3>
      <p>SSL auto-renewal, dependency updates, uptime monitoring, and error alerts. If something breaks at 2am, we fix it &mdash; not you.</p>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section">
  <div class="section-center">
    <div class="section-label">How It Works</div>
    <h2 class="section-headline">Up and running in a week.</h2>
    <p class="section-sub">We migrate your existing site or build from scratch. Either way, you're live fast.</p>
  </div>
  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <h3>Kickoff call</h3>
      <p>30 minutes. We audit your current stack, map your forms and integrations, and agree on the migration plan.</p>
    </div>
    <div class="step">
      <div class="step-num">02</div>
      <h3>We build &amp; migrate</h3>
      <p>Your site goes live on our infrastructure. Domain, SSL, email, forms, analytics &mdash; all wired up and tested.</p>
    </div>
    <div class="step">
      <div class="step-num">03</div>
      <h3>You grow, we maintain</h3>
      <p>Monthly updates, monitoring, and support. You focus on revenue &mdash; we keep the engine running.</p>
    </div>
  </div>
</section>

<!-- DIY vs MANAGED -->
<section class="compare-section">
  <div class="compare-inner">
    <div class="section-center">
      <div class="section-label">Why Managed?</div>
      <h2 class="section-headline">DIY stack vs. Treetop-managed.</h2>
    </div>
    <div class="compare-grid">
      <div class="compare-card compare-diy">
        <h3>Doing It Yourself</h3>
        <ul class="compare-list">
          <li>5+ vendor accounts to manage and pay</li>
          <li>SSL expires and you find out from a customer</li>
          <li>Form breaks silently &mdash; leads vanish for weeks</li>
          <li>Analytics setup takes a weekend, then nobody checks it</li>
          <li>Every site change requires a developer invoice</li>
          <li>Transactional emails land in spam</li>
          <li>"It was working last month" becomes your catchphrase</li>
