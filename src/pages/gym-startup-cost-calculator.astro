.cta-section{background:#0A1A0A;border:1px solid rgba(0,200,83,0.4);padding:2rem;margin-top:2rem}
.cta-section h3{font-family:'Instrument Serif',serif;font-size:1.4rem;color:#F0FFF0;margin-bottom:0.75rem;font-weight:400}
.cta-section p{font-size:0.92rem;color:#8FAF8F;line-height:1.65;margin-bottom:1.25rem;max-width:680px}
.cta-buttons{display:flex;gap:0.75rem;flex-wrap:wrap}
.btn-g{display:inline-flex;align-items:center;gap:6px;background:transparent;color:#F0FFF0;padding:0.875rem 1.5rem;font-size:0.85rem;font-weight:600;text-decoration:none;border:1px solid #1A3A1A}

.body{font-size:0.95rem;color:#C0D8C0;line-height:1.8;max-width:780px;margin-bottom:1rem}
