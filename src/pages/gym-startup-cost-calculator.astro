<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
body{background:#050D05;color:#F0FFF0;font-family:'DM Sans',sans-serif;font-weight:300;-webkit-font-smoothing:antialiased}
nav{position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(5,13,5,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #1A3A1A}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 2.5rem;height:64px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:'Instrument Serif',serif;font-size:1.3rem;font-style:italic;color:#F0FFF0;text-decoration:none}
.nav-link{font-size:0.82rem;color:rgba(240,255,240,0.5);text-decoration:none}.nav-link:hover{color:#F0FFF0}
.btn-p{display:inline-flex;align-items:center;gap:6px;background:#00C853;color:#050D05;padding:0.875rem 1.75rem;font-size:0.85rem;font-weight:600;text-decoration:none}.btn-p:hover{opacity:0.88}
.badge{display:inline-flex;align-items:center;gap:8px;font-size:0.72rem;font-weight:500;color:#00C853;letter-spacing:0.06em;margin-bottom:1.5rem}
.badge-dot{width:7px;height:7px;border-radius:50%;background:#00C853;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
section{padding:4rem 2.5rem;border-top:1px solid #1A3A1A}.sec-inner{max-width:1100px;margin:0 auto}
.hero{min-height:30vh;display:flex;align-items:center;padding:7rem 2.5rem 2rem}.hero-inner{max-width:1100px;margin:0 auto;width:100%}
.hero-h{font-family:'Instrument Serif',serif;font-size:clamp(2.2rem,4.2vw,3.2rem);font-weight:400;line-height:1.1;color:#F0FFF0;margin-bottom:1rem}
.hero-sub{font-size:1rem;color:#C0D8C0;line-height:1.7;max-width:780px}

/* Calculator layout */
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:2rem}
@media(max-width:900px){.calc-grid{grid-template-columns:1fr}}
.calc-inputs{background:#0A1A0A;border:1px solid #1A3A1A;padding:2rem}
.calc-result{background:#0A1A0A;border:1px solid rgba(0,200,83,0.4);padding:2rem;position:sticky;top:90px;align-self:flex-start}
.input-group{margin-bottom:1.75rem}
.input-label{display:block;font-size:0.85rem;font-weight:500;color:#C0D8C0;margin-bottom:0.6rem}
.input-help{font-size:0.78rem;color:#8FAF8F;margin-bottom:0.6rem}
.input-select{width:100%;background:#050D05;border:1px solid #1A3A1A;color:#F0FFF0;padding:0.75rem 1rem;font-family:inherit;font-size:0.95rem;border-radius:0;cursor:pointer}
.input-select:focus{outline:none;border-color:#00C853}
.input-slider-wrap{display:flex;align-items:center;gap:1rem}
.input-slider{flex:1;-webkit-appearance:none;appearance:none;background:#1A3A1A;height:4px;outline:none;border-radius:2px}
.input-slider::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;background:#00C853;width:18px;height:18px;border-radius:50%;cursor:pointer}
.input-slider::-moz-range-thumb{background:#00C853;width:18px;height:18px;border-radius:50%;cursor:pointer;border:none}
.input-value{font-family:'Instrument Serif',serif;font-size:1.2rem;color:#00C853;min-width:80px;text-align:right}

.result-label{font-size:0.72rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.5rem;display:block}
.result-total{font-family:'Instrument Serif',serif;font-size:clamp(2.5rem,5vw,4rem);color:#F0FFF0;line-height:1;margin-bottom:0.5rem}
.result-range{font-size:0.95rem;color:#8FAF8F;margin-bottom:2rem}
.result-breakdown{border-top:1px solid #1A3A1A;padding-top:1.5rem}
.result-row{display:flex;justify-content:space-between;padding:0.65rem 0;border-bottom:1px solid #1A3A1A;font-size:0.92rem}
