  <thead>
    <tr>
      <th>Feature</th>
      <th>Free</th>
      <th>Pro ($20/mo)</th>
      <th class="highlight-row">Team ($30/seat/mo)</th>
      <th>Enterprise</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Minimum seats</td>
      <td>1</td>
      <td>1</td>
      <td class="highlight-row">5</td>
      <td>Custom</td>
    </tr>
