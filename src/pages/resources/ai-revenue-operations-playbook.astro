    .roadmap-body { padding: 1.1rem 1.5rem; }
    .roadmap-body ul { margin-bottom: 0; }
    .roadmap-body ul li { font-size: 0.88rem; color: #8FAF8F; }

    .roi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1px; background: #1A3A1A; border: 1px solid #1A3A1A; margin: 1.5rem 0; }
    .roi-cell { background: #0A1A0A; padding: 1.5rem; }
    .roi-metric { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #00C853; line-height: 1; margin-bottom: 0.4rem; }
    .roi-label { font-size: 0.78rem; color: #4A6A4A; line-height: 1.5; }

    .article-cta { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2.5rem; margin-top: 3rem; text-align: center; }
    .article-cta-h { font-family: 'Instrument Serif', serif; font-size: 1.5rem; color: #F0FFF0; margin-bottom: 0.75rem; font-weight: 400; }
    .article-cta p { font-size: 0.88rem; color: #8FAF8F; margin-bottom: 1.5rem; line-height: 1.7; }
    .cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
