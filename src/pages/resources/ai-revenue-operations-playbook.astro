    .stack-cat { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #4A6A4A; margin-bottom: 0.5rem; display: block; }
    .stack-tool { font-size: 0.9rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.35rem; }
