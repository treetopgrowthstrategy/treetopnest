    .system-desc { font-size: 0.92rem; color: #8FAF8F; line-height: 1.8; margin-bottom: 0.75rem; }
    .system-card ul { margin-bottom: 0; }
    .system-card ul li { font-size: 0.9rem; }

    .stack-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #1A3A1A; border: 1px solid #1A3A1A; margin: 1.5rem 0 2rem; }
