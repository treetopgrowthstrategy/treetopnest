  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; }
    .btn-p:hover { opacity: 0.88; }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 0.75rem; display: block; }
    section { padding: 4rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .hero { min-height: 50vh; display: flex; align-items: center; padding: 7rem 2.5rem 3rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem,5vw,4rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; margin-bottom: 1.25rem; }
    .hero-sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 640px; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 400; line-height: 1.15; color: #F0FFF0; margin-bottom: 0.5rem; }
    .sec-lead { font-size: 0.95rem; color: #8FAF8F; line-height: 1.7; max-width: 720px; margin-bottom: 2rem; }
    /* Quick-nav strip */
    .nav-strip { display: flex; gap: 1rem; flex-wrap: wrap; padding: 1.5rem 0; border-top: 1px solid #1A3A1A; border-bottom: 1px solid #1A3A1A; margin-top: 1rem; }
    .nav-chip { display: inline-flex; align-items: center; gap: 6px; background: #0A1A0A; border: 1px solid #1A3A1A; padding: 0.55rem 1rem; font-size: 0.78rem; color: #C0D8C0; text-decoration: none; transition: border-color 0.2s; }
    .nav-chip:hover { border-color: rgba(0,200,83,0.4); color: #F0FFF0; }
    /* Calculator grid (3 cols) */
    .calc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    @media(max-width:900px) { .calc-grid { grid-template-columns: 1fr; } section { padding: 3.5rem 1.5rem; } .hide-mob{display:none!important} }
    .calc-card { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column; gap: 0.5rem; transition: border-color 0.2s; }
    .calc-card:hover { border-color: rgba(0,200,83,0.4); }
    .calc-icon { font-family: 'Instrument Serif', serif; color: #00C853; font-style: italic; font-size: 0.9rem; letter-spacing: 0.06em; }
    .calc-title { font-family: 'Instrument Serif', serif; font-size: 1.15rem; color: #F0FFF0; font-weight: 400; line-height: 1.3; }
    .calc-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.5; }
    /* Article cards (2 cols for playbooks, 3 cols for others) */
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    @media(max-width:900px) { .grid-2, .grid-3 { grid-template-columns: 1fr; } }
    .item { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column; gap: 0.5rem; transition: border-color 0.2s; }
    .item:hover { border-color: rgba(0,200,83,0.4); }
    .item-cat { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; }
    .item-title { font-family: 'Instrument Serif', serif; font-size: 1.1rem; color: #F0FFF0; font-weight: 400; line-height: 1.3; }
    .item-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.5; }
    .featured { padding: 1.75rem; }
    .featured .item-title { font-size: 1.3rem; }
    .featured .item-desc { font-size: 0.88rem; }
    /* Compact list */
    .compact-list { display: flex; flex-direction: column; gap: 0; }
    .compact-row { display: flex; justify-content: space-between; align-items: center; padding: 0.85rem 0; border-bottom: 1px solid #1A3A1A; text-decoration: none; color: #C0D8C0; font-size: 0.92rem; transition: color 0.2s; }
    .compact-row:hover { color: #00C853; }
    .compact-row span:last-child { color: #4A6A4A; font-size: 0.78rem; }
    /* Subgrid for compact lists in 2 columns */
    .compact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 2.5rem; }
    @media(max-width:900px) { .compact-grid { grid-template-columns: 1fr; gap: 0; } }
    /* CTA strip */
    .cta-box { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
    .cta-text { font-family: 'Instrument Serif', serif; font-size: 1.5rem; color: #F0FFF0; }
    .cta-sub { font-size: 0.88rem; color: #8FAF8F; margin-top: 0.5rem; }
  </style>

