---
import GlobalFooter from '../../components/GlobalFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resources | Treetop Growth Strategy</title>
  <meta name="description" content="Practical guides on Claude implementation, AI workflows for small business, and getting real ROI from AI tools. No hype — just what works." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
    .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s; }
    .card-mid:hover { border-color: rgba(0,200,83,0.35); }
    @media(max-width:768px){ .mob-col{flex-direction:column!important} .hide-mob{display:none!important} section{padding:3.5rem 1.5rem} }

    .hero {
      min-height: 50vh;
      display: flex;
      align-items: center;
      padding-top: 7rem;
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(2.8rem, 5vw, 4rem);
      font-weight: 400;
      line-height: 1.08;
      color: #F0FFF0;
      margin-bottom: 1.25rem;
    }
    .hero-sub {
      font-size: 1rem;
      color: #8FAF8F;
      line-height: 1.75;
      max-width: 560px;
    }

    .articles-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media(max-width:900px){ .articles-grid { grid-template-columns: 1fr; } }

    .article-card {
      background: #0A1A0A;
      border: 1px solid #1A3A1A;
      padding: 2rem;
      transition: border-color 0.2s;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      text-decoration: none;
    }
    .article-card:hover { border-color: rgba(0,200,83,0.35); }

    .article-cat {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #00C853;
    }
    .article-title {
      font-family: 'Instrument Serif', serif;
      font-size: 1.3rem;
      color: #F0FFF0;
      font-weight: 400;
      line-height: 1.25;
      flex: 1;
    }
    .article-excerpt {
      font-size: 0.85rem;
      color: #8FAF8F;
      line-height: 1.7;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.75rem;
      color: #4A6A4A;
    }
    .article-read {
      font-size: 0.82rem;
      color: rgba(240,255,240,0.4);
      margin-top: 0.25rem;
    }

    .cta-box {
      background: #0A1A0A;
      border: 1px solid #1A3A1A;
      padding: 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .cta-text { font-family: 'Instrument Serif', serif; font-size: 1.5rem; color: #F0FFF0; font-weight: 400; }
    .cta-sub { font-size: 0.88rem; color: #8FAF8F; margin-top: 0.5rem; }
    .cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<!-- Hero -->
<div class="hero">
  <div class="hero-inner">
    <div class="badge">
      <span class="badge-dot"></span>
      Resources
    </div>
    <h1 class="hero-h">
      What we've learned<br/>
      <em style="color:#00C853;font-style:italic;">implementing Claude.</em>
    </h1>
    <p class="hero-sub">
      Practical guides on Claude implementation, AI workflows, and getting real ROI from AI tools. Written from direct experience — not theory.
    </p>
  </div>
</div>

<!-- Articles -->
<section>
  <div class="sec-inner">
    <div class="articles-grid">

      <a href="/resources/how-to-set-up-claude-projects" class="article-card">
        <div class="article-cat">Implementation</div>
        <div class="article-title">How to Set Up Claude Projects for Your Small Business</div>
        <div class="article-excerpt">
          Claude Projects are the single most powerful feature most small businesses never configure. Here's exactly how to set them up — system prompts, knowledge base, and all.
        </div>
        <div class="article-meta">
          <span>May 2026</span>
          <span>·</span>
          <span>8 min read</span>
        </div>
        <div class="article-read">Read →</div>
      </a>

      <a href="/resources/claude-vs-chatgpt-small-business" class="article-card">
        <div class="article-cat">Comparison</div>
        <div class="article-title">Claude vs ChatGPT for Small Business: What We've Found After Implementing Both</div>
        <div class="article-excerpt">
          We've implemented both at dozens of businesses. Here's an honest breakdown of which one wins for which use cases — and why Claude is our default recommendation.
        </div>
        <div class="article-meta">
          <span>May 2026</span>
          <span>·</span>
          <span>6 min read</span>
        </div>
        <div class="article-read">Read →</div>
      </a>

      <a href="/resources/five-claude-workflows-small-business" class="article-card">
        <div class="article-cat">Workflow</div>
        <div class="article-title">The 5 Claude Workflows Every Small Business Should Build First</div>
        <div class="article-excerpt">
          Not all AI workflows are created equal. After implementing Claude across many small businesses, these are the five that consistently deliver the most time savings.
        </div>
        <div class="article-meta">
          <span>May 2026</span>
          <span>·</span>
          <span>10 min read</span>
        </div>
        <div class="article-read">Read →</div>
      </a>

    </div>
  </div>
</section>

<!-- CTA -->
<section style="border-top:1px solid #1A3A1A;">
  <div class="sec-inner">
    <div class="cta-box">
      <div>
        <div class="cta-text">Want us to implement these for you?</div>
        <div class="cta-sub">Reading about workflows is useful. Having them built is better.</div>
      </div>
      <div class="cta-btns">
        <a href="/services/implementation" class="btn-p">See Implementation →</a>
        <a href="/services/ai-audit" class="btn-g">Start with an Audit</a>
      </div>
    </div>
  </div>
</section>

<GlobalFooter />

</body>
</html>
