<script is:inline>
async function submitForm() {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending...'; btn.disabled = true;
  try {
    await fetch('/api/lead-capture', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ first_name: document.getElementById('first_name').value, last_name: document.getElementById('last_name').value, email: document.getElementById('email').value, company: document.getElementById('company').value, message: document.getElementById('message').value, source: 'chatgpt-vs-claude' }) });
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('thankyou').style.display = 'block';
  } catch(e) { btn.textContent = 'Get Claude Working →'; btn.disabled = false; }
}
</script>
