---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import GlobalNav from '../components/GlobalNav.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
---

<Layout
  title="Pricing: Diagnose, Run, or Lead your revenue engine | Treetop"
  description="Three ways to work with Treetop. Diagnose your engine at $99 or $1,500. Run it every month at $249, $999, or $2,500. Or hand a fractional CMO the number. Book a strategy call to pick the right rung."
  canonicalUrl="https://treetopgrowthstrategy.com/pricing"
>
<style>
  .lbl { font-size:0.68rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#00C853; margin-bottom:0.75rem; display:block; }
  .btn-p { display:inline-flex; align-items:center; gap:6px; background:#00C853; color:#050D05; padding:0.75rem 1.4rem; font-family:'DM Sans',sans-serif; font-size:0.82rem; font-weight:600; text-decoration:none; white-space:nowrap; transition:opacity 0.2s; }
  .btn-p:hover { opacity:0.88; }
  .btn-g { display:inline-flex; align-items:center; gap:6px; background:transparent; color:#F0FFF0; padding:0.75rem 1.4rem; font-family:'DM Sans',sans-serif; font-size:0.82rem; font-weight:600; text-decoration:none; border:1px solid #1A3A1A; white-space:nowrap; transition:border-color 0.2s,background 0.2s; }
  .btn-g:hover { border-color:rgba(0,200,83,0.4); background:rgba(0,200,83,0.05); }

  .hero { padding:8rem 2.5rem 3rem; }
  .hero-inner { max-width:920px; margin:0 auto; }
  .hero-h { font-family:'Instrument Serif',serif; font-size:clamp(2.5rem,5vw,3.8rem); font-weight:400; line-height:1.08; color:#F0FFF0; margin-bottom:1.25rem; }
  .hero-h em { color:#00C853; font-style:italic; }
  .hero-sub { font-size:1.05rem; color:#C0D8C0; line-height:1.75; max-width:700px; }

  section.pg { padding:4.5rem 2.5rem; border-top:1px solid #1A3A1A; }
  .sec-inner { max-width:1120px; margin:0 auto; }
  .h2 { font-family:'Instrument Serif',serif; font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:400; color:#F0FFF0; margin-bottom:0.75rem; line-height:1.15; }
  .body { font-size:0.95rem; color:#8FAF8F; line-height:1.75; max-width:720px; margin-bottom:1.25rem; }

  /* Grouped stairstep */
  .group-block { border:1px solid #1A3A1A; margin-bottom:2rem; }
  .group-head { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:1.25rem 1.75rem; background:#0A1A0A; border-bottom:1px solid #1A3A1A; flex-wrap:wrap; }
  .group-title { font-family:'Instrument Serif',serif; font-size:1.5rem; color:#F0FFF0; font-weight:400; }
  .group-title em { font-style:italic; color:#00C853; }
  .group-cap { font-size:0.68rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#4A6A4A; }

  .rung { display:grid; grid-template-columns:30px 1fr auto auto; gap:1.5rem; align-items:center; background:#050D05; border-bottom:1px solid #1A3A1A; border-left:3px solid #1A3A1A; padding:1.6rem 1.9rem; transition:border-color 0.2s,background 0.2s; }
  .rung:last-child { border-bottom:none; }
  .rung:hover { background:#0f200f; border-left-color:rgba(0,200,83,0.5); }
  .rung.featured { border-left-color:#00C853; }
  .rung-num { font-family:'Instrument Serif',serif; font-size:1.4rem; font-style:italic; color:rgba(0,200,83,0.35); line-height:1; }
  .rung.featured .rung-num { color:#00C853; }
  .rung-name { font-family:'Instrument Serif',serif; font-size:1.4rem; color:#F0FFF0; font-weight:400; margin-bottom:0.25rem; }
  .rung-name .tag { display:inline-block; font-family:'DM Sans',sans-serif; font-size:0.58rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; background:rgba(0,200,83,0.12); color:#00C853; padding:2px 7px; margin-left:0.6rem; vertical-align:middle; }
  .rung-best { font-size:0.86rem; color:#8FAF8F; line-height:1.5; }
  .rung-best strong { color:#C0D8C0; font-weight:500; }
  .rung-climb { font-size:0.78rem; color:#4A6A4A; font-style:italic; margin-top:0.35rem; }
  .rung-price { font-family:'Instrument Serif',serif; font-size:1.9rem; color:#F0FFF0; line-height:1; text-align:right; white-space:nowrap; }
  .rung-price small { font-family:'DM Sans',sans-serif; font-size:0.72rem; color:#4A6A4A; font-weight:400; display:block; margin-top:0.25rem; }
  .rung-price em { color:#00C853; font-style:normal; }

  /* Comparison table */
  .table-wrap { margin-top:2rem; overflow-x:auto; border:1px solid #1A3A1A; }
  table.cmp { width:100%; min-width:960px; border-collapse:collapse; font-size:0.85rem; }
  table.cmp th, table.cmp td { padding:0.9rem 1rem; text-align:left; border-bottom:1px solid #1A3A1A; vertical-align:top; }
  table.cmp thead th { background:#0A1A0A; color:#F0FFF0; font-weight:600; font-size:0.78rem; }
  table.cmp thead th .th-price { display:block; font-family:'Instrument Serif',serif; font-size:1rem; color:#00C853; font-weight:400; margin-top:0.15rem; }
  table.cmp thead th .th-group { display:block; font-family:'DM Sans',sans-serif; font-size:0.62rem; color:#8FAF8F; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; margin-top:0.35rem; }
  table.cmp tbody th { font-weight:400; color:#C0D8C0; background:#070F07; }
  table.cmp td { color:#8FAF8F; text-align:center; }
  table.cmp td:first-of-type, table.cmp tbody th { text-align:left; }
  table.cmp .yes { color:#00C853; font-weight:600; }
  table.cmp .no { color:#2A4A2A; }
  table.cmp tbody tr:hover td, table.cmp tbody tr:hover th { background:rgba(0,200,83,0.03); }
  table.cmp .row-price th { font-weight:600; color:#F0FFF0; }
  table.cmp .row-price td { color:#F0FFF0; font-weight:500; }

  .faq { background:#0A1A0A; border:1px solid #1A3A1A; padding:1.5rem 1.75rem; margin-bottom:1rem; }
  .faq h3 { font-family:'Instrument Serif',serif; font-size:1.1rem; color:#F0FFF0; font-weight:400; margin-bottom:0.5rem; }
  .faq p { font-size:0.88rem; color:#8FAF8F; line-height:1.7; }
  .faq a { color:#00C853; text-decoration:none; }
  .cta-box { background:#0A1A0A; border:1px solid rgba(0,200,83,0.2); padding:3rem; display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
  .cta-text { font-family:'Instrument Serif',serif; font-size:1.6rem; color:#F0FFF0; }
  .cta-sub { font-size:0.88rem; color:#8FAF8F; margin-top:0.5rem; max-width:560px; }

  @media(max-width:820px){
    section.pg { padding:3.5rem 1.5rem; }
    .hero { padding:7rem 1.5rem 2.5rem; }
    .rung { grid-template-columns:1fr auto; gap:0.75rem 1rem; padding:1.4rem 1.5rem; }
    .rung-num { display:none; }
    .rung-price { font-size:1.6rem; text-align:right; }
    .rung-cta { grid-column:1 / -1; }
    .rung-cta .btn-p, .rung-cta .btn-g { width:100%; justify-content:center; }
  }
</style>

<GlobalNav active="pricing" />

<div class="hero">
  <div class="hero-inner">
    <span class="lbl">Pricing</span>
    <h1 class="hero-h">Diagnose it. <em>Run it.</em> Or hand a leader the number.</h1>
    <p class="hero-sub">
      Three ways to work with Treetop, grouped by the phase of the Revenue Engine Method each one installs.
      Start where you are. Climb when you are ready. No step locks you into the next, and no call is required
      to begin at the floor.
    </p>
  </div>
</div>

<!-- DIAGNOSE -->
<section class="pg" id="diagnose">
  <div class="sec-inner">
    <span class="lbl">Phase 01 &middot; Memory</span>
    <h2 class="h2">Diagnose your engine.</h2>
    <p class="body">See exactly where you stand. Live competitive data, a written diagnosis, and a 90-day roadmap you can act on whether or not you keep working with us.</p>

    <div class="group-block">
      <div class="group-head">
        <div class="group-title">Diagnose <em>(one-time)</em></div>
        <div class="group-cap">Two entry points</div>
      </div>

      <div class="rung">
        <div class="rung-num">01</div>
        <div>
          <div class="rung-name">Starter Report</div>
          <div class="rung-best"><strong>Best for:</strong> seeing where you stand in the fastest, lowest-risk way. Live Ahrefs data on 3 competitors, keyword gap, growth levers, and a 90-day roadmap. Same day, in your inbox.</div>
          <div class="rung-climb">The floor of the ladder. Most people start here.</div>
        </div>
        <div class="rung-price"><em>$99</em><small>one-time</small></div>
        <div class="rung-cta"><a href="/ai-cmo-advisor" class="btn-p">Get the report &rarr;</a></div>
      </div>

      <div class="rung">
        <div class="rung-num">02</div>
        <div>
          <div class="rung-name">Revenue Engine Audit</div>
          <div class="rung-best"><strong>Best for:</strong> a full written diagnosis of the current state of your revenue engine. Interviews, data pulls, competitive review, and a written plan for the first 90 days. Delivered in 5 business days.</div>
          <div class="rung-climb">Climb here when you want the diagnosis to be interview-driven, not automated, and creditable toward implementation.</div>
        </div>
        <div class="rung-price"><em>$1,500</em><small>5-day written</small></div>
        <div class="rung-cta"><a href="/services/ai-audit" class="btn-g">See the Audit &rarr;</a></div>
      </div>
    </div>
  </div>
</section>

<!-- RUN -->
<section class="pg" id="run">
  <div class="sec-inner">
    <span class="lbl">Phase 02 &middot; Intelligence + Motion</span>
    <h2 class="h2">Run your engine.</h2>
    <p class="body">Keep the diagnosis current and get a strategist on call. Always-on, productized, cancel any time. Climb only when you need more.</p>

    <div class="group-block">
      <div class="group-head">
        <div class="group-title">Run <em>(monthly)</em></div>
        <div class="group-cap">The productized layer</div>
      </div>

      <div class="rung">
        <div class="rung-num">03</div>
        <div>
          <div class="rung-name">Monitor</div>
          <div class="rung-best"><strong>Best for:</strong> staying current without hiring. The report refreshed every month, a what-changed memo, and one priority question answered.</div>
          <div class="rung-climb">Climb here when one snapshot is not enough and you want the diagnosis kept fresh.</div>
        </div>
        <div class="rung-price"><em>$249</em><small>/ month</small></div>
        <div class="rung-cta"><a href="/ai-cmo-advisor/upgrade?tier=monitor" class="btn-g">Start Monitor &rarr;</a></div>
      </div>

      <div class="rung featured">
        <div class="rung-num">04</div>
        <div>
          <div class="rung-name">Guided <span class="tag">Most popular</span></div>
          <div class="rung-best"><strong>Best for:</strong> a plan plus a strategist on call. Everything in Monitor, a monthly working call, up to 6 competitors, and we draft or review your priority assets.</div>
          <div class="rung-climb">Climb here when you want to talk it through and have us shape the work.</div>
        </div>
        <div class="rung-price"><em>$999</em><small>/ month</small></div>
        <div class="rung-cta"><a href="/ai-cmo-advisor/upgrade?tier=guided" class="btn-p">Start Guided &rarr;</a></div>
      </div>

      <div class="rung">
        <div class="rung-num">05</div>
        <div>
          <div class="rung-name">Embedded</div>
          <div class="rung-best"><strong>Best for:</strong> a part-time CMO who does the work with you. Biweekly calls, we produce the deliverables, and execution gets tracked, not just recommended.</div>
          <div class="rung-climb">Climb here when you need execution, not just direction.</div>
        </div>
        <div class="rung-price"><em>$2,500</em><small>/ month</small></div>
        <div class="rung-cta"><a href="/ai-cmo-advisor/upgrade?tier=embedded" class="btn-g">Start Embedded &rarr;</a></div>
      </div>
    </div>
  </div>
</section>

<!-- LEAD -->
<section class="pg" id="lead">
  <div class="sec-inner">
    <span class="lbl">Phase 03 &middot; A human owns the number</span>
    <h2 class="h2">Lead your engine.</h2>
    <p class="body">A senior operator takes accountability for the number and runs the plan. Retainer, custom scope, always a flat monthly fee. Starts with a strategy call so both sides know the fit.</p>

    <div class="group-block">
      <div class="group-head">
        <div class="group-title">Lead <em>(retainer)</em></div>
        <div class="group-cap">Flagship engagement</div>
      </div>

      <div class="rung">
        <div class="rung-num">06</div>
        <div>
          <div class="rung-name">Fractional CMO</div>
          <div class="rung-best"><strong>Best for:</strong> marketing leadership that owns the outcome and installs the engine. The full Revenue Engine Method, led by Bill. Ideal at $2M to $50M in revenue with no marketing leader in the seat.</div>
          <div class="rung-climb">Climb here when the problem is not tactics. It is that no one is truly leading marketing.</div>
        </div>
        <div class="rung-price"><em>Custom</em><small>retainer, scoped to fit</small></div>
        <div class="rung-cta"><a href="/fractional-cmo" class="btn-g">See Fractional CMO &rarr;</a></div>
      </div>

      <div class="rung">
        <div class="rung-num">07</div>
        <div>
          <div class="rung-name">Fractional CRO</div>
          <div class="rung-best"><strong>Best for:</strong> the full revenue lifecycle, not just marketing. Sales, marketing, and CS alignment under one accountable leader. Ideal at $5M to $50M with a founder still running the number.</div>
          <div class="rung-climb">Climb here when marketing alone will not fix it because the sales and CS motion is broken too.</div>
        </div>
        <div class="rung-price"><em>Custom</em><small>retainer, scoped to fit</small></div>
        <div class="rung-cta"><a href="/fractional-cro" class="btn-g">See Fractional CRO &rarr;</a></div>
      </div>
    </div>
  </div>
</section>

<!-- COMPARISON TABLE -->
<section class="pg">
  <div class="sec-inner">
    <span class="lbl">Compare</span>
    <h2 class="h2">What you get at each rung.</h2>
    <p class="body">Everything below a rung is generally included when you climb. Scroll to compare across the whole ladder.</p>

    <div class="table-wrap">
      <table class="cmp">
        <thead>
          <tr>
            <th>&nbsp;</th>
            <th>Starter<span class="th-price">$99</span><span class="th-group">Diagnose</span></th>
            <th>Audit<span class="th-price">$1,500</span><span class="th-group">Diagnose</span></th>
            <th>Monitor<span class="th-price">$249/mo</span><span class="th-group">Run</span></th>
            <th>Guided<span class="th-price">$999/mo</span><span class="th-group">Run</span></th>
            <th>Embedded<span class="th-price">$2,500/mo</span><span class="th-group">Run</span></th>
            <th>Fractional<span class="th-price">Custom</span><span class="th-group">Lead</span></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th>Live competitive analysis</th>
            <td>Once</td><td>Once, deeper</td><td>Monthly</td><td>Monthly</td><td>Monthly</td><td>Continuous</td>
          </tr>
          <tr>
            <th>Competitors tracked</th>
            <td>3</td><td>5+</td><td>3</td><td>6</td><td>6+</td><td>Custom</td>
          </tr>
          <tr>
            <th>Written diagnosis and roadmap</th>
            <td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td>
          </tr>
          <tr>
            <th>Founder + team interviews</th>
            <td class="no">&middot;</td><td class="yes">&#10003;</td><td class="no">&middot;</td><td class="no">&middot;</td><td>Included</td><td class="yes">&#10003;</td>
          </tr>
          <tr>
            <th>What-changed memo</th>
            <td class="no">&middot;</td><td class="no">&middot;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td>
          </tr>
          <tr>
            <th>Priority question answered</th>
            <td class="no">&middot;</td><td>Once</td><td>1 / mo</td><td>Async</td><td>Direct</td><td>Continuous</td>
          </tr>
          <tr>
            <th>Monthly working call</th>
            <td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td>45 min</td><td>Biweekly</td><td>Weekly</td>
          </tr>
          <tr>
            <th>We draft or review your assets</th>
            <td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="yes">&#10003;</td><td>We produce them</td><td class="yes">&#10003;</td>
          </tr>
          <tr>
            <th>Hands-on execution</th>
            <td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td>
          </tr>
          <tr>
            <th>Owns the number</th>
            <td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="yes">&#10003;</td>
          </tr>
          <tr>
            <th>Hires and manages doers</th>
            <td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="no">&middot;</td><td class="yes">&#10003;</td>
          </tr>
          <tr class="row-price">
            <th>Price</th>
            <td>$99 once</td><td>$1,500 once</td><td>$249/mo</td><td>$999/mo</td><td>$2,500/mo</td><td>Custom</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="pg">
  <div class="sec-inner">
    <span class="lbl">FAQ</span>
    <h2 class="h2">Common questions</h2>

    <div class="faq">
      <h3>Do I have to start at the bottom?</h3>
      <p>No. Most people start with the $99 Starter Report because it is the lowest-risk way to see the thinking, but you can begin at any rung. The ladder is there so you climb only when you actually need more, not because you were funneled into it. If you already know you want a Fractional CMO, <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8">book a strategy call</a>.</p>
    </div>

    <div class="faq">
      <h3>What is the real difference between Diagnose, Run, and Lead?</h3>
      <p>How much of the work we do. Diagnose is a one-time read on where you stand. Run is the always-on productized layer that keeps the diagnosis current and gives you a strategist on call. Lead is a senior operator (a Fractional CMO or CRO) who takes accountability for the number, runs the plan, and hires the doers. The data and the roadmap run through all of them. What changes is who owns the doing.</p>
    </div>

    <div class="faq">
      <h3>Can I move up or down later?</h3>
      <p>Yes. Upgrade when you want more, cancel or step down when you want less. The productized subscriptions (Monitor, Guided, Embedded) cancel any time from your Stripe customer portal. Retainer engagements are month-to-month with 30 days notice.</p>
    </div>

    <div class="faq">
      <h3>Why is the Fractional CMO price listed as Custom?</h3>
      <p>Because the scope of a retainer varies more than a subscription does. Some engagements are 20 hours a month leading an existing team, some are 40 hours a month building a new one. We scope on the strategy call, quote a flat monthly fee, and stick to it. Anchor: most Fractional CMO engagements land between what you would pay for the Embedded subscription and what a full-time CMO would cost.</p>
    </div>

    <div class="faq">
      <h3>What data do the reports and audits use?</h3>
      <p>Live Ahrefs API data pulled at the time of each report: domain rating, organic keyword count, estimated monthly traffic, and the top traffic-driving keywords for you and your competitors. Plus the intake answers you provide, and for the Audit and up, interviews with your team.</p>
    </div>

    <div class="faq">
      <h3>How fast does the Starter Report arrive?</h3>
      <p>Usually within a few hours, the same day in almost every case. We pull the data, run the analysis, and Bill reviews it before it goes out. Always within 24 hours.</p>
    </div>

  </div>
</section>

<!-- FINAL CTA -->
<section class="pg">
  <div class="sec-inner">
    <div class="cta-box">
      <div>
        <div class="cta-text">Not sure which rung is right?</div>
        <div class="cta-sub">Book a 30-minute strategy call. We look at where you are, decide whether you need to Diagnose, Run, or Lead first, and go from there. No deck, no pitch.</div>
      </div>
      <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" class="btn-p" style="padding:0.9rem 1.75rem;font-size:0.85rem;">Book a strategy call &rarr;</a>
    </div>
  </div>
</section>

<GlobalFooter />

</Layout>
