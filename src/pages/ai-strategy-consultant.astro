      </a>
      <a href="/results" style="flex:1;min-width:200px;background:#0A1A0A;border:1px solid #1A3A1A;padding:1.5rem;text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(0,200,83,0.35)'" onmouseout="this.style.borderColor='#1A3A1A'">
        <div style="font-size:0.78rem;font-weight:600;color:#00C853;margin-bottom:0.4rem;">Results</div>
        <div style="font-size:0.85rem;color:#F0FFF0;font-weight:500;margin-bottom:0.25rem;">38 GTM Systems Built</div>
        <div style="font-size:0.78rem;color:#8FAF8F;line-height:1.6;">Outcomes from real engagements across B2B companies.</div>
      </a>
    </div>
  </div>
</div>

<GlobalFooter />

<script>
  const form = document.getElementById('ai-form');
  const thanks = document.getElementById('ai-thanks');
  const wrap = document.getElementById('ai-form-wrap');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    try {
      await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
    } catch (_) {}
    if (wrap) wrap.style.display = 'none';
    if (thanks) thanks.style.display = 'block';
  });
</script>
</body>
</html>
