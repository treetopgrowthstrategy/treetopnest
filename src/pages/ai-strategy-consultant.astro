  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-g { display: inline-flex; align-items: center; gap: 6px; background: transparent; color: #F0FFF0; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid #1A3A1A; transition: border-color 0.2s; }
    .btn-g:hover { border-color: rgba(0,200,83,0.4); background: rgba(0,200,83,0.05); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; }
    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 2.5rem 5rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h { font-family: 'Instrument Serif', serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; line-height: 1.08; color: #F0FFF0; max-width: 860px; margin-bottom: 1.75rem; }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: #8FAF8F; max-width: 560px; line-height: 1.8; margin-bottom: 2.5rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .sub { font-size: 1rem; color: #8FAF8F; line-height: 1.75; max-width: 600px; margin-bottom: 3rem; }
    .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1px; background: #1A3A1A; }
    .grid-cell { background: #050D05; padding: 2rem; }
    .grid-cell-alt { background: #0A1A0A; padding: 2rem; }
    .step-row { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid #1A3A1A; }
    .step-row:last-child { border-bottom: none; }
    .step-num { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-style: italic; color: rgba(0,200,83,0.3); flex-shrink: 0; width: 2.5rem; }
    .step-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.4rem; }
    .step-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.7; }
    .cell-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #00C853; margin-bottom: 0.6rem; display: block; }
    .cell-title { font-size: 0.95rem; font-weight: 600; color: #F0FFF0; margin-bottom: 0.5rem; }
    .cell-desc { font-size: 0.85rem; color: #8FAF8F; line-height: 1.65; }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    .form-label { font-size: 0.75rem; font-weight: 500; color: #8FAF8F; margin-bottom: 0.4rem; display: block; letter-spacing: 0.03em; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-field { margin-bottom: 1rem; }
    .thankyou { display: none; text-align: center; padding: 3rem 0; }
    .thankyou-h { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #F0FFF0; margin-bottom: 0.75rem; }
    .thankyou-p { color: #8FAF8F; }
    .quote-block { border-left: 3px solid rgba(0,200,83,0.4); padding: 1.5rem 2rem; background: rgba(0,200,83,0.04); margin: 2rem 0; }
    @media(max-width:768px){ .hide-mob{display:none!important} section,.hero{padding:3.5rem 1.5rem} .hero{padding-top:5rem} .form-grid{grid-template-columns:1fr} }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Build the Roadmap →</a>
  </div>
</nav>

<div class="hero" style="background:#050D05;">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>AI Strategy</div>
    <h1 class="hero-h">AI Strategy Consulting:<br/><em style="color:#00C853;font-style:italic;">Build the Roadmap Before You Buy the Tools.</em></h1>
    <p class="hero-sub">Most companies buy AI tools, then figure out strategy. That's backwards. You end up with a collection of subscriptions, no clear owner, and nothing measurably better. We fix the sequence.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-p">Build the Roadmap →</a>
      <a href="/what-is-ai-native-gtm" class="btn-g">What Is AI-Native GTM?</a>
    </div>
  </div>
</div>

<!-- The problem -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The Actual Problem</span>
    <h2 class="h2">You Bought the Tools.<br/>Nothing Changed.</h2>
    <p class="sub">It's not a tool problem. It's a sequencing problem. AI tools are powerful — but only when deployed against specific workflows, with clear owners and measurable outcomes.</p>
    <div class="grid-2" style="margin-top:1rem;">
      <div class="grid-cell-alt">
        <span class="cell-label">What Most Companies Do</span>
        <div class="cell-title">Buy tools → Hope for adoption → Get nothing</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Someone reads about an AI tool. Gets excited. Buys it. Tells the team. The team logs in once, doesn't know what to do with it, and goes back to how they were working. $2,000/month wasted. Repeated 4 times.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-label">What Actually Works</span>
        <div class="cell-title">Map workflows → Prioritize impact → Deploy deliberately</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Start by auditing where your team actually spends time. Identify the highest-leverage opportunities. Build a prioritized roadmap. Then deploy tools against specific problems — with training, accountability, and measurement baked in.</div>
      </div>
    </div>
    <div class="quote-block" style="margin-top:2.5rem;">
      <p style="font-size:0.95rem;color:#8FAF8F;line-height:1.8;font-style:italic;">"The companies that win with AI in the next 3 years won't be the ones who bought the most tools. They'll be the ones who figured out which 3 tools to go deep on — and built real workflows around them."</p>
      <p style="font-size:0.8rem;color:#4A6A4A;margin-top:0.75rem;">— Bill Colbert, Treetop Growth Strategy</p>
    </div>
  </div>
</section>

<!-- What an engagement covers -->
<section style="background:#050D05;">
  <div class="sec-inner">
    <span class="lbl">The Engagement</span>
    <h2 class="h2">What an AI Strategy<br/>Engagement Actually Covers.</h2>
    <p class="sub">30 days. One focused engagement. The output is a prioritized implementation roadmap — not a slide deck with frameworks on it.</p>
    <div>
      <div class="step-row">
        <div class="step-num">01</div>
        <div>
          <div class="step-title">Workflow Audit — Where Time Is Actually Going</div>
          <div class="step-desc">Week 1. We map the workflows across your highest-value functions — sales, marketing, ops, CS, finance. We're looking for tasks that are high-frequency, high-effort, and low-judgment. That's where AI compounds fastest.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">02</div>
        <div>
          <div class="step-title">Tool Evaluation — What You Have, What You Need</div>
          <div class="step-desc">Week 1–2. Audit your current AI subscriptions (most companies are paying for 3–7 tools with 20% adoption). Identify what to keep, what to cut, and what specific gaps exist. We're not selling you more tools — we're telling you what's worth using.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">03</div>
        <div>
          <div class="step-title">Opportunity Prioritization — ROI Ranked</div>
          <div class="step-desc">Week 2. Rank every AI opportunity by implementation effort vs. time saved vs. revenue impact. Not all AI opportunities are equal. You'll know exactly which 3–5 to move on first and why.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">04</div>
        <div>
          <div class="step-title">Implementation Roadmap — 90-Day Execution Plan</div>
          <div class="step-desc">Week 3. A quarter-by-quarter roadmap with specific tools, workflows, owners, and success metrics. Designed to be executed by your team — not by us. Includes prompt libraries, workflow documentation, and rollout sequencing.</div>
        </div>
      </div>
      <div class="step-row">
        <div class="step-num">05</div>
        <div>
          <div class="step-title">Executive Presentation & Board-Ready Summary</div>
          <div class="step-desc">Week 4. Present findings to your leadership team. Includes competitive analysis (what your industry is doing with AI), a risk assessment, and a build-vs-buy recommendation for any custom tooling.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Who this is for -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Who This Is For</span>
    <h2 class="h2">Two Types of Companies<br/>Who Need This.</h2>
    <div class="grid-2" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <span class="cell-label">Type A</span>
        <div class="cell-title">CEOs and COOs Deciding Where to Start</div>
        <div class="cell-desc" style="margin-top:0.75rem;">You know AI is important. You don't know whether to start with sales automation, content generation, operations, or customer support. You need someone who's deployed AI across multiple B2B companies to help you prioritize — not a vendor trying to sell you their specific product.</div>
      </div>
      <div class="grid-cell-alt">
        <span class="cell-label">Type B</span>
        <div class="cell-title">Companies That Bought Tools and Got Nothing</div>
        <div class="cell-desc" style="margin-top:0.75rem;">You're 6 months into an AI initiative. You have subscriptions. You did some workshops. Adoption is 15%. Nothing has measurably changed. You need a reset — a clear-eyed assessment of what went wrong and a practical plan to fix it.</div>
      </div>
    </div>
  </div>
</section>

<!-- What makes this different -->
<section style="background:#050D05;">
  <div class="sec-inner">
    <span class="lbl">What's Different</span>
    <h2 class="h2">This Isn't Generic<br/>AI Consulting.</h2>
    <p class="sub">Most AI consulting produces a framework and a slide deck. We produce a working roadmap and start implementation in the same engagement.</p>
    <div class="grid-3" style="margin-top:2rem;">
      <div class="grid-cell">
        <span class="cell-label">Not This</span>
        <div class="cell-title">Vendor-Neutral in Theory, Biased in Practice</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Big consulting firms say they're vendor-neutral and then recommend the platforms they have partnerships with. We have no referral agreements. We recommend what actually works.</div>
      </div>
      <div class="grid-cell">
        <span class="cell-label">Not This</span>
        <div class="cell-title">Strategy Without Implementation</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Plenty of consultants will write you an AI strategy. Few of them will help you execute it. We build implementations — through our AI audit, Claude implementation, and ongoing retainer services.</div>
      </div>
      <div class="grid-cell">
        <span class="cell-label">Not This</span>
        <div class="cell-title">One-Size-Fits-All Frameworks</div>
        <div class="cell-desc" style="margin-top:0.75rem;">Every AI strategy engagement starts with your actual workflows, your actual team, and your actual constraints. The output is specific to your company — not a templated framework dressed up with your logo.</div>
      </div>
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="/services/ai-audit" class="btn-g">See the AI Audit →</a>
      <a href="/results" class="btn-g">See Results →</a>
      <a href="/claude-for-small-business" class="btn-g">Claude for Small Business →</a>
    </div>
  </div>
</section>

<!-- Process summary -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">The Process</span>
    <h2 class="h2">30 Days to a Roadmap<br/>You Can Actually Execute.</h2>
    <div class="grid-3" style="margin-top:2rem;">
      <div class="grid-cell-alt">
        <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#00C853;margin-bottom:0.5rem;">Week 1</div>
        <div class="cell-title">Audit & Inventory</div>
        <div class="cell-desc" style="margin-top:0.4rem;">Workflow mapping, tool audit, stakeholder interviews. We learn how your business actually runs before making any recommendations.</div>
      </div>
      <div class="grid-cell-alt">
        <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#00C853;margin-bottom:0.5rem;">Week 2–3</div>
        <div class="cell-title">Analysis & Prioritization</div>
        <div class="cell-desc" style="margin-top:0.4rem;">ROI scoring, competitive benchmarking, tool selection. We identify your highest-leverage opportunities and sequence them in a 90-day implementation plan.</div>
      </div>
      <div class="grid-cell-alt">
        <div style="font-family:'Instrument Serif',serif;font-size:2.5rem;font-style:italic;color:#00C853;margin-bottom:0.5rem;">Week 4</div>
        <div class="cell-title">Roadmap Delivery</div>
        <div class="cell-desc" style="margin-top:0.4rem;">Executive presentation, full written roadmap, prompt libraries for immediate use, and a 30-minute Q&A with your leadership team.</div>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" style="background:#050D05;">
  <div class="sec-inner" style="max-width:720px;">
    <span class="lbl">Get Started</span>
    <h2 class="h2">Build the Roadmap<br/>Before You Buy More Tools.</h2>
    <p class="sub">Tell us where you are with AI right now. We'll respond with an honest assessment of what a strategy engagement would look like for your company.</p>

    <div id="ai-form-wrap">
      <form id="ai-form" style="margin-top:1.5rem;">
        <div class="form-grid">
          <div class="form-field">
            <label class="form-label" for="ai-first">First Name</label>
            <input class="input-field" type="text" id="ai-first" name="first_name" placeholder="Jane" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="ai-last">Last Name</label>
            <input class="input-field" type="text" id="ai-last" name="last_name" placeholder="Smith" required />
          </div>
        </div>
        <div class="form-field">
          <label class="form-label" for="ai-email">Work Email</label>
          <input class="input-field" type="email" id="ai-email" name="email" placeholder="jane@company.com" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="ai-company">Company</label>
          <input class="input-field" type="text" id="ai-company" name="company" placeholder="Acme Corp" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="ai-gain">What revenue problem are you trying to solve?</label>
          <textarea class="input-field" id="ai-gain" name="gain" rows="4" placeholder="Where are you with AI right now? What's working, what isn't, and what are you trying to figure out?"></textarea>
        </div>
        <input type="hidden" name="source" value="ai-strategy-consultant" />
        <button type="submit" class="btn-p" style="width:100%;justify-content:center;margin-top:0.5rem;">Send →</button>
      </form>
    </div>
    <div class="thankyou" id="ai-thanks">
      <div class="thankyou-h">We'll be in touch.</div>
      <p class="thankyou-p">Expect a response within one business day. If you'd like to move faster, book directly at <a href="https://calendar.app.google/GS5H5y8U3PrN8u4A8" style="color:#00C853;">calendar.app.google</a>.</p>
    </div>
  </div>
</section>

