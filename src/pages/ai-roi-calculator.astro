<script is:inline>
  (function() {
    function fmt(n) {
      if (n >= 1000000) return '$' + (n/1000000).toFixed(1) + 'M';
      if (n >= 1000) return '$' + Math.round(n/1000) + 'K';
      return '$' + Math.round(n);
    }
    function fmtInput(n) {
      if (n >= 1000) return '$' + Math.round(n/1000) + 'K';
      return '$' + n;
    }

    var inputs = {
      teamSize: document.getElementById('team-size'),
      avgSalary: document.getElementById('avg-salary'),
      hoursPct: document.getElementById('hours-pct'),
      captureRate: document.getElementById('capture-rate'),
      aiCost: document.getElementById('ai-cost'),
    };
    var labels = {
      teamSize: document.getElementById('team-size-val'),
      avgSalary: document.getElementById('avg-salary-val'),
      hoursPct: document.getElementById('hours-pct-val'),
      captureRate: document.getElementById('capture-rate-val'),
      aiCost: document.getElementById('ai-cost-val'),
    };
    var outputs = {
      annualSavings: document.getElementById('annual-savings'),
      hoursSaved: document.getElementById('hours-saved'),
      fteEquiv: document.getElementById('fte-equiv'),
      netYearOne: document.getElementById('net-year-one'),
      payback: document.getElementById('payback'),
      roiMult: document.getElementById('roi-mult'),
    };

    var HOURS_PER_FTE = 1872; // 52 weeks × 36 productive hrs

    function recalc() {
      var team = parseInt(inputs.teamSize.value, 10);
      var salary = parseInt(inputs.avgSalary.value, 10);
      var pct = parseInt(inputs.hoursPct.value, 10) / 100;
      var capture = parseInt(inputs.captureRate.value, 10) / 100;
      var aiCost = parseInt(inputs.aiCost.value, 10);

      labels.teamSize.textContent = team;
      labels.avgSalary.textContent = fmtInput(salary);
      labels.hoursPct.textContent = pct * 100 + '%';
      labels.captureRate.textContent = capture * 100 + '%';
      labels.aiCost.textContent = fmtInput(aiCost);

      // Dollar value saved = team × salary × pct × capture
      var annual = team * salary * pct * capture;
      // Hours saved = team × HOURS_PER_FTE × pct × capture
      var hours = team * HOURS_PER_FTE * pct * capture;
      // FTE equivalent
      var fte = hours / HOURS_PER_FTE;
      // Net year one
      var net = annual - aiCost;
      // Payback (months, then convert)
      var monthlyRate = annual / 12;
      var paybackMonths = aiCost / monthlyRate;
      var paybackText;
      if (paybackMonths < 1) paybackText = Math.round(paybackMonths * 4.33) + ' weeks';
      else if (paybackMonths < 12) paybackText = paybackMonths.toFixed(1) + ' months';
      else paybackText = (paybackMonths / 12).toFixed(1) + ' years';
      // ROI multiple
      var roi = annual / aiCost;

      outputs.annualSavings.textContent = fmt(annual);
      outputs.hoursSaved.textContent = Math.round(hours).toLocaleString() + ' hrs';
      outputs.fteEquiv.textContent = fte.toFixed(1) + ' FTE';
      outputs.netYearOne.textContent = fmt(net);
      outputs.payback.textContent = paybackText;
      outputs.roiMult.textContent = roi.toFixed(1) + '×';
    }

    Object.keys(inputs).forEach(function(k) {
      inputs[k].addEventListener('input', recalc);
    });
    recalc();
  })();
</script>

</body>
</html>
