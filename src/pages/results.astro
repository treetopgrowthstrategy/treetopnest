---
export const prerender = true;
import GlobalFooter from '../components/GlobalFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Results | Treetop Growth Strategy</title>
  <meta name="description" content="Real results from Treetop Growth Strategy clients — $127M+ pipeline generated, 38 GTM systems built, 4.2x average revenue multiple. See what happens when GTM gets fixed." />
  <link rel="canonical" href="https://treetopgrowthstrategy.com/results" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: #050D05; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-weight: 300; -webkit-font-smoothing: antialiased; }
    .lbl { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #00C853; margin-bottom: 1.25rem; display: block; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(5,13,5,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #1A3A1A; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-style: italic; color: #F0FFF0; text-decoration: none; }
    .nav-link { font-size: 0.82rem; color: rgba(240,255,240,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #F0FFF0; }
    .btn-p { display: inline-flex; align-items: center; gap: 6px; background: #00C853; color: #050D05; padding: 0.875rem 1.75rem; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-p:hover { opacity: 0.88; transform: translateY(-1px); }
    .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 500; color: #00C853; letter-spacing: 0.06em; margin-bottom: 1.5rem; }
    .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #00C853; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    section { padding: 5rem 2.5rem; border-top: 1px solid #1A3A1A; }
    .sec-inner { max-width: 1200px; margin: 0 auto; }
    .h2 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.12; color: #F0FFF0; margin-bottom: 1.25rem; }
    .body-text { font-size: 0.95rem; color: #8FAF8F; line-height: 1.75; }
    .card-mid { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 2rem; transition: border-color 0.2s; }
    .card-mid:hover { border-color: rgba(0,200,83,0.35); }
    .input-field { width: 100%; background: rgba(240,255,240,0.04); border: 1px solid #1A3A1A; padding: 0.875rem 1rem; color: #F0FFF0; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .input-field:focus { border-color: rgba(0,200,83,0.5); }
    .input-field::placeholder { color: #4A6A4A; }
    @media(max-width:768px){ .mob-col{flex-direction:column!important} .hide-mob{display:none!important} section{padding:3.5rem 1.5rem} }

    /* Hero */
    .hero {
      min-height: 70vh;
      display: flex;
      align-items: center;
      padding-top: 7rem;
      padding-left: 2.5rem;
      padding-right: 2.5rem;
      padding-bottom: 5rem;
    }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
    .hero-h {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 400;
      line-height: 1.08;
      color: #F0FFF0;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: 1.05rem;
      color: #8FAF8F;
      line-height: 1.75;
      max-width: 560px;
      margin-bottom: 3.5rem;
    }

    /* Aggregate stats */
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
    @media(max-width:900px){ .stats-row { grid-template-columns: repeat(2, 1fr); } }
    @media(max-width:500px){ .stats-row { grid-template-columns: 1fr; } }
    .stat-box { background: #0A1A0A; border: 1px solid #1A3A1A; padding: 1.75rem 1.5rem; }
    .stat-num {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(2.2rem, 4vw, 3rem);
      color: #00C853;
      font-weight: 400;
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .stat-label { font-size: 0.8rem; color: #8FAF8F; line-height: 1.5; }

    /* Case studies */
    .case-studies-grid { display: flex; flex-direction: column; gap: 2.5rem; }

    .case-card {
      background: #0A1A0A;
      border: 1px solid #1A3A1A;
      padding: 2.5rem;
      transition: border-color 0.2s;
    }
    .case-card:hover { border-color: rgba(0,200,83,0.3); }

    .case-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(0,200,83,0.1);
      border: 1px solid rgba(0,200,83,0.25);
      color: #00C853;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.3rem 0.75rem;
      margin-bottom: 1.75rem;
    }

    .case-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem;
    }
    @media(max-width:900px){ .case-grid { grid-template-columns: 1fr; gap: 1.5rem; } }

    .case-section-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #4A6A4A;
      margin-bottom: 0.75rem;
    }
    .case-section-body {
      font-size: 0.88rem;
      color: #8FAF8F;
      line-height: 1.7;
    }

    .result-nums {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .result-num-row { display: flex; align-items: baseline; gap: 0.75rem; }
    .result-big {
      font-family: 'Instrument Serif', serif;
      font-size: 2rem;
      color: #00C853;
      font-weight: 400;
      line-height: 1;
      flex-shrink: 0;
    }
    .result-desc { font-size: 0.82rem; color: #8FAF8F; line-height: 1.5; }

    .divider-v { width: 1px; background: #1A3A1A; }
    @media(max-width:900px){ .divider-v { display: none; } }

    /* Methodology */
    .method-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3.5rem; }
    @media(max-width:768px){ .method-grid { grid-template-columns: 1fr; } }

    .method-card {
      position: relative;
      padding: 2rem;
      background: #0A1A0A;
      border: 1px solid #1A3A1A;
      text-decoration: none;
      display: block;
      transition: border-color 0.2s;
    }
    .method-card:hover { border-color: rgba(0,200,83,0.35); }

    .method-step {
      font-family: 'Instrument Serif', serif;
      font-size: 3rem;
      color: rgba(0,200,83,0.15);
      font-weight: 400;
      line-height: 1;
      margin-bottom: 1rem;
    }
    .method-name {
      font-family: 'Instrument Serif', serif;
      font-size: 1.45rem;
      color: #F0FFF0;
      font-weight: 400;
      margin-bottom: 0.75rem;
    }
    .method-desc { font-size: 0.88rem; color: #8FAF8F; line-height: 1.7; margin-bottom: 1rem; }
    .method-link { font-size: 0.78rem; color: #00C853; font-weight: 500; }

    /* Testimonials */
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    @media(max-width:768px){ .testimonials-grid { grid-template-columns: 1fr; } }

    .testimonial-card {
      background: #0A1A0A;
      border: 1px solid #1A3A1A;
      padding: 2.25rem;
    }
    .quote-mark {
      font-family: 'Instrument Serif', serif;
      font-size: 3rem;
      color: rgba(0,200,83,0.3);
      line-height: 0.8;
      margin-bottom: 1.25rem;
    }
    .quote-text {
      font-family: 'Instrument Serif', serif;
      font-size: 1.1rem;
      color: #F0FFF0;
      font-weight: 400;
      line-height: 1.65;
      font-style: italic;
      margin-bottom: 1.5rem;
    }
    .quote-attr-name { font-size: 0.82rem; font-weight: 600; color: #F0FFF0; }
    .quote-attr-role { font-size: 0.78rem; color: #4A6A4A; margin-top: 0.2rem; }

    /* Contact */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    @media(max-width:768px){ .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    @media(max-width:768px){ .form-row { grid-template-columns: 1fr; } }

    .form-field { margin-bottom: 1rem; }
    .form-label { display: block; font-size: 0.75rem; font-weight: 600; color: rgba(240,255,240,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.4rem; }

    .success-msg { display: none; background: rgba(0,200,83,0.08); border: 1px solid rgba(0,200,83,0.3); padding: 1.5rem; text-align: center; }
    .success-msg p { color: #00C853; font-size: 0.9rem; }

    .confidentiality-note {
      font-size: 0.72rem;
      color: #4A6A4A;
      letter-spacing: 0.04em;
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 2rem;
    }
    .confidentiality-note::before {
      content: '';
      display: inline-block;
      width: 16px;
      height: 1px;
      background: #4A6A4A;
      flex-shrink: 0;
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/claude-for-small-business" class="nav-link">Claude for SMB</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="#contact" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Get Started</a>
  </div>
</nav>

<!-- Hero -->
<div class="hero">
  <div class="hero-inner">
    <div class="badge">
      <span class="badge-dot"></span>
      Client Results
    </div>
    <h1 class="hero-h">
      What Happens When<br/>
      <em style="color:#00C853;font-style:italic;">GTM Gets Fixed</em>
    </h1>
    <p class="hero-sub">
      These are the outcomes when B2B companies replace guesswork with a system. Real numbers, real timelines, real businesses — anonymized by request.
    </p>

    <!-- Aggregate stats -->
    <div class="stats-row">
      <div class="stat-box">
        <div class="stat-num">$127M+</div>
        <div class="stat-label">Pipeline generated across client engagements</div>
      </div>
      <div class="stat-box">
        <div class="stat-num">38</div>
        <div class="stat-label">GTM systems built and deployed</div>
      </div>
      <div class="stat-box">
        <div class="stat-num">4.2x</div>
        <div class="stat-label">Average revenue multiple from system implementations</div>
      </div>
      <div class="stat-box">
        <div class="stat-num">90 days</div>
        <div class="stat-label">Average time from kickoff to measurable velocity</div>
      </div>
    </div>
  </div>
</div>

<!-- Case Studies -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">Case Studies</span>
    <h2 class="h2" style="max-width:600px;margin-bottom:0.75rem;">Three companies.<br/>Three different problems.<br/>One approach.</h2>
    <p class="body-text" style="max-width:560px;margin-bottom:2.5rem;">
      Every engagement starts with an <a href="/services/ai-audit" style="color:#00C853;text-decoration:none;">AI-native GTM audit</a>. What follows is specific to the business — no templates, no copy-paste strategies.
    </p>
    <div class="confidentiality-note">Company names and identifying details anonymized for confidentiality</div>

    <div class="case-studies-grid">

      <!-- Case Study 1 -->
      <div class="case-card">
        <div class="case-badge">B2B SaaS / $8M ARR / Austin, TX</div>
        <div class="case-grid">
          <div>
            <div class="case-section-label">The Problem</div>
            <p class="case-section-body">
              A fast-growing SaaS company at $8M ARR with a strong product and a broken top-of-funnel. The sales team was generating pipeline manually — every rep doing their own outreach, no shared playbook, no repeatable motion. The CMO seat had been vacant for seven months. Leadership knew they needed a system, not another hire.
            </p>
          </div>
          <div>
            <div class="case-section-label">What We Did</div>
            <p class="case-section-body">
              Ran a full <a href="/services/ai-audit" style="color:#00C853;text-decoration:none;">AI-native GTM audit</a> to identify leverage points, then <a href="/services/implementation" style="color:#00C853;text-decoration:none;">implemented</a> a Claude-powered outbound engine and content system — sequencing, ICP messaging, weekly content output. Stepped in as <a href="/fractional-cmo" style="color:#00C853;text-decoration:none;">fractional CMO</a> for eight months to run the system, iterate, and build the playbook the next hire would inherit.
            </p>
          </div>
          <div>
            <div class="case-section-label">The Results</div>
            <div class="result-nums">
              <div class="result-num-row">
                <span class="result-big">3.1x</span>
                <span class="result-desc">pipeline volume within six months</span>
              </div>
              <div class="result-num-row">
                <span class="result-big">$2.4M</span>
                <span class="result-desc">new ARR generated in the engagement period</span>
              </div>
              <div class="result-num-row">
                <span class="result-big">8 mo.</span>
                <span class="result-desc">to hire full-time CMO with a working playbook already in hand</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Case Study 2 -->
      <div class="case-card">
        <div class="case-badge">Professional Services / $14M Revenue / Remote</div>
        <div class="case-grid">
          <div>
            <div class="case-section-label">The Problem</div>
            <p class="case-section-body">
              A professional services firm doing $14M in revenue — entirely referral-dependent, with no marketing infrastructure to speak of. They wanted to expand into a new vertical but had no system for reaching net-new buyers. Proposals were taking 6–10 hours each. The team was stretched, and growth felt like it required hiring they weren't ready for.
            </p>
          </div>
          <div>
            <div class="case-section-label">What We Did</div>
            <p class="case-section-body">
              Implemented Claude across their proposal workflow, client reporting, and content output — cutting hours-per-proposal dramatically. Simultaneously built the GTM strategy and outbound infrastructure for the new vertical: ICP definition, messaging, sequence build, and launch plan. Used the <a href="/services/retainer" style="color:#00C853;text-decoration:none;">ongoing retainer</a> to optimize through launch.
            </p>
          </div>
          <div>
            <div class="case-section-label">The Results</div>
            <div class="result-nums">
              <div class="result-num-row">
                <span class="result-big">60%</span>
                <span class="result-desc">reduction in time spent per proposal</span>
              </div>
              <div class="result-num-row">
                <span class="result-big">11 wks</span>
                <span class="result-desc">from kickoff to new vertical launch</span>
              </div>
              <div class="result-num-row">
                <span class="result-big">4</span>
                <span class="result-desc">qualified inbound leads in the first month after launch</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Case Study 3 -->
      <div class="case-card">
        <div class="case-badge">E-Commerce & Wholesale / $22M Revenue / DTC</div>
        <div class="case-grid">
          <div>
            <div class="case-section-label">The Problem</div>
            <p class="case-section-body">
              A DTC brand doing $22M across direct and wholesale channels with a marketing team of two — doing the work of eight. AI was in the mix but ad hoc: different tools, inconsistent outputs, no shared system. Team morale was suffering. Content was a bottleneck. Email was underperforming relative to their list size.
            </p>
          </div>
          <div>
            <div class="case-section-label">What We Did</div>
            <p class="case-section-body">
              Ran a full <a href="/services/implementation" style="color:#00C853;text-decoration:none;">Claude implementation</a> across every marketing function: email campaign production, content calendar, performance reporting, and a customer service response library. Monthly <a href="/services/retainer" style="color:#00C853;text-decoration:none;">optimization retainer</a> to build new workflows and track results quarter over quarter.
            </p>
          </div>
          <div>
            <div class="case-section-label">The Results</div>
            <div class="result-nums">
              <div class="result-num-row">
                <span class="result-big">14 hrs</span>
                <span class="result-desc">per week reclaimed per team member</span>
              </div>
              <div class="result-num-row">
                <span class="result-big">4x</span>
                <span class="result-desc">content output without adding headcount</span>
              </div>
              <div class="result-num-row">
                <span class="result-big">22%</span>
                <span class="result-desc">lift in email-attributed revenue within 90 days</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Methodology -->
<section>
  <div class="sec-inner">
    <span class="lbl">How It Works</span>
    <h2 class="h2" style="max-width:560px;">Three phases.<br/>One continuous system.</h2>
    <p class="body-text" style="max-width:540px;">
      Every engagement follows the same architecture — adapted to your business, not templated. See the full breakdown on the <a href="/services" style="color:#00C853;text-decoration:none;">services page</a>.
    </p>
    <div class="method-grid">
      <a href="/services/ai-audit" class="method-card">
        <div class="method-step">01</div>
        <div class="method-name">Audit</div>
        <p class="method-desc">
          We map your current GTM motion — what's working, what's broken, and where AI creates immediate leverage. You leave with a prioritized implementation plan, a baseline for measuring results, and clarity on what the next 90 days should look like. You can act on it with us or on your own.
        </p>
        <div class="method-link">AI Readiness Audit →</div>
      </a>
      <a href="/services/implementation" class="method-card">
        <div class="method-step">02</div>
        <div class="method-name">Build</div>
        <p class="method-desc">
          We implement Claude workflows inside your actual business — configured with your brand voice, your product context, your team's SOPs. Outbound systems, content engines, reporting automation, proposal workflows. Real work, not demos. Measured against the baselines we set in the audit.
        </p>
        <div class="method-link">Claude Implementation →</div>
      </a>
      <a href="/services/retainer" class="method-card">
        <div class="method-step">03</div>
        <div class="method-name">Optimize</div>
        <p class="method-desc">
          GTM systems degrade if they're not tended. The retainer keeps your implementation current — new workflows as your business evolves, monthly performance reviews, and ongoing strategic guidance from someone who knows your numbers. This is where the compounding starts.
        </p>
        <div class="method-link">Ongoing Retainer →</div>
      </a>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section style="background:#0A1A0A;">
  <div class="sec-inner">
    <span class="lbl">What Our Clients Say</span>
    <h2 class="h2" style="margin-bottom:3rem;">Specific. Measurable.<br/>Not agency-speak.</h2>
    <div class="testimonials-grid">

      <div class="testimonial-card">
        <div class="quote-mark">"</div>
        <p class="quote-text">
          We'd been talking about building a real outbound motion for two years. Bill had the infrastructure running in six weeks and we had our first SQLs from it in week eight. The ROI on the engagement paid for itself before month four.
        </p>
        <div class="quote-attr-name">CEO, B2B SaaS</div>
        <div class="quote-attr-role">$8M ARR · Austin, TX</div>
      </div>

      <div class="testimonial-card">
        <div class="quote-mark">"</div>
        <p class="quote-text">
          I've never had a tool change the way I work the way this did. I'm not just faster — I'm producing things I wouldn't have had the bandwidth to attempt before. Content, reporting, strategy docs. It doesn't feel like AI anymore, it just feels like how we work.
        </p>
        <div class="quote-attr-name">Director of Marketing, Professional Services</div>
        <div class="quote-attr-role">$14M Revenue · Remote</div>
      </div>

      <div class="testimonial-card">
        <div class="quote-mark">"</div>
        <p class="quote-text">
          Every agency we'd worked with before gave us a deck and disappeared. Bill built things. He sat in our Slack, he knew our customers, and when we said something wasn't working, it was fixed the next week. That's a completely different relationship than what we were used to.
        </p>
        <div class="quote-attr-name">Founder, E-Commerce Brand</div>
        <div class="quote-attr-role">$22M Revenue · DTC</div>
      </div>

    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact">
  <div class="sec-inner">
    <div class="contact-grid">
      <div>
        <span class="lbl">Get Started</span>
        <h2 class="h2">Want Results<br/>Like These?</h2>
        <p class="body-text" style="margin-top:1rem;margin-bottom:1.75rem;">
          We start with an audit. You leave with a plan — whether we work together or not.
        </p>
        <p class="body-text" style="margin-bottom:1.75rem;">
          The audit identifies exactly where your GTM system is leaking, what AI can fix first, and what 90-day velocity looks like for your business. It's the same starting point for every client in these case studies.
        </p>
        <p style="font-size:0.85rem;color:#4A6A4A;">
          Or reach out directly:<br/>
          <a href="mailto:bill@treetopgrowthstrategy.com" style="color:#00C853;text-decoration:none;">bill@treetopgrowthstrategy.com</a>
        </p>
        <div style="margin-top:2.5rem;padding-top:2rem;border-top:1px solid #1A3A1A;">
          <p style="font-size:0.78rem;color:#4A6A4A;line-height:1.7;">
            We work with <a href="/about" style="color:#8FAF8F;text-decoration:none;">$5M–$50M B2B companies</a> across SaaS, professional services, and e-commerce. Engagements start with the <a href="/services/ai-audit" style="color:#8FAF8F;text-decoration:none;">AI Readiness Audit</a>.
          </p>
        </div>
      </div>

      <div>
        <form id="contact-form">
          <div class="form-row">
            <div>
              <label class="form-label" for="first_name">First name</label>
              <input class="input-field" type="text" id="first_name" name="first_name" placeholder="Jane" required />
            </div>
            <div>
              <label class="form-label" for="last_name">Last name</label>
              <input class="input-field" type="text" id="last_name" name="last_name" placeholder="Smith" required />
            </div>
          </div>
          <div class="form-field">
            <label class="form-label" for="email">Email</label>
            <input class="input-field" type="email" id="email" name="email" placeholder="jane@company.com" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="company">Company</label>
            <input class="input-field" type="text" id="company" name="company" placeholder="Your company name" />
          </div>
          <div class="form-field">
            <label class="form-label" for="gain">What result are you after?</label>
            <textarea class="input-field" id="gain" name="gain" rows="4" placeholder="More pipeline, faster content, a repeatable outbound system — tell us what you're trying to accomplish and where things are breaking down." required></textarea>
          </div>
          <button type="submit" class="btn-p" style="width:100%;justify-content:center;">
            Book a Discovery Call →
          </button>
        </form>

        <div class="success-msg" id="success-msg" style="margin-top:1rem;">
          <p>You're in. We'll reach out within one business day to schedule a call.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<GlobalFooter />

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-msg') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const body = {
      first_name: data.get('first_name'),
      last_name: data.get('last_name'),
      email: data.get('email'),
      company: data.get('company'),
      gain: data.get('gain'),
      source: 'results-page',
    };
    try {
      await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      form.style.display = 'none';
      successMsg.style.display = 'block';
    } catch {
      alert('Something went wrong. Please email us directly at bill@treetopgrowthstrategy.com');
    }
  });
</script>

</body>
</html>
