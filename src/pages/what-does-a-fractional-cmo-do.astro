{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "name": "What Does a Fractional CMO Do? (Day-to-Day Breakdown)",
      "description": "A plain-English breakdown of what a fractional CMO actually does — day-to-day activities, what they own vs. advise on, how to measure their impact, and when it makes sense.",
      "url": "https://treetopgrowthstrategy.com/what-does-a-fractional-cmo-do",
