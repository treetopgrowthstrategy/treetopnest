<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Treetop</a>
    <div class="hide-mob" style="display:flex;gap:2rem;align-items:center;">
      <a href="/services" class="nav-link">Services</a>
      <a href="/fractional-cro" class="nav-link">Fractional CRO</a>
      <a href="/resources" class="nav-link">Resources</a>
      <a href="/about" class="nav-link">About</a>
    </div>
    <a href="/quiz" class="btn-p" style="padding:0.6rem 1.25rem;font-size:0.78rem;">Take the Gap Assessment →</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="badge"><span class="badge-dot"></span>Free calculator · 60 seconds</div>
    <h1 class="hero-h">Sales rep capacity <em style="color:#00C853;font-style:italic;">calculator.</em></h1>
    <p class="hero-sub">
      Most sales orgs over-stack accounts on reps because the org chart was designed before AI compressed prep time. This calculator tells you how many accounts each rep can credibly own in traditional vs AI-enabled mode — and what that means for headcount.
    </p>
  </div>
</div>

<section>
  <div class="sec-inner">
    <div class="calc">
      <div class="calc-inputs">
        <span class="lbl">Your inputs</span>

        <div class="field">
          <label for="reps">Number of quota-carrying reps (AEs/SDRs)</label>
          <div class="slider-row">
            <input type="range" id="reps" min="1" max="50" value="6" />
            <span class="slider-val" id="reps-val">6</span>
          </div>
        </div>

        <div class="field">
          <label for="prep-time">Current prep time per account (minutes)</label>
          <span class="helper">Research + brief + outreach drafting. Typical: 60-120 min.</span>
          <div class="slider-row">
            <input type="range" id="prep-time" min="15" max="180" value="90" />
            <span class="slider-val" id="prep-time-val">90 min</span>
          </div>
        </div>

        <div class="field">
          <label for="ai-prep-time">AI-enabled prep time (minutes)</label>
          <span class="helper">With proper Claude Project + research workflows. Typical: 10-20 min.</span>
          <div class="slider-row">
            <input type="range" id="ai-prep-time" min="5" max="60" value="12" />
            <span class="slider-val" id="ai-prep-time-val">12 min</span>
          </div>
        </div>

        <div class="field">
          <label for="touches">Touches per account per quarter</label>
          <span class="helper">Active outreach + research refreshes. Typical: 8-12.</span>
          <div class="slider-row">
            <input type="range" id="touches" min="3" max="20" value="10" />
            <span class="slider-val" id="touches-val">10</span>
          </div>
        </div>

        <div class="field">
          <label for="hours">Active selling hours per rep per quarter</label>
          <span class="helper">Excluding meetings, training, admin. Typical: 400-500 hrs.</span>
          <div class="slider-row">
            <input type="range" id="hours" min="200" max="600" step="25" value="450" />
            <span class="slider-val" id="hours-val">450 hrs</span>
          </div>
        </div>
      </div>

      <div class="calc-outputs">
        <span class="lbl">Capacity comparison</span>

        <div class="output-num" id="capacity-lift">5.0×</div>
        <div class="output-label">AI capacity vs traditional (accounts per rep)</div>

        <div class="output-row">
          <span class="output-row-label">Traditional capacity per rep</span>
          <span class="output-row-val" id="trad-per">30 acct</span>
        </div>
        <div class="output-row">
          <span class="output-row-label">AI-enabled capacity per rep</span>
          <span class="output-row-val" id="ai-per">150 acct</span>
        </div>
        <div class="output-row">
          <span class="output-row-label">Total addressable accounts (traditional)</span>
          <span class="output-row-val" id="trad-total">180</span>
        </div>
        <div class="output-row">
          <span class="output-row-label">Total addressable accounts (AI)</span>
          <span class="output-row-val" id="ai-total">900</span>
        </div>
        <div class="output-row">
          <span class="output-row-label">Reps needed to match current footprint</span>
          <span class="output-row-val" id="reps-needed">1.2 reps</span>
        </div>
        <div class="output-row">
          <span class="output-row-label">Headcount savings if footprint fixed</span>
          <span class="output-row-val" id="hc-savings">4.8 reps</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">How the math works</span>
    <h2 class="h2">What's behind the calculation</h2>
    <p class="body"><strong style="color:#F0FFF0;">Capacity per rep</strong> = (active selling hours × 60 min) ÷ (prep time per touch × touches per quarter). The math is intentionally conservative — it excludes the time freed up on follow-ups, proposal drafting, and call prep (all of which also compress with AI).</p>
    <p class="body"><strong style="color:#F0FFF0;">The interpretation:</strong> AI doesn't typically mean "fire most of your reps." It means each remaining rep can credibly own a much larger book. Most healthy AI-native sales orgs use this capacity to <em>upgrade rep seniority and territory quality</em> rather than just shrink headcount. The headcount-savings number above is a theoretical maximum, not a recommendation.</p>
    <p class="body">For the full sales-team rebuild playbook, see <a href="/how-to-build-an-ai-native-sales-team" style="color:#00C853;text-decoration:none;">how to build an AI-native sales team</a>.</p>
  </div>
</section>

<section>
  <div class="sec-inner">
    <span class="lbl">Related</span>
    <h2 class="h2">Related calculators &amp; resources</h2>
    <ul style="list-style:none;padding:0;color:#C0D8C0;font-size:0.95rem;line-height:1.85;">
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/pipeline-coverage-calculator" style="color:#00C853;text-decoration:none;">Pipeline coverage calculator →</a></li>
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/ai-roi-calculator" style="color:#00C853;text-decoration:none;">AI ROI calculator →</a></li>
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-to-build-an-ai-native-sales-team" style="color:#00C853;text-decoration:none;">How to build an AI-native sales team →</a></li>
      <li style="padding:0.5rem 0;border-bottom:1px solid #1A3A1A;"><a href="/how-to-use-ai-to-research-prospects" style="color:#00C853;text-decoration:none;">How to use AI to research prospects →</a></li>
      <li style="padding:0.5rem 0;"><a href="/claude-prompts-for-sales" style="color:#00C853;text-decoration:none;">12 Claude prompts for sales →</a></li>
    </ul>
  </div>
</section>

<section>
  <div class="sec-inner">
    <div class="cta-box">
      <div>
        <div class="cta-text">Want to redesign your sales team capacity?</div>
        <div class="cta-sub">Fractional CRO engagements drive exactly this rebuild over 6-12 months.</div>
      </div>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/fractional-cro" class="btn-p">See Fractional CRO →</a>
        <a href="/services/ai-audit" class="btn-g">Book the AI Audit</a>
      </div>
    </div>
  </div>
</section>

<!-- treetop-linker-related-START -->
<section style="padding:3.5rem 2.5rem;border-top:1px solid #1A3A1A;background:#050D05;">
  <div style="max-width:780px;margin:0 auto;">
    <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#00C853;margin-bottom:0.75rem;display:block;">Related</span>
    <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.5rem,2.8vw,2rem);font-weight:400;line-height:1.2;color:#F0FFF0;margin-bottom:1.5rem;">Explore more from Treetop</h2>
    <ul style="list-style:none;padding:0;font-size:0.96rem;line-height:1.9;color:#C0D8C0;">
    <li><a href="/fractional-cmo" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Hire a fractional Chief Marketing Officer &rarr;</a></li>
    <li><a href="/ai-for-cmos" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">AI tools every CMO should know &rarr;</a></li>
    <li><a href="/the-ai-native-gtm-framework" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">How AI-native GTM works &rarr;</a></li>
    <li><a href="/what-is-ai-native-gtm" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Plain-English: AI-native GTM &rarr;</a></li>
    <li><a href="/how-to-use-ai-in-your-business" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Getting started with AI in your business &rarr;</a></li>
    <li><a href="/glossary" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Full AI and GTM glossary &rarr;</a></li>
    <li><a href="/resources" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">All Treetop resources &rarr;</a></li>
    <li><a href="/best-ai-tools-for-cmos-2026" style="color:#00C853;text-decoration:none;border-bottom:1px solid rgba(0,200,83,0.3);">Best AI tools for CMOs (2026) &rarr;</a></li>
    </ul>
  </div>
</section>
<!-- treetop-linker-related-END -->

<GlobalFooter />

<script is:inline>
(function() {
  var inputs = {reps:document.getElementById('reps'),prep:document.getElementById('prep-time'),aiPrep:document.getElementById('ai-prep-time'),touches:document.getElementById('touches'),hours:document.getElementById('hours')};
  var labels = {reps:document.getElementById('reps-val'),prep:document.getElementById('prep-time-val'),aiPrep:document.getElementById('ai-prep-time-val'),touches:document.getElementById('touches-val'),hours:document.getElementById('hours-val')};
  function recalc(){
    var reps=parseInt(inputs.reps.value,10),prep=parseInt(inputs.prep.value,10),aiPrep=parseInt(inputs.aiPrep.value,10),touches=parseInt(inputs.touches.value,10),hours=parseInt(inputs.hours.value,10);
    labels.reps.textContent=reps;labels.prep.textContent=prep+' min';labels.aiPrep.textContent=aiPrep+' min';labels.touches.textContent=touches;labels.hours.textContent=hours+' hrs';
    var tradCap=Math.round((hours*60)/(prep*touches));
    var aiCap=Math.round((hours*60)/(aiPrep*touches));
    var lift=(aiCap/tradCap).toFixed(1);
    var tradTotal=tradCap*reps;
    var aiTotal=aiCap*reps;
    var repsNeeded=(tradTotal/aiCap).toFixed(1);
    var savings=(reps-tradTotal/aiCap).toFixed(1);
    document.getElementById('capacity-lift').textContent=lift+'×';
    document.getElementById('trad-per').textContent=tradCap+' acct';
    document.getElementById('ai-per').textContent=aiCap+' acct';
    document.getElementById('trad-total').textContent=tradTotal.toLocaleString();
    document.getElementById('ai-total').textContent=aiTotal.toLocaleString();
    document.getElementById('reps-needed').textContent=repsNeeded+' reps';
    document.getElementById('hc-savings').textContent=savings+' reps';
  }
  Object.keys(inputs).forEach(function(k){inputs[k].addEventListener('input',recalc);});
  recalc();
})();
</script>

</body>
</html>
