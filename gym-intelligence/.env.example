# Copy this file to .env and fill in real values. Never commit .env.

# Google Cloud — Places API v1
# Reuse the same key already used by use-billy (set in Vercel as GOOGLE_PLACES_API_KEY)
GOOGLE_PLACES_API_KEY=

# Anthropic — used for website content extraction
ANTHROPIC_API_KEY=

# Airtable Personal Access Token with data.records:read/write + schema.bases:read on the
# Treetop Database base (app0cpbQjtdZh1sHT)
AIRTABLE_PAT=
